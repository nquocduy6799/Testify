@* Neural Links Section *@
<section class="bg-white rounded-[40px] p-8 shadow-sm border border-slate-50">
    <div class="flex justify-between items-center mb-6">
        <h3 class="text-xl font-bold text-slate-800">Neural Links</h3>
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-slate-300">
            <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
            <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
        </svg>
    </div>
    <div class="space-y-6">
        @foreach (var link in _externalLinks)
        {
            <div class="flex gap-4 items-center p-4 rounded-2xl bg-slate-50 hover:bg-slate-100 transition-all cursor-pointer group">
                <div class="w-10 h-10 rounded-xl flex items-center justify-center @link.BgColor">
                    @((MarkupString)link.Icon)
                </div>
                <div class="flex-1">
                    <h4 class="text-sm font-bold text-slate-700 group-hover:text-[#E85D3F] transition-colors">@link.Name</h4>
                    <p class="text-xs font-bold text-slate-400 uppercase tracking-tight">@link.Status</p>
                </div>
            </div>
        }
    </div>
</section>

@code {
    private List<ExternalLinkItem> _externalLinks = new()
    {
        new ExternalLinkItem
        {
            Name = "Slack Workspace",
            Status = "CONNECTED",
            BgColor = "bg-purple-50",
            Icon = "<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"text-purple-500\"><rect width=\"3\" height=\"8\" x=\"13\" y=\"2\" rx=\"1.5\"/><path d=\"M19 8.5V10h1.5A1.5 1.5 0 1 0 19 8.5\"/><rect width=\"3\" height=\"8\" x=\"8\" y=\"14\" rx=\"1.5\"/><path d=\"M5 15.5V14H3.5A1.5 1.5 0 1 0 5 15.5\"/><rect width=\"8\" height=\"3\" x=\"14\" y=\"13\" rx=\"1.5\"/><path d=\"M15.5 19H14v1.5a1.5 1.5 0 1 0 1.5-1.5\"/><rect width=\"8\" height=\"3\" x=\"2\" y=\"8\" rx=\"1.5\"/><path d=\"M8.5 5H10V3.5A1.5 1.5 0 1 0 8.5 5\"/></svg>"
        },
        new ExternalLinkItem
        {
            Name = "GitHub Repos",
            Status = "5 ACTIVE",
            BgColor = "bg-slate-50",
            Icon = "<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"text-slate-700\"><path d=\"M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4\"/><path d=\"M9 18c-4.51 2-5-2-7-2\"/></svg>"
        }
    };

    private class ExternalLinkItem
    {
        public string Name { get; set; } = string.Empty;
        public string Status { get; set; } = string.Empty;
        public string Icon { get; set; } = string.Empty;
        public string BgColor { get; set; } = string.Empty;
    }
}
