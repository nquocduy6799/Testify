@page "/dashboard"
@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Testify.Client.Interfaces
@using Testify.Client.Features.Home.Components
@using Testify.Shared.DTOs.Projects
@using Testify.Shared.DTOs.Milestones
@using Testify.Shared.DTOs.KanbanTasks
@using Testify.Shared.Enums
@using static Testify.Shared.Enums.MilestoneEnum
@inject IProjectService ProjectService
@inject IMilestoneService MilestoneService
@inject IKanbanTaskService KanbanTaskService
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthenticationStateProvider
@rendermode InteractiveWebAssembly
@attribute [Authorize]

<PageTitle>Dashboard - Testify</PageTitle>

@if (isLoading)
{
    <div class="flex flex-col items-center justify-center min-h-screen">
        <div class="h-12 w-12 animate-spin rounded-full border-b-2 border-[#E85D3F]"></div>
        <p class="mt-4 font-medium text-slate-400">Loading your dashboard...</p>
    </div>
}
else
{
    <div class="max-w-[1400px] mx-auto px-8 mt-10 pb-24 space-y-10 animate-in fade-in slide-in-from-bottom-4 duration-700">
      
        @* Welcome Section *@
        <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-6">
            <div>
                <h1 class="text-5xl font-extrabold text-slate-900 tracking-tight leading-tight">
                    Welcome back, <span class="text-[#E85D3F]">@GetFirstName()</span>
                </h1>
                <p class="text-slate-500 mt-2 text-lg">
                    You have @activeProjectsCount active projects and @activeMilestonesCount active milestones today.
                </p>
            </div>
            <div class="flex gap-4">
                <button class="px-6 py-3 bg-[#1C1D2A] text-white rounded-2xl font-bold flex items-center gap-2 hover:scale-105 transition-all shadow-xl active:scale-95">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[#E85D3F]">
                        <path d="M13 10V3L4 14h7v7l9-11h-7z"/>
                    </svg>
                    Go Pro
                </button>
                <button 
                    @onclick='() => Navigation.NavigateTo("/projects")'
                    class="px-6 py-3 bg-white text-slate-800 border border-slate-200 rounded-2xl font-bold flex items-center gap-2 hover:bg-slate-50 transition-all active:scale-95"
                >
                    Find Work
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
                    </svg>
                </button>
            </div>
        </div>

        @* Stats Quick View *@
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
            @foreach (var stat in GetStats())
            {
                <div class="bg-white p-6 rounded-[32px] shadow-sm border border-slate-50 flex items-center gap-5 hover:shadow-md transition-shadow">
                    <div class="w-14 h-14 @stat.BgColor rounded-2xl flex items-center justify-center">
                        @((MarkupString)stat.Icon)
                    </div>
                    <div>
                        <p class="text-slate-400 text-xs font-bold uppercase tracking-wider">@stat.Label</p>
                        <h3 class="text-2xl font-bold text-slate-800">@stat.Value</h3>
                    </div>
                </div>
            }
        </div>

        @* Main Grid Content *@
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-10">
            
            @* Active Projects & Today's Focus *@
            <div class="lg:col-span-8 space-y-10">
                
                @* Active Projects *@
                <section class="bg-white rounded-[40px] p-8 shadow-sm border border-slate-50">
                    <div class="flex justify-between items-center mb-8">
                        <h3 class="text-2xl font-bold text-slate-800">Active Workspaces</h3>
                        <button 
                            @onclick='() => Navigation.NavigateTo("/projects")'
                            class="text-sm font-bold text-[#7E96E1] hover:underline"
                        >
                            View Portfolio
                        </button>
                    </div>
                    <div class="space-y-4">
                        @if (activeProjects.Any())
                        {
                            @foreach (var project in activeProjects.Take(3))
                            {
                                <div 
                                    @onclick='() => Navigation.NavigateTo($"/projects/{project.Id}")'
                                    class="p-6 rounded-[32px] bg-slate-50 hover:bg-white border border-transparent hover:border-slate-100 transition-all cursor-pointer flex flex-col md:flex-row md:items-center justify-between gap-6 group"
                                >
                                    <div class="flex items-center gap-4">
                                        <div class="w-12 h-12 bg-[#1C1D2A] rounded-xl flex items-center justify-center text-white font-bold group-hover:bg-[#E85D3F] transition-colors">
                                            @GetProjectInitial(project)
                                        </div>
                                        <div>
                                            <h4 class="font-bold text-slate-800 group-hover:text-[#E85D3F] transition-colors">@project.Name</h4>
                                            <p class="text-xs text-slate-400 font-medium">@(string.IsNullOrEmpty(project.Client) ? "Internal" : project.Client) • @project.MembersCount members</p>
                                        </div>
                                    </div>
                                    
                                    <div class="flex-1 max-w-[200px] hidden md:block">
                                        <div class="flex justify-between text-[10px] font-bold text-slate-400 mb-1 uppercase">
                                            <span>Progress</span>
                                            <span>@project.Progress%</span>
                                        </div>
                                        <div class="w-full h-1.5 bg-slate-200 rounded-full overflow-hidden">
                                            <div 
                                                class="h-full bg-[#E85D3F] transition-all duration-1000" 
                                                style="width: @(project.Progress)%"
                                            ></div>
                                        </div>
                                    </div>

                                    <div class="flex items-center gap-4">
                                        <div class="flex items-center gap-2 text-slate-500 text-xs font-medium">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
                                            </svg>
                                            @FormatDeadline(project.Deadline)
                                        </div>
                                        <div class="p-2 text-slate-300 group-hover:text-[#E85D3F] transition-colors">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
                                            </svg>
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="text-center py-12">
                                <p class="text-slate-400 text-sm">No active projects yet. Start by creating your first project!</p>
                            </div>
                        }
                    </div>
                </section>

                @* Today's Focus *@
                <section class="bg-[#1C1D2A] rounded-[40px] p-10 text-white relative overflow-hidden group">
                    <div class="absolute top-0 right-0 w-64 h-64 bg-white/5 rounded-full -mr-32 -mt-32 blur-3xl"></div>
                    <div class="relative z-10 flex flex-col md:flex-row gap-10">
                        <div class="flex-1 space-y-6">
                            <div>
                                <h3 class="text-3xl font-bold mb-2">Today's Focus</h3>
                                <p class="text-slate-400 text-sm">Synchronize with your project team goals.</p>
                            </div>
                            <div class="space-y-3">
                                @if (focusTasks.Any())
                                {
                                    @foreach (var task in focusTasks)
                                    {
                                        <div 
                                            @onclick='() => ToggleTask(task.Id)'
                                            class="flex items-center gap-4 group/task cursor-pointer"
                                        >
                                            <div class="w-6 h-6 rounded-lg border-2 flex items-center justify-center transition-all @(completedTaskIds.Contains(task.Id) ? "bg-emerald-500 border-emerald-500" : "border-slate-600 group-hover/task:border-[#E85D3F]")">
                                                @if (completedTaskIds.Contains(task.Id))
                                                {
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-white">
                                                        <polyline points="20 6 9 17 4 12"/>
                                                    </svg>
                                                }
                                            </div>
                                            <span class="text-sm font-medium transition-all @(completedTaskIds.Contains(task.Id) ? "text-slate-500 line-through" : "text-slate-200")">
                                                @task.Title
                                            </span>
                                        </div>
                                    }
                                }
                                else
                                {
                                    <div class="text-center py-8 space-y-3">
                                        <div class="w-16 h-16 mx-auto bg-white/10 rounded-2xl flex items-center justify-center">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-slate-500">
                                                <path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
                                            </svg>
                                        </div>
                                        <p class="text-slate-400 text-sm">No pending tasks for today</p>
                                        <p class="text-slate-500 text-xs">You're all caught up!</p>
                                    </div>
                                }
                            </div>
                        </div>
                        <div class="w-full md:w-[240px] bg-white/10 backdrop-blur-md rounded-3xl p-6 flex flex-col items-center justify-center text-center gap-4 border border-white/10">
                            @if (focusTasks.Any())
                            {
                                <div class="w-20 h-20 rounded-full border-4 border-[#E85D3F] flex items-center justify-center relative shadow-lg shadow-orange-900/20">
                                    <span class="text-2xl font-extrabold">@taskProgress%</span>
                                    <div class="absolute inset-0 border-4 border-transparent border-t-white rounded-full animate-spin"></div>
                                </div>
                                <p class="text-sm font-bold">Daily Protocol</p>
                                <button class="mt-2 text-[#E85D3F] text-xs font-bold uppercase tracking-widest hover:underline">Full Schedule</button>
                            }
                            else
                            {
                                <div class="w-20 h-20 rounded-full border-4 border-slate-600 flex items-center justify-center">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-slate-500">
                                        <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
                                    </svg>
                                </div>
                                <p class="text-sm font-bold text-slate-400">All Clear</p>
                                <p class="text-xs text-slate-500">No tasks scheduled</p>
                            }
                        </div>
                    </div>
                </section>

            </div>

            @* Sidebar *@
            <div class="lg:col-span-4 space-y-10">
                
                @* Upcoming Events *@
                <section class="bg-white rounded-[40px] p-8 shadow-sm border border-slate-50">
                    <div class="flex justify-between items-center mb-6">
                        <h3 class="text-xl font-bold text-slate-800">System Deadlines</h3>
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-slate-300">
                            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
                        </svg>
                    </div>
                    <div class="space-y-6">
                        @{
                            var upcomingDeadlines = GetUpcomingDeadlines();
                        }
                        @if (upcomingDeadlines.Any())
                        {
                            @foreach (var (deadline, index) in upcomingDeadlines.Select((d, i) => (d, i)))
                            {
                                <div class="flex gap-4 items-start relative pl-6 group">
                                    <div class="absolute left-0 top-1.5 w-2.5 h-2.5 rounded-full @deadline.Color shadow-sm group-hover:scale-150 transition-transform"></div>
                                    <div class="absolute left-[4px] top-4 w-[1px] h-full bg-slate-100 @(index == upcomingDeadlines.Count - 1 ? "hidden" : "")"></div>
                                    <div>
                                        <p class="text-xs font-bold text-slate-400 mb-0.5">@deadline.Time</p>
                                        <h4 class="text-sm font-bold text-slate-700">@deadline.Title</h4>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="text-center py-12 space-y-3">
                                <div class="w-16 h-16 mx-auto bg-slate-50 rounded-2xl flex items-center justify-center">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-slate-300">
                                        <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
                                    </svg>
                                </div>
                                <p class="text-slate-400 text-sm font-medium">No upcoming deadlines</p>
                                <p class="text-slate-400 text-xs">Stay organized!</p>
                            </div>
                        }
                    </div>
                    <button class="w-full mt-8 py-4 bg-slate-50 rounded-2xl text-slate-500 font-bold text-xs uppercase tracking-widest hover:bg-slate-100 transition-colors">
                        Portfolio Calendar
                    </button>
                </section>

                <ConnectSection />

                @* Quick Tip / Community *@
                <section class="bg-[#7E96E1] rounded-[40px] p-8 text-white relative overflow-hidden group shadow-xl shadow-blue-900/10">
                    <div class="absolute -bottom-10 -left-10 w-40 h-40 bg-white/10 rounded-full blur-2xl"></div>
                    <div class="relative z-10 space-y-4">
                        <h3 class="text-xl font-bold flex items-center gap-2">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" stroke="none">
                                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                            </svg>
                            Community Tip
                        </h3>
                        <p class="text-slate-100 text-sm italic leading-relaxed">"Always add a 15% buffer to your migration estimates. Your team will appreciate early delivery more than missed dates."</p>
                        <div class="flex items-center gap-3 pt-2">
                            <img src="https://picsum.photos/seed/sarah/50/50" class="w-8 h-8 rounded-full border-2 border-white/20" alt="Author" />
                            <span class="text-xs font-bold uppercase tracking-tight">— Sarah Chen, Senior QA</span>
                        </div>
                    </div>
                </section>

            </div>

        </div>
    </div>
}

@code {
    private bool isLoading = true;
    private string userName = "User";
    private string userEmail = "";
    
    private List<ProjectResponse> projects = new();
    private List<ProjectResponse> activeProjects = new();
    private int activeProjectsCount = 0;
    private int activeMilestonesCount = 0;
    private int totalTeamSize = 0;
    private int totalTasksResolved = 0;
    
    private List<KanbanTaskResponse> focusTasks = new();
    private HashSet<int> completedTaskIds = new();
    private int taskProgress = 0;

    protected override async Task OnInitializedAsync()
    {
        await LoadDashboardData();
    }

    private async Task LoadDashboardData()
    {
        try
        {
            isLoading = true;
            
            // Get user info
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            
            if (user.Identity?.IsAuthenticated == true)
            {
                userName = user.FindFirst(ClaimTypes.Name)?.Value 
                    ?? user.FindFirst("name")?.Value 
                    ?? user.Identity.Name 
                    ?? "User";
                userEmail = user.FindFirst(ClaimTypes.Email)?.Value ?? "";
            }

            // Load projects
            projects = await ProjectService.GetProjectsAsync();
            activeProjects = projects.Where(p => p.Progress < 100).ToList();
            activeProjectsCount = activeProjects.Count;
            totalTeamSize = projects.Sum(p => p.MembersCount);

            // Load milestones and tasks for active projects
            var allMilestones = new List<MilestoneResponse>();
            var allTasks = new List<KanbanTaskResponse>();

            foreach (var project in activeProjects)
            {
                try
                {
                    var milestones = await MilestoneService.GetMilestonesByProjectAsync(project.Id);
                    allMilestones.AddRange(milestones);
                    
                    var projectTasks = await KanbanTaskService.GetTasksByProjectIdAsync(project.Id);
                    allTasks.AddRange(projectTasks);
                }
                catch
                {
                    // Continue if a project fails to load
                }
            }

            activeMilestonesCount = allMilestones.Count(m => m.Status == MilestoneStatus.Active);
            totalTasksResolved = allTasks.Count(t => t.Status == KanbanTaskStatus.Done);

            // Get focus tasks (pending/in-progress tasks)
            focusTasks = allTasks
                .Where(t => t.Status == KanbanTaskStatus.InProgress || t.Status == KanbanTaskStatus.ToDo)
                .OrderBy(t => t.Priority)
                .Take(4)
                .ToList();

            CalculateTaskProgress();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading dashboard: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private string GetFirstName()
    {
        return userName.Split(' ').FirstOrDefault() ?? "User";
    }

    private string GetProjectInitial(ProjectResponse project)
    {
        if (!string.IsNullOrEmpty(project.Client))
            return project.Client.FirstOrDefault().ToString().ToUpper();
        return project.Name.FirstOrDefault().ToString().ToUpper();
    }

    private string FormatDeadline(DateTime? deadline)
    {
        if (!deadline.HasValue)
            return "No deadline";

        var days = (deadline.Value - DateTime.Now).Days;
        if (days < 0)
            return "Overdue";
        if (days == 0)
            return "Today";
        if (days == 1)
            return "Tomorrow";
        if (days < 7)
            return $"{days} days";
        
        return deadline.Value.ToString("MMM dd");
    }

    private List<StatItem> GetStats()
    {
        return new List<StatItem>
        {
            new StatItem 
            { 
                Label = "Profile Views", 
                Value = "---", 
                Icon = "<svg class=\"w-7 h-7 text-blue-500\" xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z\"/><circle cx=\"12\" cy=\"12\" r=\"3\"/></svg>", 
                BgColor = "bg-blue-50" 
            },
            new StatItem 
            { 
                Label = "Tasks Resolved", 
                Value = totalTasksResolved.ToString(), 
                Icon = "<svg class=\"w-7 h-7 text-orange-500\" xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><rect width=\"20\" height=\"14\" x=\"2\" y=\"7\" rx=\"2\" ry=\"2\"/><path d=\"M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16\"/></svg>", 
                BgColor = "bg-orange-50" 
            },
            new StatItem 
            { 
                Label = "Team Size", 
                Value = totalTeamSize.ToString(), 
                Icon = "<svg class=\"w-7 h-7 text-purple-500\" xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2\"/><circle cx=\"9\" cy=\"7\" r=\"4\"/><path d=\"M22 21v-2a4 4 0 0 0-3-3.87\"/><path d=\"M16 3.13a4 4 0 0 1 0 7.75\"/></svg>", 
                BgColor = "bg-purple-50" 
            },
            new StatItem 
            { 
                Label = "Quality Score", 
                Value = "---", 
                Icon = "<svg class=\"w-7 h-7 text-yellow-500\" xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" fill=\"currentColor\" stroke=\"none\"><polygon points=\"12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2\"/></svg>", 
                BgColor = "bg-yellow-50" 
            }
        };
    }

    private List<DeadlineItem> GetUpcomingDeadlines()
    {
        // Get real deadlines from projects
        var projectDeadlines = activeProjects
            .Where(p => p.Deadline.HasValue && p.Deadline.Value >= DateTime.Now)
            .OrderBy(p => p.Deadline)
            .Select((p, index) => new DeadlineItem 
            { 
                Time = FormatDeadline(p.Deadline), 
                Title = $"{p.Name}", 
                Color = index == 0 ? "bg-orange-500" : (index == 1 ? "bg-blue-500" : "bg-purple-500")
            })
            .Take(3)
            .ToList();

        return projectDeadlines;
    }

    private void ToggleTask(int taskId)
    {
        if (completedTaskIds.Contains(taskId))
            completedTaskIds.Remove(taskId);
        else
            completedTaskIds.Add(taskId);
        
        CalculateTaskProgress();
    }

    private void CalculateTaskProgress()
    {
        if (focusTasks.Count == 0)
        {
            taskProgress = 0;
            return;
        }
        
        taskProgress = (int)((double)completedTaskIds.Count / focusTasks.Count * 100);
    }

    private class StatItem
    {
        public string Label { get; set; } = string.Empty;
        public string Value { get; set; } = string.Empty;
        public string Icon { get; set; } = string.Empty;
        public string BgColor { get; set; } = string.Empty;
    }

    private class DeadlineItem
    {
        public string Time { get; set; } = string.Empty;
        public string Title { get; set; } = string.Empty;
        public string Color { get; set; } = string.Empty;
    }
}
