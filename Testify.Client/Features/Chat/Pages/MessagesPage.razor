                            {
                                "Ended" => "bg-green-50 border-green-200",
                                "Missed" => "bg-red-50 border-red-200",
                                "Rejected" => "bg-orange-50 border-orange-200",
                                "Cancelled" => "bg-slate-50 border-slate-200",
                                _ => "bg-slate-50 border-slate-200"
                            };

                            <div @key="message.Id" data-message-id="@message.Id" class="flex justify-center my-3">
                                <div class="@statusBg border rounded-2xl px-5 py-3 flex items-center gap-4 max-w-sm w-full shadow-sm">
                                    @* Call icon *@
                                    <div class="w-10 h-10 rounded-full flex items-center justify-center flex-shrink-0 @(callMeta.CallStatus == "Ended" ? "bg-green-100" : callMeta.CallStatus == "Missed" ? "bg-red-100" : callMeta.CallStatus == "Rejected" ? "bg-orange-100" : "bg-slate-100")">
