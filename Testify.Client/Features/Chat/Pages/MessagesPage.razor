    private async void NotifyTyping()
    {
        if (!activeRoomId.HasValue || hubService == null) return;

        _typingStopCts?.Cancel();
        _typingStartCts?.Cancel();
        _typingStopCts = new CancellationTokenSource();
        _typingStartCts = new CancellationTokenSource();
        var stopCts = _typingStopCts;
        var startCts = _typingStartCts;
        var roomId = activeRoomId.Value;

        if (!string.IsNullOrWhiteSpace(messageInput))
        {
            if (!_hasSentTyping)
            {
                _ = Task.Run(async () =>
                {
                    try
                    {
                        await Task.Delay(300, startCts.Token);
                        await InvokeAsync(async () =>
                        {
                            if (hubService != null && activeRoomId == roomId)
                            {
                                await hubService.StartTypingAsync(roomId);
                                _hasSentTyping = true;
                                StateHasChanged();
                            }
                        });
                    }
                    catch (OperationCanceledException) { }
                });
            }
            _ = Task.Run(async () =>
            {
                try
                {
                    await Task.Delay(2000, stopCts.Token);
                    await InvokeAsync(async () =>
                    {
                        if (hubService != null && activeRoomId == roomId)
                        {
                            await hubService.StopTypingAsync(roomId);
                            _hasSentTyping = false;
                            StateHasChanged();
                        }
                    });
                }
                catch (OperationCanceledException) { }
            });
        }
        else
        {
            _ = InvokeAsync(async () =>
            {
                await hubService!.StopTypingAsync(roomId);
                _hasSentTyping = false;
                StateHasChanged();
            });
        }
    }

