            </div>
        }
    </div>
}

@* Video Call Components (rendered outside main layout for PiP overlay) *@
<VideoCallWindow @ref="videoCallWindow"
                 IsVisible="@isInCall"
                 CurrentCallType="@currentCallType"
                 PeerName="@callPeerName"
                 PeerAvatarUrl="@callPeerAvatarUrl"
                 CallSessionId="@activeCallSessionId"
                 WebRtcService="@webRtcService"
                 CallHubService="@callHubService"
                 OnCallEnded="HandleCallEndedUI" />

<IncomingCallDialog IsVisible="@hasIncomingCall"
                    IncomingCall="@incomingCallData"
                    OnAccepted="AcceptIncomingCall"
                    OnRejected="RejectIncomingCall" />

@code {
    private List<ChatRoomResponse> rooms = new();
    private List<ChatRoomResponse> filteredRooms = new();
    private List<ChatMessageResponse> messages = new();
    private List<string> typingUsers = new();
    
    private bool isLoading = true;
    private int? activeRoomId;
    private ChatRoomResponse? activeRoom;
    private string messageInput = string.Empty;
    private string searchQuery = string.Empty;
    private string? currentUserId;
    private ChatHubService? hubService;
    private NotificationHubService? notificationHubService;
    private bool showNewChatModal;
    private CancellationTokenSource? _typingStopCts;
    private CancellationTokenSource? _typingStartCts;
    private bool _hasSentTyping;
    private int? _editingMessageId;
    private string _editContent = string.Empty;
    private ChatMessageResponse? replyToMessage;
    private int messageSkip;
    private bool hasMoreMessages = true;
    private bool isLoadingMore;
    private bool showCreateGroupModal;
    private string newGroupRoomName = string.Empty;
    private List<string> selectedUserIdsForGroup = new();
    private List<ChatUserItemResponse> usersForGroup = new();
    private bool isLoadingUsersForGroup;

    // File upload state
    private List<FileUploadItem> selectedFiles = new();
    private InputFile? fileInput;
    private bool isSending;
    private string uploadError = string.Empty;
    private const long MaxFileSizeBytes = 25 * 1024 * 1024; // 25 MB

    // Message search state
    private bool isMessageSearchOpen;
    private string messageSearchQuery = string.Empty;
    private List<ChatMessageResponse> searchResults = new();
    private int searchTotalCount;
    private int searchSkip;
    private bool isSearching;
    private bool hasMoreSearchResults;
    private int? highlightedMessageId;
    private CancellationTokenSource? _searchDebounceCts;

    // Pinned messages state
    private bool isPinnedPanelOpen;
    private List<ChatPinnedMessageResponse> pinnedMessages = new();
    private bool isLoadingPinned;
    private bool isPinning;

    // Emoji picker state
    private bool isEmojiPickerOpen;
    private int? reactionEmojiPickerMessageId;

    // Room settings state
    private bool isRoomSettingsOpen;

    // Call state
    private CallHubService? callHubService;
    private VideoCallWindow? videoCallWindow;
    private bool isInCall;
    private bool hasIncomingCall;
    private IncomingCallResponse? incomingCallData;
    private int? activeCallSessionId;
    private WebRtcService? webRtcService;
    private CallType currentCallType;
    private string callPeerName = string.Empty;
    private string? callPeerAvatarUrl;
    private CancellationTokenSource? _ringingTimeoutCts;
    private CancellationTokenSource? _connectingTimeoutCts;

    protected override async Task OnInitializedAsync()
    {
        await LoadCurrentUser();
        await LoadRooms();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            hubService = ServiceProvider.GetService<ChatHubService>();
            if (hubService != null)
            {
                if (!hubService.IsConnected)
                    await hubService.StartAsync();
                hubService.OnMessageReceived += HandleMessageReceived;
                hubService.OnUserTyping += HandleUserTyping;
                hubService.OnMessageDeleted += HandleMessageDeleted;
                hubService.OnMessageUpdated += HandleMessageUpdated;
                hubService.OnReactionAdded += HandleReactionAdded;
                hubService.OnReactionRemoved += HandleReactionRemoved;
                hubService.OnMessageRead += HandleMessageRead;
                hubService.OnMessagePinned += HandleMessagePinned;
                hubService.OnMessageUnpinned += HandleMessageUnpinned;
                hubService.OnRoomUpdated += HandleRoomUpdatedSignalR;
                hubService.OnParticipantsAdded += HandleParticipantsAddedSignalR;
                hubService.OnParticipantRemoved += HandleParticipantRemovedSignalR;
            }

            notificationHubService = ServiceProvider.GetService<NotificationHubService>();
            if (notificationHubService != null)
            {
                if (!notificationHubService.IsConnected)
                    await notificationHubService.StartAsync();
                notificationHubService.OnUserStatusChanged += HandleUserStatusChanged;

                // Sync initial online status from the live presence data.
                // The API response may be stale if the user's presence changed
                // between the API call (OnInitializedAsync) and now.
                SyncOnlineStatusFromPresence();
            }

            // Initialize Call Hub (may already be started by GlobalCallHandler)
            callHubService = ServiceProvider.GetService<CallHubService>();
            if (callHubService != null)
            {
                if (!callHubService.IsConnected)
                    await callHubService.StartAsync();
                callHubService.OnIncomingCall += HandleIncomingCall;
                callHubService.OnCallRinging += HandleCallRinging;
                callHubService.OnCallAnswered += HandleCallAnswered;
                callHubService.OnIceCandidateReceived += HandleIceCandidateReceived;
                callHubService.OnCallEnded += HandleCallEndedSignalR;
                callHubService.OnCallError += HandleCallError;
                callHubService.OnMediaToggled += HandleMediaToggled;
                callHubService.OnReconnected += HandleCallHubReconnected;

                // Check if there's a pending incoming call accepted from another page
                // (via GlobalCallHandler). If so, process it now.
                if (callHubService.PendingIncomingCall != null)
                {
                    var pendingCall = callHubService.PendingIncomingCall;
                    callHubService.PendingIncomingCall = null;
                    // Process the pending call after WebRTC service is initialized
                    _ = ProcessPendingIncomingCall(pendingCall);
                }
            }

            // Initialize WebRTC service
            webRtcService = ServiceProvider.GetService<WebRtcService>();
            if (webRtcService != null)
            {
                webRtcService.IceCandidateGenerated += HandleLocalIceCandidate;
                webRtcService.ConnectionStateChanged += HandleWebRtcStateChanged;
            }
        }
    }

    /// <summary>
    /// Syncs room online status from the live NotificationHubService presence data.
    /// This ensures the UI reflects the correct status even if the API response was stale.
    /// </summary>
    private void SyncOnlineStatusFromPresence()
    {
        if (notificationHubService == null) return;

        foreach (var room in rooms)
        {
            if (room.OtherParticipant != null)
            {
                var isOnline = notificationHubService.IsUserOnline(room.OtherParticipant.UserId);
                room.OtherParticipant.IsOnline = isOnline;
                room.OtherParticipant.Status = isOnline ? "Online" : "Offline";
            }
        }
        StateHasChanged();
    }

    /// <summary>
    /// Processes a pending incoming call that was accepted from the GlobalCallHandler
    /// on a different page. This completes the WebRTC handshake.
    /// </summary>
    private async Task ProcessPendingIncomingCall(IncomingCallResponse pendingCall)
    {
        // Small delay to ensure WebRTC service is fully initialized
        await Task.Delay(100);

        if (webRtcService == null || callHubService == null)
        {
            Console.WriteLine("[MessagesPage] Cannot process pending call — services not ready");
            return;
        }

        // Set call state
        incomingCallData = pendingCall;
        hasIncomingCall = false;
        isInCall = true;
        activeCallSessionId = pendingCall.CallSessionId;
        currentCallType = pendingCall.CallType;
        callPeerName = pendingCall.CallerName;
        callPeerAvatarUrl = pendingCall.CallerAvatarUrl;
        StateHasChanged();

        videoCallWindow?.SetCallState(VideoCallWindow.CallState.Connecting);

        // Initialize WebRTC
        var initialized = await webRtcService.InitializeAsync(pendingCall.CallType == CallType.Video);
        if (!initialized)
        {
            await callHubService.RejectCallAsync(pendingCall.CallSessionId);
            isInCall = false;
            activeCallSessionId = null;
            incomingCallData = null;
            StateHasChanged();
            return;
        }

        // Set remote description (offer from caller)
        await webRtcService.SetRemoteDescriptionAsync(pendingCall.SdpOffer);

        // Create answer
        var sdpAnswer = await webRtcService.CreateAnswerAsync();
        if (string.IsNullOrEmpty(sdpAnswer))
        {
            await callHubService.RejectCallAsync(pendingCall.CallSessionId);
            isInCall = false;
            activeCallSessionId = null;
            incomingCallData = null;
            await webRtcService.DisposeWebRtcAsync();
            StateHasChanged();
            return;
        }

        // Send answer
        await callHubService.SendAnswerAsync(new CallAnswerRequest
        {
            CallSessionId = pendingCall.CallSessionId,
            SdpAnswer = sdpAnswer
        });

        videoCallWindow?.SetCallState(VideoCallWindow.CallState.Active);
        incomingCallData = null;

        // Start connecting timeout for callee side
        StartConnectingTimeout();

        Console.WriteLine("[MessagesPage] Pending call processed — WebRTC handshake sent");
    }

    private void HandleUserStatusChanged(string userId, bool isOnline)
    {
        foreach (var room in rooms.Where(r => r.OtherParticipant?.UserId == userId))
        {
            room.OtherParticipant!.IsOnline = isOnline;
            room.OtherParticipant.Status = isOnline ? "Online" : "Offline";
        }
        if (activeRoom?.OtherParticipant?.UserId == userId)
        {
            activeRoom.OtherParticipant.IsOnline = isOnline;
            activeRoom.OtherParticipant.Status = isOnline ? "Online" : "Offline";
        }
        InvokeAsync(StateHasChanged);
    }

    private async Task LoadCurrentUser()
    {
        currentUserId = await ChatService.GetCurrentUserIdAsync();
    }

    private async Task LoadRooms()
    {
        try
        {
            isLoading = true;
            rooms = await ChatService.GetChatRoomsAsync();
            FilterRooms();
        }
        catch { }
        finally
        {
            isLoading = false;
        }
    }

    private void OnSearchQueryInput(ChangeEventArgs e)
    {
        searchQuery = e.Value?.ToString() ?? string.Empty;
        FilterRooms();
    }

    private void FilterRooms()
    {
        if (string.IsNullOrWhiteSpace(searchQuery))
        {
            filteredRooms = rooms;
        }
        else
        {
            filteredRooms = rooms.Where(r => 
                GetRoomDisplayName(r).Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ||
                (r.LastMessage?.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ?? false)
            ).ToList();
        }
    }

    private async Task SelectRoom(int roomId)
    {
        activeRoomId = roomId;
        activeRoom = rooms.FirstOrDefault(r => r.Id == roomId);
        messages.Clear();
        typingUsers.Clear();
        replyToMessage = null;
        _editingMessageId = null;
        messageSkip = 0;
        hasMoreMessages = true;
        ClearSelectedFiles();
        uploadError = string.Empty;
        ClearMessageSearch();
        isMessageSearchOpen = false;
        isPinnedPanelOpen = false;
        isRoomSettingsOpen = false;
        pinnedMessages.Clear();

        if (activeRoom != null)
        {
            // Reset unread count immediately for responsive UI
            activeRoom.UnreadCount = 0;
            StateHasChanged();

            messages = await ChatService.GetRoomMessagesAsync(roomId);
            messageSkip = messages.Count;
            hasMoreMessages = messages.Count >= 50;
            if (hubService != null)
                await hubService.JoinRoomAsync(roomId);

            // Load pinned messages in background
            _ = LoadPinnedMessagesAsync(roomId);

            if (messages.Any())
            {
                var lastMessage = messages.Last();
                await ChatService.MarkAsReadAsync(roomId, lastMessage.Id);
            }
            StateHasChanged();
            await ScrollToBottomAsync(false);
        }
    }

    private async Task SendMessage()
    {
        if (isSending) return;
        
        var hasText = !string.IsNullOrWhiteSpace(messageInput);
        var hasFiles = selectedFiles.Any();

        if (!hasText && !hasFiles) return;
        if (!activeRoomId.HasValue) return;

        if (hubService != null && activeRoomId.HasValue)
            await hubService.StopTypingAsync(activeRoomId.Value);
        _hasSentTyping = false;

        isSending = true;
        uploadError = string.Empty;
        StateHasChanged();

        try
        {
            ChatMessageResponse msg;

            if (hasFiles)
            {
                // Send with attachments
                msg = await ChatService.SendMessageWithAttachmentsAsync(
                    activeRoomId.Value,
                    hasText ? messageInput.Trim() : null,
                    replyToMessage?.Id,
                    selectedFiles);
            }
            else
            {
                // Send text-only message
                var request = new SendMessageRequest
                {
                    RoomId = activeRoomId.Value,
                    Content = messageInput.Trim(),
                    MessageType = MessageType.Text,
                    ParentMessageId = replyToMessage?.Id
                };
                msg = await ChatService.SendMessageAsync(request);
            }

            messageInput = string.Empty;
            replyToMessage = null;
            ClearSelectedFiles();

            // Add own message immediately (sender is excluded from SignalR broadcast)
            if (!messages.Any(m => m.Id == msg.Id))
                messages.Add(msg);

            // Update sidebar
            var room = rooms.FirstOrDefault(r => r.Id == msg.RoomId);
            if (room != null)
            {
                room.LastMessage = msg.Content;
                room.LastMessageSender = msg.UserName;
                room.LastMessageTime = msg.CreatedAt;
                room.LastActivityAt = msg.CreatedAt;
                rooms = rooms.OrderByDescending(r => r.LastActivityAt).ToList();
                FilterRooms();
            }

            StateHasChanged();
            await ScrollToBottomAsync();
        }
        catch (Exception ex)
        {
            uploadError = ex.Message.Contains("size")
                ? "One or more files exceed the maximum allowed size."
                : "Failed to send message. Please try again.";
            StateHasChanged();
        }
        finally
        {
            isSending = false;
            StateHasChanged();
        }
    }

