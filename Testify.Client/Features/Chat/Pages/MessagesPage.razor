@page "/messages"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using Testify.Client.Interfaces
@using Testify.Client.Features.Chat.Components
@using Testify.Client.Features.Chat.Services
@using Testify.Client.Shared.Services
@using Testify.Shared.DTOs.Chat
@using Testify.Shared.Enums
@using System.Threading
@inject IChatService ChatService
@inject IServiceProvider ServiceProvider
@inject IJSRuntime JSRuntime

@rendermode InteractiveWebAssembly
@attribute [Authorize]
@implements IAsyncDisposable

<PageTitle>Messages - Testify</PageTitle>

@if (isLoading)
{
    <div class="flex items-center justify-center min-h-screen">
        <div class="h-12 w-12 animate-spin rounded-full border-b-2 border-[#E85D3F]"></div>
    </div>
}
else
{
    <div @onclick="CloseEmojiPickers" class="max-w-[1400px] mx-auto px-6 h-[calc(100vh-160px)] flex gap-8">
        @* Sidebar *@
        <div class="w-80 flex flex-col gap-6 h-full">
            <div class="bg-white rounded-[40px] p-6 border border-slate-100 shadow-sm flex flex-col h-full overflow-hidden">
                <div class="flex justify-between items-center mb-6">
                    <h2 class="text-2xl font-black text-slate-800">Messages</h2>
                    <div class="flex gap-1">
                        <button @onclick="OpenCreateGroupModal" class="p-2 bg-slate-50 hover:bg-slate-100 rounded-xl transition-all text-slate-600" title="Create group">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                            </svg>
                        </button>
                        <button @onclick="OpenNewChatDialog" class="p-2 bg-slate-50 hover:bg-slate-100 rounded-xl transition-all text-[#E85D3F]" title="Chat mới">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M5 12h14"/><path d="M12 5v14"/>
                            </svg>
                        </button>
                    </div>
                </div>

                <div class="relative mb-6">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400">
                        <circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>
                    </svg>
                    <input 
                        type="text" 
                        value="@searchQuery"
                        @oninput="OnSearchQueryInput"
                        placeholder="Find people or channels"
                        class="w-full pl-11 pr-4 py-3 bg-slate-50 rounded-2xl text-xs font-bold focus:outline-none focus:bg-white focus:ring-2 focus:ring-slate-100 transition-all"
                    />
                </div>

                <div class="flex-1 overflow-y-auto no-scrollbar space-y-2">
                    <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2 px-2">Recent Chats</p>
                    
                    @if (filteredRooms.Any())
                    {
                        @foreach (var room in filteredRooms)
                        {
                            <button
                                @onclick="() => SelectRoom(room.Id)"
                                class="@GetRoomButtonClass(room.Id) w-full flex items-center gap-3 p-3 rounded-3xl transition-all relative group text-left"
                            >
                                <div class="relative flex-shrink-0">
                                    @if (room.RoomType == ChatRoomType.Private && room.OtherParticipant != null)
                                    {
                                        @if (!string.IsNullOrEmpty(room.OtherParticipant.AvatarUrl))
                                        {
                                            <img src="@room.OtherParticipant.AvatarUrl" class="w-12 h-12 rounded-2xl object-cover" alt="" />
                                        }
                                        else
                                        {
                                            <div class="w-12 h-12 rounded-2xl bg-slate-100 flex items-center justify-center font-bold text-slate-600">
                                                @GetInitials(room.OtherParticipant.FullName ?? room.OtherParticipant.UserName)
                                            </div>
                                        }
                                        <div class="@GetStatusDotClass(room.OtherParticipant.IsOnline, activeRoomId == room.Id) absolute -bottom-1 -right-1 w-4 h-4 rounded-full border-2"></div>
                                    }
                                    else
                                    {
                                        <div class="@(activeRoomId == room.Id ? "bg-slate-700" : "bg-slate-100 text-slate-400") w-12 h-12 rounded-2xl flex items-center justify-center font-bold">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <path d="M4 21V4a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v17"/>
                                            </svg>
                                        </div>
                                    }
                                </div>
                                
                                <div class="flex-1 min-w-0 text-left overflow-hidden">
                                    <div class="flex justify-between items-center gap-2">
                                        <span class="@(room.UnreadCount > 0 && room.Id != activeRoomId ? "font-black text-xs truncate text-slate-900" : "font-bold text-xs truncate") ">@GetRoomDisplayName(room)</span>
                                        <span class="@(activeRoomId == room.Id ? "text-slate-400" : room.UnreadCount > 0 ? "text-[#E85D3F] font-black" : "text-slate-300") text-[9px] font-bold flex-shrink-0">
                                            @FormatTime(room.LastMessageTime)
                                        </span>
                                    </div>
                                    <p class="@(activeRoomId == room.Id ? "text-slate-300" : room.UnreadCount > 0 ? "text-slate-700 font-bold" : "text-slate-400") text-[10px] truncate mt-0.5">
                                        @(room.LastMessage ?? "No messages yet")
                                    </p>
                                </div>

                                @if (room.UnreadCount > 0 && room.Id != activeRoomId)
                                {
                                    <div class="absolute right-3 bottom-4 bg-[#E85D3F] text-white text-[9px] font-black min-w-5 h-5 flex items-center justify-center rounded-full px-1">
                                        @(room.UnreadCount > 9 ? "9+" : room.UnreadCount.ToString())
                                    </div>
                                }
                            </button>
                        }
                    }
                    else
                    {
                        <div class="text-center py-12">
                            <p class="text-sm text-slate-400">No conversations yet</p>
                            <button @onclick="OpenNewChatDialog" class="mt-4 text-xs font-black text-[#E85D3F] hover:underline">
                                Start New Chat
                            </button>
                        </div>
                    }
                </div>
            </div>
        </div>

        @* Chat Area *@
        @if (activeRoom != null)
        {
            <div class="flex-1 bg-white rounded-[48px] border border-slate-100 shadow-sm flex flex-col overflow-hidden relative">
                @* Chat Header *@
                <div class="p-8 border-b border-slate-50 flex items-center justify-between bg-white/50 backdrop-blur-sm sticky top-0 z-10">
                    <div class="flex items-center gap-4">
                        <div class="relative">
                            @if (activeRoom.RoomType == ChatRoomType.Private && activeRoom.OtherParticipant != null)
                            {
                                @if (!string.IsNullOrEmpty(activeRoom.OtherParticipant.AvatarUrl))
                                {
                                    <img src="@activeRoom.OtherParticipant.AvatarUrl" class="w-14 h-14 rounded-[22px] object-cover shadow-sm" alt="" />
                                }
                                else
                                {
                                    <div class="w-14 h-14 rounded-[22px] bg-slate-100 flex items-center justify-center font-bold text-slate-600 text-xl shadow-sm">
                                        @GetInitials(activeRoom.OtherParticipant.FullName ?? activeRoom.OtherParticipant.UserName)
                                    </div>
                                }
                                <div class="@GetStatusDotClass(activeRoom.OtherParticipant.IsOnline, false) absolute -bottom-1 -right-1 w-5 h-5 rounded-full border-4 border-white"></div>
                            }
                            else
                            {
                                <div class="w-14 h-14 bg-slate-100 rounded-[22px] flex items-center justify-center text-slate-400">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M4 21V4a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v17"/>
                                    </svg>
                                </div>
                            }
                        </div>
                        <div>
                            <h3 class="text-xl font-black text-slate-800 flex items-center gap-2">
                                @GetRoomDisplayName(activeRoom)
                                @if (activeRoom.RoomType != ChatRoomType.Private)
                                {
                                    <span class="text-[10px] bg-slate-100 text-slate-400 px-2 py-0.5 rounded-full uppercase tracking-tighter">
                                        @(activeRoom.RoomType == ChatRoomType.Group ? "Group" : "Project")
                                    </span>
                                }
                            </h3>
                            <p class="text-[11px] font-bold text-slate-400 flex items-center gap-1.5 mt-0.5 uppercase tracking-widest">
                                @if (activeRoom.RoomType == ChatRoomType.Private && activeRoom.OtherParticipant != null)
                                {
                                    <span class="w-2 h-2 rounded-full @(activeRoom.OtherParticipant.IsOnline ? "bg-emerald-500" : "bg-slate-300")"></span>
                                    <span>@(activeRoom.OtherParticipant.IsOnline ? "Online" : "Offline")</span>
                                }
                                else
                                {
                                    <span class="opacity-30">•</span>
                                    <span>@activeRoom.Participants.Count Members</span>
                                }
                            </p>
                        </div>
                    </div>

                    <div class="flex items-center gap-2">
                        @if (activeRoom.RoomType == ChatRoomType.Private)
                        {
                            <button @onclick="() => StartCall(CallType.Audio)" class="p-3 text-slate-400 hover:bg-slate-50 rounded-2xl transition-all" title="Voice call" disabled="@isInCall">
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
                                </svg>
                            </button>
                            <button @onclick="() => StartCall(CallType.Video)" class="p-3 text-slate-400 hover:bg-slate-50 rounded-2xl transition-all" title="Video call" disabled="@isInCall">
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="m22 8-6 4 6 4V8Z"/><rect width="14" height="12" x="2" y="6" rx="2" ry="2"/>
                                </svg>
                            </button>
                        }
                        <div class="w-px h-8 bg-slate-100 mx-2"></div>
                        <button @onclick="ToggleMessageSearch" class="@(isMessageSearchOpen ? "p-3 text-[#E85D3F] bg-red-50 rounded-2xl transition-all" : "p-3 text-slate-400 hover:bg-slate-50 rounded-2xl transition-all")" title="Search messages">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>
                            </svg>
                        </button>
                        <button @onclick="TogglePinnedPanel" class="@(isPinnedPanelOpen ? "p-3 text-[#E85D3F] bg-red-50 rounded-2xl transition-all" : "p-3 text-slate-400 hover:bg-slate-50 rounded-2xl transition-all") relative" title="Pinned messages">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M12 17v5"/><path d="M9 10.76a2 2 0 0 1-1.11 1.79l-1.78.9A2 2 0 0 0 5 15.24V16a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-.76a2 2 0 0 0-1.11-1.79l-1.78-.9A2 2 0 0 1 15 10.76V7a1 1 0 0 1 1-1 2 2 0 0 0 0-4H8a2 2 0 0 0 0 4 1 1 0 0 1 1 1z"/>
                            </svg>
                            @if (pinnedMessages.Any())
                            {
                                <span class="absolute -top-0.5 -right-0.5 w-5 h-5 bg-[#E85D3F] text-white text-[9px] font-black rounded-full flex items-center justify-center">@pinnedMessages.Count</span>
                            }
                        </button>
                        <button @onclick="ToggleRoomSettings" class="@(isRoomSettingsOpen ? "p-3 text-[#E85D3F] bg-red-50 rounded-2xl transition-all" : "p-3 text-slate-400 hover:bg-slate-50 rounded-2xl transition-all")" title="Room settings">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/>
                            </svg>
                        </button>
                    </div>
                </div>

                @* Message Search Bar *@
                @if (isMessageSearchOpen)
                {
                    <div class="px-8 py-3 bg-slate-50/80 border-b border-slate-100 flex items-center gap-3">
                        <div class="relative flex-1">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400">
                                <circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>
                            </svg>
                            <input type="text"
                                   @bind="messageSearchQuery"
                                   @bind:event="oninput"
                                   @bind:after="OnMessageSearchInput"
                                   placeholder="Search in this conversation..."
                                   class="w-full pl-10 pr-4 py-2.5 bg-white rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-[#E85D3F]/20 border border-slate-200 transition-all" />
                        </div>
                        @if (isSearching)
                        {
                            <div class="h-5 w-5 animate-spin rounded-full border-2 border-[#E85D3F] border-t-transparent"></div>
                        }
                        else if (!string.IsNullOrWhiteSpace(messageSearchQuery))
                        {
                            <span class="text-xs font-bold text-slate-400 whitespace-nowrap">@searchTotalCount result@(searchTotalCount != 1 ? "s" : "")</span>
                        }
                        <button @onclick="CloseMessageSearch" class="p-2 text-slate-400 hover:text-slate-600 hover:bg-slate-100 rounded-xl transition-all" title="Close">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M18 6 6 18"/><path d="m6 6 12 12"/>
                            </svg>
                        </button>
                    </div>

                    @* Search Results Dropdown *@
                    @if (searchResults.Any())
                    {
                        <div class="max-h-64 overflow-y-auto border-b border-slate-100 bg-white shadow-inner">
                            @foreach (var result in searchResults)
                            {
                                <button @onclick="() => NavigateToSearchResult(result)"
                                        class="@(highlightedMessageId == result.Id ? "bg-amber-50 border-l-2 border-[#E85D3F]" : "border-l-2 border-transparent hover:bg-slate-50") w-full text-left px-8 py-3 transition-all">
                                    <div class="flex items-center gap-3">
                                        <div class="w-8 h-8 rounded-lg bg-slate-100 flex items-center justify-center text-xs font-bold text-slate-500 flex-shrink-0">
                                            @GetInitials(result.UserName)
                                        </div>
                                        <div class="flex-1 min-w-0">
                                            <div class="flex items-center gap-2">
                                                <span class="text-xs font-bold text-slate-700">@result.UserName</span>
                                                <span class="text-[10px] text-slate-400">@result.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
                                            </div>
                                            <p class="text-xs text-slate-500 truncate mt-0.5">@HighlightSearchMatch(result.Content)</p>
                                        </div>
                                    </div>
                                </button>
                            }
                            @if (hasMoreSearchResults)
                            {
                                <div class="flex justify-center py-2">
                                    <button @onclick="LoadMoreSearchResults" disabled="@isSearching"
                                            class="text-xs font-bold text-[#E85D3F] hover:underline disabled:opacity-50">
                                        Load more results
                                    </button>
                                </div>
                            }
                        </div>
                    }
                    else if (!isSearching && !string.IsNullOrWhiteSpace(messageSearchQuery) && messageSearchQuery.Length >= 2)
                    {
                        <div class="px-8 py-4 border-b border-slate-100 bg-white">
                            <p class="text-xs text-slate-400 text-center">No messages found for "@messageSearchQuery"</p>
                        </div>
                    }
                }

                @* Pinned Messages Panel *@
                @if (isPinnedPanelOpen)
                {
                    <div class="border-b border-slate-100 bg-amber-50/50">
                        <div class="px-8 py-3 flex items-center justify-between">
                            <div class="flex items-center gap-2">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-amber-500">
                                    <path d="M12 17v5"/><path d="M9 10.76a2 2 0 0 1-1.11 1.79l-1.78.9A2 2 0 0 0 5 15.24V16a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-.76a2 2 0 0 0-1.11-1.79l-1.78-.9A2 2 0 0 1 15 10.76V7a1 1 0 0 1 1-1 2 2 0 0 0 0-4H8a2 2 0 0 0 0 4 1 1 0 0 1 1 1z"/>
                                </svg>
                                <span class="text-xs font-bold text-amber-700">Pinned Messages (@pinnedMessages.Count)</span>
                            </div>
                            <button @onclick="TogglePinnedPanel" class="p-1.5 text-slate-400 hover:text-slate-600 hover:bg-slate-100 rounded-lg transition-all" title="Close">
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M18 6 6 18"/><path d="m6 6 12 12"/>
                                </svg>
                            </button>
                        </div>
                        @if (isLoadingPinned)
                        {
                            <div class="px-8 py-4 flex justify-center">
                                <div class="h-5 w-5 animate-spin rounded-full border-2 border-amber-500 border-t-transparent"></div>
                            </div>
                        }
                        else if (pinnedMessages.Any())
                        {
                            <div class="max-h-64 overflow-y-auto">
                                @foreach (var pin in pinnedMessages)
                                {
                                    <div class="px-8 py-3 hover:bg-amber-50 transition-all border-t border-amber-100/50 group/pin">
                                        <div class="flex items-start gap-3">
                                            <div class="w-8 h-8 rounded-lg bg-slate-100 flex items-center justify-center text-xs font-bold text-slate-500 flex-shrink-0 mt-0.5">
                                                @GetInitials(pin.Message.UserName)
                                            </div>
                                            <div class="flex-1 min-w-0">
                                                <div class="flex items-center justify-between gap-2">
                                                    <div class="flex items-center gap-2">
                                                        <span class="text-xs font-bold text-slate-700">@pin.Message.UserName</span>
                                                        <span class="text-[10px] text-slate-400">@pin.Message.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
                                                    </div>
                                                    <div class="flex items-center gap-1 opacity-0 group-hover/pin:opacity-100 transition-opacity">
                                                        <button @onclick="() => NavigateToPinnedMessage(pin.MessageId)" class="text-[10px] font-bold text-[#7E96E1] hover:text-[#5A78D0] px-2 py-1 rounded-lg hover:bg-blue-50 transition-all" title="Jump to message">
                                                            Jump
                                                        </button>
                                                        <button @onclick="() => UnpinMessage(pin.RoomId, pin.MessageId)" class="text-[10px] font-bold text-slate-400 hover:text-red-500 px-2 py-1 rounded-lg hover:bg-red-50 transition-all" title="Unpin">
                                                            Unpin
                                                        </button>
                                                    </div>
                                                </div>
                                                <p class="text-xs text-slate-600 mt-0.5 line-clamp-2">
                                                    @(pin.Message.IsDeleted ? "[Message withdrawn]" : pin.Message.Content)
                                                </p>
                                                @if (!string.IsNullOrWhiteSpace(pin.Note))
                                                {
                                                    <p class="text-[10px] text-amber-600 mt-1 italic">Note: @pin.Note</p>
                                                }
                                                <p class="text-[10px] text-slate-400 mt-1">Pinned by @pin.PinnedByUserName · @pin.PinnedAt.ToString("dd/MM HH:mm")</p>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="px-8 py-4">
                                <p class="text-xs text-slate-400 text-center">No pinned messages in this conversation</p>
                            </div>
                        }
                    </div>
                }

                @* Message List *@
                <div id="chat-messages" class="flex-1 overflow-y-auto p-10 space-y-8 no-scrollbar">
                    @if (hasMoreMessages)
                    {
                        <div class="flex justify-center mb-4">
                            <button @onclick="LoadMoreMessages" disabled="@isLoadingMore"
                                    class="px-4 py-2 text-xs font-bold text-slate-500 bg-slate-100 hover:bg-slate-200 rounded-full transition-all disabled:opacity-50">
                                @(isLoadingMore ? "Loading..." : "Load older messages")
                            </button>
                        </div>
                    }
                    @{
                        DateTime? _lastMsgDate = null;
                    }
                    @foreach (var message in messages)
                    {
                        var msgDate = message.CreatedAt.Date;
                        if (_lastMsgDate == null || msgDate != _lastMsgDate.Value)
                        {
                            _lastMsgDate = msgDate;
                            <div class="flex flex-col items-center my-6">
                                <div class="bg-slate-50 px-4 py-1.5 rounded-full text-[10px] font-black text-slate-400 uppercase tracking-widest">
                                    @FormatDateSeparator(msgDate)
                                </div>
                            </div>
                        }
                        var isOwn = IsOwnMessage(message);

                        @* --- Call message special rendering --- *@
                        @if (message.MessageType == MessageType.Call)
                        {
                            var callMeta = ParseCallMetadata(message.Metadata);
                            var isOutgoing = message.UserId == currentUserId;
                            var callIcon = callMeta.CallType == "Video" ? "video" : "phone";
                            var statusColor = callMeta.CallStatus switch
                            {
                                "Ended" => "text-green-600",
                                "Missed" => "text-red-500",
                                "Rejected" => "text-orange-500",
                                "Cancelled" => "text-slate-400",
                                _ => "text-slate-500"
                            };
