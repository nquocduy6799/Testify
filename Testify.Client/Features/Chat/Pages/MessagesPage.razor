    private async void HandleMessageReceived(ChatMessageResponse message)
    {
        await InvokeAsync(async () =>
        {
            var room = rooms.FirstOrDefault(r => r.Id == message.RoomId);
            if (room == null)
            {
                var newRoom = await ChatService.GetChatRoomByIdAsync(message.RoomId);
                if (newRoom != null)
                {
                    newRoom.LastMessage = message.Content;
                    newRoom.LastMessageSender = message.UserName;
                    newRoom.LastMessageTime = message.CreatedAt;
                    newRoom.LastActivityAt = message.CreatedAt;
                    if (message.UserId != currentUserId)
                        newRoom.UnreadCount = 1;
                    rooms.Insert(0, newRoom);
                    rooms = rooms.OrderByDescending(r => r.LastActivityAt).ToList();
                    FilterRooms();
                }
            }
            else
            {
                room.LastMessage = message.Content;
                room.LastMessageSender = message.UserName;
                room.LastMessageTime = message.CreatedAt;
                room.LastActivityAt = message.CreatedAt;
                if (message.RoomId != activeRoomId && message.UserId != currentUserId)
                    room.UnreadCount++;
                rooms = rooms.OrderByDescending(r => r.LastActivityAt).ToList();
                FilterRooms();
            }

            if (message.RoomId == activeRoomId)
            {
                if (!messages.Any(m => m.Id == message.Id))
                    messages.Add(message);
                if (message.UserId != currentUserId)
                    _ = ChatService.MarkAsReadAsync(message.RoomId, message.Id);
            }

            StateHasChanged();
            if (message.RoomId == activeRoomId)
                await ScrollToBottomAsync();
        });
    }

