                                <div class="flex justify-center py-6"><div class="h-8 w-8 animate-spin rounded-full border-2 border-[#E85D3F] border-t-transparent"></div></div>
                            }
                            else
                            {
                                <div class="max-h-48 overflow-y-auto space-y-1 rounded-2xl border border-slate-100 p-2">
                                    @foreach (var u in usersForGroup)
                                    {
                                        var isSelected = selectedUserIdsForGroup.Contains(u.Id);
                                        <button type="button" @onclick="() => ToggleGroupUser(u.Id)"
                                                class="w-full flex items-center gap-3 p-2.5 rounded-xl text-left transition-all @(isSelected ? "bg-[#E85D3F]/10 ring-1 ring-[#E85D3F]/30" : "hover:bg-slate-50")">
                                            @if (!string.IsNullOrEmpty(u.AvatarUrl))
                                            {
                                                <img src="@u.AvatarUrl" class="w-9 h-9 rounded-xl object-cover flex-shrink-0" alt="" />
                                            }
                                            else
                                            {
                                                <div class="w-9 h-9 rounded-xl bg-slate-100 flex items-center justify-center font-bold text-slate-600 text-xs flex-shrink-0">@GetInitials(u.FullName ?? u.UserName)</div>
                                            }
                                            <span class="flex-1 font-bold text-slate-800 text-sm truncate">@(u.FullName ?? u.UserName)</span>
                                            @if (isSelected)
                                            {
                                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-[#E85D3F] flex-shrink-0"><path d="M20 6 9 17l-5-5"/></svg>
