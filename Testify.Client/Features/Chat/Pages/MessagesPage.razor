        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2)
            return $"{parts[0][0]}{parts[1][0]}".ToUpper();
        return parts[0][..1].ToUpper();
    }

    private string FormatTime(DateTime? time)
    {
        if (!time.HasValue) return "";
        
        var now = DateTime.Now;
        var diff = now - time.Value;
        
        if (diff.TotalMinutes < 1) return "Now";
        if (diff.TotalHours < 1) return $"{(int)diff.TotalMinutes}m";
        if (diff.TotalDays < 1) return time.Value.ToString("HH:mm");
        if (diff.TotalDays < 2) return "Yesterday";
        if (diff.TotalDays < 7) return time.Value.ToString("ddd");
        return time.Value.ToString("MMM dd");
    }

    private string FormatDateSeparator(DateTime date)
    {
        var today = DateTime.Today;
        if (date == today) return $"Today, {date:MMMM dd}";
        if (date == today.AddDays(-1)) return $"Yesterday, {date:MMMM dd}";
        if (date.Year == today.Year) return date.ToString("dddd, MMMM dd");
        return date.ToString("dddd, MMMM dd, yyyy");
    }

    private string FormatFileSize(long bytes)
    {
        string[] sizes = { "B", "KB", "MB", "GB" };
        double len = bytes;
        int order = 0;
        while (len >= 1024 && order < sizes.Length - 1)
        {
            order++;
            len = len / 1024;
        }
        return $"{len:0.##} {sizes[order]}";
    }

