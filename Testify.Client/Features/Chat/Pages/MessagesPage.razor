    private async Task ToggleReaction(int messageId, string emoji, bool hasReacted)
    {
        try
        {
            var msg = messages.FirstOrDefault(m => m.Id == messageId);
            if (msg == null) return;

            if (hasReacted)
            {
                // Optimistic local update: remove reaction
                var existing = msg.Reactions.FirstOrDefault(r => r.UserId == currentUserId && r.Emoji == emoji);
                if (existing != null) msg.Reactions.Remove(existing);
                StateHasChanged();
                await ChatService.RemoveReactionAsync(messageId, emoji);
            }
            else
            {
                // Optimistic local update: add reaction
                if (msg.Reactions.All(r => r.UserId != currentUserId || r.Emoji != emoji))
                {
                    msg.Reactions.Add(new ChatMessageReactionResponse
                    {
                        MessageId = messageId,
                        UserId = currentUserId ?? "",
                        UserName = "",
                        Emoji = emoji
                    });
                }
                StateHasChanged();
                await ChatService.AddReactionAsync(new AddReactionRequest { MessageId = messageId, Emoji = emoji });
            }
        }
        catch { }
    }

