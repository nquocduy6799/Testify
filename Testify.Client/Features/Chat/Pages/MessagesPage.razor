    private void HandleMessageDeleted(int messageId)
    {
        var msg = messages.FirstOrDefault(m => m.Id == messageId);
        if (msg != null)
        {
            msg.Content = "The message has been withdrawn.";
            msg.IsDeleted = true;

            // Update ParentMessage references in replies
            foreach (var m in messages.Where(m => m.ParentMessage?.Id == messageId))
            {
                m.ParentMessage!.Content = "The message has been withdrawn.";
                m.ParentMessage.IsDeleted = true;
            }

            // Update sidebar if this was the last message in the room
            var room = rooms.FirstOrDefault(r => r.Id == msg.RoomId);
            if (room != null && messages.LastOrDefault()?.Id == messageId)
            {
                room.LastMessage = "The message has been withdrawn.";
            }
        }
        InvokeAsync(StateHasChanged);
    }

