    #region Call Methods

    private record CallMetadata(string CallType, string CallStatus, int? DurationSeconds, string CallerUserId, string CalleeUserId);

    private CallMetadata ParseCallMetadata(string? metadata)
    {
        if (string.IsNullOrEmpty(metadata))
            return new CallMetadata("Audio", "Ended", null, "", "");

        try
        {
            using var doc = System.Text.Json.JsonDocument.Parse(metadata);
            var root = doc.RootElement;
            return new CallMetadata(
                root.TryGetProperty("callType", out var ct) ? ct.GetString() ?? "Audio" : "Audio",
                root.TryGetProperty("callStatus", out var cs) ? cs.GetString() ?? "Ended" : "Ended",
                root.TryGetProperty("durationSeconds", out var ds) && ds.ValueKind == System.Text.Json.JsonValueKind.Number ? ds.GetInt32() : null,
                root.TryGetProperty("callerUserId", out var cu) ? cu.GetString() ?? "" : "",
                root.TryGetProperty("calleeUserId", out var ceu) ? ceu.GetString() ?? "" : ""
            );
        }
        catch
        {
            return new CallMetadata("Audio", "Ended", null, "", "");
        }
    }

    private async Task StartCallFromHistory(string callTypeStr)
    {
        var callType = callTypeStr == "Video" ? CallType.Video : CallType.Audio;
        await StartCall(callType);
    }

    private async Task StartCall(CallType callType)
    {
        if (isInCall || activeRoom == null || activeRoom.RoomType != ChatRoomType.Private) return;

        currentCallType = callType;
        callPeerName = activeRoom.OtherParticipant?.FullName ?? activeRoom.OtherParticipant?.UserName ?? "Unknown";
        callPeerAvatarUrl = activeRoom.OtherParticipant?.AvatarUrl;

        // Initialize WebRTC and get local media
        if (webRtcService == null) return;
        var initialized = await webRtcService.InitializeAsync(callType == CallType.Video);
        if (!initialized)
        {
            // Media access denied or failed
            return;
        }

        // Create SDP offer
        var sdpOffer = await webRtcService.CreateOfferAsync();
        if (string.IsNullOrEmpty(sdpOffer)) return;

        isInCall = true;
        videoCallWindow?.SetCallState(VideoCallWindow.CallState.Ringing);
        StateHasChanged();

        // Send offer via SignalR
        if (callHubService != null)
        {
            await callHubService.SendOfferAsync(new CallOfferRequest
            {
                RoomId = activeRoom.Id,
                CallType = callType,
                SdpOffer = sdpOffer
            });
        }

        // Play ring-back tone for the caller while waiting
        if (webRtcService != null)
            await webRtcService.PlayRingtoneAsync();

        // Start ringing timeout (30 seconds) — auto-cancel if no answer
        _ringingTimeoutCts?.Cancel();
        _ringingTimeoutCts = new CancellationTokenSource();
        var token = _ringingTimeoutCts.Token;
        _ = Task.Run(async () =>
        {
            try
            {
                await Task.Delay(30_000, token);
                if (!token.IsCancellationRequested && isInCall && activeCallSessionId.HasValue)
                {
                    await InvokeAsync(async () =>
                    {
                        if (callHubService != null)
                            await callHubService.CancelCallAsync(activeCallSessionId.Value);
                    });
                }
            }
            catch (TaskCanceledException) { /* Expected when call is answered or cancelled manually */ }
        });
    }



    private void HandleIncomingCall(IncomingCallResponse incomingCall)
    {
        if (isInCall)
        {
            // Already in a call, auto-reject
            _ = InvokeAsync(async () =>
            {
                if (callHubService != null)
                    await callHubService.RejectCallAsync(incomingCall.CallSessionId);
            });
            return;
        }

        incomingCallData = incomingCall;
        hasIncomingCall = true;

        // Play ringtone
        _ = InvokeAsync(async () =>
        {
            if (webRtcService != null)
                await webRtcService.PlayRingtoneAsync();
            StateHasChanged();
        });
    }

    private void HandleCallRinging(int callSessionId)
    {
        activeCallSessionId = callSessionId;
        InvokeAsync(StateHasChanged);
    }

    private void HandleCallAnswered(CallAnsweredResponse response)
    {
        // Cancel ringing timeout — call was answered
        _ringingTimeoutCts?.Cancel();

        _ = InvokeAsync(async () =>
        {
            if (webRtcService == null) return;
            // Stop ring-back tone
            await webRtcService.StopRingtoneAsync();
            // Set remote description (answer)
            await webRtcService.SetRemoteDescriptionAsync(response.SdpAnswer);
            videoCallWindow?.SetCallState(VideoCallWindow.CallState.Connecting);
            StateHasChanged();

            // Start connecting timeout (15s) — auto-end if WebRTC handshake doesn't complete
            StartConnectingTimeout();
        });
    }

    private void HandleIceCandidateReceived(IceCandidateRequest ice)
    {
        _ = InvokeAsync(async () =>
        {
            if (webRtcService != null)
                await webRtcService.AddIceCandidateAsync(ice.Candidate, ice.SdpMid, ice.SdpMLineIndex);
        });
    }

    private void HandleLocalIceCandidate(string candidate, string? sdpMid, int sdpMLineIndex)
    {
        if (!activeCallSessionId.HasValue || callHubService == null) return;

        _ = InvokeAsync(async () =>
        {
            await callHubService.SendIceCandidateAsync(new IceCandidateRequest
            {
                CallSessionId = activeCallSessionId.Value,
                Candidate = candidate,
                SdpMid = sdpMid,
                SdpMLineIndex = sdpMLineIndex
            });
        });
    }

    private void HandleCallEndedSignalR(CallEndedResponse response)
    {
        _ringingTimeoutCts?.Cancel();

        _ = InvokeAsync(async () =>
        {
            if (webRtcService != null)
            {
                await webRtcService.StopRingtoneAsync();
                await webRtcService.DisposeWebRtcAsync();
            }
            videoCallWindow?.SetCallState(VideoCallWindow.CallState.Ended);
            isInCall = false;
