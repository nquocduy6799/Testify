    private async Task OnFilesSelected(InputFileChangeEventArgs e)
    {
        uploadError = string.Empty;

        try
        {
            var filesToAdd = e.GetMultipleFiles();

            foreach (var browserFile in filesToAdd)
            {
                if (browserFile.Size > MaxFileSizeBytes)
                {
                    uploadError = $"File '{browserFile.Name}' exceeds the maximum size of {MaxFileSizeBytes / (1024 * 1024)} MB.";
                    continue;
                }

                if (browserFile.Size == 0)
                {
                    uploadError = $"File '{browserFile.Name}' is empty.";
                    continue;
                }

                // Read file content into a MemoryStream (for Blazor WASM, we buffer it)
                var ms = new MemoryStream();
                await browserFile.OpenReadStream(MaxFileSizeBytes).CopyToAsync(ms);
                ms.Position = 0;

                selectedFiles.Add(new FileUploadItem
                {
                    FileName = browserFile.Name,
                    Size = browserFile.Size,
                    ContentType = browserFile.ContentType ?? "application/octet-stream",
                    Content = ms
                });
            }

            StateHasChanged();
        }
        catch (Exception ex)
        {
            uploadError = "Failed to read selected files. Please try again.";
            Console.WriteLine($"File selection error: {ex.Message}");
            StateHasChanged();
        }
    }

    private void RemoveSelectedFile(int index)
    {
        if (index >= 0 && index < selectedFiles.Count)
        {
            var file = selectedFiles[index];
            file.Content?.Dispose();
            selectedFiles.RemoveAt(index);
            StateHasChanged();
        }
    }

    private void ClearSelectedFiles()
    {
        foreach (var file in selectedFiles)
        {
            file.Content?.Dispose();
        }
        selectedFiles.Clear();
    }

