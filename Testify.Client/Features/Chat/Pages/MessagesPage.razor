    private void HandleParticipantsAddedSignalR(int roomId, List<ChatParticipantResponse> newMembers)
    {
        if (activeRoom != null && activeRoom.Id == roomId)
        {
            _ = HandleMembersAdded(newMembers);
        }
        // Also update the room in the sidebar
        var room = rooms.FirstOrDefault(r => r.Id == roomId);
        if (room != null)
        {
            foreach (var member in newMembers)
            {
                if (!room.Participants.Any(p => p.UserId == member.UserId))
                {
                    room.Participants.Add(member);
                }
            }
            InvokeAsync(StateHasChanged);
        }
    }

    private void HandleParticipantRemovedSignalR(int roomId, string removedUserId, string removedByUserId)
    {
        if (removedUserId == currentUserId)
        {
            // Current user was removed from the room
            rooms.RemoveAll(r => r.Id == roomId);
            if (activeRoom != null && activeRoom.Id == roomId)
            {
                activeRoom = null;
                activeRoomId = null;
                messages.Clear();
                isRoomSettingsOpen = false;
            }
            InvokeAsync(StateHasChanged);
            return;
        }
        if (activeRoom != null && activeRoom.Id == roomId)
        {
            activeRoom.Participants.RemoveAll(p => p.UserId == removedUserId);
            InvokeAsync(StateHasChanged);
        }
        var room = rooms.FirstOrDefault(r => r.Id == roomId);
        if (room != null)
        {
            room.Participants.RemoveAll(p => p.UserId == removedUserId);
            InvokeAsync(StateHasChanged);
        }
    }

