    private async Task OnMessageSearchInput()
    {
        _searchDebounceCts?.Cancel();
        _searchDebounceCts?.Dispose();
        _searchDebounceCts = new CancellationTokenSource();
        var token = _searchDebounceCts.Token;

        try
        {
            await Task.Delay(350, token);
            if (token.IsCancellationRequested) return;
            await ExecuteMessageSearch(resetResults: true);
        }
        catch (TaskCanceledException) { }
    }

    private async Task ExecuteMessageSearch(bool resetResults)
    {
        if (activeRoomId == null) return;

        var query = messageSearchQuery?.Trim() ?? string.Empty;
        if (query.Length < 2)
        {
            searchResults.Clear();
            searchTotalCount = 0;
            hasMoreSearchResults = false;
            StateHasChanged();
            return;
        }

        if (resetResults)
        {
            searchSkip = 0;
            searchResults.Clear();
        }

        isSearching = true;
        StateHasChanged();

        try
        {
            var (results, totalCount) = await ChatService.SearchMessagesAsync(activeRoomId.Value, query, searchSkip, 20);
            if (resetResults)
            {
                searchResults = results;
            }
            else
            {
                searchResults.AddRange(results);
            }
            searchTotalCount = totalCount;
            searchSkip = searchResults.Count;
            hasMoreSearchResults = searchResults.Count < totalCount;
        }
        catch
        {
            // Silently handle errors
        }
        finally
        {
            isSearching = false;
            StateHasChanged();
        }
    }

    private async Task LoadMoreSearchResults()
    {
        await ExecuteMessageSearch(resetResults: false);
    }

    private async Task NavigateToSearchResult(ChatMessageResponse result)
    {
        if (activeRoomId == null) return;

        highlightedMessageId = result.Id;
        StateHasChanged();

        // Check if the message is already loaded in the current message list
        var existingMessage = messages.FirstOrDefault(m => m.Id == result.Id);
        if (existingMessage != null)
        {
            // Scroll to the message
            await JSRuntime.InvokeVoidAsync("eval", $"document.querySelector('[data-message-id=\"{result.Id}\"]')?.scrollIntoView({{ behavior: 'smooth', block: 'center' }})");
        }
        else
        {
            // Need to load messages around this result
            // Find approximate skip to load the page containing this message
            // Load from the beginning and paginate until we find it, or reload with a targeted skip
            messages.Clear();
            messageSkip = 0;
            hasMoreMessages = true;

            // Load messages page by page until we find the target
            bool found = false;
            int maxAttempts = 20; // Prevent infinite loops
            while (!found && hasMoreMessages && maxAttempts > 0)
            {
                var batch = await ChatService.GetRoomMessagesAsync(activeRoomId.Value, messageSkip, 50);
                if (batch.Count < 50) hasMoreMessages = false;

                messages.InsertRange(0, batch);
                messageSkip += batch.Count;
                maxAttempts--;

                if (batch.Any(m => m.Id == result.Id))
                {
                    found = true;
                }
            }

            StateHasChanged();
            await Task.Delay(100); // Wait for DOM to update
            await JSRuntime.InvokeVoidAsync("eval", $"document.querySelector('[data-message-id=\"{result.Id}\"]')?.scrollIntoView({{ behavior: 'smooth', block: 'center' }})");
        }

        // Auto-clear highlight after 3 seconds
        _ = Task.Run(async () =>
        {
            await Task.Delay(3000);
            await InvokeAsync(() =>
            {
                if (highlightedMessageId == result.Id)
                {
                    highlightedMessageId = null;
                    StateHasChanged();
                }
            });
        });
    }

    private MarkupString HighlightSearchMatch(string content)
    {
        if (string.IsNullOrWhiteSpace(content) || string.IsNullOrWhiteSpace(messageSearchQuery))
            return new MarkupString(System.Net.WebUtility.HtmlEncode(content));

        var query = messageSearchQuery.Trim();
        var encoded = System.Net.WebUtility.HtmlEncode(content);
        var encodedQuery = System.Net.WebUtility.HtmlEncode(query);

        // Case-insensitive replacement with highlighting
        var index = encoded.IndexOf(encodedQuery, StringComparison.OrdinalIgnoreCase);
        if (index < 0)
            return new MarkupString(encoded);

        var before = encoded[..index];
        var match = encoded.Substring(index, encodedQuery.Length);
        var after = encoded[(index + encodedQuery.Length)..];

        return new MarkupString($"{before}<mark class=\"bg-amber-200 rounded px-0.5\">{match}</mark>{after}");
    }

