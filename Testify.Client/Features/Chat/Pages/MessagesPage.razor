    private void HandleMediaToggled(string userId, bool isAudioEnabled, bool isVideoEnabled)
    {
        videoCallWindow?.SetRemoteVideoEnabled(isVideoEnabled);
    }

    private void HandleWebRtcStateChanged(string state)
    {
        if (state == "connected")
        {
            // WebRTC handshake complete — cancel connecting timeout and move to Active
            _connectingTimeoutCts?.Cancel();
            videoCallWindow?.SetCallState(VideoCallWindow.CallState.Active);
            InvokeAsync(StateHasChanged);
            return;
        }

        if (state == "failed" || state == "closed")
        {
            _ringingTimeoutCts?.Cancel();
            _connectingTimeoutCts?.Cancel();

            _ = InvokeAsync(async () =>
            {
                Console.WriteLine($"WebRTC connection {state} — auto-ending call");
                if (webRtcService != null)
                    await webRtcService.DisposeWebRtcAsync();

                // Notify server if we have an active session
                if (callHubService != null && activeCallSessionId.HasValue)
                    await callHubService.EndCallAsync(activeCallSessionId.Value);

                videoCallWindow?.SetCallState(VideoCallWindow.CallState.Ended);
                isInCall = false;
                hasIncomingCall = false;
                incomingCallData = null;
                activeCallSessionId = null;
                StateHasChanged();
            });
        }
    }

    private async Task AcceptIncomingCall()
    {
        if (incomingCallData == null || callHubService == null) return;

        // Stop ringtone
        if (webRtcService != null)
            await webRtcService.StopRingtoneAsync();

        hasIncomingCall = false;
        isInCall = true;
        activeCallSessionId = incomingCallData.CallSessionId;
        currentCallType = incomingCallData.CallType;
        callPeerName = incomingCallData.CallerName;
        callPeerAvatarUrl = incomingCallData.CallerAvatarUrl;
        StateHasChanged();

        videoCallWindow?.SetCallState(VideoCallWindow.CallState.Connecting);

        // Initialize WebRTC
        if (webRtcService == null) return;
        var initialized = await webRtcService.InitializeAsync(incomingCallData.CallType == CallType.Video);
        if (!initialized)
        {
            await callHubService.RejectCallAsync(incomingCallData.CallSessionId);
            isInCall = false;
            activeCallSessionId = null;
            StateHasChanged();
            return;
        }

        // Set remote description (offer from caller)
        await webRtcService.SetRemoteDescriptionAsync(incomingCallData.SdpOffer);

        // Create answer
        var sdpAnswer = await webRtcService.CreateAnswerAsync();
        if (string.IsNullOrEmpty(sdpAnswer))
        {
            await callHubService.RejectCallAsync(incomingCallData.CallSessionId);
            isInCall = false;
            activeCallSessionId = null;
            await webRtcService.DisposeWebRtcAsync();
            StateHasChanged();
            return;
        }

        // Send answer
        await callHubService.SendAnswerAsync(new CallAnswerRequest
        {
            CallSessionId = incomingCallData.CallSessionId,
            SdpAnswer = sdpAnswer
        });

        videoCallWindow?.SetCallState(VideoCallWindow.CallState.Active);
        incomingCallData = null;

        // Start connecting timeout for callee side
        StartConnectingTimeout();
    }

    private async Task RejectIncomingCall()
    {
        if (incomingCallData == null || callHubService == null) return;

        // Stop ringtone
        if (webRtcService != null)
            await webRtcService.StopRingtoneAsync();

        await callHubService.RejectCallAsync(incomingCallData.CallSessionId);
        hasIncomingCall = false;
        incomingCallData = null;
        StateHasChanged();
    }

    private async Task HandleCallEndedUI()
    {
        _ringingTimeoutCts?.Cancel();
        isInCall = false;
        hasIncomingCall = false;
        incomingCallData = null;
        activeCallSessionId = null;
        StateHasChanged();
    }

    private void StartConnectingTimeout()
    {
        _connectingTimeoutCts?.Cancel();
        _connectingTimeoutCts = new CancellationTokenSource();
        var token = _connectingTimeoutCts.Token;
        _ = Task.Run(async () =>
        {
            try
            {
                await Task.Delay(15_000, token);
                if (!token.IsCancellationRequested && isInCall && activeCallSessionId.HasValue)
                {
                    await InvokeAsync(async () =>
                    {
                        Console.WriteLine("Connecting timeout — auto-ending call");
                        if (webRtcService != null)
                            await webRtcService.DisposeWebRtcAsync();
                        if (callHubService != null)
                            await callHubService.EndCallAsync(activeCallSessionId.Value);
                        videoCallWindow?.SetCallState(VideoCallWindow.CallState.Ended);
                        isInCall = false;
                        activeCallSessionId = null;
                        StateHasChanged();
                    });
                }
            }
            catch (TaskCanceledException) { }
        });
    }

    private async Task HandleCallHubReconnected()
    {
        if (callHubService == null) return;

        var activeCall = await callHubService.GetActiveCallAsync();
        if (activeCall == null)
        {
            if (isInCall)
            {
                if (webRtcService != null)
                    await webRtcService.DisposeWebRtcAsync();
                videoCallWindow?.SetCallState(VideoCallWindow.CallState.Ended);
                isInCall = false;
                activeCallSessionId = null;
                await InvokeAsync(StateHasChanged);
            }
            return;
        }

        isInCall = true;
        activeCallSessionId = activeCall.CallSessionId;
        currentCallType = activeCall.CallType;
        callPeerName = activeCall.PeerName;
        callPeerAvatarUrl = activeCall.PeerAvatarUrl;

        if (activeCall.Status == CallStatus.Active)
            videoCallWindow?.SetCallState(VideoCallWindow.CallState.Active);
        else
            videoCallWindow?.SetCallState(VideoCallWindow.CallState.Ringing);

        await InvokeAsync(StateHasChanged);
    }

    #endregion

    public async ValueTask DisposeAsync()
    {
        _typingStopCts?.Cancel();
        _typingStartCts?.Cancel();
        _searchDebounceCts?.Cancel();
        _searchDebounceCts?.Dispose();
        ClearSelectedFiles();
        if (hubService != null)
        {
            hubService.OnMessageReceived -= HandleMessageReceived;
            hubService.OnUserTyping -= HandleUserTyping;
            hubService.OnMessageDeleted -= HandleMessageDeleted;
            hubService.OnMessageUpdated -= HandleMessageUpdated;
            hubService.OnReactionAdded -= HandleReactionAdded;
            hubService.OnReactionRemoved -= HandleReactionRemoved;
            hubService.OnMessageRead -= HandleMessageRead;
            hubService.OnMessagePinned -= HandleMessagePinned;
            hubService.OnMessageUnpinned -= HandleMessageUnpinned;
            hubService.OnRoomUpdated -= HandleRoomUpdatedSignalR;
            hubService.OnParticipantsAdded -= HandleParticipantsAddedSignalR;
            hubService.OnParticipantRemoved -= HandleParticipantRemovedSignalR;
            if (activeRoomId.HasValue)
                await hubService.LeaveRoomAsync(activeRoomId.Value);
        }
        if (notificationHubService != null)
            notificationHubService.OnUserStatusChanged -= HandleUserStatusChanged;

        // Cleanup call services
        if (callHubService != null)
        {
            callHubService.OnIncomingCall -= HandleIncomingCall;
            callHubService.OnCallRinging -= HandleCallRinging;
            callHubService.OnCallAnswered -= HandleCallAnswered;
            callHubService.OnIceCandidateReceived -= HandleIceCandidateReceived;
            callHubService.OnCallEnded -= HandleCallEndedSignalR;
            callHubService.OnCallError -= HandleCallError;
            callHubService.OnMediaToggled -= HandleMediaToggled;
            callHubService.OnReconnected -= HandleCallHubReconnected;
        }
        if (webRtcService != null)
        {
            webRtcService.IceCandidateGenerated -= HandleLocalIceCandidate;
            webRtcService.ConnectionStateChanged -= HandleWebRtcStateChanged;
            if (isInCall)
                await webRtcService.DisposeWebRtcAsync();
        }

        _ringingTimeoutCts?.Cancel();
        _ringingTimeoutCts?.Dispose();
        _connectingTimeoutCts?.Cancel();
        _connectingTimeoutCts?.Dispose();
    }
}
