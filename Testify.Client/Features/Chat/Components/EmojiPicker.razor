        ["🙏"] = new[] { "pray", "please", "thanks" },
        ["💪"] = new[] { "strong", "muscle", "flex" },
        ["👀"] = new[] { "eyes", "look", "see" },
        ["🤝"] = new[] { "handshake", "deal", "agree" },
    };

    private List<string> GetFilteredEmojis()
    {
        if (string.IsNullOrWhiteSpace(searchQuery)) return new();

        var query = searchQuery.Trim().ToLower();
        var results = new List<string>();

        // Search by keyword
        foreach (var kvp in EmojiKeywords)
        {
            if (kvp.Value.Any(k => k.Contains(query)))
            {
                results.Add(kvp.Key);
            }
        }

        // Search all emojis by matching the emoji itself
        foreach (var cat in EmojiCategories.Values)
        {
            foreach (var emoji in cat)
            {
                if (!results.Contains(emoji) && emoji.Contains(query))
                    results.Add(emoji);
            }
        }

        return results.Distinct().Take(64).ToList();
    }

    private async Task SelectEmoji(string emoji)
    {
        await OnEmojiSelected.InvokeAsync(emoji);
    }
}
