@using Testify.Client.Features.Chat.Services
@using Testify.Shared.DTOs.Chat
@using Testify.Shared.Enums
@using Testify.Shared.Helpers
@inject IJSRuntime JSRuntime
@implements IAsyncDisposable

@if (IsVisible)
{
    <div class="fixed z-50 @(isMinimized ? "bottom-6 right-6" : "bottom-6 right-6")"
         style="@GetWindowStyle()">
        
        @* Main call window *@
        <div class="bg-slate-900 rounded-3xl shadow-2xl overflow-hidden flex flex-col @(isMinimized ? "w-72 h-20" : "w-80 h-[460px]")
                    border border-slate-700/50 transition-all duration-300">
            
            @if (!isMinimized)
            {
                @* Video area *@
                <div class="relative flex-1 bg-black">
                    @* Remote video (full area) *@
                    <video id="remoteVideo" autoplay playsinline
                           class="w-full h-full object-cover">
                    </video>

                    @* No remote video placeholder *@
                    @if (!isRemoteVideoEnabled)
                    {
                        <div class="absolute inset-0 flex flex-col items-center justify-center bg-slate-800">
                            <div class="w-20 h-20 rounded-full bg-slate-700 flex items-center justify-center text-white text-2xl font-bold mb-3">
                                @StringHelper.GetInitials(PeerName)
                            </div>
                            <span class="text-slate-400 text-sm font-medium">@PeerName</span>
                        </div>
                    }

                    @* Local video (small overlay) *@
                    <div class="absolute top-3 right-3 w-24 h-32 rounded-xl overflow-hidden bg-slate-700 shadow-lg border border-slate-600/50">
                        <video id="localVideo" autoplay playsinline muted
                               class="w-full h-full object-cover @(!isLocalVideoEnabled ? "hidden" : "")">
                        </video>
                        @if (!isLocalVideoEnabled)
                        {
                            <div class="w-full h-full flex items-center justify-center bg-slate-700">
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-slate-400">
                                    <path d="M17 11.28V7a1 1 0 0 0-1-1H4a1 1 0 0 0-1 1v10a1 1 0 0 0 1 1h6"/>
                                    <path d="m2 2 20 20"/><path d="m22 8-6 4 6 4V8Z"/>
                                </svg>
                            </div>
                        }
                    </div>

                    @* Call status overlay *@
                    @if (callState == CallState.Ringing || callState == CallState.Connecting)
                    {
                        <div class="absolute inset-0 flex flex-col items-center justify-center bg-slate-900/80 backdrop-blur-sm">
                            <div class="w-20 h-20 rounded-full bg-slate-700 flex items-center justify-center text-white text-2xl font-bold mb-4 animate-pulse">
                                @StringHelper.GetInitials(PeerName)
                            </div>
                            <span class="text-white font-bold text-lg mb-1">@PeerName</span>
                            <span class="text-slate-400 text-sm">
                                @(callState == CallState.Ringing ? "Calling..." : "Connecting...")
                            </span>
                        </div>
                    }

                    @* Call duration *@
                    @if (callState == CallState.Active)
                    {
                        <div class="absolute top-3 left-3 bg-black/50 backdrop-blur-sm rounded-full px-3 py-1 flex items-center gap-2">
                            <div class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></div>
                            <span class="text-white text-xs font-bold">@StringHelper.FormatDuration(callDuration)</span>
                        </div>
                    }
                </div>
            }

            @* Controls bar *@
            <div class="@(isMinimized ? "flex items-center justify-between px-4 h-full" : "flex items-center justify-center gap-3 p-4") bg-slate-900">
                @if (isMinimized)
                {
                    @* Minimized: show name + duration + expand *@
                    <div class="flex items-center gap-3">
                        <div class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></div>
                        <div>
                            <span class="text-white text-sm font-bold block">@PeerName</span>
                            <span class="text-slate-400 text-[10px]">@StringHelper.FormatDuration(callDuration)</span>
                        </div>
                    </div>
                    <div class="flex items-center gap-2">
                        <button @onclick="ToggleMinimize" class="p-2 rounded-xl bg-slate-700 hover:bg-slate-600 text-white transition-all" title="Expand">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="15 3 21 3 21 9"/><polyline points="9 21 3 21 3 15"/><line x1="21" y1="3" x2="14" y2="10"/><line x1="3" y1="21" x2="10" y2="14"/>
                            </svg>
                        </button>
                        <button @onclick="HangUp" class="p-2 rounded-xl bg-red-500 hover:bg-red-600 text-white transition-all" title="End call">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72"/>
                                <line x1="1" y1="1" x2="23" y2="23"/>
                            </svg>
                        </button>
                    </div>
                }
                else
                {
                    @* Full controls *@
                    <button @onclick="ToggleAudio"
                            class="@(isAudioEnabled ? "p-3 rounded-2xl bg-slate-700 hover:bg-slate-600 text-white" : "p-3 rounded-2xl bg-red-500/20 text-red-400 hover:bg-red-500/30") transition-all"
                            title="@(isAudioEnabled ? "Mute" : "Unmute")">
                        @if (isAudioEnabled)
                        {
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="22"/>
                            </svg>
                        }
                        else
                        {
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <line x1="2" y1="2" x2="22" y2="22"/><path d="M18.89 13.23A7.12 7.12 0 0 0 19 12v-2"/><path d="M5 10v2a7 7 0 0 0 12 5.17"/><path d="M15 9.34V5a3 3 0 0 0-5.68-1.33"/><path d="M9 9v3a3 3 0 0 0 5.12 2.12"/><line x1="12" y1="19" x2="12" y2="22"/>
                            </svg>
                        }
                    </button>

                    @if (CurrentCallType == CallType.Video)
                    {
                        <button @onclick="ToggleVideo"
                                class="@(isLocalVideoEnabled ? "p-3 rounded-2xl bg-slate-700 hover:bg-slate-600 text-white" : "p-3 rounded-2xl bg-red-500/20 text-red-400 hover:bg-red-500/30") transition-all"
                                title="@(isLocalVideoEnabled ? "Turn off camera" : "Turn on camera")">
                            @if (isLocalVideoEnabled)
                            {
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="m22 8-6 4 6 4V8Z"/><rect width="14" height="12" x="2" y="6" rx="2" ry="2"/>
                                </svg>
                            }
                            else
                            {
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M17 11.28V7a1 1 0 0 0-1-1H4a1 1 0 0 0-1 1v10a1 1 0 0 0 1 1h6"/>
                                    <path d="m2 2 20 20"/><path d="m22 8-6 4 6 4V8Z"/>
                                </svg>
                            }
                        </button>
                    }

                    <button @onclick="ToggleMinimize"
                            class="p-3 rounded-2xl bg-slate-700 hover:bg-slate-600 text-white transition-all"
                            title="Minimize">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="4 14 10 14 10 20"/><polyline points="20 10 14 10 14 4"/><line x1="14" y1="10" x2="21" y2="3"/><line x1="3" y1="21" x2="10" y2="14"/>
                        </svg>
                    </button>

                    <button @onclick="HangUp"
                            class="p-3 rounded-2xl bg-red-500 hover:bg-red-600 text-white transition-all shadow-lg shadow-red-500/30"
                            title="End call">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
                            <line x1="1" y1="1" x2="23" y2="23"/>
                        </svg>
                    </button>
                }
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public CallType CurrentCallType { get; set; }
    [Parameter] public string PeerName { get; set; } = string.Empty;
    [Parameter] public string? PeerAvatarUrl { get; set; }
    [Parameter] public int? CallSessionId { get; set; }
    [Parameter] public WebRtcService? WebRtcService { get; set; }
    [Parameter] public CallHubService? CallHubService { get; set; }
    [Parameter] public EventCallback OnCallEnded { get; set; }

    public enum CallState { Ringing, Connecting, Active, Ended }
    private CallState callState = CallState.Ringing;

    private bool isMinimized;
    private bool isAudioEnabled = true;
    private bool isLocalVideoEnabled = true;
    private bool isRemoteVideoEnabled = true;
    private int callDuration;
    private System.Threading.Timer? _durationTimer;

    protected override void OnParametersSet()
    {
        if (IsVisible && callState == CallState.Ended)
        {
            // Reset state for new call
            callState = CallState.Ringing;
            isMinimized = false;
            isAudioEnabled = true;
            isLocalVideoEnabled = true;
            isRemoteVideoEnabled = true;
            callDuration = 0;
        }
    }

    public void SetCallState(CallState state)
    {
        callState = state;
        if (state == CallState.Active)
            StartDurationTimer();
        else if (state == CallState.Ended)
            StopDurationTimer();
        InvokeAsync(StateHasChanged);
    }

    public void SetRemoteVideoEnabled(bool enabled)
    {
        isRemoteVideoEnabled = enabled;
        InvokeAsync(StateHasChanged);
    }

    private void StartDurationTimer()
    {
        callDuration = 0;
        _durationTimer?.Dispose();
        _durationTimer = new System.Threading.Timer(_ =>
        {
            callDuration++;
            InvokeAsync(StateHasChanged);
        }, null, 1000, 1000);
    }

    private void StopDurationTimer()
    {
        _durationTimer?.Dispose();
        _durationTimer = null;
    }

    private async Task ToggleAudio()
    {
        isAudioEnabled = !isAudioEnabled;
        if (WebRtcService != null)
            await WebRtcService.ToggleAudioAsync(isAudioEnabled);
        if (CallHubService != null && CallSessionId.HasValue)
            await CallHubService.ToggleMediaAsync(CallSessionId.Value, isAudioEnabled, isLocalVideoEnabled);
    }

    private async Task ToggleVideo()
    {
        isLocalVideoEnabled = !isLocalVideoEnabled;
        if (WebRtcService != null)
            await WebRtcService.ToggleVideoAsync(isLocalVideoEnabled);
        if (CallHubService != null && CallSessionId.HasValue)
            await CallHubService.ToggleMediaAsync(CallSessionId.Value, isAudioEnabled, isLocalVideoEnabled);
    }

    private void ToggleMinimize()
    {
        isMinimized = !isMinimized;
    }

    private async Task HangUp()
    {
        StopDurationTimer();
        callState = CallState.Ended;

        if (CallHubService != null && CallSessionId.HasValue)
            await CallHubService.EndCallAsync(CallSessionId.Value);

        if (WebRtcService != null)
            await WebRtcService.DisposeWebRtcAsync();

        await OnCallEnded.InvokeAsync();
    }

    private string GetWindowStyle()
    {
        return isMinimized
            ? "width: 288px;"
            : "width: 320px;";
    }

    // GetInitials and FormatDuration moved to Testify.Shared.Helpers.StringHelper

    public async ValueTask DisposeAsync()
    {
        StopDurationTimer();
        if (WebRtcService != null && callState != CallState.Ended)
            await WebRtcService.DisposeWebRtcAsync();
    }
}
