@using System.ComponentModel.DataAnnotations
@using Testify.Shared.DTOs.TestTemplates

<div class="fixed inset-0 z-[150] flex items-center justify-center p-6">
    <div class="animate-in fade-in absolute inset-0 bg-slate-900/40 backdrop-blur-sm duration-300"
         @onclick="Close"></div>

    <div class="animate-in zoom-in-95 relative flex w-full max-w-md flex-col overflow-hidden rounded-[48px] bg-white shadow-2xl duration-300">
        <div class="flex items-start justify-between border-b border-slate-50 bg-slate-50/50 p-10">
            <div class="flex items-center gap-4">
                <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-[#7E96E1] text-white shadow-lg shadow-blue-100">
                    <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 5v14m7-7H5" />
                    </svg>
                </div>
                <div>
                    <h2 class="text-2xl font-black text-slate-800">@HeaderTitle</h2>
                    <p class="mt-0.5 font-black tracking-widest text-[10px] text-slate-400 uppercase">@HeaderSubtitle</p>
                </div>
            </div>
            <button @onclick="Close"
                    class="rounded-2xl p-3 text-slate-400 shadow-sm transition-all hover:bg-white">
                <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                </svg>
            </button>
        </div>

        <EditForm Model="_formData" OnValidSubmit="HandleSubmit" class="space-y-6 p-10">
            <DataAnnotationsValidator />

            <div class="space-y-1.5">
                <label class="flex items-center gap-2 font-black tracking-widest text-[10px] text-slate-400 uppercase">
                    <svg class="h-3.5 w-3.5 text-[#7E96E1]" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 6.75h8.5M9.75 12h8.5m-8.5 5.25h8.5M5.25 6.75h.01M5.25 12h.01M5.25 17.25h.01" />
                    </svg>
                    Suite Name
                </label>
                <InputText @bind-Value="_formData.Name"
                           class="w-full rounded-2xl border-2 border-transparent bg-slate-50 px-6 py-4 font-bold text-slate-800 transition-all outline-none focus:border-[#7E96E1] focus:bg-white"
                           placeholder="e.g. Authentication & Security"
                           autofocus />
                <ValidationMessage For="@(() => _formData.Name)" class="text-xs text-red-500 mt-1" />
            </div>

            <div class="relative space-y-3">
                <label class="flex items-center gap-2 px-1 font-black tracking-widest text-[10px] text-slate-400 uppercase">
                    <svg class="h-3.5 w-3.5 text-[#7E96E1]" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 3h9l4.5 4.5v9L16.5 21h-9L3 16.5v-9L7.5 3z" />
                    </svg>
                    Folder / Category
                </label>

                <div class="group relative">
                    <svg class="absolute top-1/2 left-4 h-3.5 w-3.5 -translate-y-1/2 text-slate-300 transition-colors group-focus-within:text-[#7E96E1]" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35m1.85-5.65a7.5 7.5 0 11-15 0 7.5 7.5 0 0115 0z" />
                    </svg>
                    <input type="text"
                           value="@_folderSearch"
                           @oninput="HandleFolderSearch"
                           @onfocus="() => _isDropdownOpen = true"
                           placeholder="Search or create category..."
                           class="w-full pl-11 pr-10 py-4 bg-slate-50 border-2 border-transparent focus:border-[#7E96E1] focus:bg-white rounded-2xl outline-none transition-all font-bold text-slate-800 text-xs" />
                    <svg class="pointer-events-none absolute top-1/2 right-4 h-4 w-4 -translate-y-1/2 text-slate-300 transition-transform @(_isDropdownOpen ? "rotate-180" : "")" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                    </svg>
                </div>

                @if (_isDropdownOpen)
                {
                    <div class="animate-in fade-in slide-in-from-top-2 absolute top-full right-0 left-0 z-20 mt-2 overflow-hidden rounded-3xl border border-slate-100 bg-white shadow-2xl duration-200">
                        <div class="no-scrollbar max-h-60 space-y-1 overflow-y-auto p-2">
                            @if (FilteredFolders.Count > 0)
                            {
                                @foreach (var folder in FilteredFolders)
                                {
                                    <button type="button"
                                            @onclick="() => SelectFolder(folder.Key)"
                                            class="w-full flex items-center justify-between p-3 rounded-2xl hover:bg-slate-50 transition-all text-left group">
                                        <div class="flex items-center gap-3">
                                            <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-blue-50 text-[#7E96E1]">
                                                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 7.5h6l2 2H21v9a1.5 1.5 0 01-1.5 1.5h-15A1.5 1.5 0 013 18V7.5z" />
                                                </svg>
                                            </div>
                                            <span class="text-xs font-black text-slate-800">@folder.Value</span>
                                        </div>
                                        @if (_selectedFolderId == folder.Key)
                                        {
                                            <svg class="h-4 w-4 text-[#7E96E1]" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                                            </svg>
                                        }
                                    </button>
                                }
                            }
                            else
                            {
                                <div class="p-4 text-center">
                                    <p class="font-bold text-[10px] text-slate-300 uppercase">
                                        @(!string.IsNullOrWhiteSpace(_folderSearch) ? $"Create new: \"{_folderSearch}\"" : "Type to search or create")
                                    </p>
                                </div>
                            }

                            @if (!string.IsNullOrWhiteSpace(_folderSearch) && !AvailableFolders.Values.Any(folder => string.Equals(folder, _folderSearch, StringComparison.OrdinalIgnoreCase)))
                            {
                                <div class="mt-1 border-t border-slate-50 pt-1">
                                    <button type="button"
                                            @onclick="SelectNewFolder"
                                            class="flex w-full items-center gap-2 rounded-2xl p-3 text-left font-black text-[10px] text-[#7E96E1] uppercase transition-all hover:bg-slate-50">
                                        <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 5v14m7-7H5" />
                                        </svg>
                                        Create "@_folderSearch"
                                    </button>
                                </div>
                            }
                        </div>
                    </div>
                }

                @* Selected folder display *@
                @if (_selectedFolderId.HasValue || !string.IsNullOrWhiteSpace(_newFolderName))
                {
                    <div class="flex items-center gap-2 rounded-2xl bg-blue-50 px-4 py-2 text-xs">
                        <svg class="h-3.5 w-3.5 text-[#7E96E1]" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M3 7.5h6l2 2H21v9a1.5 1.5 0 01-1.5 1.5h-15A1.5 1.5 0 013 18V7.5z" />
                        </svg>
                        <span class="font-bold text-slate-700">
                            @if (_newFolderName != null)
                            {
                                <text>@_newFolderName <span class="text-[#7E96E1]">(New)</span></text>
                            }
                            else if (_selectedFolderId.HasValue && AvailableFolders.TryGetValue(_selectedFolderId.Value, out var folderName))
                            {
                                <text>@folderName</text>
                            }
                        </span>
                        <button type="button"
                                @onclick="ClearFolderSelection"
                                class="ml-auto rounded-lg p-1 transition-all hover:bg-white">
                            <svg class="h-3 w-3 text-slate-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                            </svg>
                        </button>
                    </div>
                }
            </div>

            <div class="space-y-1.5">
                <label class="flex items-center gap-2 font-black tracking-widest text-[10px] text-slate-400 uppercase">
                    <svg class="h-3.5 w-3.5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 6.75h8.5M9.75 12h8.5m-8.5 5.25h8.5M5.25 6.75h.01M5.25 12h.01M5.25 17.25h.01" />
                    </svg>
                    Description
                </label>
                <InputTextArea @bind-Value="_formData.Description"
                               rows="3"
                               class="w-full resize-none rounded-2xl border-2 border-transparent bg-slate-50 px-6 py-4 font-medium text-slate-600 transition-all outline-none focus:border-[#7E96E1] focus:bg-white"
                               placeholder="What logical group of features does this suite cover?" />
            </div>

            <div class="pt-6">
                <button type="submit"
                        class="flex w-full items-center justify-center gap-3 rounded-2xl bg-[#1C1D2A] py-5 text-lg font-black text-white shadow-lg transition-all hover:bg-slate-800 hover:shadow-xl active:scale-95">
                    <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7" />
                    </svg>
                    @SubmitLabel
                </button>
            </div>
        </EditForm>
    </div>
</div>

@code {
    [Parameter] public EventCallback<CreateTestSuiteTemplateRequest> OnSave { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public Dictionary<int, string> AvailableFolders { get; set; } = new(); 
    [Parameter] public int? InitialFolderId { get; set; }
    [Parameter] public string Type { get; set; } = "Library";

    private readonly FormModel _formData = new();
    private bool _isDropdownOpen;
    private string _folderSearch = string.Empty;
    private int? _selectedFolderId;
    private string? _newFolderName;

    private string HeaderTitle => Type == "Library" ? "Library Suite" : "New Suite";
    private string HeaderSubtitle => Type == "Library" ? "Reusable testing asset" : "Categorize your test repository";
    private string SubmitLabel => Type == "Library" ? "Add to Library" : "Initialize Suite";

    private IReadOnlyList<KeyValuePair<int, string>> FilteredFolders =>
        AvailableFolders
            .Where(folder => string.IsNullOrWhiteSpace(_folderSearch) || folder.Value.Contains(_folderSearch, StringComparison.OrdinalIgnoreCase))
            .OrderBy(folder => folder.Value)
            .ToList();

    protected override void OnParametersSet()
    {
        _selectedFolderId = InitialFolderId;
        if (_selectedFolderId.HasValue && AvailableFolders.TryGetValue(_selectedFolderId.Value, out var folderName))
        {
            _folderSearch = folderName;
        }
    }

    private void HandleFolderSearch(ChangeEventArgs args)
    {
        _folderSearch = args.Value?.ToString() ?? string.Empty;
        _isDropdownOpen = true;
        _selectedFolderId = null;
        _newFolderName = null;
    }

    private void SelectFolder(int folderId)
    {
        _selectedFolderId = folderId;
        _newFolderName = null;
        if (AvailableFolders.TryGetValue(folderId, out var name))
        {
            _folderSearch = name;
        }
        _isDropdownOpen = false;
    }

    private void SelectNewFolder()
    {
        _newFolderName = _folderSearch.Trim();
        _selectedFolderId = null;
        _isDropdownOpen = false;
    }

    private void ClearFolderSelection()
    {
        _selectedFolderId = null;
        _newFolderName = null;
        _folderSearch = string.Empty;
    }

    private async Task HandleSubmit()
    {
        var request = new CreateTestSuiteTemplateRequest
        {
            Name = _formData.Name.Trim(),
            Description = string.IsNullOrWhiteSpace(_formData.Description) ? null : _formData.Description.Trim(),
            FolderId = _selectedFolderId,
            NewFolderName = _newFolderName
        };

        await OnSave.InvokeAsync(request);
    }

    private async Task Close()
    {
        await OnClose.InvokeAsync();
    }

    private class FormModel
    {
        [Required(ErrorMessage = "Suite name is required")]
        [StringLength(200, ErrorMessage = "Suite name cannot exceed 200 characters")]
        public string Name { get; set; } = string.Empty;

        [StringLength(1000, ErrorMessage = "Description cannot exceed 1000 characters")]
        public string? Description { get; set; }
    }
}