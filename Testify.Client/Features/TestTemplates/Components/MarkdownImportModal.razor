@using Testify.Shared.DTOs
@using Testify.Shared.DTOs.TestCases
@using Testify.Shared.Enums
@using System.Text.RegularExpressions
@inject HttpClient HttpClient
@inject IJSRuntime JSRuntime

<div class="fixed inset-0 z-[200] flex items-center justify-center p-6">
    <div class="absolute inset-0 bg-slate-900/60 backdrop-blur-md animate-in fade-in duration-300" @onclick="OnClose"></div>
    
    <div class="relative bg-white w-full max-w-6xl rounded-[48px] shadow-2xl overflow-hidden flex flex-col animate-in zoom-in-95 duration-300 h-[85vh]">
        <!-- Header -->
        <div class="p-8 border-b border-slate-50 flex items-center justify-between bg-slate-50/50">
            <div class="flex items-center gap-4">
                <div class="w-12 h-12 bg-[#1C1D2A] rounded-2xl flex items-center justify-center text-white shadow-lg">
                    <svg class="w-6 h-6 text-[#E85D3F]" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 00-2.456 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z" />
                    </svg>
                </div>
                <div>
                    <h2 class="text-2xl font-black text-slate-800">Markdown Architect</h2>
                    <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mt-0.5">Automated Grid Decomposition</p>
                </div>
            </div>
            
            <!-- Tabs -->
            <div class="flex bg-slate-100 p-1 rounded-xl">
                <button @onclick="() => _activeTab = InputTab.Editor" 
                    class="px-4 py-2 rounded-lg text-[10px] font-black uppercase transition-all flex items-center gap-2 cursor-pointer @(_activeTab == InputTab.Editor ? "bg-white text-slate-800 shadow-sm" : "text-slate-400")">
                    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5" />
                    </svg>
                    Manual Editor
                </button>
                <button @onclick="() => _activeTab = InputTab.AI" 
                    class="px-4 py-2 rounded-lg text-[10px] font-black uppercase transition-all flex items-center gap-2 cursor-pointer @(_activeTab == InputTab.AI ? "bg-white text-[#E85D3F] shadow-sm" : "text-slate-400")">
                    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z" />
                    </svg>
                    Neural Prompt
                </button>
            </div>
            
            <button @onclick="OnClose" class="p-3 hover:bg-white rounded-2xl text-slate-400 transition-all shadow-sm cursor-pointer">
                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                </svg>
            </button>
        </div>

        <!-- Content -->
        <div class="flex-1 flex overflow-hidden">
            <!-- Left Panel - Editor/AI -->
            <div class="flex-1 border-r border-slate-100 flex flex-col bg-[#0F111A]">
                @if (_activeTab == InputTab.Editor)
                {
                    <div class="p-4 border-b border-white/5 flex items-center justify-between">
                        <div class="flex items-center gap-2">
                            <span class="text-[10px] font-black text-slate-500 uppercase tracking-widest ml-2">Source Blueprint</span>
                        </div>
                        
                        <!-- Editor Toolbar -->
                        <div class="flex items-center gap-1 bg-white/5 rounded-lg p-1">
                             <button @onclick='() => InsertTemplate("Header")' class="p-1.5 hover:bg-white/10 rounded-md text-slate-400 hover:text-white transition-all" title="Heading">
                                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25H12" /></svg>
                            </button>
                            <button @onclick='() => InsertTemplate("List")' class="p-1.5 hover:bg-white/10 rounded-md text-slate-400 hover:text-white transition-all" title="List">
                                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 6.75h12M8.25 12h12m-12 5.25h12M3.75 6.75h.007v.008H3.75V6.75zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zM3.75 12h.007v.008H3.75V12zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm-.375 5.25h.007v.008H3.75v-.008zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" /></svg>
                            </button>
                            <div class="w-px h-4 bg-white/10 mx-1"></div>
                            <button @onclick='() => InsertTemplate("Full")' class="p-1.5 hover:bg-white/10 rounded-md text-slate-400 hover:text-[#E85D3F] transition-all flex items-center gap-1.5" title="Insert Template">
                                <span class="text-[9px] font-black uppercase">Template</span>
                            </button>
                        </div>

                        <button @onclick="RefineViaAI" class="text-[9px] font-black text-slate-500 uppercase tracking-widest hover:text-[#E85D3F] transition-colors flex items-center gap-1.5 cursor-pointer">
                            <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M15.59 14.37a6 6 0 01-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 006.16-12.12A14.98 14.98 0 009.631 8.41m5.96 5.96a14.926 14.926 0 01-5.841 2.58m-.119-8.54a6 6 0 00-7.381 5.84h4.8m2.581-5.84a14.927 14.927 0 00-2.58 5.84m2.699 2.7c-.103.021-.207.041-.311.06a15.09 15.09 0 01-2.448-2.448 14.9 14.9 0 01.06-.312m-2.24 2.39a4.493 4.493 0 00-1.757 4.306 4.493 4.493 0 004.306-1.758M16.5 9a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0z" />
                            </svg>
                            Refine via AI
                        </button>
                    </div>
                    <div class="relative flex-1">
                        <textarea 
                            @ref="_editorRef"
                            id="markdown-editor"
                            value="@_rawText"
                            @oninput="OnMarkdownInput"
                            @onkeydown="HandleKeyDown"
                            @onkeyup="HandleKeyUp"
                            @onclick="UpdateCursor"
                            class="w-full h-full bg-transparent p-10 text-emerald-400 font-mono text-sm leading-relaxed outline-none resize-none selection:bg-emerald-500/30"
                            placeholder="# Title... &#10;Priority: High... &#10;## Steps..."></textarea>
                            
                        @if (_showSuggestions)
                        {
                            <div class="absolute z-50 bg-[#1C1D2A] border border-white/10 rounded-xl shadow-2xl p-1 w-64 animate-in fade-in zoom-in-95 duration-100" 
                                 style="top: @(_suggestionTop)px; left: @(_suggestionLeft)px;">
                                <div class="text-[9px] font-black text-slate-500 uppercase tracking-widest px-3 py-2 border-b border-white/5 bg-white/5 rounded-t-lg mb-1">
                                    Suggestions
                                </div>
                                <div class="max-h-48 overflow-y-auto custom-scrollbar">
                                    @foreach (var item in _suggestions)
                                    {
                                        <button @onclick="() => SelectSuggestion(item)" 
                                                class="w-full text-left px-3 py-2 rounded-lg hover:bg-white/10 text-xs font-medium text-slate-300 hover:text-white flex items-center gap-2 transition-all group">
                                            <span class="w-5 h-5 rounded-md bg-white/5 flex items-center justify-center text-[10px] group-hover:bg-[#E85D3F] transition-colors">@item.Icon</span>
                                            <div class="flex-1">
                                                <div class="text-white">@item.Label</div>
                                                <div class="text-[9px] text-slate-500">@item.Description</div>
                                            </div>
                                        </button>
                                    }
                                </div>
                            </div>
                        }
                    </div>

                }
                else
                {
                    <div class="flex-1 p-10 flex flex-col items-center justify-center space-y-8 animate-in fade-in duration-300">
                        <div class="w-20 h-20 bg-white/5 rounded-[32px] flex items-center justify-center border border-white/10">
                            @if (_isGenerating)
                            {
                                <svg class="w-10 h-10 text-[#E85D3F] animate-spin" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99" />
                                </svg>
                            }
                            else
                            {
                                <svg class="w-10 h-10 text-slate-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 01.865-.501 48.172 48.172 0 003.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z" />
                                </svg>
                            }
                        </div>
                        <div class="text-center max-w-sm space-y-2">
                            <h4 class="text-xl font-black text-white">Neural Architect</h4>
                            <p class="text-slate-500 text-xs font-medium">Describe requirements in plain English. Gemini will generate technical markdown for grid conversion.</p>
                        </div>
                        <div class="w-full space-y-4">
                            <textarea 
                                @bind="_aiPrompt"
                                placeholder="e.g. User should be able to reset password..."
                                class="w-full h-32 bg-white/5 border border-white/10 rounded-[32px] p-6 text-white text-sm outline-none focus:border-[#E85D3F]/50 transition-all resize-none"></textarea>
                            <button 
                                @onclick="GenerateScenario"
                                disabled="@(_isGenerating || string.IsNullOrWhiteSpace(_aiPrompt))"
                                class="w-full py-5 bg-[#E85D3F] text-white rounded-2xl font-black text-xs uppercase tracking-widest shadow-xl hover:bg-orange-600 transition-all flex items-center justify-center gap-3 disabled:opacity-50 cursor-pointer">
                                @(_isGenerating ? "Synthesizing..." : "Generate Blueprint")
                                <svg class="w-4 h-4 fill-white" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
                                </svg>
                            </button>
                        </div>
                    </div>
                }
            </div>

            <!-- Right Panel - Preview -->
            <div class="flex-1 flex flex-col bg-slate-50/30 overflow-y-auto">
                <div class="p-4 border-b border-slate-100 flex items-center justify-between bg-white/50 backdrop-blur-sm sticky top-0 z-10">
                    <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest flex items-center gap-2">
                        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                        </svg>
                        Blueprint Mapping
                    </span>
                </div>
                
                <div class="p-10 space-y-8">
                    <!-- Meta -->
                    <div class="space-y-2">
                        <div class="flex items-center gap-2 text-[9px] font-black text-slate-400 uppercase">
                            <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M5.25 8.25h15m-16.5 7.5h15m-1.8-13.5l-3.9 19.5m-2.1-19.5l-3.9 19.5" />
                            </svg>
                            Meta
                        </div>
                        <div class="bg-white p-6 rounded-3xl border border-slate-100 shadow-sm relative overflow-hidden">
                            <h3 class="text-xl font-black text-slate-800">@_parsedData.Title</h3>
                            <span class="text-[10px] font-black uppercase px-2 py-0.5 rounded-md mt-2 block w-fit @GetPriorityClasses(_parsedData.Priority)">
                                @_parsedData.Priority Priority
                            </span>
                        </div>
                    </div>

                    <!-- Steps -->
                    <div class="space-y-2">
                        <div class="flex items-center gap-2 text-[9px] font-black text-slate-400 uppercase">
                            <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 6.75h12M8.25 12h12m-12 5.25h12M3.75 6.75h.007v.008H3.75V6.75zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zM3.75 12h.007v.008H3.75V12zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm-.375 5.25h.007v.008H3.75v-.008zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" />
                            </svg>
                            Decomposed Steps
                        </div>
                        <div class="space-y-2">
                            @foreach (var step in _parsedData.Steps)
                            {
                                <div class="bg-white p-4 rounded-2xl border border-slate-100 shadow-sm flex items-center gap-4">
                                    <span class="w-6 h-6 rounded-lg bg-slate-50 flex items-center justify-center text-[10px] font-black text-slate-400">@step.StepNumber</span>
                                    <p class="text-xs font-bold text-slate-700">@step.Action</p>
                                </div>
                            }
                        </div>
                    </div>

                    <!-- Expected Result -->
                    <div class="space-y-2">
                        <div class="flex items-center gap-2 text-[9px] font-black text-slate-400 uppercase">
                            <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                            </svg>
                            Expected Result
                        </div>
                        <div class="bg-white p-6 rounded-[32px] border border-slate-100 shadow-sm min-h-[80px]">
                            <MarkdownRenderer Content="@(_parsedData.ExpectedResult ?? "*No expected result detected*")" />
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Footer -->
        <div class="p-8 border-t border-slate-50 bg-white flex items-center justify-between">
            <div class="flex items-center gap-3 text-slate-400">
                <svg class="w-4 h-4 text-amber-500" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
                </svg>
                <p class="text-[10px] font-bold uppercase">Grid mapping confirmed. AI has isolated @_parsedData.Steps.Count logical steps.</p>
            </div>
            <div class="flex gap-3">
                <button @onclick="OnClose" class="px-6 py-3 bg-white border border-slate-200 text-slate-400 font-black text-xs uppercase tracking-widest rounded-xl hover:text-slate-600 cursor-pointer">
                    Cancel
                </button>
                <button @onclick="HandleSave" class="px-10 py-3 bg-[#1C1D2A] text-white font-black text-xs uppercase tracking-widest rounded-xl hover:bg-slate-800 transition-all flex items-center gap-2 shadow-xl shadow-slate-200 cursor-pointer">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M17.593 3.322c1.1.128 1.907 1.077 1.907 2.185V21L12 17.25 4.5 21V5.507c0-1.108.806-2.057 1.907-2.185a48.507 48.507 0 0111.186 0z" />
                    </svg>
                    Commit to Suite
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public int SuiteTemplateId { get; set; }

    [Parameter]
    public EventCallback OnClose { get; set; }

    [Parameter]
    public EventCallback<TestCaseFormResult> OnImport { get; set; }

    private enum InputTab { Editor, AI }
    private InputTab _activeTab = InputTab.Editor;
    private bool _isGenerating;
    private string _aiPrompt = string.Empty;
    private string _rawText = @"# Verify User Login
Priority: High

## Steps
1. Navigate to /login
2. Enter valid credentials
3. Click 'Submit'

## Expected Result
User is redirected to the dashboard and sees a welcome message.";

    private ParsedTestCase _parsedData = new();

    protected override void OnInitialized()
    {
        ParseMarkdown();
    }

    private void OnMarkdownInput(ChangeEventArgs e)
    {
        _rawText = e.Value?.ToString() ?? string.Empty;
        ParseMarkdown();
    }

    private void HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Tab")
        {
            // TODO: Ideally insert at cursor, but for now append or simple logic
            // Without JS cursor tracking, complex tab handling is limited
        }
    }

    private void InsertTemplate(string type)
    {
        var template = type switch
        {
            "Header" => "\n## New Section\n",
            "List" => "\n1. Step One\n2. Step Two\n",
            "Full" => "\n# New Benefit Scenario\nPriority: High\n\n## Steps\n1. Action 1\n2. Action 2\n\n## Expected Result\nSuccess message appears.",
            _ => ""
        };

        if (!string.IsNullOrEmpty(template))
        {
            _rawText += template;
            ParseMarkdown();
        }
    }

    private void ParseMarkdown()
    {
        var lines = _rawText.Split('\n');
        var title = "Untitled Scenario";
        var priority = TestCasePriority.Medium;
        var rawStepsStr = "";
        var expectedResult = "";
        var currentSection = "none";

        foreach (var line in lines)
        {
            var trimmed = line.Trim();
            
            if (trimmed.StartsWith("# ") && currentSection == "none")
            {
                title = trimmed.Replace("# ", "").Trim();
            }
            else if (trimmed.ToLower().StartsWith("priority:"))
            {
                var p = trimmed.Split(':').ElementAtOrDefault(1)?.Trim().ToLower() ?? "";
                if (p.Contains("high")) priority = TestCasePriority.High;
                else if (p.Contains("low")) priority = TestCasePriority.Low;
                else priority = TestCasePriority.Medium;
            }
            else if (trimmed.ToLower().Contains("## steps"))
            {
                currentSection = "steps";
            }
            else if (trimmed.ToLower().Contains("## expected"))
            {
                currentSection = "expected";
            }
            else
            {
                if (currentSection == "steps") rawStepsStr += line + "\n";
                else if (currentSection == "expected") expectedResult += line + "\n";
            }
        }

        // Parse steps
        var stepList = new List<ParsedStep>();
        var stepLines = rawStepsStr.Split('\n')
            .Where(l => !string.IsNullOrWhiteSpace(l) && (Regex.IsMatch(l, @"^\d+\.") || l.Trim().StartsWith("-")))
            .ToList();

        for (int i = 0; i < stepLines.Count; i++)
        {
            var action = Regex.Replace(stepLines[i], @"^\d+\.|^\*|-", "").Trim();
            stepList.Add(new ParsedStep { StepNumber = i + 1, Action = action });
        }

        if (stepList.Count == 0 && !string.IsNullOrWhiteSpace(rawStepsStr.Trim()))
        {
            stepList.Add(new ParsedStep { StepNumber = 1, Action = rawStepsStr.Trim() });
        }

        _parsedData = new ParsedTestCase
        {
            Title = title,
            Priority = priority,
            Steps = stepList,
            ExpectedResult = expectedResult.Trim()
        };
    }

    private async Task GenerateScenario()
    {
        if (string.IsNullOrWhiteSpace(_aiPrompt)) return;
        
        _isGenerating = true;
        StateHasChanged();

        try
        {
            // TODO: Integrate with Gemini API
            // For now, generate a template based on the prompt
            var generatedMarkdown = $@"# {_aiPrompt}
Priority: Medium

## Steps
1. Navigate to the relevant page
2. Perform the required action
3. Verify the expected behavior
4. Check for edge cases

## Expected Result
The system should successfully handle the scenario: {_aiPrompt}";

            _rawText = generatedMarkdown;
            ParseMarkdown();
            _activeTab = InputTab.Editor;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"AI Generation failed: {ex.Message}");
        }
        finally
        {
            _isGenerating = false;
            StateHasChanged();
        }
    }

    private void RefineViaAI()
    {
        _aiPrompt = _rawText;
        _activeTab = InputTab.AI;
    }

    private async Task HandleSave()
    {
        var result = new TestCaseFormResult
        {
            Title = _parsedData.Title,
            Priority = _parsedData.Priority,
            Steps = _parsedData.Steps.Select(s => new TestStepFormResult
            {
                StepNumber = s.StepNumber,
                Action = s.Action,
                TestData = string.Empty,
                ExpectedResult = _parsedData.ExpectedResult ?? string.Empty
            }).ToList()
        };

        await OnImport.InvokeAsync(result);
    }

    private string GetPriorityClasses(TestCasePriority priority) => priority switch
    {
        TestCasePriority.High => "bg-red-50 text-red-500",
        TestCasePriority.Low => "bg-green-50 text-green-500",
        _ => "bg-blue-50 text-blue-500"
    };

    private class ParsedTestCase
    {
        public string Title { get; set; } = "Untitled Scenario";
        public TestCasePriority Priority { get; set; } = TestCasePriority.Medium;
        public List<ParsedStep> Steps { get; set; } = new();
        public string? ExpectedResult { get; set; }
    }

    private class ParsedStep
    {
        public int StepNumber { get; set; }
        public string Action { get; set; } = string.Empty;
    }

    // Autocomplete State
    private ElementReference _editorRef;
    private bool _showSuggestions;
    private double _suggestionTop;
    private double _suggestionLeft;
    private List<SuggestionItem> _suggestions = new();
    
    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        await UpdateCursor();
        
        if (e.Key == " " || e.Key == "Enter" || e.Key == "Escape") 
        {
            _showSuggestions = false;
            return;
        }

        await CheckSuggestions();
    }
    
    private async Task UpdateCursor()
    {
        // Placeholder for future logic
    }

    private async Task CheckSuggestions()
    {
        try 
        {
            var cursorIndex = await JSRuntime.InvokeAsync<int>("editorExtensions.getCursorIndex", _editorRef);
            var text = _rawText;
            
            // Safety check
            if (cursorIndex < 0 || cursorIndex > text.Length) return;

            var leftPart = text.Substring(0, cursorIndex);
            
            _suggestions.Clear();

            // 1. Title Trigger (#)
            if (leftPart.EndsWith("#") || leftPart.EndsWith("\n#"))
            {
                _suggestions.Add(new SuggestionItem(" ", "Scenario Title", "Add scenario title", "T"));
            }
            // 2. Section Trigger (##)
            else if (leftPart.EndsWith("##"))
            {
                 _suggestions.Add(new SuggestionItem(" Steps", "Steps Section", "Define steps", "S"));
                 _suggestions.Add(new SuggestionItem(" Expected Result", "Expected Result", "Success Criteria", "E"));
            }
            // 3. Priority Trigger
            else if (leftPart.ToLower().EndsWith("priority: "))
            {
                _suggestions.Add(new SuggestionItem("High", "High", "Critical path", "!"));
                _suggestions.Add(new SuggestionItem("Medium", "Medium", "Normal flow", "-"));
                _suggestions.Add(new SuggestionItem("Low", "Low", "Minor edge case", "."));
            }
            
            if (_suggestions.Any())
            {
                var coords = await JSRuntime.InvokeAsync<CaretCoordinates>("editorExtensions.getCaretCoordinates", _editorRef, cursorIndex);
                // Adjust for padding (40px = p-10)
                _suggestionTop = coords.Top + coords.LineHeight + 40; 
                _suggestionLeft = coords.Left + 40;
                
                _showSuggestions = true;
                StateHasChanged();
            }
            else
            {
                if (_showSuggestions) 
                {
                    _showSuggestions = false;
                    StateHasChanged();
                }
            }
        }
        catch (Exception ex) 
        { 
            Console.WriteLine($"Autocomplete Error: {ex.Message}");
        }
    }

    private async Task SelectSuggestion(SuggestionItem item)
    {
        await JSRuntime.InvokeVoidAsync("editorExtensions.insertText", _editorRef, item.Value);
        _showSuggestions = false;
    }

    private class SuggestionItem
    {
        public string Value { get; set; }
        public string Label { get; set; }
        public string Description { get; set; }
        public string Icon { get; set; }
        
        public SuggestionItem(string v, string l, string d, string i) { Value = v; Label = l; Description = d; Icon = i; }
    }
    
    private class CaretCoordinates
    {
        public double Top { get; set; }
        public double Left { get; set; }
        public double LineHeight { get; set; }
    }
}
