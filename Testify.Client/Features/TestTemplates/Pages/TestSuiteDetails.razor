@page "/testsuites/{TestSuiteId:int}"
@using Microsoft.AspNetCore.Authorization
@using Testify.Client.Features.TestTemplates.Components
@using Testify.Client.Interfaces
@using Testify.Shared.DTOs
@using Testify.Shared.DTOs.TestCases
@using Testify.Shared.DTOs.TestTemplates
@inject ITestSuiteTemplateService TestSuiteTemplateService
@inject ITestCaseTemplateService TestCaseTemplateService
@inject NavigationManager Navigation
@rendermode InteractiveWebAssembly
@attribute [Authorize]
@implements IDisposable

<PageTitle>Suite Details</PageTitle>

@if (_isLoading)
{
    <div class="flex items-center gap-3 text-sm font-medium text-slate-400 p-8">
        <div class="h-4 w-4 animate-spin rounded-full border-2 border-slate-300 border-t-transparent"></div>
        Loading suite details...
    </div>
}
else if (!string.IsNullOrWhiteSpace(_errorMessage))
{
    <div class="rounded-[24px] border border-red-100 bg-red-50 px-6 py-4 text-sm font-medium text-red-600 m-4">
        @_errorMessage
    </div>
}
else if (_suite is not null)
{
    <div class="animate-in fade-in slide-in-from-right-4 duration-500 space-y-6 pb-12 p-4">
        @if (!string.IsNullOrEmpty(_operationError))
        {
            <div class="bg-red-50 border border-red-200 text-red-700 px-5 py-3 rounded-2xl flex items-center justify-between animate-in fade-in slide-in-from-top-2 duration-300">
                <div class="flex items-center gap-3">
                    <svg class="w-5 h-5 text-red-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
                    </svg>
                    <span class="text-sm font-semibold">@_operationError</span>
                </div>
                <button @onclick="() => _operationError = null" class="text-red-400 hover:text-red-600 cursor-pointer">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>
        }

        <div class="flex flex-col md:flex-row md:items-end justify-between gap-4">
            <div class="flex items-center gap-4">
                <button 
                    @onclick="OnBack"
                    class="p-3 bg-white hover:bg-slate-50 rounded-2xl border border-slate-100 shadow-sm transition-all text-slate-400 hover:text-slate-800 active:scale-95 cursor-pointer">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19 12H5m7-7l-7 7 7 7" />
                    </svg>
                </button>
                <div>
                    <div class="flex items-center gap-2 mb-2">
                        <span class="bg-indigo-600 text-white px-3 py-0.5 rounded-lg text-[10px] font-black uppercase tracking-widest">
                            Global Template
                        </span>
                        <span class="text-[10px] font-black text-slate-300 uppercase tracking-widest">ID @_suite.Id</span>
                        @if (_suite.FolderId.HasValue)
                        {
                            <div class="w-1 h-1 bg-slate-200 rounded-full mx-1"></div>
                            <span class="text-[10px] font-black text-[#7E96E1] uppercase tracking-widest">Folder @_suite.FolderId</span>
                        }
                    </div>
                    <h2 class="text-2xl font-black text-slate-800 tracking-tight">@_suite.Name</h2>
                </div>
            </div>

            <div class="flex items-center gap-3">
                <button 
                    @onclick="OnEditSuite"
                    class="p-3 bg-white border border-slate-100 rounded-xl text-slate-400 hover:text-slate-600 hover:shadow-md transition-all cursor-pointer">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                    </svg>
                </button>
                <button 
                    @onclick="OnCloneToRun"
                    class="px-5 py-3 rounded-xl font-black text-[10px] uppercase tracking-widest transition-all flex items-center gap-2 bg-[#7E96E1] text-white hover:bg-[#6b84d4] hover:shadow-md cursor-pointer border border-[#7E96E1]">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M5 3l14 9-14 9V3z" />
                    </svg>
                    Clone to Run
                </button>
            </div>
        </div>

        <!-- Metrics Dashboard -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
            <!-- Global Health Card -->
            <div class="bg-[#1C1D2A] rounded-[32px] p-6 text-white relative overflow-hidden flex items-center justify-between">
                <div class="relative z-10">
                    <p class="text-[10px] font-black text-slate-500 uppercase tracking-widest">Global Health</p>
                    <h4 class="text-2xl font-black mt-1">@_stats.PassRate%</h4>
                    <p class="text-[10px] font-bold text-emerald-400 mt-1 uppercase">Passed Scenarios</p>
                </div>
                <div class="relative w-16 h-16 flex items-center justify-center">
                    <svg class="w-full h-full transform -rotate-90">
                        <circle cx="32" cy="32" r="28" stroke="#2D2F3E" stroke-width="4" fill="transparent" />
                        <circle cx="32" cy="32" r="28" stroke="#7E96E1" stroke-width="4" fill="transparent" 
                            stroke-dasharray="176" stroke-dashoffset="@(176 * (1 - _stats.PassRate/100.0))" 
                            stroke-linecap="round" />
                    </svg>
                    <svg class="w-5 h-5 text-[#7E96E1] absolute" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
                    </svg>
                </div>
                <div class="absolute -bottom-10 -right-10 w-24 h-24 bg-[#7E96E1]/10 rounded-full blur-2xl"></div>
            </div>

            <!-- Total Cases Card -->
            <div class="bg-white p-5 rounded-[28px] border border-slate-100 shadow-sm flex items-center gap-4">
                <div class="w-11 h-11 bg-blue-50 rounded-xl flex items-center justify-center">
                    <svg class="w-5 h-5 text-blue-500" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
                    </svg>
                </div>
                <div>
                    <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Total Cases</p>
                    <h4 class="text-xl font-black text-slate-800 mt-0.5">@_stats.Total</h4>
                </div>
            </div>

            <!-- Critical Failures Card -->
            <div class="bg-white p-5 rounded-[28px] border border-slate-100 shadow-sm flex items-center gap-4">
                <div class="w-11 h-11 bg-red-50 rounded-xl flex items-center justify-center">
                    <svg class="w-5 h-5 text-red-500" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
                    </svg>
                </div>
                <div>
                    <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Critical Failures</p>
                    <h4 class="text-xl font-black text-slate-800 mt-0.5">@_stats.Failed</h4>
                </div>
            </div>

            <!-- Pending Validation Card -->
            <div class="bg-white p-5 rounded-[28px] border border-slate-100 shadow-sm flex items-center gap-4">
                <div class="w-11 h-11 bg-amber-50 rounded-xl flex items-center justify-center">
                    <svg class="w-5 h-5 text-amber-500" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                </div>
                <div>
                    <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Pending Validation</p>
                    <h4 class="text-xl font-black text-slate-800 mt-0.5">@_stats.Pending</h4>
                </div>
            </div>
        </div>

        <!-- Main Content Grid -->
        <div class="grid grid-cols-1 xl:grid-cols-12 gap-6">
            <!-- Left: Test Scenario Repository -->
            <div class="xl:col-span-8 space-y-6">
                <div class="flex items-center justify-between px-4">
                    <h4 class="text-xs font-black text-slate-400 uppercase tracking-widest flex items-center gap-2">
                        <svg class="w-4 h-4 text-[#7E96E1]" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        Scenario Repository
                    </h4>
                    <div class="flex items-center gap-3">
                        <button 
                            @onclick="OnAddMarkdownCase"
                            class="bg-slate-50 text-slate-600 px-4 py-2 rounded-xl text-[10px] font-black uppercase tracking-widest flex items-center gap-2 hover:bg-slate-100 transition-all border border-slate-100 cursor-pointer">
                            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5" />
                            </svg>
                            New via Markdown
                        </button>
                        <button 
                            @onclick="OnAddTestCase"
                            class="bg-blue-50 text-blue-600 px-4 py-2 rounded-xl text-[10px] font-black uppercase tracking-widest flex items-center gap-2 hover:bg-blue-100 transition-all border border-blue-100 cursor-pointer">
                            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                            </svg>
                            Add Scenario
                        </button>
                    </div>
                </div>

                <div class="space-y-3">
                    @foreach (var tc in _suite.TestCaseTemplates)
                    {
                        var status = GetTestCaseStatus(tc);
                        var caseId = tc.Id;
                        <div 
                            @onclick="() => OnViewTestCase(tc.Id)"
                            class="bg-white p-6 rounded-[32px] border border-slate-50 shadow-sm hover:shadow-xl hover:scale-[1.01] transition-all group cursor-pointer flex items-center justify-between">
                            <div class="flex items-center gap-5">
                                <div class="@GetStatusIconClass(status)">
                                    @if (status == "Passed")
                                    {
                                        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                                        </svg>
                                    }
                                    else if (status == "Failed")
                                    {
                                        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 9.75l4.5 4.5m0-4.5l-4.5 4.5M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                                        </svg>
                                    }
                                    else
                                    {
                                        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23-.693L5 14.5m14.8.8l1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0112 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5" />
                                        </svg>
                                    }
                                </div>
                                <div>
                                    <h5 class="text-[15px] font-black text-slate-800 group-hover:text-[#7E96E1] transition-colors">@tc.Title</h5>
                                    <div class="flex items-center gap-3 mt-1.5">
                                        <span class="text-[10px] font-black text-slate-300 uppercase tracking-widest">TC-@tc.Id</span>
                                        <div class="w-1 h-1 bg-slate-200 rounded-full"></div>
                                        <span class="@GetPriorityClass(tc.Priority)">@tc.Priority Priority</span>
                                    </div>
                                </div>
                            </div>
                            <div class="flex items-center gap-2 opacity-0 group-hover:opacity-100 transition-all">
                                <button
                                    @onclick="() => OnEditTestCase(caseId)"
                                    @onclick:stopPropagation="true"
                                    class="p-2.5 bg-blue-50 hover:bg-blue-100 rounded-xl text-blue-500 hover:text-blue-700 transition-all cursor-pointer"
                                    title="Edit Scenario">
                                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />
                                    </svg>
                                </button>
                                <button
                                    @onclick="() => OnConfirmDeleteTestCase(caseId, tc.Title)"
                                    @onclick:stopPropagation="true"
                                    class="p-2.5 bg-red-50 hover:bg-red-100 rounded-xl text-red-400 hover:text-red-600 transition-all cursor-pointer"
                                    title="Delete Scenario">
                                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />
                                    </svg>
                                </button>
                                <div class="px-4 py-2 bg-slate-50 rounded-xl text-[10px] font-black text-slate-400 uppercase tracking-widest flex items-center gap-2">
                                    View Details 
                                    <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
                                    </svg>
                                </div>
                            </div>
                        </div>
                    }

                    @if (_suite.TestCaseTemplates.Count == 0)
                    {
                        <div class="py-24 flex flex-col items-center justify-center text-center bg-white/40 rounded-[48px] border-2 border-dashed border-slate-100">
                            <svg class="w-12 h-12 text-slate-200 mb-6" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23-.693L5 14.5m14.8.8l1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0112 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5" />
                            </svg>
                            <h5 class="text-xl font-black text-slate-400">No Scenarios Defined</h5>
                            <p class="text-slate-300 text-sm font-medium mt-1 max-w-xs px-6">This test suite is currently empty. Start by adding new test scenarios or importing from library.</p>
                            <div class="flex gap-4 mt-8">
                                <button 
                                    @onclick="OnAddMarkdownCase"
                                    class="px-8 py-3 bg-white border border-slate-200 text-slate-600 rounded-2xl font-black text-xs uppercase tracking-widest hover:scale-105 active:scale-95 transition-all shadow-sm cursor-pointer">
                                    Quick Markdown
                                </button>
                                <button 
                                    @onclick="OnAddTestCase"
                                    class="px-8 py-3 bg-[#1C1D2A] text-white rounded-2xl font-black text-xs uppercase tracking-widest hover:scale-105 active:scale-95 transition-all shadow-lg cursor-pointer">
                                    Add First Case
                                </button>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- Right: Suite Intelligence -->
            <div class="xl:col-span-4 space-y-5">
                <div class="bg-white rounded-[28px] p-6 border border-slate-100 shadow-sm space-y-5">
                    <div class="flex items-center gap-3">
                        <div class="w-10 h-10 bg-slate-50 rounded-xl flex items-center justify-center">
                            <svg class="w-5 h-5 text-[#7E96E1]" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z" />
                            </svg>
                        </div>
                        <h4 class="text-[11px] font-black text-slate-800 uppercase tracking-widest">Suite Intelligence</h4>
                    </div>

                    <div class="space-y-4">
                        <div>
                            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-3">Mission Statement</p>
                            <p class="text-sm font-medium text-slate-500 leading-relaxed italic">
                                "@(!string.IsNullOrWhiteSpace(_suite.Description) ? _suite.Description : "Validating the core logic and integration stability of this feature set.")"
                            </p>
                        </div>

                        <div class="pt-4 border-t border-slate-50">
                            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-3">Coverage Heatmap</p>
                            <div class="flex h-2 w-full bg-slate-100 rounded-full overflow-hidden">
                                <div class="bg-emerald-500 h-full" style="width: @(_stats.PassRate)%"></div>
                                <div class="bg-red-500 h-full" style="width: @(_stats.FailedRate)%"></div>
                                <div class="bg-amber-400 h-full" style="width: @(_stats.PendingRate)%"></div>
                            </div>
                            <div class="flex justify-between mt-3">
                                <span class="text-[9px] font-bold text-emerald-500 uppercase tracking-tighter">@_stats.Passed Passed</span>
                                <span class="text-[9px] font-bold text-red-500 uppercase tracking-tighter">@_stats.Failed Failed</span>
                                <span class="text-[9px] font-bold text-slate-400 uppercase tracking-tighter">@_stats.Pending Pending</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Template Master Card -->
                <div class="bg-gradient-to-br from-indigo-600 to-indigo-800 rounded-[28px] p-6 text-white shadow-xl">
                    <div class="flex items-center gap-3 mb-4">
                        <div class="w-10 h-10 bg-white/20 rounded-2xl flex items-center justify-center backdrop-blur-md">
                            <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
                            </svg>
                        </div>
                        <h4 class="text-xs font-black uppercase tracking-widest">Template Master</h4>
                    </div>
                    <p class="text-white/80 text-xs font-medium leading-relaxed">
                        This is a master template. Changes here affect the blueprint used for all future project imports.
                    </p>
                </div>
            </div>
        </div>
    </div>

    @if (_isTestCaseFormOpen)
    {
        <TestCaseForm 
            ParentSuiteId="TestSuiteId"
            OnClose="CloseTestCaseForm"
            OnSave="HandleSaveTestCase"
            InitialData="_editInitialData" />
    }

    @if (_isDeleteConfirmOpen)
    {
        <div class="fixed inset-0 z-[250] flex items-center justify-center p-6">
            <div class="absolute inset-0 bg-slate-900/60 backdrop-blur-md animate-in fade-in duration-300" @onclick="CloseDeleteConfirm"></div>
            <div class="relative bg-white w-full max-w-md rounded-[32px] shadow-2xl overflow-hidden animate-in zoom-in-95 duration-300">
                <div class="p-8 text-center space-y-5">
                    <div class="w-16 h-16 bg-red-50 rounded-2xl flex items-center justify-center mx-auto">
                        <svg class="w-8 h-8 text-red-500" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
                        </svg>
                    </div>
                    <div>
                        <h3 class="text-lg font-black text-slate-800">Delete Scenario</h3>
                        <p class="text-sm text-slate-500 mt-2 leading-relaxed">
                            Are you sure you want to delete <span class="font-bold text-slate-700">"@_deleteTargetTitle"</span>? This action cannot be undone.
                        </p>
                    </div>
                    <div class="flex gap-3 justify-center pt-2">
                        <button
                            @onclick="CloseDeleteConfirm"
                            class="px-6 py-3 bg-white border border-slate-200 text-slate-500 font-black text-[10px] uppercase tracking-widest rounded-xl hover:text-slate-800 transition-all cursor-pointer">
                            Cancel
                        </button>
                        <button
                            @onclick="HandleDeleteTestCase"
                            disabled="@_isDeleting"
                            class="px-6 py-3 bg-red-600 text-white font-black text-[10px] uppercase tracking-widest rounded-xl hover:bg-red-700 shadow-lg transition-all active:scale-95 flex items-center gap-2 cursor-pointer disabled:opacity-50">
                            @if (_isDeleting)
                            {
                                <div class="w-4 h-4 border-2 border-white/30 border-t-white rounded-full animate-spin"></div>
                            }
                            else
                            {
                                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />
                                </svg>
                            }
                            Delete Permanently
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }

    @if (_isMarkdownImportOpen)
    {
        <MarkdownImportModal 
            SuiteTemplateId="TestSuiteId"
            OnClose="CloseMarkdownImport"
            OnImport="HandleImportTestCase" />
    }
}

@code {
    [Parameter]
    public int TestSuiteId { get; set; }

    private TestSuiteTemplateResponse? _suite;
    private bool _isLoading = true;
    private string? _errorMessage;
    private string? _operationError;
    private System.Timers.Timer? _errorTimer;
    private SuiteStats _stats = new();
    private bool _isTestCaseFormOpen;
    private bool _isMarkdownImportOpen;
    private int? _editingTestCaseId;
    private TestCaseFormResult? _editInitialData;
    private bool _isDeleteConfirmOpen;
    private int? _deleteTargetId;
    private string? _deleteTargetTitle;
    private bool _isDeleting;

    private void ShowTimedError(string message, int milliseconds = 5000)
    {
        _errorTimer?.Stop();
        _errorTimer?.Dispose();
        _operationError = message;
        _errorTimer = new System.Timers.Timer(milliseconds);
        _errorTimer.Elapsed += (_, _) =>
        {
            InvokeAsync(() =>
            {
                _operationError = null;
                _errorTimer?.Dispose();
                _errorTimer = null;
                StateHasChanged();
            });
        };
        _errorTimer.AutoReset = false;
        _errorTimer.Start();
    }

    public void Dispose()
    {
        _errorTimer?.Stop();
        _errorTimer?.Dispose();
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadSuiteAsync();
    }

    private async Task LoadSuiteAsync()
    {
        _isLoading = true;
        _errorMessage = null;

        try
        {
            _suite = await TestSuiteTemplateService.GetTestSuiteTemplateByIdAsync(TestSuiteId);
            CalculateStats();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Unable to load suite details. {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void CalculateStats()
    {
        if (_suite is null) return;

        var total = _suite.TestCaseTemplates.Count;
        
        // Since templates don't have actual run status, we simulate based on priority
        // In real scenario, this would come from actual test runs
        var passed = _suite.TestCaseTemplates.Count(tc => tc.Priority == Testify.Shared.Enums.TestCasePriority.Low);
        var failed = _suite.TestCaseTemplates.Count(tc => tc.Priority == Testify.Shared.Enums.TestCasePriority.High);
        var pending = total - passed - failed;

        _stats = new SuiteStats
        {
            Total = total,
            Passed = passed,
            Failed = failed,
            Pending = pending,
            Blocked = 0,
            PassRate = total > 0 ? (int)Math.Round((double)passed / total * 100) : 0,
            FailedRate = total > 0 ? (int)Math.Round((double)failed / total * 100) : 0,
            PendingRate = total > 0 ? (int)Math.Round((double)pending / total * 100) : 0
        };
    }

    private string GetTestCaseStatus(TestCaseTemplateResponse tc)
    {
        // Simulate status based on priority for demo purposes
        return tc.Priority switch
        {
            Testify.Shared.Enums.TestCasePriority.Low => "Passed",
            Testify.Shared.Enums.TestCasePriority.High => "Failed",
            _ => "Pending"
        };
    }

    private string GetStatusIconClass(string status) => status switch
    {
        "Passed" => "w-12 h-12 rounded-2xl flex items-center justify-center transition-all bg-emerald-50 text-emerald-500",
        "Failed" => "w-12 h-12 rounded-2xl flex items-center justify-center transition-all bg-red-50 text-red-500",
        _ => "w-12 h-12 rounded-2xl flex items-center justify-center transition-all bg-slate-50 text-slate-400"
    };

    private string GetPriorityClass(Testify.Shared.Enums.TestCasePriority priority) => priority switch
    {
        Testify.Shared.Enums.TestCasePriority.High => "text-[10px] font-black uppercase tracking-widest text-red-400",
        _ => "text-[10px] font-black uppercase tracking-widest text-slate-400"
    };

    private void OnBack()
    {
        Navigation.NavigateTo("/test-templates/suite-library");
    }

    private void OnEditSuite()
    {
        Navigation.NavigateTo($"/test-templates/suite-library?editId={TestSuiteId}");
    }

    private void OnCloneToRun()
    {
        Navigation.NavigateTo($"/test-templates/suite-library?cloneId={TestSuiteId}");
    }

    private void OnAddTestCase()
    {
        _editingTestCaseId = null;
        _editInitialData = null;
        _isTestCaseFormOpen = true;
    }

    private void CloseTestCaseForm()
    {
        _isTestCaseFormOpen = false;
        _editingTestCaseId = null;
        _editInitialData = null;
    }

    private async Task HandleSaveTestCase(TestCaseFormResult formResult)
    {
        if (_suite is null) return;

        try
        {
            if (_editingTestCaseId.HasValue)
            {
                // Update existing test case template
                var updateRequest = new UpdateTestCaseTemplateRequest
                {
                    Title = formResult.Title,
                    Preconditions = formResult.Preconditions,
                    Postconditions = formResult.Postconditions,
                    Priority = formResult.Priority,
                    TestStepTemplates = formResult.Steps.Select(s => new UpdateTestStepTemplateRequest
                    {
                        StepNumber = s.StepNumber,
                        Action = s.Action,
                        TestData = s.TestData,
                        ExpectedResult = s.ExpectedResult
                    }).ToList()
                };

                await TestCaseTemplateService.UpdateTestCaseTemplateAsync(_editingTestCaseId.Value, updateRequest);
            }
            else
            {
                // Create new test case template
                var request = new CreateTestCaseTemplateRequest
                {
                    Title = formResult.Title,
                    Preconditions = formResult.Preconditions,
                    Postconditions = formResult.Postconditions,
                    Priority = formResult.Priority,
                    TestStepTemplates = formResult.Steps.Select(s => new CreateTestStepTemplateRequest
                    {
                        StepNumber = s.StepNumber,
                        Action = s.Action,
                        TestData = s.TestData,
                        ExpectedResult = s.ExpectedResult
                    }).ToList()
                };

                await TestCaseTemplateService.CreateTestCaseTemplateAsync(TestSuiteId, request);
            }
            
            // Reload suite to get updated data (and new stats)
            await LoadSuiteAsync();
            _isTestCaseFormOpen = false;
            _editingTestCaseId = null;
            _editInitialData = null;
        }
        catch (Exception ex)
        {
            _isTestCaseFormOpen = false;
            _editingTestCaseId = null;
            _editInitialData = null;
            ShowTimedError(ex.Message);
        }
    }

    private async Task OnEditTestCase(int testCaseId)
    {
        try
        {
            var testCase = await TestCaseTemplateService.GetTestCaseTemplateByIdAsync(testCaseId);
            if (testCase is null) return;

            _editingTestCaseId = testCaseId;
            _editInitialData = new TestCaseFormResult
            {
                Title = testCase.Title,
                Preconditions = testCase.Preconditions,
                Postconditions = testCase.Postconditions,
                Priority = testCase.Priority,
                Steps = testCase.TestStepTemplates.Select(s => new TestStepFormResult
                {
                    StepNumber = s.StepNumber,
                    Action = s.Action,
                    TestData = s.TestData,
                    ExpectedResult = s.ExpectedResult
                }).ToList()
            };
            _isTestCaseFormOpen = true;
        }
        catch (Exception ex)
        {
            ShowTimedError($"Failed to load test case for editing: {ex.Message}");
        }
    }

    private void OnConfirmDeleteTestCase(int testCaseId, string title)
    {
        _deleteTargetId = testCaseId;
        _deleteTargetTitle = title;
        _isDeleteConfirmOpen = true;
    }

    private void CloseDeleteConfirm()
    {
        _isDeleteConfirmOpen = false;
        _deleteTargetId = null;
        _deleteTargetTitle = null;
    }

    private async Task HandleDeleteTestCase()
    {
        if (!_deleteTargetId.HasValue) return;

        _isDeleting = true;
        try
        {
            var success = await TestCaseTemplateService.DeleteTestCaseTemplateAsync(_deleteTargetId.Value);
            if (success)
            {
                await LoadSuiteAsync();
            }
            else
            {
                ShowTimedError("Failed to delete the test case.");
            }
        }
        catch (Exception ex)
        {
            ShowTimedError($"Delete failed: {ex.Message}");
        }
        finally
        {
            _isDeleting = false;
            CloseDeleteConfirm();
        }
    }

    private void OnAddMarkdownCase()
    {
        _isMarkdownImportOpen = true;
    }

    private void CloseMarkdownImport()
    {
        _isMarkdownImportOpen = false;
    }

    private async Task HandleImportTestCase(TestCaseFormResult formResult)
    {
        if (_suite is null) return;

        try
        {
            var request = new CreateTestCaseTemplateRequest
            {
                Title = formResult.Title,
                Preconditions = formResult.Preconditions,
                Postconditions = formResult.Postconditions,
                Priority = formResult.Priority,
                TestStepTemplates = formResult.Steps.Select(s => new CreateTestStepTemplateRequest
                {
                    StepNumber = s.StepNumber,
                    Action = s.Action,
                    TestData = s.TestData,
                    ExpectedResult = s.ExpectedResult
                }).ToList()
            };

            await TestCaseTemplateService.CreateTestCaseTemplateAsync(TestSuiteId, request);

            // Reload suite to get updated data
            await LoadSuiteAsync();
            _isMarkdownImportOpen = false;
        }
        catch (Exception ex)
        {
            _isMarkdownImportOpen = false;
            ShowTimedError(ex.Message);
        }
    }

    private void OnViewTestCase(int testCaseId)
    {
        Navigation.NavigateTo($"/test-cases/{testCaseId}");
    }

    private class SuiteStats
    {
        public int Total { get; set; }
        public int Passed { get; set; }
        public int Failed { get; set; }
        public int Pending { get; set; }
        public int Blocked { get; set; }
        public int PassRate { get; set; }
        public int FailedRate { get; set; }
        public int PendingRate { get; set; }
    }
}
