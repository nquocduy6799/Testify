@page "/test-templates/suite-library"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.JSInterop
@using Testify.Client.Features.TestTemplates.Components
@using Testify.Client.Interfaces
@using Testify.Shared.DTOs.TemplateFolders
@using Testify.Shared.DTOs.TestCases
@using Testify.Shared.DTOs.TestTemplates
@using Testify.Shared.DTOs.Tags
@using Testify.Shared.DTOs.Categories
@using Testify.Shared.Enums
@inject ITestSuiteTemplateService TestSuiteTemplateService
@inject ITemplateFolderService TemplateFolderService
@inject ITemplateReviewService TemplateReviewService
@inject ITagService TagService
@inject ICategoryService CategoryService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@rendermode InteractiveWebAssembly
@attribute [Authorize]


<PageTitle>Suite Library</PageTitle>

<!-- Suite Library - Pixel-Perfect Design Based on Sketch -->
<div class="min-h-screen bg-[#F3F5F9]" style="font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;">
    
    <!-- Header Section -->
    <div class="bg-[#F8F9FB] border-b border-[#e2e8f0]">
        <div class="mx-auto max-w-[1600px] px-8 py-8 pb-12">
            <!-- Title & Description - Centered with Animation -->
            <div class="text-center mb-8 animate-fade-in">
                <h1 class="mb-3 text-[40px] font-extrabold tracking-tight text-transparent bg-clip-text bg-gradient-to-r from-[#2E5BFF] via-[#6366F1] to-[#8B5CF6] animate-pulse-slow">
                    Suite Library
                </h1>
                <p class="text-[15px] font-medium text-[#64748B] max-w-4xl mx-auto px-4">
                    Global test repository. These templates are shared across the system ecosystem.
                </p>
            </div>

            <!-- Search & Action Buttons - Centered with Gap -->
            <div class="flex flex-wrap justify-center items-center gap-3">
                    <!-- Search Input - Compact & Centered -->
                    <div class="relative w-full sm:w-auto sm:max-w-xs">
                        <svg class="pointer-events-none absolute left-4 top-1/2 h-5 w-5 -translate-y-1/2 text-[#94A3B8]" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
                        </svg>
                        <input type="text"
                               placeholder="Search templates..."
                               @bind="_searchQuery"
                               @bind:event="oninput"
                               style="border-radius: 12px;"
                               class="w-full sm:w-64 border border-[#e2e8f0] bg-white py-2.5 pr-4 pl-11 text-[13px] text-[#0F172A] outline-none transition-all placeholder:text-[#94A3B8] focus:border-[#2E5BFF] focus:ring-2 focus:ring-[#2E5BFF]/20 hover:border-[#2E5BFF]/50" />
                    </div>

                    <!-- Category Filter Dropdown -->
                    <div class="relative w-full sm:w-auto">
                        <select @bind="_selectedCategoryId"
                                style="border-radius: 12px;"
                                class="w-full sm:w-48 appearance-none border border-[#e2e8f0] bg-white py-2.5 px-4 pr-10 text-[13px] text-[#0F172A] outline-none transition-all focus:border-[#2E5BFF] focus:ring-2 focus:ring-[#2E5BFF]/20 hover:border-[#2E5BFF]/50">
                            <option value="">All Categories</option>
                            @foreach (var category in _categories)
                            {
                                <option value="@category.Id">@category.Name</option>
                            }
                        </select>
                        <svg class="pointer-events-none absolute right-3 top-1/2 h-4 w-4 -translate-y-1/2 text-[#94A3B8]" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                        </svg>
                    </div>

                    <!-- Sort Options Dropdown -->
                    <div class="relative w-full sm:w-auto">
                        <select @bind="_sortOption"
                                style="border-radius: 12px;"
                                class="w-full sm:w-48 appearance-none border border-[#e2e8f0] bg-white py-2.5 px-4 pr-10 text-[13px] text-[#0F172A] outline-none transition-all focus:border-[#2E5BFF] focus:ring-2 focus:ring-[#2E5BFF]/20 hover:border-[#2E5BFF]/50">
                            <option value="name-asc">Name (A-Z)</option>
                            <option value="name-desc">Name (Z-A)</option>
                            <option value="date-desc">Newest First</option>
                            <option value="date-asc">Oldest First</option>
                            <option value="cases-desc">Most Test Cases</option>
                            <option value="cases-asc">Least Test Cases</option>
                        </select>
                        <svg class="pointer-events-none absolute right-3 top-1/2 h-4 w-4 -translate-y-1/2 text-[#94A3B8]" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                        </svg>
                    </div>

                    <!-- Action Buttons - Modern Design -->
                    <div class="flex items-center gap-3">
                        <!-- Import Templates Button - Orange Style -->
                        <label class="group relative flex items-center gap-2 bg-white border-2 border-orange-500/20 px-4 py-2.5 rounded-xl text-[11px] font-bold uppercase tracking-wide text-orange-600 transition-all duration-300 hover:border-orange-500 hover:bg-gradient-to-r hover:from-orange-500/5 hover:to-orange-500/10 hover:shadow-lg hover:shadow-orange-500/20 hover:-translate-y-0.5 cursor-pointer"
                                title="Import templates from JSON file">
                            <svg class="h-4 w-4 transition-transform group-hover:scale-110 duration-300" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5" />
                            </svg>
                            <span class="hidden sm:inline">Import</span>
                            <InputFile OnChange="HandleFileImport" accept=".json" style="display: none;" />
                        </label>

                        <!-- Export Templates Button - Green Style -->
                        <button @onclick="ExportTemplates"
                                class="group relative flex items-center gap-2 bg-white border-2 border-green-500/20 px-4 py-2.5 rounded-xl text-[11px] font-bold uppercase tracking-wide text-green-600 transition-all duration-300 hover:border-green-500 hover:bg-gradient-to-r hover:from-green-500/5 hover:to-green-500/10 hover:shadow-lg hover:shadow-green-500/20 hover:-translate-y-0.5"
                                title="Export filtered templates to JSON">
                            <svg class="h-4 w-4 transition-transform group-hover:scale-110 duration-300" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
                            </svg>
                            <span class="hidden sm:inline">Export</span>
                        </button>

                        <!-- New Folder Button - Modern Blue Style -->
                        <button @onclick="() => _isCreatingFolder = true"
                                class="group relative flex items-center gap-2 bg-white border-2 border-[#2E5BFF]/20 px-4 py-2.5 rounded-xl text-[11px] font-bold uppercase tracking-wide text-[#2E5BFF] transition-all duration-300 hover:border-[#2E5BFF] hover:bg-gradient-to-r hover:from-[#2E5BFF]/5 hover:to-[#2E5BFF]/10 hover:shadow-lg hover:shadow-[#2E5BFF]/20 hover:-translate-y-0.5">
                            <svg class="h-4 w-4 transition-transform group-hover:rotate-90 duration-300" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                            </svg>
                            <span class="hidden sm:inline">New Folder</span>
                        </button>

                        <!-- New Suite Template Button - Matching Style with Purple/Indigo -->
                        <button @onclick="() => _isSuiteFormOpen = true"
                                class="group relative flex items-center gap-2 bg-white border-2 border-[#6366F1]/20 px-4 py-2.5 rounded-xl text-[11px] font-bold uppercase tracking-wide text-[#6366F1] transition-all duration-300 hover:border-[#6366F1] hover:bg-gradient-to-r hover:from-[#6366F1]/5 hover:to-[#6366F1]/10 hover:shadow-lg hover:shadow-[#6366F1]/20 hover:-translate-y-0.5">
                            <svg class="h-4 w-4 transition-transform group-hover:rotate-90 duration-300" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                            </svg>
                            <span class="hidden sm:inline">New Suite Template</span>
                        </button>
                    </div>
                <!-- End Action Buttons -->
            </div>
        </div>
    </div>

    <!-- Custom CSS for Animations -->
    <style>
        @@keyframes fade-in {
            from {
                opacity: 0;
                transform: translateY(-10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        
        @@keyframes pulse-slow {
            0%, 100% {
                opacity: 1;
            }
            50% {
                opacity: 0.8;
            }
        }
        
        .animate-fade-in {
            animation: fade-in 0.8s ease-out;
        }
        
        .animate-pulse-slow {
            animation: pulse-slow 3s ease-in-out infinite;
        }
    </style>

    <!-- Main Content Container -->
    <div class="mx-auto max-w-[1400px] px-8 py-8">

        <!-- Create Folder Form -->
        @if (_isCreatingFolder)
        {
            <div class="mb-6 border-2 border-dashed border-[#2E5BFF] bg-[#F8F9FB] p-6" style="border-radius: 40px;">
                <form class="flex flex-col md:flex-row items-stretch md:items-center gap-4" @onsubmit="HandleCreateFolder">
                    <div class="flex h-14 w-14 flex-shrink-0 items-center justify-center bg-[#2E5BFF]/10" style="border-radius: 50px;">
                        <svg class="h-7 w-7 text-[#2E5BFF]" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12.75V12A2.25 2.25 0 014.5 9.75h15A2.25 2.25 0 0121.75 12v.75m-8.69-6.44l-2.12-2.12a1.5 1.5 0 00-1.061-.44H4.5A2.25 2.25 0 002.25 6v12a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9a2.25 2.25 0 00-2.25-2.25h-5.379a1.5 1.5 0 01-1.06-.44z" />
                        </svg>
                    </div>
                    <input autoFocus
                           type="text"
                           @bind="_newFolderName"
                           placeholder="Name your folder (e.g. Performance Testing)"
                           class="flex-1 border-none bg-transparent text-[16px] font-semibold text-[#0F172A] outline-none placeholder:text-[#94A3B8]" />
                    <div class="flex items-center gap-3">
                        <button type="submit" style="border-radius: 50px;" class="bg-[#1C1D2A] px-6 py-3 text-[13px] font-bold text-white transition-all hover:bg-[#2a2b3a]">CREATE</button>
                        <button type="button" @onclick="() => _isCreatingFolder = false" class="p-2.5 text-[#94A3B8] transition-all hover:text-[#0F172A]">
                            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                            </svg>
                        </button>
                    </div>
                </form>
            </div>
        }

        <!-- Loading & Error States -->
        @if (_isLoading)
        {
            <div class="flex items-center justify-center gap-3 py-16 text-[14px] font-medium text-[#94A3B8]">
                <div class="h-6 w-6 animate-spin rounded-full border-3 border-[#e2e8f0] border-t-[#2E5BFF]"></div>
                Loading suite templates...
            </div>
        }
        else if (!string.IsNullOrWhiteSpace(_errorMessage))
        {
            <div style="border-radius: 40px;" class="border border-[#fecaca] bg-[#fef2f2] px-6 py-4 text-[14px] font-medium text-[#dc2626]">
                @_errorMessage
            </div>
        }
        else
        {
            <!--Bulk Operations Toolbar -->
            @if (_isSelectionMode)
            {
                <div class="mb-6 animate-fade-in border-2 border-[#2E5BFF] bg-[#F8F9FB] p-5 shadow-lg" style="border-radius: 40px;">
                    <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-3">
                        <!-- Selection Info -->
                        <div class="flex items-center gap-3">
                            <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-[#2e5bff] text-white">
                                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                                </svg>
                            </div>
                            <div>
                                <h3 class="text-sm md:text-base font-bold text-[#121926]">
                                    @_selectedTemplateIds.Count @(_selectedTemplateIds.Count == 1 ? "template" : "templates") selected
                                </h3>
                                <p class="text-xs text-[#697586]">Select templates to perform bulk actions</p>
                            </div>
                        </div>

                        <!-- Action Buttons -->
                        <div class="flex flex-wrap items-center gap-2 w-full md:w-auto">
                            <!-- Select All -->
                            <button @onclick="SelectAll"
                                    class="flex items-center gap-2 rounded-lg bg-white px-3 py-2 text-xs font-bold text-[#2e5bff] shadow-sm transition-all hover:shadow-md">
                                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                                </svg>
                                Select All
                            </button>

                            <!-- Move To Folder -->
                            @if (_selectedTemplateIds.Count > 0)
                            {
                                <div class="relative">
                                    <button @onclick="() => _showBulkMoveDropdown = !_showBulkMoveDropdown"
                                            class="flex items-center gap-2 rounded-lg bg-white px-3 py-2 text-xs font-bold text-blue-600 shadow-sm transition-all hover:shadow-md">
                                        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 13h6m-3-3v6m-9 1V7a2 2 0 012-2h6l2 2h6a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2z" />
                                        </svg>
                                        Move to...
                                        <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                                        </svg>
                                    </button>

                                    @if (_showBulkMoveDropdown)
                                    {
                                        <div class="absolute left-0 top-full z-50 mt-2 w-56 rounded-lg border border-slate-200 bg-white shadow-xl">
                                            <div class="max-h-64 overflow-y-auto p-2">
                                                <button @onclick="() => HandleBulkMove(null)"
                                                        class="w-full rounded-md px-3 py-2 text-left text-xs font-semibold text-[#697586] transition-colors hover:bg-slate-50">
                                                    📦 Uncategorized
                                                </button>
                                                @foreach (var folder in _folders)
                                                {
                                                    <button @onclick="() => HandleBulkMove(folder.Key)"
                                                            class="w-full rounded-md px-3 py-2 text-left text-xs font-semibold text-[#697586] transition-colors hover:bg-slate-50">
                                                        📁 @folder.Value
                                                    </button>
                                                }
                                            </div>
                                        </div>
                                    }
                                </div>

                                <!-- Delete Selected -->
                                <button @onclick="OpenBulkDeleteConfirmation"
                                        class="flex items-center gap-2 rounded-lg bg-red-500 px-3 py-2 text-xs font-bold text-white shadow-sm transition-all hover:bg-red-600 hover:shadow-md">
                                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />
                                    </svg>
                                    Delete Selected
                                </button>
                            }

                            <!-- Cancel Selection Mode -->
                            <button @onclick="ExitSelectionMode"
                                    class="flex items-center gap-2 rounded-lg bg-slate-100 px-3 py-2 text-xs font-bold text-slate-600 transition-all hover:bg-slate-200">
                                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                                </svg>
                                Cancel
                            </button>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <!-- Enable Selection Mode Button -->
                <div class="mb-6 flex justify-end">
                    <button @onclick="EnterSelectionMode"
                            style="border-radius: 50px;"
                            class="flex items-center gap-2 border border-[#e2e8f0] bg-white px-5 py-3 text-[12px] font-bold text-[#0F172A] transition-all hover:border-[#2E5BFF] hover:text-[#2E5BFF] hover:shadow-md">
                        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        SELECT MULTIPLE
                    </button>
                </div>
            }

            <!--  Main Layout: Grid 8:4 (Left Content : Right Navigator) -->
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
            
                <!-- CONTENT AREA (Left) - 8 columns -->
                <section class="lg:col-span-8 pl-2">
                    <!-- Section Header -->
                    <div class="mb-6 flex items-center justify-between">
                        <h2 class="text-[11px] font-bold uppercase tracking-[0.15em] text-[#0F172A]">
                            @if (_showStarredOnly)
                            {
                                <text>MY STARRED</text>
                            }
                            else
                            {
                                <text>@(_selectedFolderId.HasValue ? _folders[_selectedFolderId.Value].ToUpper() : "UNCATEGORIZED TEMPLATES")</text>
                            }
                        </h2>
                        <span style="border-radius: 50px;" class="bg-[#1C1D2A] px-4 py-2 text-[10px] font-bold uppercase tracking-wider text-white">@FilteredSuites.Count SUITES</span>
                    </div>

                    <!-- Content Container -->
                    <div class="min-h-[650px] bg-[#F8F9FB] shadow-sm" style="border-radius: 40px;">
                        @if (FilteredSuites.Count == 0)
                        {
                            <!-- Empty State - Inbox Icon -->
                            <div class="flex min-h-[650px] flex-col items-center justify-center p-12 text-center">
                                <!-- Large Inbox Icon -->
                                <div class="mb-8">
                                    <svg class="h-32 w-32 text-[#cbd5e1] opacity-40" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 3.75H6.912a2.25 2.25 0 00-2.15 1.588L2.35 13.177a2.25 2.25 0 00-.1.661V18a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18v-4.162c0-.224-.034-.447-.1-.661L19.24 5.338a2.25 2.25 0 00-2.15-1.588H15M2.25 13.5h3.86a2.25 2.25 0 012.012 1.244l.256.512a2.25 2.25 0 002.013 1.244h3.218a2.25 2.25 0 002.013-1.244l.256-.512a2.25 2.25 0 012.013-1.244h3.859" />
                                    </svg>
                                </div>
                                <p class="mb-3 text-[13px] font-bold uppercase tracking-[0.2em] text-[#94A3B8]">
                                    THIS VIEW IS CURRENTLY EMPTY
                                </p>
                                <p class="max-w-md text-[13px] text-[#94A3B8]">
                                    @if (!string.IsNullOrWhiteSpace(_searchQuery))
                                    {
                                        <text>No templates match your search criteria</text>
                                    }
                                    else
                                    {
                                        <text>Start by creating your first test suite template</text>
                                    }
                                </p>
                            </div>
                        }
                    else
                    {
                        <!-- Suite Cards Grid -->
                        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 h-full w-full gap-3 md:gap-4 overflow-y-auto p-3 md:p-6">
                            @foreach (var suite in FilteredSuites)
                            {
                                <div draggable="true"
                                     @ondragstart="(args) => OnDragStart(args, suite.Id)"
                                     @oncontextmenu="(e) => ShowContextMenu(e, suite.Id)"
                                     @oncontextmenu:preventDefault="true"
                                     class="@GetSuiteCardClass(suite)">
                                    
                                    <!-- Selection Checkbox -->
                                    @if (_isSelectionMode)
                                    {
                                        <div class="absolute -left-2 -top-2 z-10">
                                            <label class="flex h-6 w-6 cursor-pointer items-center justify-center rounded-full bg-white shadow-md transition-all hover:scale-110"
                                                   @onclick:stopPropagation="true">
                                                <input type="checkbox"
                                                       checked="@IsSelected(suite.Id)"
                                                       @onchange="() => ToggleSelection(suite.Id)"
                                                       class="hidden" />
                                                @if (IsSelected(suite.Id))
                                                {
                                                    <svg class="h-5 w-5 text-[#2e5bff]" fill="currentColor" viewBox="0 0 24 24">
                                                        <path d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                                                    </svg>
                                                }
                                                else
                                                {
                                                    <div class="h-5 w-5 rounded-full border-2 border-slate-300"></div>
                                                }
                                            </label>
                                        </div>
                                    }

                                    <!-- Card Header with Actions -->
                                    <div class="mb-3 md:mb-4 flex items-center justify-between">
                                        <div class="flex h-10 w-10 md:h-12 md:w-12 items-center justify-center rounded-xl bg-slate-50 text-slate-400 transition-all group-hover:bg-[#2e5bff] group-hover:text-white">
                                            <svg class="h-5 w-5 md:h-6 md:w-6" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                                            </svg>
                                        </div>
                                        <div class="flex items-center gap-1 md:gap-2">
                                            <!-- Test Cases Count -->
                                            <div class="flex items-center gap-1 md:gap-1.5 rounded-xl border border-slate-100 bg-slate-50 px-2 md:px-3 py-0.5 md:py-1">
                                                <svg class="h-3.5 w-3.5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                                                </svg>
                                                <span class="text-[10px] font-bold text-slate-600">@suite.TestCaseTemplates.Count</span>
                                            </div>
                                            <!-- View Count -->
                                            <div class="flex items-center gap-1 md:gap-1.5 rounded-xl border border-slate-100 bg-slate-50 px-2 md:px-3 py-0.5 md:py-1">
                                                <svg class="h-3.5 w-3.5 text-blue-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
                                                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                                </svg>
                                                <span class="text-[10px] font-bold text-slate-600">@suite.ViewCount</span>
                                            </div>
                                            <!-- Clone Count -->
                                            <div class="flex items-center gap-1 md:gap-1.5 rounded-xl border border-slate-100 bg-slate-50 px-2 md:px-3 py-0.5 md:py-1">
                                                <svg class="h-3.5 w-3.5 text-green-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 17.25v3.375c0 .621-.504 1.125-1.125 1.125h-9.75a1.125 1.125 0 01-1.125-1.125V7.875c0-.621.504-1.125 1.125-1.125H6.75a9.06 9.06 0 011.5.124m7.5 10.376h3.375c.621 0 1.125-.504 1.125-1.125V11.25c0-4.46-3.243-8.161-7.5-8.876a9.06 9.06 0 00-1.5-.124H9.375c-.621 0-1.125.504-1.125 1.125v3.5m7.5 10.375H9.375a1.125 1.125 0 01-1.125-1.125v-9.25m12 6.625v-1.875a3.375 3.375 0 00-3.375-3.375h-1.5a1.125 1.125 0 01-1.125-1.125v-1.5a3.375 3.375 0 00-3.375-3.375H9.75" />
                                                </svg>
                                                <span class="text-[10px] font-bold text-slate-600">@suite.CloneCount</span>
                                            </div>
                                            <!-- Star Button -->
                                            <button @onclick="() => ToggleStar(suite.Id)"
                                                    @onclick:stopPropagation="true"
                                                    class="opacity-0 group-hover:opacity-100 transition-opacity p-2 rounded-lg hover:bg-yellow-50">
                                                <svg class="h-4 w-4 @(IsStarred(suite.Id) ? "fill-yellow-400 text-yellow-400" : "text-slate-400")" fill="@(IsStarred(suite.Id) ? "currentColor" : "none")" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                                    <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" />
                                                </svg>
                                            </button>
                                        </div>
                                    </div>

                                    <!-- Card Content - Clickable -->
                                    <div @onclick="() => SelectSuite(suite)" class="cursor-pointer">
                                        <h4 class="truncate text-xs md:text-sm font-bold text-[#121926] transition-colors group-hover:text-[#2e5bff]">@suite.Name</h4>
                                        <p class="mt-1 md:mt-2 line-clamp-2 h-6 md:h-8 text-[9px] md:text-[10px] font-medium text-[#9aa4b2]">@(!string.IsNullOrWhiteSpace(suite.Description) ? suite.Description : "Standard regression suite asset.")</p>
                                    </div>

                                    <!-- Tags and Public/Private Badge -->
                                    <div class="mt-3 md:mt-4 flex items-center gap-1.5 md:gap-2 flex-wrap">
                                        <!-- Public/Private Badge -->
                                        @if (suite.IsPublic)
                                        {
                                            <span class="flex items-center gap-1 px-2 py-0.5 rounded-full bg-green-50 text-green-700 text-[9px] font-bold">
                                                <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 10.5V6.75a4.5 4.5 0 119 0v3.75M3.75 21.75h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H3.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />
                                                </svg>
                                                PUBLIC
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="flex items-center gap-1 px-2 py-0.5 rounded-full bg-amber-50 text-amber-700 text-[9px] font-bold">
                                                <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                                    <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />
                                                </svg>
                                                PRIVATE
                                            </span>
                                        }
                                        
                                        <!-- Category Badge -->
                                        @if (suite.Category != null)
                                        {
                                            <span class="px-2 py-0.5 rounded-full bg-blue-50 text-blue-700 text-[9px] font-bold">
                                                @suite.Category.Name
                                            </span>
                                        }
                                        
                                        <!-- Tags -->
                                        @foreach (var tag in suite.Tags.Take(3))
                                        {
                                            <span class="px-2 py-0.5 rounded-full bg-slate-100 text-slate-600 text-[9px] font-semibold">
                                                #@tag.TagName
                                            </span>
                                        }
                                        @if (suite.Tags.Count > 3)
                                        {
                                            <span class="px-2 py-0.5 rounded-full bg-slate-50 text-slate-400 text-[9px] font-bold">
                                                +@(suite.Tags.Count - 3)
                                            </span>
                                        }
                                    </div>

                                    <!-- Card Footer with Actions -->
                                    <div class="mt-4 md:mt-6 flex items-center justify-between border-t border-slate-50 pt-3 md:pt-4">
                                        <span class="text-[9px] font-bold uppercase tracking-wider text-[#9aa4b2]">ID @suite.Id</span>
                                        <div class="flex items-center gap-2">
                                            <!-- Clone Button -->
                                            <button @onclick="async () => await CloneSuite(suite.Id)"
                                                    @onclick:stopPropagation="true"
                                                    title="Clone Template"
                                                    class="opacity-0 group-hover:opacity-100 transition-opacity p-1.5 rounded-lg hover:bg-purple-50 text-slate-400 hover:text-purple-600">
                                                <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 17.25v3.375c0 .621-.504 1.125-1.125 1.125h-9.75a1.125 1.125 0 01-1.125-1.125V7.875c0-.621.504-1.125 1.125-1.125H6.75a9.06 9.06 0 011.5.124m7.5 10.376h3.375c.621 0 1.125-.504 1.125-1.125V11.25c0-4.46-3.243-8.161-7.5-8.876a9.06 9.06 0 00-1.5-.124H9.375c-.621 0-1.125.504-1.125 1.125v3.5m7.5 10.375H9.375a1.125 1.125 0 01-1.125-1.125v-9.25m12 6.625v-1.875a3.375 3.375 0 00-3.375-3.375h-1.5a1.125 1.125 0 01-1.125-1.125v-1.5a3.375 3.375 0 00-3.375-3.375H9.75" />
                                                </svg>
                                            </button>
                                            <!-- Share Button -->
                                            <button @onclick="() => OpenShareModal(suite.Id)"
                                                    @onclick:stopPropagation="true"
                                                    title="Share"
                                                    class="opacity-0 group-hover:opacity-100 transition-opacity p-1.5 rounded-lg hover:bg-blue-50 text-slate-400 hover:text-[#2e5bff]">
                                                <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                                    <path stroke-linecap="round" stroke-linejoin="round" d="M7.217 10.907a2.25 2.25 0 100 2.186m0-2.186c.18.324.283.696.283 1.093s-.103.77-.283 1.093m0-2.186l9.566-5.314m-9.566 7.5l9.566 5.314m0 0a2.25 2.25 0 103.935 2.186 2.25 2.25 0 00-3.935-2.186zm0-12.814a2.25 2.25 0 103.933-2.185 2.25 2.25 0 00-3.933 2.185z" />
                                                </svg>
                                            </button>
                                            <!-- Edit Button -->
                                            <button @onclick="() => OpenEditModal(suite)"
                                                    @onclick:stopPropagation="true"
                                                    title="Edit"
                                                    class="opacity-0 group-hover:opacity-100 transition-opacity p-1.5 rounded-lg hover:bg-blue-50 text-slate-400 hover:text-[#2e5bff]">
                                                <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                                    <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />
                                                </svg>
                                            </button>
                                            <!-- Delete Button -->
                                            <button @onclick="() => OpenDeleteConfirmation(suite.Id, suite.Name)"
                                                    @onclick:stopPropagation="true"
                                                    title="Delete"
                                                    class="opacity-0 group-hover:opacity-100 transition-opacity p-1.5 rounded-lg hover:bg-red-50 text-slate-400 hover:text-red-500">
                                                <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                                    <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />
                                                </svg>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    </div>
                </section>

                <!-- SIDEBAR (Right) - Template Navigator - 4 columns -->
                <aside class="lg:col-span-4 pr-2">
                    <div class="mb-6">
                        <h3 class="text-[11px] font-bold uppercase tracking-[0.15em] text-[#0F172A]">
                            TEMPLATE NAVIGATOR
                        </h3>
                    </div>

                    <ul class="space-y-3">
                        <!-- UNCATEGORIZED -->
                        <li @onclick="() => SelectFolder(null)"
                            @ondragover="(e) => OnDragOver(e, null)"
                            @ondragover:preventDefault
                            @ondragleave="OnDragLeave"
                            @ondrop="(e) => OnDrop(e, null)"
                            @ondrop:preventDefault
                            class="@GetPixelPerfectFolderClass(null)">
                            <div class="flex items-center gap-4">
                                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 7.5l-.625 10.632a2.25 2.25 0 01-2.247 2.118H6.622a2.25 2.25 0 01-2.247-2.118L3.75 7.5M10 11.25h4M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z" />
                                </svg>
                                <span class="flex-1 text-[13px] font-semibold">Uncategorized</span>
                            </div>
                            <span class="@GetPixelPerfectCountBadgeClass(!_selectedFolderId.HasValue && !_showStarredOnly)">
                                @_suites.Count(s => !s.FolderId.HasValue)
                            </span>
                        </li>

                        <!-- MY STARRED -->
                        <li @onclick="() => FilterByStarred()"
                            class="@GetPixelPerfectFolderClass(_showStarredOnly ? -1 : null)">
                            <div class="flex items-center gap-4">
                                <svg class="h-5 w-5 @(_showStarredOnly ? "fill-current" : "")" fill="@(_showStarredOnly ? "currentColor" : "none")" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" />
                                </svg>
                                <span class="flex-1 text-[13px] font-semibold">My Starred</span>
                            </div>
                            <span class="@GetPixelPerfectCountBadgeClass(_showStarredOnly)">
                                @_starredSuites.Count
                            </span>
                        </li>

                        <div class="my-4 h-px bg-[#e2e8f0] mx-3"></div>

                        <!-- CATEGORIES/FOLDERS -->
                        @foreach (var folder in PaginatedFolders)
                        {
                            <li @ondragover="(e) => OnDragOver(e, folder.Key)"
                                @ondragover:preventDefault
                                @ondragleave="OnDragLeave"
                                @ondrop="(e) => OnDrop(e, folder.Key)"
                                @ondrop:preventDefault
                                class="@GetPixelPerfectFolderClass(folder.Key)">
                                <div @onclick="() => SelectFolder(folder.Key)" class="flex items-center gap-4 flex-1 min-w-0 cursor-pointer">
                                    <svg class="h-5 w-5 flex-shrink-0 text-[#2E5BFF]" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12.75V12A2.25 2.25 0 014.5 9.75h15A2.25 2.25 0 0121.75 12v.75m-8.69-6.44l-2.12-2.12a1.5 1.5 0 00-1.061-.44H4.5A2.25 2.25 0 002.25 6v12a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9a2.25 2.25 0 00-2.25-2.25h-5.379a1.5 1.5 0 01-1.06-.44z" />
                                    </svg>
                                    <span class="flex-1 text-[13px] font-semibold truncate">@folder.Value</span>
                                </div>
                                <div class="flex items-center gap-2">
                                    <span class="@GetPixelPerfectCountBadgeClass(_selectedFolderId == folder.Key)">
                                        @_suites.Count(s => s.FolderId == folder.Key)
                                    </span>
                                    <button @onclick="() => OpenDeleteFolderConfirmation(folder.Key, folder.Value)"
                                            @onclick:stopPropagation="true"
                                            class="opacity-0 group-hover:opacity-100 rounded-lg p-1.5 text-slate-400 hover:bg-red-50 hover:text-red-500 transition-all"
                                            title="Delete folder">
                                        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />
                                        </svg>
                                    </button>
                                </div>
                            </li>
                        }
                    </ul>

                    <!-- Folder Pagination Controls -->
                    @if (TotalPages > 1)
                    {
                        <div class="mt-6 flex items-center justify-between rounded-[40px] bg-[#F8F9FB] border border-[#e2e8f0] px-4 py-3">
                            <button @onclick="() => ChangePage(-1)"
                                    disabled="@(_currentPage == 1)"
                                    class="flex items-center gap-2 rounded-lg px-3 py-1.5 text-[11px] font-bold uppercase tracking-wide transition-all disabled:opacity-30 disabled:cursor-not-allowed enabled:hover:bg-[#2E5BFF]/10 enabled:text-[#2E5BFF]">
                                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
                                </svg>
                                Prev
                            </button>
                            
                            <span class="text-[11px] font-bold text-[#0F172A]">
                                Page @_currentPage of @TotalPages
                            </span>
                            
                            <button @onclick="() => ChangePage(1)"
                                    disabled="@(_currentPage == TotalPages)"
                                    class="flex items-center gap-2 rounded-lg px-3 py-1.5 text-[11px] font-bold uppercase tracking-wide transition-all disabled:opacity-30 disabled:cursor-not-allowed enabled:hover:bg-[#2E5BFF]/10 enabled:text-[#2E5BFF]">
                                Next
                                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
                                </svg>
                            </button>
                        </div>
                    }
                </aside>
            </div>
        }

    </div>
</div>

    <!-- Suite Form Modal -->
    @if (_isSuiteFormOpen)
    {
        <TestSuiteForm OnSave="HandleSaveTestSuite"
                       OnClose="CloseSuiteForm"
                       AvailableFolders="_folders"
                       InitialFolderId="_selectedFolderId"
                       AvailableCategories="_categories"
                       AvailableTags="_tags"
                       Type="Library" />
    }

    <!-- Edit Suite Form Modal -->
    @if (_isEditFormOpen && _editingSuite != null)
    {
        <TestSuiteForm OnSave="HandleUpdateTestSuite"
                       OnClose="CloseEditForm"
                       AvailableFolders="_folders"
                       InitialFolderId="_editingSuite.FolderId"
                       AvailableCategories="_categories"
                       AvailableTags="_tags"
                       ExistingSuite="_editingSuite"
                       Type="Library" />
    }

    <!-- Delete Confirmation Modal -->
    @if (_showDeleteConfirmation)
    {
        <div class="fixed inset-0 z-[200] flex items-center justify-center p-6">
            <div class="absolute inset-0 bg-slate-900/40 backdrop-blur-sm" @onclick="CloseDeleteConfirmation"></div>
            
            <div class="relative w-full max-w-md rounded-[32px] bg-white p-8 shadow-2xl">
                <div class="mb-6 flex h-16 w-16 items-center justify-center rounded-2xl bg-red-50">
                    <svg class="h-8 w-8 text-red-500" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z\" />
                    </svg>
                </div>
                
                <h3 class="mb-2 text-2xl font-bold text-[#121926]">Delete Template?</h3>
                <p class="mb-6 text-sm text-[#697586]">Are you sure you want to delete <strong>"@_deleteTargetName"</strong>? This action cannot be undone.</p>
                
                <div class="flex gap-3">
                    <button @onclick="CloseDeleteConfirmation"
                            class="flex-1 rounded-xl border border-slate-200 bg-white px-6 py-3 font-bold text-[#697586] transition-all hover:bg-slate-50">
                        Cancel
                    </button>
                    <button @onclick="ConfirmDelete"
                            class="flex-1 rounded-xl bg-red-500 px-6 py-3 font-bold text-white transition-all hover:bg-red-600">
                        Delete
                    </button>
                </div>
            </div>
        </div>
    }

    <!-- Bulk Delete Confirmation Modal -->
    @if (_showBulkDeleteConfirmation)
    {
        <div class="fixed inset-0 z-[200] flex items-center justify-center p-6">
            <div class="absolute inset-0 bg-slate-900/40 backdrop-blur-sm" @onclick="CancelBulkDelete"></div>
            
            <div class="relative w-full max-w-md rounded-[32px] bg-white p-8 shadow-2xl">
                <div class="mb-6 flex h-16 w-16 items-center justify-center rounded-2xl bg-red-50">
                    <svg class="h-8 w-8 text-red-500" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
                    </svg>
                </div>
                
                <h3 class="mb-2 text-2xl font-bold text-[#121926]">Delete @_selectedTemplateIds.Count Templates?</h3>
                <p class="mb-6 text-sm text-[#697586]">
                    Are you sure you want to delete <strong>@_selectedTemplateIds.Count template@(_selectedTemplateIds.Count != 1 ? "s" : "")</strong>? 
                    This action cannot be undone and will permanently remove all selected templates.
                </p>
                
                <div class="flex gap-3">
                    <button @onclick="CancelBulkDelete"
                            class="flex-1 rounded-xl border border-slate-200 bg-white px-6 py-3 font-bold text-[#697586] transition-all hover:bg-slate-50">
                        Cancel
                    </button>
                    <button @onclick="ConfirmBulkDelete"
