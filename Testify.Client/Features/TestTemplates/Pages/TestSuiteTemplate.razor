@page "/test-templates/suite-library"
@using Testify.Client.Features.TestTemplates.Components
@using Testify.Client.Interfaces
@using Testify.Shared.DTOs.TestTemplates
@inject ITestSuiteTemplateService TestSuiteTemplateService
@rendermode InteractiveWebAssembly

<PageTitle>Suite Library</PageTitle>

<div class="animate-in fade-in slide-in-from-bottom-4 space-y-8 pb-20 duration-500">
    <div class="flex flex-col justify-between gap-6 md:flex-row md:items-end">
        <div>
            <h2 class="text-3xl font-black tracking-tight text-slate-800">Suite Library</h2>
            <p class="mt-2 font-medium text-slate-400">Global test repository. These templates are shared across the system ecosystem.</p>
        </div>

        <div class="flex flex-wrap items-center gap-4">
            <div class="group relative">
                <svg class="absolute top-1/2 left-4 h-4 w-4 -translate-y-1/2 text-slate-300 transition-colors group-focus-within:text-[#7E96E1]" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35m1.85-5.65a7.5 7.5 0 11-15 0 7.5 7.5 0 0115 0z" />
                </svg>
                <input type="text"
                       placeholder="Search templates..."
                       @bind="_searchQuery"
                       class="w-64 rounded-[32px] border border-slate-100 bg-white py-4 pr-4 pl-11 text-xs font-bold shadow-sm transition-all outline-none focus:ring-2 focus:ring-[#7E96E1]/20" />
                @if (!string.IsNullOrWhiteSpace(_searchQuery))
                {
                    <button @onclick="ClearSearch"
                            class="absolute top-1/2 right-4 -translate-y-1/2 rounded-full p-1 transition-all hover:bg-slate-100">
                        <svg class="h-3 w-3 text-slate-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                        </svg>
                    </button>
                }
            </div>

            <button @onclick="() => _isCreatingFolder = true"
                    class="bg-white text-slate-800 px-6 py-4 rounded-[32px] border border-slate-100 flex items-center gap-3 font-black shadow-sm hover:shadow-md transition-all">
                <svg class="h-5 w-5 text-[#7E96E1]" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 5v14m7-7H5" />
                </svg>
                <span class="text-xs tracking-widest uppercase">New Folder</span>
            </button>

            <button @onclick="() => _isSuiteFormOpen = true"
                    class="bg-[#1C1D2A] text-white px-8 py-4 rounded-[32px] flex items-center gap-3 font-black shadow-lg hover:bg-slate-800 hover:shadow-xl active:scale-95 transition-all">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 5v14m7-7H5" />
                </svg>
                <span class="text-xs tracking-widest uppercase">New Suite Template</span>
            </button>
        </div>
    </div>

    @if (_isCreatingFolder)
    {
        <div class="animate-in zoom-in-95 rounded-[40px] border-2 border-dashed border-[#7E96E1] bg-white p-8 duration-200">
            <form class="flex items-center gap-4" @onsubmit="HandleCreateFolder">
                <div class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-2xl bg-blue-50">
                    <svg class="h-6 w-6 text-[#7E96E1]" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3 7.5h6l2 2H21v9a1.5 1.5 0 01-1.5 1.5h-15A1.5 1.5 0 013 18V7.5z" />
                    </svg>
                </div>
                <input autoFocus
                       type="text"
                       @bind="_newFolderName"
                       placeholder="Name your folder (e.g. Mobile Assets)"
                       class="flex-1 border-none bg-transparent text-xl font-black text-slate-800 outline-none placeholder:text-slate-300" />
                <button type="submit" class="rounded-2xl bg-[#1C1D2A] px-6 py-3 text-sm font-black text-white">Create</button>
                <button type="button" @onclick="() => _isCreatingFolder = false" class="p-3 text-slate-400 hover:text-slate-600">
                    <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
            </form>
        </div>
    }

    @if (_isLoading)
    {
        <div class="flex items-center gap-3 text-sm font-medium text-slate-400">
            <div class="h-4 w-4 animate-spin rounded-full border-2 border-slate-300 border-t-transparent"></div>
            Loading suite templates...
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <div class="rounded-[24px] border border-red-100 bg-red-50 px-6 py-4 text-sm font-medium text-red-600">
            @_errorMessage
        </div>
    }
    else
    {
        <div class="animate-in fade-in grid min-h-[600px] grid-cols-12 gap-8 duration-500">
            <div class="col-span-12 flex flex-col space-y-4 lg:col-span-8">
                <div class="flex items-center justify-between px-6 py-2">
                    <div class="flex items-center gap-3">
                        @if (_selectedFolderId.HasValue)
                        {
                            <svg class="h-5 w-5 text-[#7E96E1]" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M3 7.5h6l2 2H21v9a1.5 1.5 0 01-1.5 1.5h-15A1.5 1.5 0 013 18V7.5z" />
                            </svg>
                        }
                        else
                        {
                            <svg class="h-5 w-5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M20 7.5H4m0 0l1.5-3h13L20 7.5m0 0V18a1.5 1.5 0 01-1.5 1.5h-13A1.5 1.5 0 014 18V7.5z" />
                            </svg>
                        }
                        <h4 class="text-xs font-black tracking-widest text-slate-800 uppercase">
                            @_selectedFolderId.HasValue
                                ? $"Folder: {_folders[_selectedFolderId.Value]}"
                                : "Uncategorized Templates"
                        </h4>
                    </div>
                    <span class="rounded-full bg-slate-100 px-3 py-1 font-black text-[10px] text-slate-400 uppercase">
                        @FilteredSuites.Count Suites
                    </span>
                </div>

                <div class="flex-1 space-y-3 overflow-hidden rounded-[48px] border border-slate-100 bg-white/40 p-6 shadow-inner">
                    <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
                        @foreach (var suite in FilteredSuites)
                        {
                            <div draggable="true"
                                 @ondragstart="(args) => OnDragStart(args, suite.Id)"
                                 @onclick="() => SelectSuite(suite)"
                                 class="@GetSuiteCardClass(suite)">
                                <div class="mb-4 flex items-center justify-between">
                                    <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-slate-50 text-slate-400 transition-all group-hover:bg-[#7E96E1] group-hover:text-white">
                                        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 9.75l4.5 4.5m0-4.5l-4.5 4.5M3.75 5.25h16.5v13.5H3.75z" />
                                        </svg>
                                    </div>
                                    <div class="flex items-center gap-1.5 rounded-xl border border-slate-100 bg-slate-50 px-3 py-1">
                                        <svg class="h-3.5 w-3.5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 7.5L9 18l-4.5-4.5" />
                                        </svg>
                                        <span class="font-black text-[10px] text-slate-600">@suite.TestCaseTemplates.Count</span>
                                    </div>
                                </div>

                                <h4 class="truncate text-sm font-black text-slate-800 transition-colors group-hover:text-[#7E96E1]">@suite.Name</h4>
                                <p class="mt-2 line-clamp-2 h-8 font-medium text-[10px] text-slate-400">@(!string.IsNullOrWhiteSpace(suite.Description) ? suite.Description : "Standard regression suite asset.")</p>

                                <div class="mt-6 flex items-center justify-between border-t border-slate-50 pt-4">
                                    <span class="font-black tracking-widest text-[9px] text-slate-300 uppercase">ID @suite.Id</span>
                                    <div class="flex items-center gap-1 font-black text-[9px] text-[#7E96E1] uppercase opacity-0 transition-opacity group-hover:opacity-100">
                                        Open Template
                                        <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                                        </svg>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>

                    @if (FilteredSuites.Count == 0)
                    {
                        <div class="flex h-full flex-col items-center justify-center py-20 text-center opacity-50">
                            <svg class="mb-6 h-16 w-16 text-slate-200" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 9.75l4.5 4.5m0-4.5l-4.5 4.5M3.75 5.25h16.5v13.5H3.75z" />
                            </svg>
                            <p class="text-sm font-black tracking-widest text-slate-300 uppercase">
                                @(!string.IsNullOrWhiteSpace(_searchQuery) ? "No matching templates found" : "This view is currently empty")
                            </p>
                        </div>
                    }
                </div>
            </div>

            <div class="col-span-12 flex flex-col space-y-6 lg:col-span-4">
                <div class="flex items-center justify-between px-6 py-2">
                    <div class="flex items-center gap-3">
                        <svg class="h-5 w-5 text-[#7E96E1]" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M3 4.5h18M3 12h18M3 19.5h18" />
                        </svg>
                        <h4 class="text-xs font-black tracking-widest text-slate-800 uppercase">Template Navigator</h4>
                    </div>
                </div>

                <div class="flex-1 space-y-3">
                    <button @onclick="() => SelectFolder(null)"
                            @ondragover="(e) => OnDragOver(e, null)"
                            @ondragleave="OnDragLeave"
                            @ondrop="(e) => OnDrop(e, null)"
                            class="@GetFolderButtonClass(null)">
                        <div class="flex items-center gap-4">
                            <svg class="h-5 w-5 @( _selectedFolderId is null ? "text-[#7E96E1]" : "text-slate-300")" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M20 7.5H4m0 0l1.5-3h13L20 7.5m0 0V18a1.5 1.5 0 01-1.5 1.5h-13A1.5 1.5 0 014 18V7.5z" />
                            </svg>
                            <span class="text-sm font-black tracking-tight uppercase">Uncategorized</span>
                        </div>
                        <span class="@GetFolderCountClass(_selectedFolderId is null)">
                            @_suites.Count(s => !s.FolderId.HasValue)
                        </span>
                    </button>

                    <div class="mx-6 my-2 h-px bg-slate-100"></div>

                    <div class="min-h-[300px] space-y-3">
                        @foreach (var folder in PaginatedFolders)
                        {
                            <div @onclick="() => SelectFolder(folder.Key)"
                                 @ondragover="(e) => OnDragOver(e, folder.Key)"
                                 @ondragleave="OnDragLeave"
                                 @ondrop="(e) => OnDrop(e, folder.Key)"
                                 class="@GetFolderContainerClass(folder.Key)">
                                <div class="flex items-center gap-4">
                                    <svg class="@GetFolderIconClass(folder.Key)" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M3 7.5h6l2 2H21v9a1.5 1.5 0 01-1.5 1.5h-15A1.5 1.5 0 013 18V7.5z" />
                                    </svg>
                                    <span class="max-w-[140px] truncate text-sm font-black tracking-tight uppercase">@folder.Value</span>
                                </div>
                                <div class="flex items-center gap-3">
                                    <span class="@GetFolderCountClass(_selectedFolderId == folder.Key)">
                                        @_suites.Count(s => s.FolderId == folder.Key)
                                    </span>
                                    <button @onclick="(args) => DeleteFolder(args, folder.Key)"
                                            class="@GetFolderDeleteClass(folder.Key)">
                                        <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M6 7h12m-9 0V5h6v2m-8 0l1 12h8l1-12" />
                                        </svg>
                                    </button>
                                </div>
                            </div>
                        }

                        @if (_folders.Count == 0)
                        {
                            <div class="flex flex-col items-center justify-center rounded-[48px] border-2 border-dashed border-slate-100 bg-white/40 py-12 text-center">
                                <svg class="mb-4 h-10 w-10 text-slate-200" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 5v14m7-7H5" />
                                </svg>
                                <p class="font-black tracking-widest text-[10px] text-slate-300 uppercase">No Library Folders</p>
                            </div>
                        }
                    </div>

                    @if (TotalPages > 1)
                    {
                        <div class="mt-6 flex items-center justify-center gap-2">
                            <button disabled="_currentPage == 1"
                                    @onclick="() => ChangePage(-1)"
                                    class="p-2 bg-white border border-slate-100 rounded-xl disabled:opacity-30">
                                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
                                </svg>
                            </button>
                            <span class="font-black text-[10px] text-slate-400">PAGE @_currentPage / @TotalPages</span>
                            <button disabled="_currentPage == TotalPages"
                                    @onclick="() => ChangePage(1)"
                                    class="p-2 bg-white border border-slate-100 rounded-xl disabled:opacity-30">
                                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                                </svg>
                            </button>
                        </div>
                    }
                </div>
            </div>
        </div>
    }

    @if (_isSuiteFormOpen)
    {
        <TestSuiteForm OnSave="HandleSaveTestSuite"
                       OnClose="CloseSuiteForm"
                       AvailableFolders="_folders"
                       InitialFolderId="_selectedFolderId"
                       Type="Library" />
    }

    <div class="relative flex flex-col items-center gap-10 overflow-hidden rounded-[48px] bg-slate-900 p-10 text-white md:flex-row">
        <div class="relative z-10 flex-1">
            <h4 class="mb-2 text-2xl font-black tracking-tight">Global Entity Repository</h4>
            <p class="max-w-lg leading-relaxed font-medium text-slate-400">
                These suite templates do not belong to a specific project until imported. Changes made here affect the global master blueprints.
            </p>
        </div>
        <div class="relative flex h-32 w-32 flex-shrink-0 items-center justify-center">
            <svg class="h-16 w-16 text-[#7E96E1]" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
            </svg>
            <div class="absolute inset-0 animate-pulse rounded-full bg-[#7E96E1]/20 blur-2xl"></div>
        </div>
    </div>
</div>

@code {
    private readonly List<TestSuiteTemplateResponse> _suites = new();
    private readonly Dictionary<int, string> _folders = new();

    private string _searchQuery = string.Empty;
    private bool _isSuiteFormOpen;
    private bool _isCreatingFolder;
    private string _newFolderName = string.Empty;

    private int? _selectedFolderId;
    private int? _draggedSuiteId;
    private int? _dragOverFolderId;

    private int _currentPage = 1;
    private const int PageSize = 6;

    private bool _isLoading = true;
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadSuitesAsync();
    }

    private async Task LoadSuitesAsync()
    {
        _isLoading = true;
        _errorMessage = null;

        try
        {
            _suites.Clear();
            _suites.AddRange(await TestSuiteTemplateService.GetTestSuiteTemplatesAsync());
            BuildFolderIndex();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Unable to load suite templates. {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private List<TestSuiteTemplateResponse> FilteredSuites => _suites
        .Where(suite => !_selectedFolderId.HasValue ? !suite.FolderId.HasValue : suite.FolderId == _selectedFolderId)
        .Where(suite => string.IsNullOrWhiteSpace(_searchQuery) || suite.Name.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase))
        .ToList();

    private IReadOnlyList<KeyValuePair<int, string>> PaginatedFolders => _folders
        .OrderBy(folder => folder.Value)
        .Skip((_currentPage - 1) * PageSize)
        .Take(PageSize)
        .ToList();

    private int TotalPages => _folders.Count == 0 ? 1 : (int)Math.Ceiling(_folders.Count / (double)PageSize);

    private void BuildFolderIndex()
    {
        foreach (var suite in _suites.Where(suite => suite.FolderId.HasValue))
        {
            var folderId = suite.FolderId!.Value;
            if (!_folders.ContainsKey(folderId))
            {
                _folders[folderId] = $"Folder {folderId}";
            }
        }
    }

    private void ClearSearch() => _searchQuery = string.Empty;

    private string GetSuiteCardClass(TestSuiteTemplateResponse suite) =>
        $"p-6 bg-white rounded-[32px] border transition-all cursor-grab active:cursor-grabbing group shadow-sm hover:shadow-xl {(suite.Id == _draggedSuiteId ? "opacity-40 border-dashed border-[#7E96E1] scale-95" : "border-slate-50")}";

    private string GetFolderButtonClass(int? folderId)
    {
        var isSelected = _selectedFolderId == folderId;
        var isDragOver = _dragOverFolderId == folderId;
        var baseClass = isSelected
            ? "bg-[#1C1D2A] text-white border-transparent shadow-xl"
            : "bg-white border-slate-50 shadow-sm hover:border-[#7E96E1]/30 text-slate-600";

        var dragClass = isDragOver ? "border-dashed border-2 border-[#7E96E1] bg-blue-50/10 scale-[1.02]" : string.Empty;
        return $"w-full flex items-center justify-between px-6 py-5 rounded-[32px] border transition-all {baseClass} {dragClass}";
    }

    private string GetFolderContainerClass(int folderId)
    {
        var isSelected = _selectedFolderId == folderId;
        var isDragOver = _dragOverFolderId == folderId;

        var baseClass = isSelected
            ? "bg-[#1C1D2A] text-white border-transparent shadow-xl scale-[1.02]"
            : "bg-white border-slate-50 shadow-sm hover:border-[#7E96E1]/30 text-slate-600";

        var dragClass = isDragOver ? "border-dashed border-2 border-[#7E96E1] bg-blue-50/10 scale-[1.02]" : string.Empty;
        return $"group cursor-pointer flex items-center justify-between px-6 py-5 rounded-[32px] border transition-all relative {baseClass} {dragClass}";
    }

    private string GetFolderIconClass(int folderId) =>
        $"w-5 h-5 transition-all {( _selectedFolderId == folderId ? "text-[#7E96E1]" : "text-[#7E96E1] group-hover:scale-110")}";

    private string GetFolderCountClass(bool selected) =>
        selected
            ? "text-[10px] font-bold px-2.5 py-1 rounded-full bg-white/10 text-white"
            : "text-[10px] font-bold px-2.5 py-1 rounded-full bg-slate-100 text-slate-400";

    private string GetFolderDeleteClass(int folderId) =>
        _selectedFolderId == folderId
            ? "p-2 rounded-xl opacity-0 group-hover:opacity-100 transition-all hover:bg-red-500/20 text-slate-400"
            : "p-2 rounded-xl opacity-0 group-hover:opacity-100 transition-all hover:bg-red-50 text-red-400";

    private void SelectFolder(int? folderId) => _selectedFolderId = folderId;

    private void SelectSuite(TestSuiteTemplateResponse suite)
    {
        // Placeholder for future details view or navigation.
    }

    private void OnDragStart(DragEventArgs args, int suiteId)
    {
        _draggedSuiteId = suiteId;
    }

    private void OnDragOver(DragEventArgs args, int? folderId)
    {
        // args.PreventDefault();
        _dragOverFolderId = folderId;
    }

    private void OnDragLeave(DragEventArgs args)
    {
        _dragOverFolderId = null;
    }

    private async Task OnDrop(DragEventArgs args, int? folderId)
    {
        // args.PreventDefault();

        if (_draggedSuiteId is null)
        {
            _dragOverFolderId = null;
            return;
        }

        var suite = _suites.FirstOrDefault(s => s.Id == _draggedSuiteId);
        _draggedSuiteId = null;
        _dragOverFolderId = null;

        if (suite is null || suite.FolderId == folderId)
        {
            return;
        }

        await UpdateSuiteFolderAsync(suite, folderId);
    }

    private async Task UpdateSuiteFolderAsync(TestSuiteTemplateResponse suite, int? folderId)
    {
        try
        {
            var request = new UpdateTestSuiteTemplateRequest
            {
                Name = suite.Name,
                Description = suite.Description,
                FolderId = folderId,
                TestCaseTemplates = suite.TestCaseTemplates.Select(testCase => new UpdateTestCaseTemplateRequest
                {
                    Title = testCase.Title,
                    Priority = testCase.Priority,
                    TestStepTemplates = testCase.TestStepTemplates.Select(step => new UpdateTestStepTemplateRequest
                    {
                        StepNumber = step.StepNumber,
                        Action = step.Action,
                        TestData = step.TestData,
                        ExpectedResult = step.ExpectedResult
                    }).ToList()
                }).ToList()
            };

            var updated = await TestSuiteTemplateService.UpdateTestSuiteTemplateAsync(suite.Id, request);

            var index = _suites.FindIndex(item => item.Id == suite.Id);
            if (index >= 0)
            {
                _suites[index] = updated;
            }

            if (folderId.HasValue && !_folders.ContainsKey(folderId.Value))
            {
                _folders[folderId.Value] = $"Folder {folderId.Value}";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Unable to update folder. {ex.Message}";
        }
    }

    private async Task HandleCreateFolder()
    {
        if (string.IsNullOrWhiteSpace(_newFolderName))
        {
            return;
        }

        var name = _newFolderName.Trim();
        if (_folders.Values.Any(folder => string.Equals(folder, name, StringComparison.OrdinalIgnoreCase)))
        {
            _newFolderName = string.Empty;
            _isCreatingFolder = false;
            return;
        }

        var newId = _folders.Count == 0 ? 1 : _folders.Keys.Max() + 1;
        _folders[newId] = name;

        _newFolderName = string.Empty;
        _isCreatingFolder = false;
        _selectedFolderId = newId;

        await Task.CompletedTask;
    }

    private async Task DeleteFolder(MouseEventArgs args, int folderId)
    {
        // args.StopPropagation();

        var suitesToMove = _suites.Where(suite => suite.FolderId == folderId).ToList();
        foreach (var suite in suitesToMove)
        {
            await UpdateSuiteFolderAsync(suite, null);
        }

        _folders.Remove(folderId);

        if (_selectedFolderId == folderId)
        {
            _selectedFolderId = null;
        }
    }

    private void ChangePage(int delta)
    {
        _currentPage = Math.Clamp(_currentPage + delta, 1, TotalPages);
    }

    private void CloseSuiteForm()
    {
        _isSuiteFormOpen = false;
    }

    private async Task HandleSaveTestSuite((string Name, string? Description, int? FolderId, string? NewFolderName) form)
    {
        var folderId = form.FolderId;

        if (!string.IsNullOrWhiteSpace(form.NewFolderName))
        {
            var existingFolder = _folders.FirstOrDefault(item => string.Equals(item.Value, form.NewFolderName, StringComparison.OrdinalIgnoreCase));
            folderId = existingFolder.Key != 0 ? existingFolder.Key : null;

            if (!folderId.HasValue)
            {
                var newId = _folders.Count == 0 ? 1 : _folders.Keys.Max() + 1;
                _folders[newId] = form.NewFolderName.Trim();
                folderId = newId;
            }
        }

        try
        {
            var request = new CreateTestSuiteTemplateRequest
            {
                Name = form.Name.Trim(),
                Description = string.IsNullOrWhiteSpace(form.Description) ? null : form.Description.Trim(),
                FolderId = folderId
            };

            var created = await TestSuiteTemplateService.CreateTestSuiteTemplateAsync(request);
            _suites.Add(created);

            if (folderId.HasValue && !_folders.ContainsKey(folderId.Value))
            {
                _folders[folderId.Value] = $"Folder {folderId.Value}";
            }

            _isSuiteFormOpen = false;
        }
        catch (Exception ex)
        {
            _errorMessage = $"Unable to create suite template. {ex.Message}";
        }
    }
}



