            ? "group flex cursor-pointer items-center justify-between rounded-[50px] px-6 py-5 bg-[#121926] text-white shadow-md transition-all"
            : "group flex cursor-pointer items-center justify-between rounded-[50px] px-6 py-5 bg-white text-[#697586] shadow-sm transition-all hover:bg-slate-50";

    private string GetStarredIconClass() =>
        _showStarredOnly ? "text-yellow-300" : "text-[#697586]";

    // ========== PIXEL-PERFECT DESIGN CSS HELPERS (Based on Sketch) ==========
    
    /// <summary>
    /// Returns CSS classes for folder/category navigation items.
    /// Pixel-perfect design: #F3F5F9 (bg), #F8F9FB (surface), #1C1D2A (active), #2E5BFF (accent), #0F172A (text).
    /// Border-radius: 40px for ultimate modern look.
    /// </summary>
    private string GetPixelPerfectFolderClass(int? folderId)
    {
        bool isSelected;
        
        if (folderId == -1) // Special case for "My Starred"
        {
            isSelected = _showStarredOnly;
        }
        else if (!folderId.HasValue) // Uncategorized
        {
            isSelected = !_selectedFolderId.HasValue && !_showStarredOnly;
        }
        else // Regular folder
        {
            isSelected = _selectedFolderId == folderId && !_showStarredOnly;
        }
        
        var isDragOver = _dragOverFolderId == folderId;

        var baseClass = isSelected
            ? "cursor-pointer bg-[#1C1D2A] text-white shadow-md px-6 py-4"
            : "cursor-pointer bg-[#F8F9FB] text-[#0F172A] border border-[#e2e8f0] hover:border-[#2E5BFF] hover:shadow-md px-6 py-4";

        var dragClass = isDragOver ? "ring-2 ring-[#2E5BFF] ring-offset-2" : "";
        
        return $"group flex items-center justify-between transition-all duration-200 ease-in-out {baseClass} {dragClass} rounded-[40px]";
    }

    /// <summary>
    /// Returns CSS classes for count badges in pixel-perfect design based on sketch.
    /// Active: white text on dark background, Inactive: dark text on light background.
    /// </summary>
    private string GetPixelPerfectCountBadgeClass(bool isActive)
    {
        return isActive
            ? "flex h-7 w-auto min-w-[28px] items-center justify-center bg-white/20 px-3 text-[11px] font-bold text-white rounded-full"
            : "flex h-7 w-auto min-w-[28px] items-center justify-center bg-[#1C1D2A]/5 px-3 text-[11px] font-bold text-[#0F172A] rounded-full";
    }

    // Legacy methods for backward compatibility
    private string GetElegantFolderClass(int? folderId) => GetPixelPerfectFolderClass(folderId);
    private string GetElegantCountBadgeClass(bool isActive) => GetPixelPerfectCountBadgeClass(isActive);
    private string GetModernFolderClass(int? folderId) => GetPixelPerfectFolderClass(folderId);
    private string GetModernCountBadgeClass(bool isActive) => GetPixelPerfectCountBadgeClass(isActive);

    // ========== EXPORT/IMPORT ==========
    private async Task ExportTemplates()
    {
        try
        {
            var templatesToExport = FilteredSuites.Select(suite => new
            {
                suite.Id,
                suite.Name,
                suite.Description,
                suite.CategoryId,
                Category = suite.Category?.Name,
                Tags = suite.Tags.Select(t => t.TagName).ToList(),
                suite.IsPublic,
                TestCases = suite.TestCaseTemplates.Select(tc => new
                {
                    tc.Title,
                    tc.Priority,
                    Steps = tc.TestStepTemplates.Select(ts => new
                    {
                        ts.StepNumber,
                        ts.Action,
                        ts.TestData,
                        ts.ExpectedResult
                    }).ToList()
                }).ToList()
            }).ToList();

            var json = System.Text.Json.JsonSerializer.Serialize(templatesToExport, new System.Text.Json.JsonSerializerOptions
            {
                WriteIndented = true
            });

            var fileName = $"test-templates-{DateTime.Now:yyyy-MM-dd-HHmmss}.json";
            var bytes = System.Text.Encoding.UTF8.GetBytes(json);
            await JSRuntime.InvokeVoidAsync("downloadFileFromBytes", fileName, "application/json", bytes);
        }
        catch (Exception ex)
        {
            _errorMessage = $"Export failed: {ex.Message}";
        }
    }

    private async Task HandleFileImport(InputFileChangeEventArgs e)
    {
        try
        {
            var file = e.File;
            if (file == null) return;

            // Read file content
            using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024); // 10MB max
            using var reader = new System.IO.StreamReader(stream);
            var json = await reader.ReadToEndAsync();

            if (string.IsNullOrWhiteSpace(json))
            {
                _errorMessage = "File is empty.";
                return;
            }

            // Parse JSON
            var importedTemplates = System.Text.Json.JsonSerializer.Deserialize<List<ImportTemplateDto>>(json, new System.Text.Json.JsonSerializerOptions
            {
                PropertyNameCaseInsensitive = true
            });

            if (importedTemplates == null || !importedTemplates.Any())
            {
                _errorMessage = "No valid templates found in the file.";
                return;
            }

            // Import templates
            int successCount = 0;
            int failCount = 0;

            foreach (var template in importedTemplates)
            {
                try
                {
                    var request = new CreateTestSuiteTemplateRequest
                    {
                        Name = template.Name ?? "Imported Template",
                        Description = template.Description,
                        IsPublic = template.IsPublic,
                        CategoryId = template.CategoryId,
                        TestCaseTemplates = template.TestCases?.Select(tc => new CreateTestCaseTemplateRequest
                        {
                            Title = tc.Title ?? "Test Case",
                            Priority = Enum.TryParse<TestCasePriority>(tc.Priority, true, out var priority) ? priority : TestCasePriority.Medium,
                            TestStepTemplates = tc.Steps?.Select(ts => new CreateTestStepTemplateRequest
                            {
                                StepNumber = ts.StepNumber,
                                Action = ts.Action ?? "",
                                TestData = ts.TestData,
                                ExpectedResult = ts.ExpectedResult ?? ""
                            }).ToList() ?? new List<CreateTestStepTemplateRequest>()
                        }).ToList() ?? new List<CreateTestCaseTemplateRequest>()
                    };

                    var created = await TestSuiteTemplateService.CreateTestSuiteTemplateAsync(request);
                    _suites.Add(created);
                    successCount++;
                }
                catch
                {
                    failCount++;
                }
            }

            _errorMessage = null;
            await JSRuntime.InvokeVoidAsync("alert", $"Import completed!\nSuccess: {successCount}\nFailed: {failCount}");
        }
        catch (Exception ex)
        {
            _errorMessage = $"Import failed: {ex.Message}";
        }
    }

    // DTO for import
    private class ImportTemplateDto
    {
        public string? Name { get; set; }
        public string? Description { get; set; }
        public int? CategoryId { get; set; }
        public bool IsPublic { get; set; }
        public List<ImportTestCaseDto>? TestCases { get; set; }
    }

    private class ImportTestCaseDto
    {
        public string? Title { get; set; }
        public string? Priority { get; set; }
        public List<ImportTestStepDto>? Steps { get; set; }
    }

    private class ImportTestStepDto
    {
        public int StepNumber { get; set; }
        public string? Action { get; set; }
        public string? TestData { get; set; }
        public string? ExpectedResult { get; set; }
    }

    // ===== BULK OPERATIONS METHODS =====

    private void EnterSelectionMode()
    {
        _isSelectionMode = true;
        _selectedTemplateIds.Clear();
    }

    private void ExitSelectionMode()
    {
        _isSelectionMode = false;
        _selectedTemplateIds.Clear();
        _showBulkMoveDropdown = false;
        _showBulkDeleteConfirmation = false;
    }

    private void ToggleSelection(int id)
    {
        if (_selectedTemplateIds.Contains(id))
            _selectedTemplateIds.Remove(id);
        else
            _selectedTemplateIds.Add(id);
    }

    private bool IsSelected(int id) => _selectedTemplateIds.Contains(id);

    private void SelectAll()
    {
        _selectedTemplateIds.Clear();
        foreach (var suite in FilteredSuites)
        {
            _selectedTemplateIds.Add(suite.Id);
        }
    }

    private async Task HandleBulkMove(int? targetFolderId)
    {
        if (_selectedTemplateIds.Count == 0) return;

        try
        {
            _isLoading = true;
            _showBulkMoveDropdown = false;

            var (moved, failed) = await TestSuiteTemplateService.BulkMoveTemplatesAsync(
                _selectedTemplateIds.ToList(),
                targetFolderId
            );

            if (moved > 0)
            {
                _errorMessage = null;
                await LoadDataAsync();
                ExitSelectionMode();
                
                // Show success message in console (could use toast notification)
                Console.WriteLine($"✅ Successfully moved {moved} template(s)");
            }

            if (failed > 0)
            {
                _errorMessage = $"Failed to move {failed} template(s)";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Bulk move failed: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void OpenBulkDeleteConfirmation()
    {
        if (_selectedTemplateIds.Count == 0) return;
        _showBulkDeleteConfirmation = true;
    }

    private async Task ConfirmBulkDelete()
    {
        if (_selectedTemplateIds.Count == 0) return;

        try
        {
            _isLoading = true;
            _showBulkDeleteConfirmation = false;

            var (deleted, failed) = await TestSuiteTemplateService.BulkDeleteTemplatesAsync(
                _selectedTemplateIds.ToList()
            );

            if (deleted > 0)
            {
                _errorMessage = null;
                await LoadDataAsync();
                ExitSelectionMode();
                
                // Show success message in console (could use toast notification)
                Console.WriteLine($"✅ Successfully deleted {deleted} template(s)");
            }

            if (failed > 0)
            {
                _errorMessage = $"Failed to delete {failed} template(s)";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Bulk delete failed: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void CancelBulkDelete()
    {
        _showBulkDeleteConfirmation = false;
    }
}





