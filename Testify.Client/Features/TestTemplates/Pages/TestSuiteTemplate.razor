                <div class="mb-4">
                    <label class="mb-2 block text-xs font-bold uppercase tracking-wider text-[#9aa4b2]">Share Link</label>
                    <div class="flex items-center gap-2">
                        <input type="text"
                               readonly
                               value="@GetShareLink()"
                               class="flex-1 rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm font-medium text-[#697586]" />
                        <button @onclick="CopyShareLink"
                                class="rounded-xl bg-[#2e5bff] px-6 py-3 font-bold text-white transition-all hover:bg-[#1e4fef]">
                            @(_shareLinkCopied ? "Copied!" : "Copy")
