@code {
    private readonly List<TestSuiteTemplateResponse> _suites = new();
    private readonly Dictionary<int, string> _folders = new();
    private readonly HashSet<int> _starredSuites = new();
    private readonly List<CategoryResponse> _categories = new();
    private readonly List<TagResponse> _tags = new();

    private string _searchQuery = string.Empty;
    private string _sortOption = "name-asc";
    private string? _selectedCategoryId;
    private bool _isSuiteFormOpen;
    private bool _isCreatingFolder;
    private string _newFolderName = string.Empty;
    private bool _showStarredOnly;

    // Delete folder confirmation state
    private bool _showDeleteFolderConfirmation;
    private int? _deleteFolderTargetId;
    private string _deleteFolderTargetName = string.Empty;

    // Context menu state
    private bool _showContextMenu;
    private int _contextMenuX;
    private int _contextMenuY;
    private int _contextSuiteId;

    // Edit state
    private bool _isEditFormOpen;
    private TestSuiteTemplateResponse? _editingSuite;

    // Delete confirmation state
    private bool _showDeleteConfirmation;
    private int? _deleteTargetId;
    private string _deleteTargetName = string.Empty;

    // Share modal state
    private bool _showShareModal;
    private int? _shareTargetId;
    private bool _shareLinkCopied;

    private int? _selectedFolderId;
    private int? _draggedSuiteId;
    private int? _dragOverFolderId;

    private int _currentPage = 1;
    private const int PageSize = 6;

    private bool _isLoading = true;
    private string? _errorMessage;

    // Bulk operations state
    private bool _isSelectionMode;
    private readonly HashSet<int> _selectedTemplateIds = new();
    private bool _showBulkMoveDropdown;
    private bool _showBulkDeleteConfirmation;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
        await LoadStarredTemplatesAsync();

        var query = new Uri(Navigation.Uri).Query.TrimStart('?');
        var queryParams = query.Split('&', StringSplitOptions.RemoveEmptyEntries)
            .Select(p => p.Split('=', 2))
            .Where(p => p.Length == 2)
            .ToDictionary(p => Uri.UnescapeDataString(p[0]), p => Uri.UnescapeDataString(p[1]));

        if (queryParams.TryGetValue("editId", out var editIdStr) && int.TryParse(editIdStr, out var editId))
        {
            var suite = _suites.FirstOrDefault(s => s.Id == editId);
            if (suite != null)
            {
                _editingSuite = suite;
                _isEditFormOpen = true;
            }
        }
        else if (queryParams.TryGetValue("cloneId", out var cloneIdStr) && int.TryParse(cloneIdStr, out var cloneId))
        {
            var suite = _suites.FirstOrDefault(s => s.Id == cloneId);
            if (suite != null)
                await CloneSuite(suite.Id);
        }
    }

    private async Task LoadDataAsync()
    {
        _isLoading = true;
        _errorMessage = null;

        try
        {
            // Load data sequentially to avoid DbContext threading issues
            var folders = await TemplateFolderService.GetTemplateFoldersAsync();
            _folders.Clear();
            foreach (var folder in folders)
            {
                _folders[folder.Id] = folder.Name;
            }

            var suites = await TestSuiteTemplateService.GetTestSuiteTemplatesAsync();
            _suites.Clear();
            _suites.AddRange(suites);
            
            var categories = await CategoryService.GetAllCategoriesAsync();
            _categories.Clear();
            _categories.AddRange(categories);
            
            var tags = await TagService.GetAllTagsAsync();
            _tags.Clear();
            _tags.AddRange(tags);
        }
        catch (Exception ex)
        {
            _errorMessage = $"Unable to load data. {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadStarredTemplatesAsync()
    {
        try
        {
            var starredIds = await TemplateReviewService.GetStarredTemplateIdsAsync();
            _starredSuites.Clear();
            foreach (var id in starredIds)
            {
                _starredSuites.Add(id);
            }
        }
        catch
        {
            // Ignore errors loading starred templates
        }
    }

    private List<TestSuiteTemplateResponse> FilteredSuites
    {
        get
        {
            var filtered = _suites.AsEnumerable();

            // Apply starred filter first
            if (_showStarredOnly)
            {
                filtered = filtered.Where(suite => _starredSuites.Contains(suite.Id));
            }
            else
            {
                // Apply folder filter only when not showing starred
                filtered = filtered.Where(suite => 
                    !_selectedFolderId.HasValue ? !suite.FolderId.HasValue : suite.FolderId == _selectedFolderId);
            }

            // Apply category filter
            if (!string.IsNullOrEmpty(_selectedCategoryId))
            {
                if (int.TryParse(_selectedCategoryId, out var categoryId))
                {
                    filtered = filtered.Where(suite => suite.CategoryId == categoryId);
                }
            }

            // Apply search filter
            filtered = filtered.Where(suite => 
                string.IsNullOrWhiteSpace(_searchQuery) || 
                suite.Name.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase));

            // Apply sorting
            return _sortOption switch
            {
                "name-asc" => filtered.OrderBy(s => s.Name).ToList(),
                "name-desc" => filtered.OrderByDescending(s => s.Name).ToList(),
                "date-desc" => filtered.OrderByDescending(s => s.CreatedAt).ToList(),
                "date-asc" => filtered.OrderBy(s => s.CreatedAt).ToList(),
                "cases-desc" => filtered.OrderByDescending(s => s.TestCaseTemplates.Count).ToList(),
                "cases-asc" => filtered.OrderBy(s => s.TestCaseTemplates.Count).ToList(),
                _ => filtered.OrderBy(s => s.Name).ToList()
            };
        }
    }

    private IReadOnlyList<KeyValuePair<int, string>> PaginatedFolders => _folders
        .OrderBy(folder => folder.Value)
        .Skip((_currentPage - 1) * PageSize)
        .Take(PageSize)
        .ToList();

    private int TotalPages => _folders.Count == 0 ? 1 : (int)Math.Ceiling(_folders.Count / (double)PageSize);

    private void BuildFolderIndex()
    {
        foreach (var suite in _suites.Where(suite => suite.FolderId.HasValue))
        {
            var folderId = suite.FolderId!.Value;
            if (!_folders.ContainsKey(folderId))
            {
                _folders[folderId] = $"Folder {folderId}";
            }
        }
    }

    private void ClearSearch() => _searchQuery = string.Empty;

    private void SelectFolder(int? folderId)
    {
        _selectedFolderId = folderId;
        _showStarredOnly = false; // Clear starred filter when selecting folder
    }

    private void FilterByStarred()
    {
        _showStarredOnly = !_showStarredOnly;
        if (_showStarredOnly)
        {
            _selectedFolderId = null; // Clear folder selection when showing starred
        }
    }

    private async void SelectSuite(TestSuiteTemplateResponse suite)
    {
        await TestSuiteTemplateService.IncrementViewCountAsync(suite.Id);
        suite.ViewCount++;
        Navigation.NavigateTo($"/testsuites/{suite.Id}");
    }

    private void OnDragStart(DragEventArgs args, int suiteId)
    {
        _draggedSuiteId = suiteId;
    }

    private void OnDragOver(DragEventArgs args, int? folderId)
    {
        _dragOverFolderId = folderId;
    }

    private void OnDragLeave(DragEventArgs args)
    {
        _dragOverFolderId = null;
    }

    private async Task OnDrop(DragEventArgs args, int? folderId)
    {
        if (_draggedSuiteId is null)
        {
            _dragOverFolderId = null;
            return;
        }

        var suite = _suites.FirstOrDefault(s => s.Id == _draggedSuiteId);
        _draggedSuiteId = null;
        _dragOverFolderId = null;

        if (suite is null || suite.FolderId == folderId)
        {
            return;
        }

        await UpdateSuiteFolderAsync(suite, folderId);
    }

    private async Task UpdateSuiteFolderAsync(TestSuiteTemplateResponse suite, int? folderId)
    {
        try
        {
            var request = new UpdateTestSuiteTemplateRequest
            {
                Name = suite.Name,
                Description = suite.Description,
                FolderId = folderId,
                TestCaseTemplates = suite.TestCaseTemplates.Select(testCase => new UpdateTestCaseTemplateRequest
                {
                    Title = testCase.Title,
                    Priority = testCase.Priority,
                    TestStepTemplates = testCase.TestStepTemplates.Select(step => new UpdateTestStepTemplateRequest
                    {
                        StepNumber = step.StepNumber,
                        Action = step.Action,
                        TestData = step.TestData,
                        ExpectedResult = step.ExpectedResult
                    }).ToList()
                }).ToList()
            };

            var updated = await TestSuiteTemplateService.UpdateTestSuiteTemplateAsync(suite.Id, request);

            var index = _suites.FindIndex(item => item.Id == suite.Id);
            if (index >= 0)
            {
                _suites[index] = updated;
            }

            if (folderId.HasValue && !_folders.ContainsKey(folderId.Value))
            {
                _folders[folderId.Value] = $"Folder {folderId.Value}";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Unable to update folder. {ex.Message}";
        }
    }

    private async Task HandleCreateFolder()
    {
        if (string.IsNullOrWhiteSpace(_newFolderName))
        {
            return;
        }
        try
        {
            var request = new CreateTemplateFolderRequest
            {
                Name = _newFolderName.Trim()
            };

            var created = await TemplateFolderService.CreateTemplateFolderAsync(request);
            _folders[created.Id] = created.Name;
            _newFolderName = string.Empty;
            _isCreatingFolder = false;
        }
        catch (Exception ex)
        {
            _errorMessage = $"Unable to create folder. {ex.Message}";
		}

    }

    private void OpenDeleteFolderConfirmation(int folderId, string folderName)
    {
        _deleteFolderTargetId = folderId;
        _deleteFolderTargetName = folderName;
        _showDeleteFolderConfirmation = true;
    }

    private void CloseDeleteFolderConfirmation()
    {
        _showDeleteFolderConfirmation = false;
        _deleteFolderTargetId = null;
        _deleteFolderTargetName = string.Empty;
    }

    private async Task ConfirmDeleteFolder()
    {
        if (!_deleteFolderTargetId.HasValue) return;

        try
        {
            var folderId = _deleteFolderTargetId.Value;

            // Move all suites in this folder to Uncategorized
            var suitesToMove = _suites.Where(suite => suite.FolderId == folderId).ToList();
            foreach (var suite in suitesToMove)
            {
                await UpdateSuiteFolderAsync(suite, null);
            }

            // Delete folder via API
            var deleted = await TemplateFolderService.DeleteTemplateFolderAsync(folderId);
            
            if (deleted)
            {
                _folders.Remove(folderId);

                if (_selectedFolderId == folderId)
                {
                    _selectedFolderId = null;
                }
            }
            else
            {
                _errorMessage = $"Cannot delete folder \"@_deleteFolderTargetName\". Please remove any subfolders first, then try again.";
            }

            CloseDeleteFolderConfirmation();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Unable to delete folder. {ex.Message}";
            CloseDeleteFolderConfirmation();
        }
    }

    private void ChangePage(int delta)
    {
        _currentPage = Math.Clamp(_currentPage + delta, 1, TotalPages);
    }

    private void CloseSuiteForm()
    {
        _isSuiteFormOpen = false;
    }

    private async Task HandleSaveTestSuite(CreateTestSuiteTemplateRequest request)
    {
        var folderId = request.FolderId;

        // Handle new folder creation if specified
        if (!string.IsNullOrWhiteSpace(request.NewFolderName))
        {
            // Check if folder already exists locally
            var existingFolder = _folders.FirstOrDefault(item =>
                string.Equals(item.Value, request.NewFolderName, StringComparison.OrdinalIgnoreCase));

            if (existingFolder.Key != 0)
            {
                // Use existing folder
                folderId = existingFolder.Key;
            }
            else
            {
                // Create new folder via API
                try
                {
                    var folderRequest = new CreateTemplateFolderRequest
                    {
                        Name = request.NewFolderName.Trim()
                    };
                    var createdFolder = await TemplateFolderService.CreateTemplateFolderAsync(folderRequest);
                    _folders[createdFolder.Id] = createdFolder.Name;
                    folderId = createdFolder.Id;
                }
                catch (Exception ex)
                {
                    _errorMessage = $"Unable to create folder. {ex.Message}";
                    return;
                }
            }
        }

        try
        {
            request.FolderId = folderId;

            var created = await TestSuiteTemplateService.CreateTestSuiteTemplateAsync(request);
            _suites.Add(created);

            if (created.FolderId.HasValue && !_folders.ContainsKey(created.FolderId.Value))
            {
                _folders[created.FolderId.Value] = $"Folder {created.FolderId.Value}";
            }

            _isSuiteFormOpen = false;
        }
        catch (Exception ex)
        {
            _errorMessage = $"Unable to create suite template. {ex.Message}";
        }
    }


    // ========== EDIT FUNCTIONALITY ==========
    private void OpenEditModal(TestSuiteTemplateResponse suite)
    {
        _editingSuite = suite;
        _isEditFormOpen = true;
    }

    private void CloseEditForm()
    {
        _isEditFormOpen = false;
        _editingSuite = null;
    }

    private async Task HandleUpdateTestSuite(CreateTestSuiteTemplateRequest request)
    {
        if (_editingSuite == null) return;

        try
        {
            var updateRequest = new UpdateTestSuiteTemplateRequest
            {
                Name = request.Name,
                Description = request.Description,
                FolderId = request.FolderId,
                IsPublic = request.IsPublic,
                CategoryId = request.CategoryId,
                TagIds = request.TagIds,
                TestCaseTemplates = request.TestCaseTemplates.Select(tc => new UpdateTestCaseTemplateRequest
                {
                    Title = tc.Title,
                    Priority = tc.Priority,
                    TestStepTemplates = tc.TestStepTemplates.Select(st => new UpdateTestStepTemplateRequest
                    {
                        StepNumber = st.StepNumber,
                        Action = st.Action,
                        TestData = st.TestData,
                        ExpectedResult = st.ExpectedResult
                    }).ToList()
                }).ToList()
            };

            var updated = await TestSuiteTemplateService.UpdateTestSuiteTemplateAsync(_editingSuite.Id, updateRequest);
            
            var index = _suites.FindIndex(s => s.Id == _editingSuite.Id);
            if (index >= 0)
            {
                _suites[index] = updated;
            }

            _isEditFormOpen = false;
            _editingSuite = null;
        }
        catch (Exception ex)
        {
            _errorMessage = $"Unable to update suite template. {ex.Message}";
        }
    }

    // ========== DELETE FUNCTIONALITY ==========
    private void OpenDeleteConfirmation(int suiteId, string suiteName)
    {
        _deleteTargetId = suiteId;
        _deleteTargetName = suiteName;
        _showDeleteConfirmation = true;
    }

    private void CloseDeleteConfirmation()
    {
        _showDeleteConfirmation = false;
        _deleteTargetId = null;
        _deleteTargetName = string.Empty;
    }

    private async Task ConfirmDelete()
    {
        if (!_deleteTargetId.HasValue) return;

        try
        {
            var deleted = await TestSuiteTemplateService.DeleteTestSuiteTemplateAsync(_deleteTargetId.Value);
            if (deleted)
            {
                _suites.RemoveAll(s => s.Id == _deleteTargetId.Value);
                _starredSuites.Remove(_deleteTargetId.Value);
            }

            CloseDeleteConfirmation();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Unable to delete suite template. {ex.Message}";
            CloseDeleteConfirmation();
        }
    }

    // ========== CLONE TEMPLATE FUNCTIONALITY ==========
    private async Task CloneSuite(int suiteId)
    {
        try
        {
            var originalSuite = _suites.FirstOrDefault(s => s.Id == suiteId);
            if (originalSuite == null)
            {
                _errorMessage = "Template not found.";
                return;
            }

            // Increment clone count for original template
            await TestSuiteTemplateService.IncrementCloneCountAsync(suiteId);
            originalSuite.CloneCount++;

            // Create cloned template with "Copy of" prefix
            var cloneRequest = new CreateTestSuiteTemplateRequest
            {
                Name = $"Copy of {originalSuite.Name}",
                Description = originalSuite.Description,
                FolderId = originalSuite.FolderId,
                CategoryId = originalSuite.CategoryId,
                IsPublic = false, // Clones are private by default
                TagIds = originalSuite.Tags.Select(t => t.Id).ToList(),
                TestCaseTemplates = originalSuite.TestCaseTemplates.Select(tc => new CreateTestCaseTemplateRequest
                {
                    Title = tc.Title,
                    Priority = tc.Priority,
                    TestStepTemplates = tc.TestStepTemplates.Select(ts => new CreateTestStepTemplateRequest
                    {
                        StepNumber = ts.StepNumber,
                        Action = ts.Action,
                        TestData = ts.TestData,
                        ExpectedResult = ts.ExpectedResult
                    }).ToList()
                }).ToList()
            };

            var clonedSuite = await TestSuiteTemplateService.CreateTestSuiteTemplateAsync(cloneRequest);
            _suites.Add(clonedSuite);

            // Show success message
            await JSRuntime.InvokeVoidAsync("alert", $"Template cloned successfully!\n\nOriginal: {originalSuite.Name}\nClone: {clonedSuite.Name}");
            
            _errorMessage = null;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Unable to clone template. {ex.Message}";
        }
    }

    // ========== STAR/FAVORITE FUNCTIONALITY ==========
    private bool IsStarred(int suiteId) => _starredSuites.Contains(suiteId);

    private async Task ToggleStar(int suiteId)
    {
        try
        {
            if (_starredSuites.Contains(suiteId))
            {
                await TemplateReviewService.UnstarTemplateAsync(suiteId);
                _starredSuites.Remove(suiteId);
            }
            else
            {
                await TemplateReviewService.StarTemplateAsync(suiteId);
                _starredSuites.Add(suiteId);
            }
            StateHasChanged();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Unable to update star. {ex.Message}";
        }
    }

    // ========== SHARE FUNCTIONALITY ==========
    private void OpenShareModal(int suiteId)
    {
        _shareTargetId = suiteId;
        _showShareModal = true;
        _shareLinkCopied = false;
    }

    private void CloseShareModal()
    {
        _showShareModal = false;
        _shareTargetId = null;
        _shareLinkCopied = false;
    }

    private string GetShareLink()
    {
        if (!_shareTargetId.HasValue) return string.Empty;
        var suite = _suites.FirstOrDefault(s => s.Id == _shareTargetId.Value);
        var baseUrl = Navigation.BaseUri.TrimEnd('/');
        // If the suite is public, link to Marketplace; otherwise link to the library view
        if (suite?.IsPublic == true)
            return $"{baseUrl}/marketplace?template={_shareTargetId}";
        return $"{baseUrl}/test-templates/suite-library?highlight={_shareTargetId}";
    }

    private async Task CopyShareLink()
    {
        try
        {
            var link = GetShareLink();
            await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", link);
            _shareLinkCopied = true;
            await Task.Delay(2000);
            _shareLinkCopied = false;
        }
        catch (Exception ex)
        {
            _errorMessage = $"Copy failed: {ex.Message}";
        }
    }

    // ========== CONTEXT MENU ==========
    private void ShowContextMenu(MouseEventArgs e, int suiteId)
    {
        _contextSuiteId = suiteId;
        _contextMenuX = (int)e.ClientX;
        _contextMenuY = (int)e.ClientY;
        _showContextMenu = true;
    }

    private void HideContextMenu()
    {
        _showContextMenu = false;
    }

    private bool GetSuitePublicStatus(int suiteId)
    {
        var suite = _suites.FirstOrDefault(s => s.Id == suiteId);
        return suite?.IsPublic ?? false;
    }

    private async Task TogglePublic(int suiteId)
    {
        try
        {
            var suite = _suites.FirstOrDefault(s => s.Id == suiteId);
            if (suite == null) return;

            var updateRequest = new UpdateTestSuiteTemplateRequest
            {
                Name = suite.Name,
                Description = suite.Description,
                FolderId = suite.FolderId,
                CategoryId = suite.CategoryId,
                IsPublic = !suite.IsPublic,
                TagIds = suite.Tags.Select(t => t.Id).ToList(),
                TestCaseTemplates = suite.TestCaseTemplates.Select(tc => new UpdateTestCaseTemplateRequest
                {
                    Title = tc.Title,
                    Priority = tc.Priority,
                    TestStepTemplates = tc.TestStepTemplates.Select(ts => new UpdateTestStepTemplateRequest
                    {
                        StepNumber = ts.StepNumber,
                        Action = ts.Action,
                        TestData = ts.TestData,
                        ExpectedResult = ts.ExpectedResult
                    }).ToList()
                }).ToList()
            };

            await TestSuiteTemplateService.UpdateTestSuiteTemplateAsync(suite.Id, updateRequest);
            suite.IsPublic = !suite.IsPublic;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Unable to toggle public status. {ex.Message}";
        }
    }

    private string GetSuiteCardClass(TestSuiteTemplateResponse suite)
