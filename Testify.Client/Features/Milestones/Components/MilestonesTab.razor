@using Testify.Shared.DTOs.Milestones
@using Testify.Client.Features.Milestones.Services
@using Testify.Client.Features.Milestones.Components
@using Testify.Client.Interfaces
@using static Testify.Shared.Enums.MilestoneEnum
@inject IMilestoneService MilestoneService

<div class="animate-in fade-in space-y-8 duration-500">
    @* --- HEADER & ACTIONS --- *@
    <div class="flex flex-col justify-between gap-6 md:flex-row md:items-center">
        <div>
            <h2 class="text-2xl font-extrabold text-slate-900">Project Milestones</h2>
            <p class="text-sm font-medium text-slate-500">Track key deliverables and deadlines.</p>
        </div>
        
        <div class="flex items-center gap-4">
            @* Filter Tabs *@
            <div class="flex rounded-xl bg-slate-100 p-1">
                @foreach (var filter in new[] { "All", "Active", "Completed" })
                {
                    <button @onclick="() => activeFilter = filter" 
                            class="@(activeFilter == filter ? "bg-white text-slate-900 shadow-sm" : "text-slate-500 hover:text-slate-700") rounded-lg px-4 py-1.5 text-xs font-bold transition-all">
                        @filter
                    </button>
                }
            </div>

            @* Add Button *@
            <button @onclick="OpenCreateDialog" class="flex items-center gap-2 rounded-xl bg-slate-900 px-5 py-2.5 text-xs font-bold text-white shadow-lg shadow-slate-900/10 transition-all hover:bg-[#E85D3F] hover:shadow-[#E85D3F]/20">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
                Add Milestone
            </button>
        </div>
    </div>

    @* --- MILESTONE LIST --- *@
    @if (isLoading)
    {
        <div class="space-y-4">
            @for(int i=0; i<3; i++) {
                <div class="h-32 w-full animate-pulse rounded-3xl bg-slate-100"></div>
            }
        </div>
    }
    else if (filteredMilestones == null || !filteredMilestones.Any())
    {
        <div class="flex flex-col items-center justify-center rounded-[32px] border border-dashed border-slate-200 bg-slate-50/50 p-16 text-center">
            <div class="mb-4 flex h-16 w-16 items-center justify-center rounded-2xl bg-white text-slate-300 shadow-sm">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" x2="4" y1="22" y2="15"/></svg>
            </div>
            <h3 class="text-lg font-bold text-slate-900">No milestones found</h3>
            <p class="text-sm text-slate-500">@(activeFilter == "All" ? "Create your first milestone to get started." : $"No {activeFilter.ToLower()} milestones found.")</p>
        </div>
    }
    else
    {
        <div class="space-y-4">
            @foreach (var milestone in filteredMilestones)
            {
                <div class="group relative flex flex-col gap-6 overflow-hidden rounded-3xl border border-slate-100 bg-white p-6 shadow-sm transition-all hover:shadow-md md:flex-row md:items-center">
                   
                    @* Left: Status & Info *@
                    <div class="flex-1 space-y-3">
                        <div class="flex items-center gap-3">
                             <span class="@(milestone.Status == MilestoneStatus.Completed ? "bg-emerald-100 text-emerald-700" : "bg-orange-100 text-orange-700") rounded-full px-3 py-1 font-extrabold tracking-wide text-[10px] uppercase">
								@milestone.Status 
                            </span>
                        </div>
                        <div>
                             <h3 class="text-lg font-extrabold text-slate-900 transition-colors group-hover:text-[#E85D3F]">@milestone.Name</h3>
                             <p class="line-clamp-1 text-sm font-medium text-slate-500">@milestone.Description</p>
                        </div>
                    </div>

                    @* Middle: Metrics *@
                    <div class="flex shrink-0 gap-8 md:w-1/3">
                        <div class="space-y-1">
                            <p class="font-bold tracking-widest text-[10px] text-slate-400 uppercase">Tasks</p>
                            <div class="flex items-center gap-2">
                                <span class="text-sm font-bold text-slate-700">0/0</span>
                                @* <span class="text-xs font-medium text-slate-400">Done</span> *@
                            </div>
                        </div>
                        <div class="space-y-1">
                            <p class="font-bold tracking-widest text-[10px] text-slate-400 uppercase">Timeline</p>
                            <p class="text-sm font-bold text-slate-700">@milestone.EndDate.ToString("MMM dd")</p>
                        </div>
                        <div class="w-full max-w-[100px] space-y-1">
                             <p class="font-bold tracking-widest text-[10px] text-slate-400 uppercase">Progress</p>
                             <div class="h-1.5 w-full overflow-hidden rounded-full bg-slate-100">
                                <div class="h-full bg-[#E85D3F]" style="width: 0%"></div>
                             </div>
                        </div>
                    </div>

                    @* Right: Actions *@
                    <div class="flex shrink-0 items-center gap-3 border-t border-slate-50 pt-4 md:border-t-0 md:border-l md:pt-0 md:pl-6">
                        @if (milestone.Status != MilestoneStatus.Completed)
                        {
                            <button @onclick="() => CloseMilestone(milestone)" class="rounded-xl border border-slate-200 bg-slate-50 px-4 py-2 text-xs font-bold text-slate-600 transition-all hover:bg-slate-100 hover:text-slate-900">
                                Complete
                            </button>
                        }
                        
                         <button @onclick="() => OpenEditDialog(milestone)" class="rounded-full bg-slate-100 p-2 text-slate-400 transition-all hover:bg-[#E85D3F] hover:text-white">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                        </button>
                    </div>
                </div>
            }
        </div>
    }

    <MilestoneForm Show="showModal" Milestone="editingMilestone" OnSave="SaveMilestone" OnCancel="CloseModal" />
</div>

@code {
    [Parameter] public int ProjectId { get; set; }

    private List<MilestoneResponse>? milestones;
    private bool isLoading = true;
    private string activeFilter = "All";
    
    // Form State
    private bool showModal = false;
    private MilestoneResponse editingMilestone = new();

    private IEnumerable<MilestoneResponse>? filteredMilestones =>
        milestones?
        .Where(m => 
            activeFilter == "All" ||
            (activeFilter == "Active" && m.Status != MilestoneStatus.Completed) ||
            (activeFilter == "Completed" && m.Status == MilestoneStatus.Completed)
        );

    protected override async Task OnInitializedAsync()
    {
        await LoadMilestones();
    }

    private async Task LoadMilestones()
    {
        isLoading = true;
        try
        {
            milestones = await MilestoneService.GetMilestonesByProjectAsync(ProjectId);
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
        }
        finally
        {
            isLoading = false;
        }
    }

    private void OpenCreateDialog()
    {
        editingMilestone = new MilestoneResponse 
        { 
            ProjectId = ProjectId,
             StartDate = DateTime.Today,
            EndDate = DateTime.Today.AddDays(7)
        };
        showModal = true;
    }

    private void OpenEditDialog(MilestoneResponse milestone)
    {
        editingMilestone = new MilestoneResponse
        {
            Id = milestone.Id,
            ProjectId = milestone.ProjectId,
            Name = milestone.Name,
            Description = milestone.Description,
            StartDate = milestone.StartDate,
            EndDate = milestone.EndDate,
            Status = milestone.Status
        };
        showModal = true;
    }

    private void CloseModal() => showModal = false;

    private async Task SaveMilestone()
    {
        if (editingMilestone.Id == 0)
        {
            var createDTO = new CreateMilestoneRequest
            {
                ProjectId = editingMilestone.ProjectId,
                Name = editingMilestone.Name,
                Description = editingMilestone.Description,
                StartDate = editingMilestone.StartDate,
                EndDate = editingMilestone.EndDate
            };
            await MilestoneService.CreateMilestoneAsync(createDTO);
        }
        else
        {
            var updateDTO = new UpdateMilestoneRequest
            {
                Id = editingMilestone.Id,
                Name = editingMilestone.Name,
                Description = editingMilestone.Description,
                StartDate = editingMilestone.StartDate,
                EndDate = editingMilestone.EndDate,
                Status = editingMilestone.Status
            };
            await MilestoneService.UpdateMilestoneAsync(updateDTO);
        }
        showModal = false;
        await LoadMilestones();
    }

    private async Task CloseMilestone(MilestoneResponse milestone)
    {
        // Simple status update for now
        var updateDTO = new UpdateMilestoneRequest
        {
            Id = milestone.Id,
            Name = milestone.Name,
            Description = milestone.Description,
            StartDate = milestone.StartDate,
            EndDate = milestone.EndDate,
            Status = MilestoneStatus.Completed
        };
        await MilestoneService.UpdateMilestoneAsync(updateDTO);
        await LoadMilestones();
    }
}
