@using Testify.Shared.DTOs.Milestones

<div class="group relative flex flex-col justify-between overflow-hidden rounded-[40px] bg-white p-7 shadow-sm transition-all duration-300 hover:shadow-2xl hover:shadow-slate-200/50 border border-slate-50 h-full">
    
    @* Top Accent Bar *@
    <div class="absolute top-0 left-0 w-full h-1.5 @GetStatusColor(Milestone.Status)"></div>

    <div>
        <div class="mb-6 flex items-start justify-between">
            <span class="inline-flex items-center rounded-full px-3 py-1 text-[10px] font-extrabold uppercase tracking-widest @GetStatusBadgeColor(Milestone.Status)">
                @Milestone.Status
            </span>
            
            <div class="relative">
                <button @onclick="ToggleMenu" @onfocusout="CloseMenuAsync" class="flex h-8 w-8 items-center justify-center rounded-full text-slate-300 transition-all hover:bg-slate-50 hover:text-slate-900">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="1" /><circle cx="12" cy="5" r="1" /><circle cx="12" cy="19" r="1" /></svg>
                </button>
                
                @if (isMenuOpen)
                {
                    <div class="absolute top-8 right-0 z-10 w-40 origin-top-right rounded-2xl border border-slate-100 bg-white p-1.5 shadow-xl ring-1 ring-slate-900/5 animate-in fade-in zoom-in-95 duration-100">
                         <button @onclick="EditMilestone" @onmousedown:preventDefault class="w-full text-left px-3 py-2 text-xs font-bold text-slate-700 hover:bg-slate-50 rounded-xl flex items-center gap-2 transition-colors">
                            Edit
                        </button>
                        <button @onclick="DeleteMilestone" @onmousedown:preventDefault class="w-full text-left px-3 py-2 text-xs font-bold text-rose-600 hover:bg-rose-50 rounded-xl flex items-center gap-2 transition-colors">
                            Delete
                        </button>
                    </div>
                }
            </div>
        </div>

        <h3 class="mb-3 text-2xl font-black text-slate-900 leading-tight tracking-tight group-hover:text-[#E85D3F] transition-colors">
            @Milestone.Name
        </h3>

        <p class="mb-8 line-clamp-2 text-sm font-medium leading-relaxed text-slate-500">
            @(string.IsNullOrEmpty(Milestone.Description) ? "No description provided." : Milestone.Description)
        </p>

        @* Stats Grid *@
        <div class="grid grid-cols-2 gap-4 mb-6">
            <div class="rounded-3xl bg-slate-50 p-4">
                <p class="mb-1 text-[9px] font-black uppercase tracking-widest text-slate-400">Tasks</p>
                <p class="text-xl font-black text-slate-900">0<span class="text-slate-400">/0</span></p>
            </div>
             <div class="rounded-3xl bg-slate-50 p-4">
                <p class="mb-1 text-[9px] font-black uppercase tracking-widest text-slate-400">Timeline</p>
                <p class="text-sm font-bold text-slate-900">@Milestone.EndDate.ToString("dd/MM/yyyy")</p>
            </div>
        </div>
    </div>

    @* Footer *@
    <div class="mt-auto flex items-center justify-between border-t border-slate-50 pt-6">
        @if (Milestone.Status != "Completed")
        {
             <button class="rounded-[20px] bg-[#1C1D2A] px-5 py-2.5 text-xs font-bold text-white shadow-lg shadow-slate-900/10 transition-all hover:bg-slate-800 disabled:opacity-50 disabled:cursor-not-allowed" disabled>
                Close Milestone
            </button>
        }
        else
        {
            <span class="rounded-[20px] bg-emerald-100 px-5 py-2.5 text-xs font-bold text-emerald-700">
                Completed
            </span>
        }

        <button @onclick="EditMilestone" class="flex h-10 w-10 items-center justify-center rounded-full border border-slate-200 bg-white text-slate-400 shadow-sm transition-all hover:border-[#E85D3F] hover:text-[#E85D3F]">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14" /><path d="m12 5 7 7-7 7" /></svg>
        </button>
    </div>
    @if (Milestone.Status != "Completed")
    {
        <p class="mt-3 text-center text-[10px] font-bold text-[#E85D3F]/80">Complete all tasks to close</p>
    }

</div>

@code {
    [Parameter] public MilestoneDTO Milestone { get; set; } = default!;
    [Parameter] public EventCallback<MilestoneDTO> OnEdit { get; set; }
    [Parameter] public EventCallback<MilestoneDTO> OnDelete { get; set; }

    private bool isMenuOpen = false;

    private void ToggleMenu()
    {
        isMenuOpen = !isMenuOpen;
    }

    private async Task CloseMenuAsync()
    {
        // Small delay to allow click events on menu items to register before the menu closes
        await Task.Delay(150);
        isMenuOpen = false;
    }

    private async Task EditMilestone()
    {
        // Don't close immediately to avoid UI glitch, parent will handle dialog
        isMenuOpen = false;
        await OnEdit.InvokeAsync(Milestone);
    }

    private async Task DeleteMilestone()
    {
        isMenuOpen = false;
        await OnDelete.InvokeAsync(Milestone);
    }

    private string GetStatusColor(string status)
    {
        return status switch
        {
            "Completed" => "bg-blue-500",
            "Active" => "bg-emerald-500",
            "OnHold" => "bg-amber-500",
            "Planned" => "bg-indigo-500",
            "Closed" => "bg-slate-400",
            _ => "bg-slate-300"
        };
    }

    private string GetStatusBadgeColor(string status)
    {
        return status switch
        {
            "Completed" => "bg-blue-50 text-blue-700 ring-1 ring-blue-600/10",
            "Active" => "bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/10",
            "OnHold" => "bg-amber-50 text-amber-700 ring-1 ring-amber-600/10",
            "Planned" => "bg-indigo-50 text-indigo-700 ring-1 ring-indigo-600/10",
            "Closed" => "bg-slate-100 text-slate-600 ring-1 ring-slate-500/10",
             _ => "bg-slate-50 text-slate-600 ring-1 ring-slate-400/10"
        };
    }
}
