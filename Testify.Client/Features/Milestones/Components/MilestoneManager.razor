@using Testify.Shared.DTOs.Milestones
@using Testify.Client.Features.Milestones.Services
@using Testify.Client.Features.Milestones.Components
@using Testify.Client.Interfaces
@inject IMilestoneService MilestoneService

<div class="space-y-8 animate-in fade-in duration-500">
    @* --- HEADER & ACTIONS --- *@
    <div class="flex flex-col justify-between gap-6 md:flex-row md:items-end">
        <div>
            <h2 class="text-3xl font-black text-slate-900 tracking-tight">Project Milestones</h2>
            <p class="mt-2 font-medium text-slate-500">Track key deliverables, timelines, and release cycles.</p>
        </div>
        
        <div class="flex items-center gap-6">
            @* Stats Card (Visual Placeholder) *@
            <div class="hidden md:flex items-center gap-4 rounded-[32px] bg-white px-6 py-3 shadow-sm border border-slate-50">
                <div class="flex flex-col">
                    <span class="text-[10px] font-black uppercase tracking-widest text-slate-400">Total</span>
                    <span class="text-xl font-black text-slate-900">@milestones?.Count</span>
                </div>
                <div class="h-8 w-[1px] bg-slate-100"></div>
                <div class="flex flex-col">
                    <span class="text-[10px] font-black uppercase tracking-widest text-[#E85D3F]">Active</span>
                    <span class="text-xl font-black text-[#E85D3F]">@milestones?.Count(m => m.Status != "Completed")</span>
                </div>
            </div>

            @* Add Button *@
            <button @onclick="OpenCreateDialog" class="flex items-center gap-2 rounded-[32px] bg-[#1C1D2A] px-8 py-4 text-xs font-bold text-white shadow-xl shadow-slate-900/10 transition-all hover:bg-[#E85D3F] hover:shadow-[#E85D3F]/20 hover:-translate-y-0.5">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
                New Milestone
            </button>
        </div>
    </div>

    @* --- FILTER BAR --- *@
    <div class="flex w-fit items-center rounded-[32px] bg-white/50 p-2 shadow-sm backdrop-blur-md border border-white">
        @foreach (var filter in new[] { "All", "Active", "Completed" })
        {
            <button @onclick="() => activeFilter = filter" 
                    class="@(activeFilter == filter ? "bg-white text-slate-900 shadow-md" : "text-slate-500 hover:text-slate-800") rounded-[24px] px-6 py-2.5 text-xs font-bold transition-all duration-300">
                @filter
            </button>
        }
    </div>

    @* --- MILESTONE GRID --- *@
    @if (isLoading)
    {
        <div class="grid grid-cols-1 gap-8 md:grid-cols-2 xl:grid-cols-3">
            @for(int i=0; i<3; i++) {
                <div class="h-[300px] w-full animate-pulse rounded-[48px] bg-slate-100"></div>
            }
        </div>
    }
    else if (filteredMilestones == null || !filteredMilestones.Any())
    {
        <div class="flex flex-col items-center justify-center rounded-[48px] border-2 border-dashed border-slate-200 bg-slate-50/50 p-24 text-center">
            <div class="mb-6 flex h-20 w-20 items-center justify-center rounded-[32px] bg-white shadow-sm text-slate-300">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" x2="4" y1="22" y2="15"/></svg>
            </div>
            <h3 class="text-xl font-black text-slate-900">No milestones found</h3>
            <p class="mt-2 max-w-xs text-sm font-medium text-slate-500">@(activeFilter == "All" ? "Start by creating your first project milestone." : $"No {activeFilter.ToLower()} milestones matches your filter.")</p>
            @if(activeFilter == "All") {
                 <button @onclick="OpenCreateDialog" class="mt-6 font-bold text-[#E85D3F] hover:underline">Create Now</button>
            }
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 gap-8 md:grid-cols-2 xl:grid-cols-3">
            @foreach (var milestone in filteredMilestones)
            {
                <MilestoneCard Milestone="milestone" OnEdit="OpenEditDialog" OnDelete="DeleteMilestone"  />
            }
        </div>
    }

    <MilestoneForm Show="showModal" Milestone="editingMilestone" OnSave="SaveMilestone" OnCancel="CloseModal" />
</div>

@code {
    [Parameter] public int ProjectId { get; set; }

    private List<MilestoneDTO>? milestones;
    private bool isLoading = true;
    private string activeFilter = "All";
    
    // Form State
    private bool showModal = false;
    private MilestoneDTO editingMilestone = new();

    private IEnumerable<MilestoneDTO>? filteredMilestones =>
        milestones?
        .Where(m => 
            activeFilter == "All" ||
            (activeFilter == "Active" && m.Status != "Completed") ||
            (activeFilter == "Completed" && m.Status == "Completed")
        );

    protected override async Task OnInitializedAsync()
    {
        await LoadMilestones();
    }

    private async Task LoadMilestones()
    {
        isLoading = true;
        try
        {
            milestones = await MilestoneService.GetMilestonesByProjectAsync(ProjectId);
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
        }
        finally
        {
            isLoading = false;
        }
    }

    private void OpenCreateDialog()
    {
        editingMilestone = new MilestoneDTO 
        { 
            ProjectId = ProjectId,
             StartDate = DateTime.Today,
            EndDate = DateTime.Today.AddDays(7),
            Status = "Active"
        };
        showModal = true;
    }

    private void OpenEditDialog(MilestoneDTO milestone)
    {
        editingMilestone = new MilestoneDTO
        {
            Id = milestone.Id,
            ProjectId = milestone.ProjectId,
            Name = milestone.Name,
            Description = milestone.Description,
            StartDate = milestone.StartDate,
            EndDate = milestone.EndDate,
            Status = milestone.Status
        };
        showModal = true;
    }

    private void CloseModal() => showModal = false;

    private async Task SaveMilestone()
    {
        if (editingMilestone.Id == 0)
        {
            var createDTO = new CreateMilestoneDTO
            {
                ProjectId = editingMilestone.ProjectId,
                Name = editingMilestone.Name,
                Description = editingMilestone.Description,
                StartDate = editingMilestone.StartDate,
                EndDate = editingMilestone.EndDate
            };
            await MilestoneService.CreateMilestoneAsync(createDTO);
        }
        else
        {
            var updateDTO = new UpdateMilestoneDTO
            {
                Id = editingMilestone.Id,
                Name = editingMilestone.Name,
                Description = editingMilestone.Description,
                StartDate = editingMilestone.StartDate,
                EndDate = editingMilestone.EndDate,
                Status = editingMilestone.Status
            };
            await MilestoneService.UpdateMilestoneAsync(updateDTO);
        }
        showModal = false;
        await LoadMilestones();
    }

    private async Task DeleteMilestone(MilestoneDTO milestone)
    {
        // Implement delete logic if needed, or just update to closed
        // For now, let's assume we want to "Complete" it via the card action, 
        // but if this is a true delete:
        // await MilestoneService.DeleteMilestoneAsync(milestone.Id);
        // await LoadMilestones();
    }
}
