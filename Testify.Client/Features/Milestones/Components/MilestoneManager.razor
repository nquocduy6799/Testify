@using Testify.Shared.DTOs.Milestones
@using Testify.Client.Features.Milestones.Services
@using Testify.Client.Features.Milestones.Components
@using Testify.Client.Interfaces
@using Testify.Client.Services
@using static Testify.Shared.Enums.MilestoneEnum
@inject IMilestoneService MilestoneService
@inject IServiceProvider ServiceProvider
@implements IAsyncDisposable

<style>
    .no-scrollbar::-webkit-scrollbar {
        display: none;
    }
    
    .no-scrollbar {
        -ms-overflow-style: none;
        scrollbar-width: none;
    }
</style>

<div class="animate-in fade-in space-y-8 pb-20 duration-500">
    @* --- HEADER & ACTIONS --- *@
    <div class="flex flex-col justify-between gap-6 md:flex-row md:items-end">
        <div>
            <h2 class="text-3xl font-black tracking-tight text-slate-800">Project Milestones</h2>
            <p class="mt-2 font-medium text-slate-400">Define delivery cycles and track progress across the project timeline.</p>
        </div>
        
        <div class="flex items-center gap-3">
            @* Active Stats Badge *@
            <div class="group flex items-center gap-3 rounded-2xl border border-slate-100 bg-white px-4 py-2.5 shadow-sm transition-all hover:shadow-md">
                <div class="flex h-8 w-8 items-center justify-center rounded-xl bg-orange-50">
                    <svg class="h-4 w-4 text-[#E85D3F]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                    </svg>
                </div>
                <div>
                    <p class="mb-1 text-[9px] font-black uppercase leading-none tracking-widest text-slate-400">Active</p>
                    <p class="text-lg font-black leading-none text-slate-800">@(milestones?.Count(m => m.Status == MilestoneStatus.Active) ?? 0)</p>
                </div>
            </div>

            @* Add Button *@
            <button @onclick="OpenCreateDialog" 
                    class="flex items-center gap-2 rounded-2xl bg-[#E85D3F] px-6 py-3 text-sm font-bold text-white shadow-[0_10px_20px_-5px_rgba(232,93,63,0.3)] transition-all hover:bg-orange-600 hover:shadow-[0_12px_25px_-5px_rgba(232,93,63,0.4)] active:scale-95">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"></path>
                </svg>
                <span class="hidden sm:inline">Add Milestone</span>
            </button>
        </div>
    </div>

    @* --- FILTER BAR --- *@
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4 rounded-[32px] border border-white bg-white/50 p-2 shadow-sm backdrop-blur-md">
        <div class="flex w-full overflow-x-auto rounded-2xl bg-slate-100/50 p-1 no-scrollbar sm:w-auto">
            <button @onclick="() => activeFilter = MilestoneStatus.All"
                    class="@(activeFilter == MilestoneStatus.All ? "bg-white text-slate-900 shadow-sm" : "text-slate-400 hover:text-slate-600") whitespace-nowrap rounded-xl px-6 py-2 text-[11px] font-black uppercase tracking-widest transition-all">
                All
            </button>
            @foreach (var filter in Enum.GetValues<MilestoneStatus>())
            {
                @if (filter != MilestoneStatus.All)
                {
                    <button @onclick="() => activeFilter = filter"
                            class="@(activeFilter == filter ? "bg-white text-slate-900 shadow-sm" : "text-slate-400 hover:text-slate-600") whitespace-nowrap rounded-xl px-6 py-2 text-[11px] font-black uppercase tracking-widest transition-all">
                        @filter
                    </button>
                }
            }
        </div>
    </div>

    @* --- MILESTONE GRID --- *@
    @if (isLoading)
    {
        <div class="grid grid-cols-1 gap-8 md:grid-cols-2 xl:grid-cols-3">
            @for(int i=0; i<3; i++) {
                <div class="h-[300px] w-full animate-pulse rounded-[48px] bg-slate-100"></div>
            }
        </div>
    }
    else if (filteredMilestones == null || !filteredMilestones.Any())
    {
        @* Empty State *@
        <div class="col-span-full flex flex-col items-center justify-center rounded-[48px] border-2 border-dashed border-slate-200 bg-white/40 py-24 text-center">
            <svg class="mb-6 h-10 w-10 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <h3 class="text-2xl font-black text-slate-800">No milestones yet</h3>
            <p class="mt-2 max-w-sm font-medium text-slate-400">Create your first milestone to start tracking phases.</p>
            <button @onclick="OpenCreateDialog" 
                    class="mt-8 rounded-2xl bg-[#E85D3F] px-8 py-3 font-black text-white shadow-lg shadow-orange-100 transition-all hover:shadow-xl">
                Initialize Milestone
            </button>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 gap-8 md:grid-cols-2 xl:grid-cols-3">
            @foreach (var milestone in filteredMilestones)
            {
                <MilestoneCard 
                    Milestone="milestone" 
                    OnEdit="OpenEditDialog" 
                    OnClose="CloseMilestone" 
                    OnAddTask="OpenAddTaskDialog"
                    OnDelete="DeleteMilestone"
                    OnViewPlans="ViewTestPlans"
                />
            }
        </div>
    }

    <MilestoneForm Show="showModal" Milestone="editingMilestone" OnSave="SaveMilestone" OnCancel="CloseModal" />
</div>

@code {
    [Parameter] public int ProjectId { get; set; }

    private List<MilestoneResponse>? milestones;
    private bool isLoading = true;
    private MilestoneStatus activeFilter = MilestoneStatus.All;
    
    // Form State
    private bool showModal = false;
    private MilestoneResponse editingMilestone = new();
    
    // Real-time
    private NotificationHubService? _hubService;

    private IEnumerable<MilestoneResponse>? filteredMilestones =>
        milestones?.Where(m => 
            activeFilter == MilestoneStatus.All ||
            m.Status == activeFilter
        );

    protected override async Task OnInitializedAsync()
    {
        await LoadMilestones();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _hubService = ServiceProvider.GetService<NotificationHubService>();
            
            if (_hubService != null)
            {
                _hubService.OnMilestoneCreated += HandleMilestoneCreated;
                _hubService.OnMilestoneUpdated += HandleMilestoneUpdated;
                _hubService.OnMilestoneDeleted += HandleMilestoneDeleted;
                Console.WriteLine("[MilestoneManager] Subscribed to real-time milestone events");
            }
        }
    }

    private async void HandleMilestoneCreated(int projectId)
    {
        if (projectId == ProjectId)
        {
            Console.WriteLine($"[MilestoneManager] Milestone created in project {projectId}, reloading...");
            await InvokeAsync(async () =>
            {
                await LoadMilestones();
                StateHasChanged();
            });
        }
    }

    private async void HandleMilestoneUpdated(int projectId)
    {
        if (projectId == ProjectId)
        {
            Console.WriteLine($"[MilestoneManager] Milestone updated in project {projectId}, reloading...");
            await InvokeAsync(async () =>
            {
                await LoadMilestones();
                StateHasChanged();
            });
        }
    }

    private async void HandleMilestoneDeleted(int projectId, int milestoneId)
    {
        if (projectId == ProjectId)
        {
            Console.WriteLine($"[MilestoneManager] Milestone {milestoneId} deleted from project {projectId}, reloading...");
            await InvokeAsync(async () =>
            {
                await LoadMilestones();
                StateHasChanged();
            });
        }
    }

    private async Task LoadMilestones()
    {
        isLoading = true;
        try
        {
            milestones = await MilestoneService.GetMilestonesByProjectAsync(ProjectId);
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
        }
        finally
        {
            isLoading = false;
        }
    }

    private void OpenCreateDialog()
    {
        editingMilestone = new MilestoneResponse 
        { 
            ProjectId = ProjectId,
             StartDate = DateTime.Today,
            EndDate = DateTime.Today.AddDays(7),
            Status = MilestoneStatus.Active
        };
        showModal = true;
    }

    private void OpenEditDialog(MilestoneResponse milestone)
    {
        editingMilestone = new MilestoneResponse
        {
            Id = milestone.Id,
            ProjectId = milestone.ProjectId,
            Name = milestone.Name,
            Description = milestone.Description,
            StartDate = milestone.StartDate,
            EndDate = milestone.EndDate,
            Status = milestone.Status
        };
        showModal = true;
    }

    private void CloseModal() => showModal = false;

    private async Task SaveMilestone()
    {
        if (editingMilestone.Id == 0)
        {
            var createDTO = new CreateMilestoneRequest
            {
                ProjectId = editingMilestone.ProjectId,
                Name = editingMilestone.Name,
                Description = editingMilestone.Description,
                StartDate = editingMilestone.StartDate,
                EndDate = editingMilestone.EndDate
            };
            await MilestoneService.CreateMilestoneAsync(createDTO);
        }
        else
        {
            var updateDTO = new UpdateMilestoneRequest
            {
                Id = editingMilestone.Id,
                Name = editingMilestone.Name,
                Description = editingMilestone.Description,
                StartDate = editingMilestone.StartDate,
                EndDate = editingMilestone.EndDate,
                Status = editingMilestone.Status
            };
            await MilestoneService.UpdateMilestoneAsync(updateDTO);
        }
        showModal = false;
        await LoadMilestones();
    }


    private async Task CloseMilestone(int milestoneId)
    {
        var milestone = milestones?.FirstOrDefault(m => m.Id == milestoneId);
        if (milestone != null)
        {
            var updateDTO = new UpdateMilestoneRequest
            {
                Id = milestone.Id,
                Name = milestone.Name,
                Description = milestone.Description,
                StartDate = milestone.StartDate,
                EndDate = milestone.EndDate,
				Status = MilestoneStatus.Closed
            };
            await MilestoneService.UpdateMilestoneAsync(updateDTO);
            await LoadMilestones(); 
        }
    }

    private void OpenAddTaskDialog(int milestoneId)
    {
        Console.WriteLine($"[TODO] Open Quick Task Form for Milestone ID: {milestoneId}");
    }

    private async Task DeleteMilestone(int milestoneId)
    {
        // TODO: Add confirmation dialog
        try
        {
            await MilestoneService.DeleteMilestoneAsync(milestoneId);
            await LoadMilestones();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error deleting milestone: {ex.Message}");
        }
    }

    private void ViewTestPlans(int milestoneId)
    {
        Console.WriteLine($"[TODO] View Test Plans for Milestone ID: {milestoneId}");
        // TODO: Navigate to test plans page or open modal
    }

    public async ValueTask DisposeAsync()
    {
        if (_hubService != null)
        {
            _hubService.OnMilestoneCreated -= HandleMilestoneCreated;
            _hubService.OnMilestoneUpdated -= HandleMilestoneUpdated;
            _hubService.OnMilestoneDeleted -= HandleMilestoneDeleted;
        }
    }
}