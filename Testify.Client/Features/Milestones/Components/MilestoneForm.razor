@using System.ComponentModel.DataAnnotations
@using Testify.Shared.DTOs.Milestones

@if (Show)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center p-4">
        @* Backdrop *@
        <div class="absolute inset-0 bg-slate-900/40 backdrop-blur-sm transition-opacity" @onclick="() => OnCancel.InvokeAsync()"></div>

        @* Modal Card *@
        <div class="animate-in fade-in zoom-in-95 relative w-full max-w-xl overflow-hidden rounded-[48px] bg-white shadow-2xl duration-200">
            
            @* Header *@
            <div class="flex items-center justify-between px-10 pt-10 pb-6">
                <div>
                    <h3 class="text-3xl font-black text-slate-900 tracking-tight">
                        @(Milestone.Id == 0 ? "New Milestone" : "Edit Milestone")
                    </h3>
                    <p class="mt-1 font-medium text-slate-500">Define your objective and timeline.</p>
                </div>
                <button @onclick="() => OnCancel.InvokeAsync()" class="rounded-full bg-slate-50 p-3 text-slate-400 transition-colors hover:bg-slate-100 hover:text-slate-900">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" x2="6" y1="6" y2="18" /><line x1="6" x2="18" y1="6" y2="18" /></svg>
                </button>
            </div>

            <div class="px-10 pb-10">
                <EditForm Model="@Milestone" OnValidSubmit="HandleSubmit">
                    <DataAnnotationsValidator />
                    <ValidationSummary class="mb-6 rounded-2xl bg-red-50 p-4 text-xs font-bold text-red-600" />

                    <div class="space-y-6">
                        <div class="space-y-2">
                            <label class="ml-1 text-[11px] font-black tracking-widest text-slate-900 uppercase">Milestone Name</label>
                            <InputText @bind-Value="Milestone.Name" class="w-full rounded-2xl border-2 border-transparent bg-slate-50 px-6 py-4 text-sm font-bold text-slate-900 transition-all placeholder:text-slate-400 focus:border-[#7E96E1] focus:bg-white outline-none" placeholder="e.g. Phase 1 Delivery" />
                            <ValidationMessage For="@(() => Milestone.Name)" class="text-xs text-red-500 ml-1 font-bold" />
                        </div>

                        <div class="space-y-2">
                            <label class="ml-1 text-[11px] font-black tracking-widest text-slate-900 uppercase">Description</label>
                            <InputTextArea @bind-Value="Milestone.Description" rows="3" class="w-full rounded-2xl border-2 border-transparent bg-slate-50 px-6 py-4 text-sm font-medium text-slate-900 transition-all placeholder:text-slate-400 focus:border-[#7E96E1] focus:bg-white outline-none" placeholder="Describe the objectives and deliverables..." />
                        </div>

                        <div class="grid grid-cols-2 gap-6">
                            <div class="space-y-2">
                                <label class="ml-1 text-[11px] font-black tracking-widest text-slate-900 uppercase">Start Date</label>
                                <InputDate @bind-Value="Milestone.StartDate" class="w-full rounded-2xl border-2 border-transparent bg-slate-50 px-6 py-4 text-sm font-bold text-slate-900 transition-all focus:border-[#7E96E1] focus:bg-white outline-none" />
                            </div>
                            <div class="space-y-2">
                                <label class="ml-1 text-[11px] font-black tracking-widest text-slate-900 uppercase">End Date</label>
                                <InputDate @bind-Value="Milestone.EndDate" class="w-full rounded-2xl border-2 border-transparent bg-slate-50 px-6 py-4 text-sm font-bold text-slate-900 transition-all focus:border-[#7E96E1] focus:bg-white outline-none" />
                            </div>
                        </div>

                        <div class="space-y-2">
                            <label class="ml-1 text-[11px] font-black tracking-widest text-slate-900 uppercase">Status</label>
                            <div class="relative">
                                <InputSelect @bind-Value="Milestone.Status" class="w-full appearance-none rounded-2xl border-2 border-transparent bg-slate-50 px-6 py-4 text-sm font-bold text-slate-900 transition-all focus:border-[#7E96E1] focus:bg-white outline-none">
                                    <option value="Planned">Planned</option>
                                    <option value="Active">Active</option>
                                    <option value="Completed">Completed</option>
                                    <option value="OnHold">On Hold</option>
                                    <option value="Closed">Closed</option>
                                </InputSelect>
                                <div class="pointer-events-none absolute right-6 top-1/2 -translate-y-1/2 text-slate-500">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
                                </div>
                            </div>
                        </div>

                        <div class="flex gap-4 pt-4">
                            <button type="button" @onclick="() => OnCancel.InvokeAsync()" class="flex-1 rounded-[32px] border-2 border-slate-100 bg-white py-4 font-bold text-slate-600 transition-all hover:bg-slate-50 hover:border-slate-200">
                                Cancel
                            </button>
                            <button type="submit" class="flex-1 rounded-[32px] bg-[#1C1D2A] py-4 font-bold text-white shadow-xl shadow-slate-900/20 transition-all hover:-translate-y-0.5 hover:shadow-2xl">
                                Save Milestone
                            </button>
                        </div>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool Show { get; set; }
    [Parameter] public MilestoneDTO Milestone { get; set; } = new();
    [Parameter] public EventCallback OnSave { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    private async Task HandleSubmit()
    {
        if (!Milestone.IsValidDateRange())
        {
            // Ideally handle this with a custom validator or show a toast
            return; 
        }
        await OnSave.InvokeAsync();
    }
}
