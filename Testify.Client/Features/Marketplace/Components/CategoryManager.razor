@using Testify.Shared.DTOs.Marketplace

<div class="space-y-8 animate-in fade-in slide-in-from-bottom-4 duration-700">
    @* --- Header Section --- *@
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 bg-white/60 backdrop-blur-xl p-8 rounded-[32px] border border-white shadow-sm ring-1 ring-slate-100">
        <div>
            <h1 class="text-3xl font-black text-slate-900 tracking-tight">Category Structure</h1>
            <p class="text-slate-500 font-medium">Manage how test suites are organized in the marketplace.</p>
        </div>
        <button @onclick="() => SelectCategory(null)" 
                class="flex items-center gap-2 bg-purple-600 text-white px-6 py-3 rounded-2xl font-bold shadow-lg shadow-purple-200 hover:bg-purple-700 transition-all hover:scale-[1.02] active:scale-[0.98]">
            @* Icon: Plus (Lucide) *@
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14"/><path d="M12 5v14"/>
            </svg>
            Create Category
        </button>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10">
        
        @* --- LEFT: Category List --- *@
        <div class="lg:col-span-4 space-y-6">
            <div class="bg-white rounded-[32px] border border-slate-100 shadow-sm overflow-hidden flex flex-col h-full min-h-[500px]">
                <div class="p-6 border-b border-slate-50">
                    <h3 class="text-[11px] font-black text-slate-400 uppercase tracking-widest flex items-center gap-2 mb-4">
                        @* Icon: FolderTree (Lucide) *@
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M20 10a1 1 0 0 0 1-1V6a1 1 0 0 0-1-1h-2.5a1 1 0 0 1-.8-.4l-.9-1.2A1 1 0 0 0 15 3h-2a1 1 0 0 0-1 1v5a1 1 0 0 0 1 1Z"/><path d="M20 21a1 1 0 0 0 1-1v-3a1 1 0 0 0-1-1h-2.9a1 1 0 0 1-.88-.55l-.42-.85a1 1 0 0 0-.9-.6H13a1 1 0 0 0-1 1v5a1 1 0 0 0 1 1Z"/><path d="M3 5a2 2 0 0 0 2 2h3"/><path d="M3 3v13a2 2 0 0 0 2 2h3"/>
                        </svg>
                        Available Categories
                    </h3>
                    
                    @* Search Input *@
                    <div class="relative group">
                        <span class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-300 group-focus-within:text-purple-500 transition-colors">
                            @* Icon: Search (Lucide) *@
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>
                            </svg>
                        </span>
                        <input type="text" 
                               placeholder="Find category..." 
                               @bind="searchQuery"
                               @bind:event="oninput"
                               class="w-full pl-11 pr-4 py-3 rounded-xl border border-slate-100 bg-slate-50/50 focus:bg-white focus:border-purple-200 focus:ring-4 focus:ring-purple-500/5 outline-none text-sm font-medium transition-all" />
                    </div>
                </div>

                <div class="flex-1 overflow-y-auto px-2 py-4">
                    @if (FilteredCategories.Any())
                    {
                        <div class="space-y-1">
                            @foreach (var cat in FilteredCategories)
                            {
                                <button @onclick="() => SelectCategory(cat)"
                                        class="w-full text-left p-4 flex items-center justify-between rounded-2xl transition-all @(selectedCategory?.Id == cat.Id ? "bg-purple-50 text-purple-700 border border-purple-100 shadow-sm" : "hover:bg-slate-50 text-slate-600")">
                                    <div class="flex items-center gap-3">
                                        <div class="w-10 h-10 rounded-xl flex items-center justify-center @(selectedCategory?.Id == cat.Id ? "bg-purple-600 text-white" : "bg-slate-100 text-slate-400")">
                                            @* Icon: Grid (Lucide) *@
                                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <rect width="7" height="7" x="3" y="3" rx="1"/><rect width="7" height="7" x="14" y="3" rx="1"/><rect width="7" height="7" x="14" y="14" rx="1"/><rect width="7" height="7" x="3" y="14" rx="1"/>
                                            </svg>
                                        </div>
                                        <div>
                                            <span class="font-bold block text-sm">@cat.Name</span>
                                            <span class="text-[10px] font-bold text-slate-400 uppercase tracking-wider">@cat.Subcategories.Count Subcategories</span>
                                        </div>
                                    </div>
                                    @* Icon: ChevronRight (Lucide) *@
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="@(selectedCategory?.Id == cat.Id ? "text-purple-400" : "text-slate-200")">
                                        <path d="m9 18 6-6-6-6"/>
                                    </svg>
                                </button>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="p-12 text-center text-slate-400">
                            <div class="w-12 h-12 bg-slate-50 rounded-2xl flex items-center justify-center mx-auto mb-4">
                                @* Icon: Search (Lucide) *@
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>
                                </svg>
                            </div>
                            <p class="text-sm font-bold">No matches found</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        @* --- RIGHT: Edit Panel --- *@
        <div class="lg:col-span-8">
            <div class="bg-white rounded-[40px] border border-slate-100 shadow-sm p-10 flex flex-col h-full">
                <div class="flex justify-between items-center mb-10 pb-6 border-b border-slate-50">
                    <div>
                        <h2 class="text-2xl font-black text-slate-900 tracking-tight">
                            @(selectedCategory != null && selectedCategory.Id > 0 ? "Refine Category" : "New Category")
                        </h2>
                        <p class="text-sm text-slate-400 font-medium">Configure properties and children.</p>
                    </div>
                    @if (selectedCategory != null && selectedCategory.Id > 0)
                    {
                        <button @onclick="DeleteCategory" 
                                class="flex items-center gap-2 text-rose-500 hover:bg-rose-50 px-4 py-2 rounded-xl transition-all text-sm font-bold">
                            @* Icon: Trash2 (Lucide) *@
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/><line x1="10" x2="10" y1="11" y2="17"/><line x1="14" x2="14" y1="11" y2="17"/>
                            </svg>
                            Delete
                        </button>
                    }
                </div>
                
                <div class="space-y-10 flex-1">
                    @* Category Name *@
                    <div class="space-y-3">
                        <label class="text-[11px] font-black text-slate-400 uppercase tracking-widest flex items-center gap-2">
                            Identity & Label
                        </label>
                        <input type="text" 
                               @bind="categoryFormData.Name"
                               class="w-full px-6 py-4 rounded-2xl border border-slate-100 bg-slate-50/30 focus:bg-white focus:border-purple-200 focus:ring-4 focus:ring-purple-500/5 outline-none text-lg font-bold text-slate-900 transition-all"
                               placeholder="e.g. Enterprise Cloud" />
                    </div>

                    @* Subcategories Section *@
                    <div class="space-y-6">
                        <label class="text-[11px] font-black text-slate-400 uppercase tracking-widest flex items-center gap-2">
                            @* Icon: Tag (Lucide) *@
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M12.586 2.586A2 2 0 0 0 11.172 2H4a2 2 0 0 0-2 2v7.172a2 2 0 0 0 .586 1.414l8.704 8.704a2.426 2.426 0 0 0 3.42 0l6.58-6.58a2.426 2.426 0 0 0 0-3.42z"/><circle cx="7.5" cy="7.5" r=".5" fill="currentColor"/>
                            </svg>
                            Subcategories
                        </label>
                        
                        <div class="bg-slate-50/50 rounded-3xl p-6 border border-slate-100">
                            <div class="flex flex-wrap gap-2 mb-6 min-h-[48px]">
                                @foreach (var sub in categoryFormData.Subcategories)
                                {
                                    <div class="bg-white border border-slate-100 px-4 py-2 rounded-xl text-xs font-bold text-slate-700 flex items-center gap-2 shadow-sm group hover:border-purple-200 transition-all">
                                        <span>@sub</span>
                                        <button @onclick="() => RemoveSubcategory(sub)"
                                                class="text-slate-300 hover:text-rose-500 transition-colors">
                                            @* Icon: X (Lucide) *@
                                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <path d="M18 6 6 18"/><path d="m6 6 12 12"/>
                                            </svg>
                                        </button>
                                    </div>
                                }
                                @if (!categoryFormData.Subcategories.Any())
                                {
                                    <div class="w-full flex items-center justify-center py-4 border-2 border-dashed border-slate-100 rounded-2xl text-slate-300 text-xs font-bold">
                                        No subcategories defined yet.
                                    </div>
                                }
                            </div>

                            @* Add Subcategory *@
                            <div class="flex gap-2">
                                <input type="text" 
                                       @bind="newSubcategoryName"
                                       @onkeyup="HandleSubInputKeyUp"
                                       placeholder="Add subcategory name..."
                                       class="flex-1 px-5 py-3 rounded-xl border border-slate-100 focus:border-purple-200 outline-none bg-white text-sm font-medium transition-all" />
                                <button @onclick="AddSubcategory"
                                        class="bg-slate-900 text-white px-6 py-3 rounded-xl text-sm font-bold hover:bg-slate-800 transition-all">
                                    Add
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="pt-10 mt-10 border-t border-slate-50">
                    <button @onclick="SaveCategory"
                            class="w-full bg-purple-600 text-white py-4 rounded-2xl font-black text-sm tracking-widest uppercase shadow-xl shadow-purple-500/20 hover:bg-purple-700 transition-all transform active:scale-[0.99] flex items-center justify-center gap-3">
                        @* Icon: Save (Lucide) *@
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M15.2 3a2 2 0 0 1 1.4.6l3.8 3.8a2 2 0 0 1 .6 1.4V19a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2z"/><path d="M17 21v-7a1 1 0 0 0-1-1H8a1 1 0 0 0-1 1v7"/><path d="M7 3v4a1 1 0 0 0 1 1h7"/>
                        </svg>
                        @(selectedCategory != null && selectedCategory.Id > 0 ? "Sync Changes" : "Initialize Category")
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public List<CategoryDto> Categories { get; set; } = new();
    [Parameter] public EventCallback<CategoryDto> OnUpdateCategory { get; set; }
    [Parameter] public EventCallback<CategoryDto> OnCreateCategory { get; set; }
    [Parameter] public EventCallback<int> OnDeleteCategory { get; set; }

    // State
    private CategoryDto? selectedCategory;
    private CategoryDto categoryFormData = new();
    private string newSubcategoryName = "";
    private string searchQuery = "";

    // Computed Property for Search
    private IEnumerable<CategoryDto> FilteredCategories => 
        string.IsNullOrWhiteSpace(searchQuery) 
        ? Categories 
        : Categories.Where(c => c.Name.Contains(searchQuery, StringComparison.OrdinalIgnoreCase));

    private void SelectCategory(CategoryDto? cat)
    {
        selectedCategory = cat;
        // Deep copy để tránh sửa trực tiếp vào list gốc trước khi Save
        if (cat != null)
        {
            categoryFormData = new CategoryDto
            {
                Id = cat.Id,
                Name = cat.Name,
                Subcategories = new List<string>(cat.Subcategories)
            };
        }
        else
        {
            // Reset form for create new
            categoryFormData = new CategoryDto { Subcategories = new List<string>() };
        }
    }

    private void AddSubcategory()
    {
        if (!string.IsNullOrWhiteSpace(newSubcategoryName) && 
            !categoryFormData.Subcategories.Contains(newSubcategoryName.Trim()))
        {
            categoryFormData.Subcategories.Add(newSubcategoryName.Trim());
            newSubcategoryName = "";
        }
    }

    private void RemoveSubcategory(string sub)
    {
        categoryFormData.Subcategories.Remove(sub);
    }

    private void HandleSubInputKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") AddSubcategory();
    }

    private async Task SaveCategory()
    {
        if (string.IsNullOrWhiteSpace(categoryFormData.Name)) return; // Validation đơn giản

        if (selectedCategory != null && selectedCategory.Id > 0)
        {
            await OnUpdateCategory.InvokeAsync(categoryFormData);
        }
        else
        {
            await OnCreateCategory.InvokeAsync(categoryFormData);
            // Reset form sau khi tạo
            categoryFormData = new CategoryDto { Subcategories = new List<string>() };
        }
    }

    private async Task DeleteCategory()
    {
        if (selectedCategory != null && selectedCategory.Id > 0)
        {
            // Trong thực tế nên dùng Modal Dialog của Blazor thay vì confirm() js
            await OnDeleteCategory.InvokeAsync(selectedCategory.Id);
            SelectCategory(null);
        }
    }
}
