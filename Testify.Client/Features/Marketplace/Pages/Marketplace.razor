@page "/marketplace"
@using Testify.Shared.DTOs.Marketplace
@using Testify.Client.Features.Marketplace.Components
@using Testify.Client.Interfaces
@inject IMarketplaceService MarketplaceService
@rendermode InteractiveWebAssembly

<div class="min-h-screen bg-[#f9fafb] text-slate-900 pb-20">
    <section class="relative px-8 pt-12 pb-24 overflow-hidden bg-slate-900 rounded-b-[60px] mb-10">
        <div class="relative z-10 text-center space-y-6">
            <h1 class="text-4xl md:text-6xl font-black text-white tracking-tight">
                Marketplace <span class="text-transparent bg-clip-text bg-gradient-to-r from-purple-400 to-indigo-400">Templates</span>
            </h1>
            <div class="max-w-3xl mx-auto pt-4">
                <div class="flex items-center bg-white rounded-2xl shadow-2xl border-4 border-white/10 h-14 px-5 gap-3">
                    <svg class="text-slate-400 flex-shrink-0" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>
                    </svg>
                    <input type="text" 
                           @bind="searchTerm" 
                           @bind:event="oninput"
                           placeholder="Search templates..."
                           class="w-full h-full bg-transparent text-slate-900 text-lg font-medium focus:outline-none placeholder:text-slate-400" />
                </div>
            </div>
        </div>
    </section>

    <div class="max-w-[1400px] mx-auto px-8 -mt-10 relative z-20">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-10">
            
            <aside class="lg:col-span-3 space-y-8">
                <div class="bg-white rounded-[32px] p-8 border border-slate-100 shadow-sm sticky top-28">
                    <div class="space-y-6">
                        <h3 class="text-[11px] font-black text-slate-400 uppercase tracking-widest flex items-center gap-2">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <rect width="7" height="7" x="3" y="3" rx="1"/><rect width="7" height="7" x="14" y="3" rx="1"/><rect width="7" height="7" x="14" y="14" rx="1"/><rect width="7" height="7" x="3" y="14" rx="1"/>
                            </svg>
                            Categories
                        </h3>
                        
                        <div class="space-y-1.5">
                            <button @onclick="() => selectedCategoryId = null"
                                    class="w-full flex items-center justify-between px-4 py-3 rounded-2xl text-sm font-bold transition-all @(selectedCategoryId == null ? "bg-purple-600 text-white shadow-lg shadow-purple-200" : "text-slate-500 hover:bg-slate-50 text-slate-900")">
                                <span>All Suites</span>
                                <span class="opacity-50 font-medium">@AllTemplates.Count</span>
                            </button>

                            @foreach (var cat in Categories)
                            {
                                <button @onclick="() => selectedCategoryId = cat.Id"
                                        class="w-full flex items-center justify-between px-4 py-3 rounded-2xl text-sm font-bold transition-all @(selectedCategoryId == cat.Id ? "bg-purple-600 text-white shadow-lg shadow-purple-200" : "text-slate-500 hover:bg-slate-50 text-slate-900 group")">
                                    <div class="flex items-center gap-3">
                                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="@(selectedCategoryId == cat.Id ? "text-white" : "text-slate-400 group-hover:text-purple-500")">
                                            <rect width="7" height="7" x="3" y="3" rx="1"/><rect width="7" height="7" x="14" y="3" rx="1"/><rect width="7" height="7" x="14" y="14" rx="1"/><rect width="7" height="7" x="3" y="14" rx="1"/>
                                        </svg>
                                        <span>@cat.Name</span>
                                    </div>
                                    <span class="opacity-50 font-medium">
                                        @AllTemplates.Count(t => t.CategoryName == cat.Name)
                                    </span>
                                </button>
                            }
                        </div>
                    </div>
                </div>
            </aside>

            <div class="lg:col-span-9">
                @if (FilteredTemplates.Any())
                {
                    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
                        @foreach (var template in FilteredTemplates)
                        {
                            <TemplateCard Template="@template" 
                                          CategoryName="@template.CategoryName"
                                          OnClone="HandleClone"
                                          OnBuy="HandleBuy" />
                        }
                    </div>
                }
                else
                {
                    <div class="py-24 flex flex-col items-center justify-center bg-white rounded-[40px] border border-slate-100 border-dashed space-y-6">
                        <div class="w-20 h-20 bg-slate-50 rounded-3xl flex items-center justify-center text-slate-200">
                            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>
                            </svg>
                        </div>
                        <h3 class="text-xl font-black text-slate-900">No templates found</h3>
                        <button @onclick="ResetFilters" class="px-6 py-3 bg-slate-900 text-white rounded-2xl text-sm font-bold">
                            Clear all filters
                        </button>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    // Data gốc
    private List<TemplateDto> AllTemplates = new();
    private List<CategoryDto> Categories = new();

    // State bộ lọc
    private string searchTerm = "";
    private int? selectedCategoryId;

    // Logic lọc dữ liệu (Computed Property)
    private IEnumerable<TemplateDto> FilteredTemplates => AllTemplates
        .Where(t => string.IsNullOrWhiteSpace(searchTerm) || t.Title.Contains(searchTerm, StringComparison.OrdinalIgnoreCase))
        .Where(t => selectedCategoryId == null || GetCategoryIdByName(t.CategoryName) == selectedCategoryId);

    protected override async Task OnInitializedAsync()
    {
        // Load cả Template và Category từ API
        AllTemplates = await MarketplaceService.GetTemplatesAsync();
        Categories = await MarketplaceService.GetCategoriesAsync(); 
    }

    // Helper: Vì TemplateDto đang lưu CategoryName, cần map ngược lại ID để so sánh
    private int GetCategoryIdByName(string name) => Categories.FirstOrDefault(c => c.Name == name)?.Id ?? 0;

    private void ResetFilters()
    {
        searchTerm = "";
        selectedCategoryId = null;
    }

    private async Task HandleClone(int id) { /* Logic Clone */ }
    
    private async Task HandleBuy(int id) { /* Logic Buy */ }
}
