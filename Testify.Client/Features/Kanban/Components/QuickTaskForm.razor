﻿@using Testify.Shared.DTOs.KanbanTasks
@using Testify.Shared.Enums

<div class="fixed inset-0 z-[60] flex items-center justify-center p-6">
    <div class="animate-in fade-in absolute inset-0 bg-slate-900/40 backdrop-blur-sm duration-300"
         @onclick="OnClose"></div>

    <div class="animate-in zoom-in-95 fade-in relative flex w-full max-w-md flex-col overflow-hidden rounded-[40px] bg-white shadow-2xl duration-300"
         @onclick:stopPropagation="true">

        <div class="flex items-center justify-between border-b border-slate-50 bg-slate-50/50 p-8">
            <div>
                <h2 class="text-xl font-black text-slate-800">Quick Task</h2>
                <p class="mt-0.5 font-bold tracking-widest text-[10px] text-slate-400 uppercase">
                    Adding to @InitialStatus
                </p>
            </div>
            <button @onclick="OnClose" class="rounded-full p-2 text-slate-400 shadow-sm transition-all hover:bg-white hover:text-slate-600">
                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M18 6 6 18" />
                    <path d="m6 6 12 12" />
                </svg>
            </button>
        </div>

        <EditForm Model="@model" OnValidSubmit="HandleSubmit" class="space-y-6 p-8">
            <DataAnnotationsValidator />

            <div class="space-y-1.5">
                <label class="flex items-center gap-2 font-black tracking-widest text-[10px] text-slate-400 uppercase">
                    <svg class="h-3 w-3 text-[#E85D3F]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="4" x2="20" y1="9" y2="9" />
                        <line x1="4" x2="20" y1="15" y2="15" />
                        <line x1="10" x2="8" y1="3" y2="21" />
                        <line x1="16" x2="14" y1="3" y2="21" />
                    </svg>
                    Task Title
                </label>
                <InputText @bind-Value="model.Title"
                           placeholder="What needs to be done?"
                           class="w-full rounded-2xl border-2 border-transparent bg-slate-50 px-5 py-4 text-sm font-bold text-slate-800 transition-all outline-none focus:border-[#7E96E1] focus:bg-white" />
                <ValidationMessage For="@(() => model.Title)" class="mt-1 text-xs font-bold text-red-500" />
            </div>

            <div class="grid grid-cols-2 gap-4">

                <div class="relative space-y-1.5">
                    <label class="flex items-center gap-2 font-black tracking-widest text-[10px] text-slate-400 uppercase">
                        <svg class="h-3 w-3 text-[#7E96E1]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect width="18" height="18" x="3" y="3" rx="2" />
                            <path d="M12 8v8" />
                            <path d="M8 12h8" />
                        </svg>
                        Type
                    </label>
                    <div class="relative">
                        <InputSelect @bind-Value="model.Type"
                                     class="w-full cursor-pointer appearance-none rounded-2xl border-2 border-transparent bg-slate-50 px-5 py-4 text-sm font-bold text-slate-800 transition-all outline-none focus:border-[#7E96E1] focus:bg-white">
                            <option value="@TaskType.Feature">Feature</option>
                            <option value="@TaskType.Bug">Bug</option>
                        </InputSelect>
                        <svg class="pointer-events-none absolute top-1/2 right-4 h-4 w-4 -translate-y-1/2 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="m6 9 6 6 6-6" />
                        </svg>
                    </div>
                </div>

                <div class="relative space-y-1.5">
                    <label class="flex items-center gap-2 font-black tracking-widest text-[10px] text-slate-400 uppercase">
                        <svg class="h-3 w-3 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2" />
                        </svg>
                        Priority
                    </label>
                    <div class="relative">
                        <InputSelect @bind-Value="model.Priority"
                                     class="w-full cursor-pointer appearance-none rounded-2xl border-2 border-transparent bg-slate-50 px-5 py-4 text-sm font-bold text-slate-800 transition-all outline-none focus:border-[#7E96E1] focus:bg-white">
                            <option value="1">Low</option>
                            <option value="2">Medium</option>
                            <option value="3">High</option>
                            <option value="4">Critical</option>
                        </InputSelect>
                        <svg class="pointer-events-none absolute top-1/2 right-4 h-4 w-4 -translate-y-1/2 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="m6 9 6 6 6-6" />
                        </svg>
                    </div>
                    <ValidationMessage For="@(() => model.Priority)" class="mt-1 text-xs font-bold text-red-500" />
                </div>

            </div>

            <div class="pt-4">
                <button type="submit"
                        class="w-full rounded-2xl bg-[#1C1D2A] py-4 text-sm font-black text-white shadow-lg shadow-slate-100 transition-all hover:bg-slate-800 hover:shadow-xl active:scale-95">
                    Create Task
                </button>
            </div>
        </EditForm>
    </div>
</div>

@code {
    [Parameter] public KanbanTaskStatus InitialStatus { get; set; }
    [Parameter] public int MilestoneId { get; set; }
    [Parameter] public EventCallback<CreateKanbanTaskRequest> OnSave { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    private CreateKanbanTaskRequest model = new();

    protected override void OnInitialized()
    {
        model.Status = InitialStatus;
        model.MilestoneId = MilestoneId;
        // Default priority
        model.Priority = TaskPriority.Medium;
    }

    private async Task HandleSubmit()
    {
        await OnSave.InvokeAsync(model);
    }
}

