@using Testify.Client.Features.Kanban.Services
@using Testify.Client.Interfaces
@using Testify.Shared.DTOs.KanbanTasks
@using Testify.Shared.DTOs.TaskActivity
@using Testify.Shared.Enums
@inject IKanbanTaskService KanbanTaskService

@if (Task != null)
{
    <div class="fixed inset-0 z-[200] flex items-center justify-center p-6" @onclick="OnClose">
        <div class="absolute inset-0 bg-slate-900/60 backdrop-blur-md"></div>

        <div class="relative flex max-h-[90vh] w-full max-w-5xl flex-col overflow-hidden rounded-[48px] bg-white shadow-2xl" @onclick:stopPropagation="true">
            @* Header *@
            <div class="relative flex items-start justify-between overflow-hidden border-b border-slate-50 p-10 @(IsBug ? "bg-red-50/30" : "bg-slate-50/50")">
                <div class="relative z-10 space-y-2">
                    <div class="flex items-center gap-3">
                        <div class="rounded-lg px-3 py-1 font-black tracking-widest text-[10px] uppercase @(IsBug ? "bg-red-500 text-white" : "bg-[#1C1D2A] text-white")">
                            @(IsBug ? "Defect" : "Requirement")
                        </div>
                        <span class="font-bold tracking-widest text-[10px] text-slate-400 uppercase">TASK-@Task.Id</span>
                    </div>
                    <h2 class="text-3xl leading-none font-black tracking-tight text-slate-800">@Task.Title</h2>
                </div>

                <button @onclick="OnClose" class="relative z-10 rounded-full p-3 text-slate-400 shadow-sm transition-colors hover:bg-white">
                    @* X Icon *@
                    <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>

            <div class="grid flex-1 grid-cols-1 gap-10 overflow-y-auto p-10 lg:grid-cols-12">
                @* Main Content *@
                <div class="space-y-8 lg:col-span-7">
                    @* Status, Priority, Due Date Cards *@
                    <div class="grid grid-cols-3 gap-4">
                        <div class="rounded-[32px] border border-slate-100/50 bg-slate-50 p-6">
                            <p class="mb-3 font-black tracking-widest text-[10px] text-slate-400 uppercase">Status</p>
                            <div class="flex items-center gap-2">
                                <div class="h-2 w-2 rounded-full @(Task.Status == KanbanTaskStatus.Done ? "bg-emerald-500" : "bg-blue-500 animate-pulse")"></div>
                                <span class="truncate text-sm font-black tracking-tight text-slate-800 uppercase">@GetStatusName(Task.Status)</span>
                            </div>
                        </div>
                        <div class="rounded-[32px] border border-slate-100/50 bg-slate-50 p-6">
                            <p class="mb-3 font-black tracking-widest text-[10px] text-slate-400 uppercase">Priority</p>
                            <span class="rounded-full px-4 py-1.5 font-black tracking-widest text-[10px] uppercase @GetPriorityBgColor(Task.Priority)">
                                @Task.Priority
                            </span>
                        </div>
                        <div class="rounded-[32px] border p-6 @(IsOverdue ? "bg-red-50 border-red-100" : "bg-slate-50 border-slate-100/50")">
                            <p class="mb-3 font-black tracking-widest text-[10px] text-slate-400 uppercase">Due Date</p>
                            <div class="flex items-center gap-2">
                                <svg class="h-3.5 w-3.5 @(IsOverdue ? "text-red-500" : "text-slate-400")" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <rect width="18" height="18" x="3" y="4" rx="2" ry="2" />
                                    <line x1="16" x2="16" y1="2" y2="6" />
                                    <line x1="8" x2="8" y1="2" y2="6" />
                                    <line x1="3" x2="21" y1="10" y2="10" />
                                </svg>
                                <span class="text-sm font-black tracking-tight uppercase @(IsOverdue ? "text-red-600" : "text-slate-800")">
                                    @(Task.DueDate.HasValue? Task.DueDate.Value.ToString("MMM dd, yyyy") : "TBD")
                                </span>
                            </div>
                        </div>
                    </div>

                    @* Description Section *@
                    <div class="space-y-4">
                        <h4 class="flex items-center gap-2 px-1 text-xs font-black tracking-widest text-slate-400 uppercase">
                            <svg class="h-3.5 w-3.5 @(IsBug ? "text-red-500" : "text-[#7E96E1]")" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                            </svg>
                            @(IsBug ? "Reproduction Scenario" : "Project Specification")
                        </h4>
                        <div class="min-h-[160px] rounded-[40px] border border-slate-100 bg-slate-50/50 p-8">
                            @if (!string.IsNullOrEmpty(Task.Description))
                            {
                                <p class="text-sm leading-relaxed font-medium whitespace-pre-wrap text-slate-600">@Task.Description</p>
                            }
                            else
                            {
                                <div class="flex flex-col items-center justify-center py-10 opacity-30">
                                    <svg class="mb-2 h-8 w-8 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                                    </svg>
                                    <p class="text-xs font-bold uppercase">No specification provided</p>
                                </div>
                            }
                        </div>
                    </div>

                    @* Assignee Section *@
                    <div class="space-y-4">
                        <h4 class="flex items-center gap-2 px-1 text-xs font-black tracking-widest text-slate-400 uppercase">
                            <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                            </svg>
                            Assignee Context
                        </h4>
                        <div class="flex items-center justify-between rounded-[32px] border border-slate-100 bg-white p-6 shadow-sm">
                            <div class="flex items-center gap-4">
                                <div class="flex h-14 w-14 items-center justify-center overflow-hidden rounded-2xl @(IsBug ? "bg-red-100" : "bg-slate-100") border-2 border-slate-50 shadow-sm">
                                    @if (!string.IsNullOrEmpty(Task.AssigneeAvatarUrl))
                                    {
                                        <img src="@Task.AssigneeAvatarUrl" alt="" class="h-full w-full object-cover" />
                                    }
                                    else
                                    {
                                        <svg class="h-8 w-8 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                                        </svg>
                                    }
                                </div>
                                <div>
                                    <p class="text-sm font-black text-slate-800">@(Task.AssigneeName ?? "Unassigned")</p>
                                    <p class="font-bold text-[10px] text-slate-400 uppercase">Team Member</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    @* Test Plan Connection *@
                    @if (Task.TestPlanCount > 0)
                    {
                        <div class="space-y-4">
                            <h4 class="flex items-center gap-2 px-1 text-xs font-black tracking-widest text-slate-400 uppercase">
                                <svg class="h-3.5 w-3.5 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                                </svg>
                                Validation Traceability
                            </h4>
                            <div class="group flex items-center justify-between rounded-[32px] border border-indigo-100 bg-indigo-50 p-6">
                                <div class="flex items-center gap-4">
                                    <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-white shadow-sm">
                                        <svg class="h-5 w-5 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                                        </svg>
                                    </div>
                                    <div>
                                        <p class="text-xs font-black text-slate-800">@Task.TestPlanCount Test Plan(s) Linked</p>
                                        <p class="font-bold text-[10px] text-indigo-400 uppercase">Quality Assurance Coverage</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                @* Sidebar *@
                <div class="space-y-8 lg:col-span-5">
                    @* Attachments *@
                    <div class="space-y-4">
                        <h4 class="flex items-center gap-2 px-1 text-xs font-black tracking-widest text-slate-400 uppercase">
                            <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13" />
                            </svg>
                            Integrated Assets
                        </h4>
                        <div class="space-y-2">
                            @if (Task.Attachments != null && Task.Attachments.Any())
                            {
                                @foreach (var file in Task.Attachments)
                                {
                                    <div class="group flex items-center justify-between rounded-3xl border border-slate-100 bg-white p-4 shadow-sm transition-all hover:shadow-md">
                                        <div class="flex min-w-0 items-center gap-3">
                                            <div class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-xl bg-slate-50 transition-colors group-hover:bg-slate-100">
                                                <svg class="h-5 w-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
                                                </svg>
                                            </div>
                                            <div class="truncate">
                                                <p class="truncate text-xs font-bold text-slate-800">@file.FileName</p>
                                                <p class="font-black text-[9px] text-slate-400 uppercase">@FormatFileSize(file.FileSize)</p>
                                            </div>
                                        </div>
                                        <a href="@file.FileUrl" target="_blank" class="rounded-xl bg-slate-50 p-3 text-slate-400 transition-all hover:bg-[#1C1D2A] hover:text-white">
                                            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                                            </svg>
                                        </a>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="rounded-[32px] border-2 border-dashed border-slate-100 bg-slate-50/50 p-8 text-center">
                                    <svg class="mx-auto mb-2 h-6 w-6 text-slate-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13" />
                                    </svg>
                                    <p class="font-black text-[10px] text-slate-300 uppercase">No documentation attached</p>
                                </div>
                            }
                        </div>
                    </div>

                    @* Activity Timeline *@
                    <div class="space-y-6 rounded-[40px] border border-slate-100 bg-white p-8 shadow-sm">
                        <h4 class="flex items-center gap-2 text-xs font-black tracking-widest text-slate-800 uppercase">
                            <svg class="h-4 w-4 text-[#7E96E1]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                            </svg>
                            Transaction Log
                        </h4>
                        <div class="relative space-y-6 pl-4">
                            <div class="absolute top-0 bottom-0 left-4 w-0.5 bg-slate-50"></div>

                            @if (Task.Activities != null && Task.Activities.Any())
                            {
                                @foreach (var activity in Task.Activities)
                                {
                                    <div class="relative pl-6">
                                        <div class="absolute top-1.5 left-[-5px] h-2.5 w-2.5 rounded-full @GetActivityColor(activity.Action) ring-4 ring-white"></div>
                                        <div>
                                            <div class="flex items-center gap-2">
                                                @GetActivityIcon(activity.Action)
                                                <p class="font-black text-[10px] text-slate-800">@activity.Description</p>
                                            </div>
                                            <div class="mt-1 flex items-center gap-2">
                                                <p class="font-bold text-[9px] text-slate-400 uppercase">@FormatRelativeTime(activity.CreatedAt)</p>
                                                <span class="text-slate-300">•</span>
                                                <p class="font-bold text-[9px] text-slate-500">@activity.FullName</p>
                                            </div>
                                            @if (!string.IsNullOrEmpty(activity.OldValue) || !string.IsNullOrEmpty(activity.NewValue))
                                            {
                                                <div class="mt-2 flex items-center gap-2 text-[9px]">
                                                    @if (!string.IsNullOrEmpty(activity.OldValue))
                                                    {
                                                        <span class="rounded-lg bg-red-50 px-2 py-1 font-bold text-red-600 line-through">@activity.OldValue</span>
                                                    }
                                                    @if (!string.IsNullOrEmpty(activity.OldValue) && !string.IsNullOrEmpty(activity.NewValue))
                                                    {
                                                        <svg class="h-3 w-3 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                                                        </svg>
                                                    }
                                                    @if (!string.IsNullOrEmpty(activity.NewValue))
                                                    {
                                                        <span class="rounded-lg bg-emerald-50 px-2 py-1 font-bold text-emerald-600">@activity.NewValue</span>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="relative pl-6">
                                    <div class="absolute top-1.5 left-[-5px] h-2.5 w-2.5 rounded-full bg-emerald-400 ring-4 ring-white"></div>
                                    <div>
                                        <p class="font-black text-[10px] text-slate-800">Task Created</p>
                                        <p class="font-bold text-[9px] text-slate-400 uppercase">@FormatRelativeTime(Task.CreatedAt)</p>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            @* Footer *@
            <div class="flex items-center justify-between border-t border-slate-50 bg-slate-50/50 p-8 px-10">
                <div class="flex items-center gap-3 text-slate-400">
                    <svg class="h-4 w-4 text-[#E85D3F]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                    </svg>
                    <p class="font-bold tracking-tight text-[10px] uppercase">System trace active. All metadata is synced with the project root.</p>
                </div>
                <div class="flex gap-3">
                    <button @onclick="OnClose" class="rounded-2xl border border-slate-200 bg-white px-8 py-3 text-xs font-black tracking-widest text-slate-800 uppercase transition-all hover:bg-slate-100">
                        Close View
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public KanbanTaskResponse? Task { get; set; }

    [Parameter]
    public EventCallback OnClose { get; set; }

    private bool IsBug => Task?.Type == TaskType.Bug;
    private bool IsOverdue => Task?.DueDate.HasValue == true && Task.DueDate.Value.Date < DateTime.Now.Date;

    private string GetStatusName(KanbanTaskStatus status)
    {
        return status switch
        {
            KanbanTaskStatus.ToDo => "To Do",
            KanbanTaskStatus.InProgress => "In Progress",
            KanbanTaskStatus.ReadyForTest => "Ready for Test",
            KanbanTaskStatus.Testing => "Testing",
            KanbanTaskStatus.Done => "Done",
            _ => status.ToString()
        };
    }

    private string GetPriorityBgColor(TaskPriority priority)
    {
        return priority switch
        {
            TaskPriority.Low => "bg-slate-200 text-slate-600",
            TaskPriority.Medium => "bg-blue-100 text-blue-600",
            TaskPriority.High => "bg-red-100 text-red-600",
            _ => "bg-slate-200 text-slate-600"
        };
    }

    private string FormatFileSize(long bytes)
    {
        string[] sizes = { "B", "KB", "MB", "GB" };
        double len = bytes;
        int order = 0;
        while (len >= 1024 && order < sizes.Length - 1)
        {
            order++;
            len = len / 1024;
        }
        return $"{len:0.##} {sizes[order]}";
    }

    private string FormatRelativeTime(DateTime dateTime)
    {
        var timeSpan = DateTime.Now - dateTime;

        if (timeSpan.TotalMinutes < 1) return "Just now";
        if (timeSpan.TotalMinutes < 60) return $"{(int)timeSpan.TotalMinutes} min ago";
        if (timeSpan.TotalHours < 24) return $"{(int)timeSpan.TotalHours} hours ago";
        if (timeSpan.TotalDays < 7) return $"{(int)timeSpan.TotalDays} days ago";

        return dateTime.ToString("MMM dd, yyyy");
    }

    private string GetActivityColor(string action)
    {
        return action switch
        {
            "Created" => "bg-emerald-400",
            "Status Changed" => "bg-blue-500",
            "Priority Changed" => "bg-amber-500",
            "Assignee Changed" => "bg-purple-500",
            "Type Changed" => "bg-indigo-500",
            "Milestone Changed" => "bg-pink-500",
            "Due Date Changed" => "bg-orange-500",
            "Updated" => "bg-[#7E96E1]",
            _ => "bg-slate-400"
        };
    }

    private RenderFragment GetActivityIcon(string action)
    {
        return action switch
        {
        "Created" => @<svg class="h-3 w-3 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
        </svg>,
        
        "Status Changed" => @<svg class="h-3 w-3 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
        </svg>,
        
        "Priority Changed" => @<svg class="h-3 w-3 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
        </svg>,
        
        "Assignee Changed" => @<svg class="h-3 w-3 text-purple-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
        </svg>,
        
        "Type Changed" => @<svg class="h-3 w-3 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
        </svg>,
        
        "Milestone Changed" => @<svg class="h-3 w-3 text-pink-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>,
        
        "Due Date Changed" => @<svg class="h-3 w-3 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <rect width="18" height="18" x="3" y="4" rx="2" ry="2" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" />
                <line x1="16" x2="16" y1="2" y2="6" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" />
                <line x1="8" x2="8" y1="2" y2="6" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" />
                <line x1="3" x2="21" y1="10" y2="10" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" />
            </svg>,
        
            "Updated" => @<svg class="h-3 w-3 text-[#7E96E1]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                </svg>,

                _ => @<svg class="h-3 w-3 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                };
            }
}


@* 
    <div className="fixed inset-0 z-[200] flex items-center justify-center p-6">
      <div 
        className="absolute inset-0 bg-slate-900/60 backdrop-blur-md animate-in fade-in duration-300"
        onClick={onClose}
      ></div>
      
      <div className="relative bg-white w-full max-w-5xl rounded-[48px] shadow-2xl overflow-hidden flex flex-col animate-in zoom-in-95 duration-300 max-h-[90vh]">
        {/* Header */}
        <div className={`p-10 border-b border-slate-50 flex items-start justify-between relative overflow-hidden ${isBug ? 'bg-red-50/30' : 'bg-slate-50/50'}`}>
          <div className="relative z-10 space-y-2">
            <div className="flex items-center gap-3">
              <div className={`px-3 py-1 rounded-lg text-[10px] font-black uppercase tracking-widest ${isBug ? 'bg-red-500 text-white' : 'bg-[#1C1D2A] text-white'}`}>
                {isBug ? 'Defect' : 'Requirement'}
              </div>
              <span className="text-[10px] font-bold text-slate-400 uppercase tracking-widest">{task.id}</span>
            </div>
            <h2 className="text-3xl font-black text-slate-800 tracking-tight leading-none">{task.title}</h2>
          </div>
          
          <button 
            onClick={onClose}
            className="p-3 hover:bg-white rounded-full text-slate-400 transition-colors shadow-sm relative z-10"
          >
            <X className="w-6 h-6" />
          </button>

          {/* Decorative Background Icon */}
          <div className="absolute -right-8 -top-8 opacity-[0.03] rotate-12">
            {isBug ? <Bug className="w-48 h-48" /> : <Layout className="w-48 h-48" />}
          </div>
        </div>

        <div className="flex-1 overflow-y-auto p-10 grid grid-cols-1 lg:grid-cols-12 gap-10 no-scrollbar">
          {/* Main Context */}
          <div className="lg:col-span-7 space-y-8">
            <div className="grid grid-cols-3 gap-4">
               <div className="p-6 bg-slate-50 rounded-[32px] border border-slate-100/50">
                  <p className="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-3">Status</p>
                  <div className="flex items-center gap-2">
                     <div className={`w-2 h-2 rounded-full ${task.status === 'Done' ? 'bg-emerald-500' : 'bg-blue-500 animate-pulse'}`}></div>
                     <span className="text-sm font-black text-slate-800 uppercase tracking-tight truncate">{task.status}</span>
                  </div>
               </div>
               <div className="p-6 bg-slate-50 rounded-[32px] border border-slate-100/50">
                  <p className="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-3">Priority</p>
                  <span className={`px-4 py-1.5 rounded-full text-[10px] font-black uppercase tracking-widest ${getPriorityColor(task.priority)}`}>
                    {task.priority}
                  </span>
               </div>
               <div className={`p-6 rounded-[32px] border ${overdue ? 'bg-red-50 border-red-100' : 'bg-slate-50 border-slate-100/50'}`}>
                  <p className="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-3">Due Date</p>
                  <div className="flex items-center gap-2">
                     <Calendar className={`w-3.5 h-3.5 ${overdue ? 'text-red-500' : 'text-slate-400'}`} />
                     <span className={`text-sm font-black uppercase tracking-tight ${overdue ? 'text-red-600' : 'text-slate-800'}`}>
                        {task.dueDate ? new Date(task.dueDate).toLocaleDateString(undefined, { month: 'short', day: 'numeric', year: 'numeric' }) : 'TBD'}
                     </span>
                  </div>
               </div>
            </div>

            {/* Description Section */}
            <div className="space-y-4">
               <h4 className="text-xs font-black text-slate-400 uppercase tracking-widest flex items-center gap-2 px-1">
                 <FileSearch className={`w-3.5 h-3.5 ${isBug ? 'text-red-500' : 'text-[#7E96E1]'}`} /> 
                 {isBug ? 'Reproduction Scenario' : 'Project Specification'}
               </h4>
               <div className="p-8 bg-slate-50/50 rounded-[40px] border border-slate-100 min-h-[160px]">
                  {task.description ? (
                    <p className="text-sm font-medium text-slate-600 leading-relaxed whitespace-pre-wrap">
                      {task.description}
                    </p>
                  ) : (
                    <div className="flex flex-col items-center justify-center py-10 opacity-30">
                       <FileText className="w-8 h-8 text-slate-400 mb-2" />
                       <p className="text-xs font-bold uppercase">No specification provided</p>
                    </div>
                  )}
               </div>
            </div>

            <div className="space-y-4">
               <h4 className="text-xs font-black text-slate-400 uppercase tracking-widest flex items-center gap-2 px-1">
                 <User className="w-3.5 h-3.5" /> Assignee Context
               </h4>
               <div className="flex items-center justify-between p-6 bg-white border border-slate-100 rounded-[32px] shadow-sm">
                  <div className="flex items-center gap-4">
                     <div className="w-14 h-14 rounded-2xl overflow-hidden border-2 border-slate-50 shadow-sm">
                        <img src={`https://picsum.photos/seed/${task.assignee.replace(/\s/g, '')}/100/100`} alt="" className="w-full h-full object-cover" />
                     </div>
                     <div>
                        <p className="text-sm font-black text-slate-800">{task.assignee}</p>
                        <p className="text-[10px] font-bold text-slate-400 uppercase">Core Platform Contributor</p>
                     </div>
                  </div>
                  <button className="p-3 bg-slate-50 hover:bg-slate-100 rounded-xl transition-all">
                     <ExternalLink className="w-4 h-4 text-slate-400" />
                  </button>
               </div>
            </div>

            {/* Quality Connections */}
            <div className="space-y-4">
               <h4 className="text-xs font-black text-slate-400 uppercase tracking-widest flex items-center gap-2 px-1">
                 <ShieldCheck className="w-3.5 h-3.5 text-emerald-500" /> Validation Traceability
               </h4>
               <div className="space-y-3">
                  {linkedPlan ? (
                     <div className="p-6 bg-indigo-50 border border-indigo-100 rounded-[32px] flex items-center justify-between group">
                        <div className="flex items-center gap-4">
                           <div className="w-10 h-10 bg-white rounded-xl flex items-center justify-center shadow-sm">
                              <ClipboardList className="w-5 h-5 text-indigo-500" />
                           </div>
                           <div>
                              <p className="text-xs font-black text-slate-800">Test Plan: {linkedPlan.name}</p>
                              <p className="text-[10px] font-bold text-indigo-400 uppercase">Strategy Managed in Strategy Center</p>
                           </div>
                        </div>
                        <button 
                          onClick={() => onViewPlan(linkedPlan.id)}
                          className="px-4 py-2 bg-white text-indigo-600 rounded-xl text-[10px] font-black uppercase tracking-widest shadow-sm hover:bg-indigo-600 hover:text-white transition-all"
                        >
                           Open Plan
                        </button>
                     </div>
                  ) : task.planId && (
                    <div className="p-6 bg-slate-50 border border-slate-200 rounded-[32px] flex items-center gap-4">
                       <AlertCircle className="w-5 h-5 text-amber-500" />
                       <p className="text-xs font-black text-slate-500 uppercase tracking-widest">Broken Plan Link: {task.planId}</p>
                    </div>
                  )}

                  {linkedTestCases.length > 0 ? linkedTestCases.map((tc: any) => (
                    <div 
                      key={tc.id}
                      onClick={() => onViewTestCase(tc.id)}
                      className="p-5 bg-white border border-slate-100 rounded-[28px] hover:border-emerald-400 hover:shadow-md transition-all group cursor-pointer flex items-center justify-between"
                    >
                       <div className="flex items-center gap-4">
                          <div className={`w-10 h-10 rounded-xl flex items-center justify-center ${tc.status === 'Passed' ? 'bg-emerald-50 text-emerald-500' : 'bg-slate-50 text-slate-300'}`}>
                             <ShieldCheck className="w-5 h-5" />
                          </div>
                          <div>
                             <p className="text-xs font-bold text-slate-800 group-hover:text-emerald-600 transition-colors">{tc.title}</p>
                             <p className="text-[9px] font-black text-slate-300 uppercase mt-0.5">{tc.id} • {tc.status}</p>
                          </div>
                       </div>
                       <ChevronRight className="w-4 h-4 text-slate-200 group-hover:translate-x-1 transition-all" />
                    </div>
                  )) : (
                    <div className="py-12 flex flex-col items-center justify-center bg-slate-50/50 rounded-[32px] border-2 border-dashed border-slate-100">
                       <Activity className="w-8 h-8 text-slate-200 mb-2" />
                       <p className="text-[10px] font-black text-slate-300 uppercase tracking-widest">No individual cases linked</p>
                    </div>
                  )}
               </div>
            </div>
          </div>

          {/* Sidebar Intelligence */}
          <div className="lg:col-span-5 space-y-8">
             {/* Integrated Assets */}
             <div className="space-y-4">
                <h4 className="text-xs font-black text-slate-400 uppercase tracking-widest flex items-center gap-2 px-1">
                   <Paperclip className="w-3.5 h-3.5" /> Integrated Assets
                </h4>
                <div className="space-y-2">
                   {task.attachments && task.attachments.length > 0 ? task.attachments.map((file) => (
                      <div key={file.id} className="p-4 bg-white border border-slate-100 rounded-3xl shadow-sm flex items-center justify-between group hover:shadow-md transition-all">
                         <div className="flex items-center gap-3 min-w-0">
                            <div className="w-10 h-10 bg-slate-50 rounded-xl flex items-center justify-center flex-shrink-0 group-hover:bg-slate-100 transition-colors">
                               {getFileIcon(file.type)}
                            </div>
                            <div className="truncate">
                               <p className="text-xs font-bold text-slate-800 truncate">{file.name}</p>
                               <p className="text-[9px] font-black text-slate-400 uppercase">{formatSize(file.size)}</p>
                            </div>
                         </div>
                         <a 
                            href={file.url} 
                            download={file.name}
                            className="p-3 bg-slate-50 hover:bg-[#1C1D2A] text-slate-400 hover:text-white rounded-xl transition-all"
                         >
                            <Download className="w-4 h-4" />
                         </a>
                      </div>
                   )) : (
                      <div className="p-8 bg-slate-50/50 border-2 border-dashed border-slate-100 rounded-[32px] text-center">
                         <Paperclip className="w-6 h-6 text-slate-200 mx-auto mb-2" />
                         <p className="text-[10px] font-black text-slate-300 uppercase">No documentation attached</p>
                      </div>
                   )}
                </div>
             </div>

             {/* AI Risk Assessment */}
             <div className="bg-[#1C1D2A] rounded-[40px] p-8 text-white relative overflow-hidden shadow-xl">
                <div className="relative z-10 space-y-6">
                   <div className="flex items-center gap-3">
                      <div className="w-10 h-10 bg-purple-500/20 rounded-xl flex items-center justify-center backdrop-blur-md">
                         <Cpu className="w-5 h-5 text-purple-400" />
                      </div>
                      <h4 className="text-sm font-black uppercase tracking-widest">AI Integrity Scan</h4>
                   </div>
                   <p className="text-slate-400 text-xs leading-relaxed italic">
                     "Assessment of '{task.id}' indicates a <span className="text-emerald-400 font-bold">Low flakiness risk</span>. Historical data for {task.assignee} shows a 94% first-time pass rate for similar {isBug ? 'fixes' : 'features'}."
                   </p>
                   <div className="pt-2">
                      <div className="flex justify-between text-[9px] font-black uppercase mb-1.5 text-slate-500">
                         <span>Deployment Readiness</span>
                         <span>88%</span>
                      </div>
                      <div className="w-full h-1 bg-white/5 rounded-full overflow-hidden">
                         <div className="h-full bg-purple-500 w-[88%] rounded-full shadow-[0_0_10px_rgba(168,85,247,0.5)]"></div>
                      </div>
                   </div>
                </div>
                <div className="absolute -bottom-10 -right-10 w-32 h-32 bg-purple-500/10 rounded-full blur-3xl"></div>
             </div>

             {/* Activity Timeline */}
             <div className="bg-white rounded-[40px] p-8 border border-slate-100 shadow-sm space-y-6">
                <h4 className="text-xs font-black text-slate-800 uppercase tracking-widest flex items-center gap-2">
                   <History className="w-4 h-4 text-[#7E96E1]" />
                   Transaction Log
                </h4>
                <div className="space-y-6 relative pl-4">
                   <div className="absolute left-4 top-0 bottom-0 w-0.5 bg-slate-50"></div>
                   
                   <div className="relative pl-6">
                      <div className="absolute left-[-5px] top-1.5 w-2.5 h-2.5 rounded-full bg-[#7E96E1] ring-4 ring-white"></div>
                      <div>
                         <p className="text-[10px] font-black text-slate-800">Status updated to '{task.status}'</p>
                         <p className="text-[9px] font-bold text-slate-400 uppercase">2 hours ago</p>
                      </div>
                   </div>

                   <div className="relative pl-6">
                      <div className="absolute left-[-5px] top-1.5 w-2.5 h-2.5 rounded-full bg-slate-200 ring-4 ring-white"></div>
                      <div>
                         <p className="text-[10px] font-black text-slate-800">Assigned to {task.assignee}</p>
                         <p className="text-[9px] font-bold text-slate-400 uppercase">Yesterday</p>
                      </div>
                   </div>

                   <div className="relative pl-6">
                      <div className="absolute left-[-5px] top-1.5 w-2.5 h-2.5 rounded-full bg-emerald-400 ring-4 ring-white"></div>
                      <div>
                         <p className="text-[10px] font-black text-slate-800">Entity Created</p>
                         <p className="text-[9px] font-bold text-slate-400 uppercase">3 days ago</p>
                      </div>
                   </div>
                </div>
             </div>
          </div>
        </div>

        {/* Footer */}
        <div className="p-8 border-t border-slate-50 bg-slate-50/50 flex items-center justify-between px-10">
           <div className="flex items-center gap-3 text-slate-400">
              <Zap className="w-4 h-4 text-[#E85D3F]" />
              <p className="text-[10px] font-bold uppercase tracking-tight">System trace active. All metadata is synced with the project root.</p>
           </div>
           <div className="flex gap-3">
              <button 
                onClick={onClose}
                className="px-8 py-3 bg-white border border-slate-200 text-slate-800 font-black text-xs uppercase tracking-widest rounded-2xl hover:bg-slate-100 transition-all"
              >
                Close View
              </button>
              <button 
                className="px-8 py-3 bg-[#1C1D2A] text-white font-black text-xs uppercase tracking-widest rounded-2xl hover:bg-slate-800 shadow-lg transition-all"
              >
                Enter Execution Mode
              </button>
           </div>
        </div>
      </div>
    </div>
  );
}; *@
