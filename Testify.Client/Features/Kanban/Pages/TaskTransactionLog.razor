                                    }`}>{log.details.to}</div>
                                 </div>
                              ) : log.details.note && (
                                 <p className="text-sm font-medium text-slate-600 leading-relaxed italic">
                                    "{log.details.note}"
                                 </p>
                              )}
                           </div>
                        )}
                     </div>
                  </div>
                ))}
              </div>
           </div>
        </div>
      </div>
    </div>
  );
};
