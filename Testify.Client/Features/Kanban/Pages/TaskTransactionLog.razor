@page "/projects/{ProjectId:int}/kanban/tasks/{TaskId:int}/log"
@using Microsoft.AspNetCore.Authorization
@using Testify.Client.Interfaces
@using Testify.Shared.DTOs.KanbanTasks
@using Testify.Shared.DTOs.TaskActivity
@inject IKanbanTaskService KanbanTaskService
@inject NavigationManager Navigation
@attribute [Authorize]
@rendermode InteractiveWebAssembly

<PageTitle>Audit Trail</PageTitle>

<div class="animate-in fade-in slide-in-from-right-4 px-5 pt-3 pb-20 duration-500">
    @if (_isLoading)
    {
        <div class="flex h-96 items-center justify-center">
            <div class="h-10 w-10 animate-spin rounded-full border-b-2 border-[#7E96E1]"></div>
        </div>
    }
    else if (_task == null)
    {
        <div class="rounded border border-red-200 bg-red-50 px-4 py-3 text-red-700">
            Task not found.
        </div>
    }
    else
    {
        @* Header *@
        <div class="mb-10 flex flex-col justify-between gap-6 md:flex-row md:items-end">
            <div class="flex items-center gap-5">
                <button @onclick="GoBack"
                        class="rounded-[22px] border border-slate-100 bg-white p-4 text-slate-400 shadow-sm transition-all hover:bg-slate-50 hover:text-slate-800">
                    <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                    </svg>
                </button>
                <div>
                    <div class="mb-2 flex items-center gap-2">
                        <span class="rounded-lg bg-[#1C1D2A] px-3 py-0.5 font-black tracking-widest text-[10px] text-white uppercase">
                            Audit Trail
                        </span>
                        <span class="font-black tracking-widest text-[10px] text-slate-300 uppercase">TASK-@_task.Id</span>
                    </div>
                    <h2 class="text-4xl leading-none font-black tracking-tight text-slate-800">@_task.Title</h2>
                </div>
            </div>

            <button class="flex items-center gap-2 rounded-2xl border border-slate-200 bg-white px-8 py-4 text-xs font-black tracking-widest text-slate-800 uppercase shadow-sm transition-all hover:bg-slate-50">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                </svg>
                Export Ledger
            </button>
        </div>

        <div class="grid grid-cols-1 gap-10 lg:grid-cols-12">
            @* Sidebar Filters *@
            <div class="space-y-6 lg:col-span-3">
                <div class="space-y-8 rounded-[40px] border border-slate-100 bg-white p-8 shadow-sm">
                    <div>
                        <h4 class="mb-4 font-black tracking-widest text-[10px] text-slate-400 uppercase">Event Filtering</h4>
                        <div class="space-y-2">
                            @foreach (var filter in _filters)
                            {
                                <button @onclick="@(() => _activeFilter = filter)"
                                        class="flex w-full items-center justify-between rounded-2xl px-5 py-3 text-xs font-bold transition-all @(_activeFilter == filter ? "bg-slate-900 text-white shadow-lg" : "text-slate-500 hover:bg-slate-50")">
                                    @filter
                                    @if (_activeFilter == filter)
                                    {
                                        <div class="h-1.5 w-1.5 animate-pulse rounded-full bg-blue-400"></div>
                                    }
                                </button>
                            }
                        </div>
                    </div>

                    <div class="border-t border-slate-50 pt-8">
                        <h4 class="mb-4 font-black tracking-widest text-[10px] text-slate-400 uppercase">Entity Integrity</h4>
                        <div class="flex items-center gap-3 rounded-3xl border border-emerald-100 bg-emerald-50 p-5">
                            <svg class="h-5 w-5 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                            </svg>
                            <div>
                                <p class="font-black text-[10px] text-emerald-600 uppercase">Audit Verified</p>
                                <p class="font-bold text-[9px] text-emerald-500/80">100% Traceability</p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="relative overflow-hidden rounded-[40px] bg-gradient-to-br from-[#7E96E1] to-[#6379c9] p-8 text-white shadow-xl">
                    <div class="relative z-10 space-y-4">
                        <svg class="h-6 w-6 text-blue-100" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <circle cx="12" cy="12" r="10" stroke-width="2" />
                            <line x1="12" x2="12" y1="8" y2="12" stroke-linecap="round" stroke-width="2" />
                            <line x1="12" x2="12.01" y1="16" y2="16" stroke-linecap="round" stroke-width="2" />
                        </svg>
                        <h5 class="text-sm font-black tracking-widest uppercase">Compliance Logic</h5>
                        <p class="text-xs leading-relaxed font-medium text-blue-50 opacity-90">
                            This transaction log is immutable and synchronized with the global project repository.
                        </p>
                    </div>
                    <svg class="absolute -right-4 -bottom-4 h-24 w-24 text-white/10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" />
                    </svg>
                </div>
            </div>

            @* Timeline Content *@
            <div class="space-y-6 lg:col-span-9">
                <div class="relative rounded-[48px] border border-slate-100 bg-white p-10 shadow-sm">
                    <div class="absolute top-24 bottom-10 left-[67px] hidden w-0.5 bg-slate-100 md:block"></div>

                    @if (!FilteredLogs.Any())
                    {
                        <div class="flex flex-col items-center justify-center py-20 opacity-40">
                            <svg class="mb-3 h-10 w-10 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                            </svg>
                            <p class="text-sm font-black text-slate-400 uppercase">No events found</p>
                        </div>
                    }
                    else
                    {
                        <div class="relative z-10 space-y-12">
                            @foreach (var log in FilteredLogs)
                            {
                                <div class="flex flex-col gap-8 md:flex-row">
                                    @* Timeline Marker *@
                                    <div class="hidden w-10 shrink-0 flex-col items-center md:flex">
                                        <div class="z-20 flex h-10 w-10 items-center justify-center rounded-2xl border-4 border-slate-50 bg-white shadow-sm">
                                            @GetLogIcon(log.Action)
                                        </div>
                                        <span class="mt-2 font-black whitespace-nowrap text-[8px] text-slate-300 uppercase">#@log.Id</span>
                                    </div>

                                    @* Log Card *@
                                    <div class="flex-1 rounded-[32px] border border-slate-100 bg-slate-50/50 p-8 transition-all hover:border-[#7E96E1]/20 hover:bg-white">
                                        <div class="mb-6 flex flex-col justify-between gap-4 md:flex-row md:items-center">
                                            <div class="space-y-1">
                                                <h5 class="text-lg font-black text-slate-800">@log.Action</h5>
                                                <div class="flex items-center gap-3">
                                                    <div class="flex items-center gap-1.5">
                                                        <div class="flex h-5 w-5 items-center justify-center overflow-hidden rounded-lg bg-slate-200">
                                                            <svg class="h-3 w-3 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                                                            </svg>
                                                        </div>
                                                        <span class="font-black text-[10px] text-slate-500 uppercase">@log.FullName</span>
                                                    </div>
                                                    <div class="h-1 w-1 rounded-full bg-slate-300"></div>
                                                    <span class="flex items-center gap-1 font-bold text-[10px] text-slate-400 uppercase">
                                                        <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                            <circle cx="12" cy="12" r="10" stroke-width="2" />
                                                            <polyline points="12 6 12 12 16 14" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" />
                                                        </svg>
                                                        @FormatRelativeTime(log.CreatedAt)
                                                    </span>
                                                </div>
                                            </div>
                                            <span class="rounded-full px-4 py-1.5 font-black tracking-widest text-[9px] uppercase @GetLogTypeBadgeClass(log.Action)">
                                                @GetLogTypeLabel(log.Action)
                                            </span>
                                        </div>

                                        @if (!string.IsNullOrEmpty(log.OldValue) || !string.IsNullOrEmpty(log.NewValue) || !string.IsNullOrEmpty(log.Description))
                                        {
                                            <div class="space-y-4 rounded-2xl border border-slate-100 bg-white p-6 transition-all hover:shadow-sm">
                                                @if (!string.IsNullOrEmpty(log.OldValue) && !string.IsNullOrEmpty(log.NewValue))
                                                {
                                                    <div class="flex items-center gap-4">
                                                        <div class="rounded-lg bg-slate-100 px-3 py-1 font-black text-[10px] text-slate-400 line-through">@log.OldValue</div>
                                                        <svg class="h-4 w-4 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                                                        </svg>
                                                        <div class="rounded-lg px-3 py-1 font-black text-[10px] @(GetLogTypeLabel(log.Action) == "State" ? "bg-blue-500 text-white shadow-lg shadow-blue-100" : "bg-purple-500 text-white")">
                                                            @log.NewValue
                                                        </div>
                                                    </div>
                                                }
                                                else if (!string.IsNullOrEmpty(log.Description))
                                                {
                                                    <p class="text-sm leading-relaxed font-medium text-slate-600 italic">"@log.Description"</p>
                                                }
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public int ProjectId { get; set; }
    [Parameter] public int TaskId { get; set; }

    private KanbanTaskResponse? _task;
    private List<TaskActivityResponse> _activities = new();
    private bool _isLoading = true;
    private string _activeFilter = "All";

    private readonly string[] _filters = ["All", "State", "Personnel", "Metadata"];

    private IEnumerable<TaskActivityResponse> FilteredLogs => _activeFilter switch
    {
        "State" => _activities.Where(a => a.Action is "Created" or "Status Changed"),
        "Personnel" => _activities.Where(a => a.Action is "Assignee Changed"),
        "Metadata" => _activities.Where(a => a.Action is "Updated" or "Priority Changed" or "Type Changed" or "Milestone Changed" or "Due Date Changed"),
        _ => _activities
    };

    protected override async Task OnParametersSetAsync()
    {
        _isLoading = true;
        try
        {
            _task = await KanbanTaskService.GetTaskByIdAsync(TaskId);
            _activities = await KanbanTaskService.GetTaskActivitiesAsync(TaskId);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Failed to load audit trail: {ex.Message}");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void GoBack() => Navigation.NavigateTo($"/projects/{ProjectId}/kanban");

    private string GetLogTypeLabel(string action) => action switch
    {
        "Created" or "Status Changed" => "State",
        "Assignee Changed" => "Personnel",
        "Updated" or "Priority Changed" or "Type Changed" or "Milestone Changed" or "Due Date Changed" => "Metadata",
        _ => "Event"
    };

    private string GetLogTypeBadgeClass(string action) => GetLogTypeLabel(action) switch
    {
        "State" => "bg-blue-50 text-blue-500",
        "Personnel" => "bg-purple-50 text-purple-500",
        "Metadata" => "bg-orange-50 text-[#E85D3F]",
        _ => "bg-emerald-50 text-emerald-500"
    };

    private string FormatRelativeTime(DateTime dateTime)
    {
        var timeSpan = DateTime.Now - dateTime;
        if (timeSpan.TotalMinutes < 1) return "Just now";
        if (timeSpan.TotalMinutes < 60) return $"{(int)timeSpan.TotalMinutes} min ago";
        if (timeSpan.TotalHours < 24) return $"{(int)timeSpan.TotalHours} hours ago";
        if (timeSpan.TotalDays < 7) return $"{(int)timeSpan.TotalDays} days ago";
        return dateTime.ToString("MMM dd, yyyy");
    }

    private RenderFragment GetLogIcon(string action) => action switch
    {
        "Created" => @<svg class="h-4 w-4 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
        </svg>,

        "Status Changed" => @<svg class="h-4 w-4 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
        </svg>,

        "Priority Changed" => @<svg class="h-4 w-4 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
        </svg>,

        "Assignee Changed" => @<svg class="h-4 w-4 text-purple-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
        </svg>,

        "Type Changed" => @<svg class="h-4 w-4 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
        </svg>,

        "Milestone Changed" => @<svg class="h-4 w-4 text-pink-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>,

        "Due Date Changed" => @<svg class="h-4 w-4 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <rect width="18" height="18" x="3" y="4" rx="2" ry="2" stroke-width="2" />
            <line x1="16" x2="16" y1="2" y2="6" stroke-linecap="round" stroke-width="2" />
            <line x1="8" x2="8" y1="2" y2="6" stroke-linecap="round" stroke-width="2" />
            <line x1="3" x2="21" y1="10" y2="10" stroke-linecap="round" stroke-width="2" />
        </svg>,

        "Updated" => @<svg class="h-4 w-4 text-[#7E96E1]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
        </svg>,

        _ => @<svg class="h-4 w-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
    };
}


