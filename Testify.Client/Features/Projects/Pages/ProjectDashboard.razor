@page "/projects/{Id:int}"
@using Testify.Client.Features.Kanban.Pages
@using Testify.Client.Features.TestPlans.Pages
@using Testify.Shared.DTOs.Projects
@using Testify.Client.Features.Milestones.Components
@using Testify.Client.Features.Projects.Components
@using Testify.Client.Interfaces
@using Testify.Shared.Enums
@inject IProjectService ProjectService
@inject NavigationManager Navigation
@inject IMilestoneService MilestoneService
@rendermode InteractiveWebAssembly

<div class="min-h-screen bg-white text-slate-900">
    <div class="animate-in fade-in mx-auto max-w-[1400px] px-6 pt-8 pb-24 duration-700">

        @if (isLoading)
        {
            <div class="flex h-screen w-full items-center justify-center">
                <div class="h-12 w-12 animate-spin rounded-full border-4 border-slate-200 border-t-[#E85D3F]"></div>
            </div>
        }
        else if (project == null)
        {
            <div class="flex h-screen w-full flex-col items-center justify-center gap-4 text-center">
                <h2 class="text-2xl font-bold text-slate-800">Project Not Found</h2>
                <a href="/projects" class="font-bold text-[#E85D3F] hover:underline">Return to Projects</a>
            </div>
        }
        else
        {
            @* Breadcrumb / Back button *@
            <div class="mb-6 flex items-center gap-4">
                <button @onclick='() => Navigation.NavigateTo("/projects")'
                        class="p-2 hover:bg-white rounded-xl transition-all text-slate-400 hover:text-slate-800 border border-transparent hover:border-slate-100">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="m15 18-6-6 6-6" />
                    </svg>
                </button>
                <div class="flex items-center gap-3">
                    <div class="h-3 w-3 rounded-full" style="background-color: @(project.Color ?? "#E85D3F")"></div>
                    <span class="text-sm font-black tracking-tight tracking-widest text-slate-800 uppercase">@project.Name</span>
                    <span class="mx-1 text-slate-300">/</span>
                    <span class="text-sm font-bold text-slate-400">@activeTab</span>
                </div>
            </div>

            @* Sub-navigation *@
            <div class="no-scrollbar mb-8 flex w-fit max-w-full items-center gap-2 overflow-x-auto rounded-[32px] border border-white bg-white/60 p-1.5 shadow-sm">
                @* Tab Overview *@
                <button @onclick='() => activeTab = "Overview"'
                        class="@(activeTab == "Overview" ? "bg-[#1C1D2A] text-white shadow-lg" : "text-slate-400 hover:text-slate-600 hover:bg-white") flex items-center gap-2 px-6 py-3 rounded-3xl text-sm font-black transition-all whitespace-nowrap">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect width="7" height="9" x="3" y="3" rx="1" />
                        <rect width="7" height="5" x="14" y="3" rx="1" />
                        <rect width="7" height="9" x="14" y="12" rx="1" />
                        <rect width="7" height="5" x="3" y="16" rx="1" />
                    </svg>
                    Overview
                </button>

                @* Tab Board *@
                <button @onclick='() => activeTab = "KanbanBoard"'
                        class="@(activeTab == "Kanban Board" ? "bg-[#1C1D2A] text-white shadow-lg" : "text-slate-400 hover:text-slate-600 hover:bg-white") flex items-center gap-2 px-6 py-3 rounded-3xl text-sm font-black transition-all whitespace-nowrap">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect width="18" height="18" x="3" y="3" rx="2" />
                        <path d="M8 7v7" />
                        <path d="M12 7v4" />
                        <path d="M16 7v10" />
                    </svg>
                    KanbanBoard
                </button>

                @* Tab Milestones *@
                <button @onclick='() => activeTab = "Milestones"'
                        class="@(activeTab == "Milestones" ? "bg-[#1C1D2A] text-white shadow-lg" : "text-slate-400 hover:text-slate-600 hover:bg-white") flex items-center gap-2 px-6 py-3 rounded-3xl text-sm font-black transition-all whitespace-nowrap">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z" />
                        <line x1="4" x2="4" y1="22" y2="15" />
                    </svg>
                    Milestones
                </button>

                @* Tab Strategy (Test Plans) *@
                @if (currentUserRole == ProjectRole.Tester || currentUserRole == ProjectRole.PM)
                {
                    <button @onclick='() => activeTab = "Strategy"'
                            class="@(activeTab == "Strategy" ? "bg-[#1C1D2A] text-white shadow-lg" : "text-slate-400 hover:text-slate-600 hover:bg-white") flex items-center gap-2 px-6 py-3 rounded-3xl text-sm font-black transition-all whitespace-nowrap">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M12 20a8 8 0 1 0 0-16 8 8 0 0 0 0 16Z" />
                            <path d="M12 14a2 2 0 1 0 0-4 2 2 0 0 0 0 4Z" />
                            <path d="M12 2v2" />
                            <path d="M12 22v-2" />
                            <path d="m17 20.66-1-1.73" />
                            <path d="M11 10.27 7 3.34" />
                            <path d="m20.66 17-1.73-1" />
                            <path d="m3.34 7 1.73 1" />
                            <path d="M14 12h8" />
                            <path d="M2 12h2" />
                            <path d="m20.66 7-1.73 1" />
                            <path d="m3.34 17 1.73-1" />
                            <path d="m17 3.34-1 1.73" />
                            <path d="m11 13.73-4 6.93" />
                        </svg>
                        TestPlans
                    </button>
                }

                @* Tab Team *@
                <button @onclick='() => activeTab = "Team"'
                        class="@(activeTab == "Team" ? "bg-[#1C1D2A] text-white shadow-lg" : "text-slate-400 hover:text-slate-600 hover:bg-white") flex items-center gap-2 px-6 py-3 rounded-3xl text-sm font-black transition-all whitespace-nowrap">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" />
                        <circle cx="9" cy="7" r="4" />
                        <path d="M22 21v-2a4 4 0 0 0-3-3.87" />
                        <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                    </svg>
                    Team
                </button>
            </div>

            @* Render Active View *@
            <div class="animate-in fade-in slide-in-from-bottom-4 duration-500">
                @if (activeTab == "Overview")
                {
                    <ProjectOverview ProjectId="@Id" />
                }
                else if (activeTab == "KanbanBoard")
                {
                    <Kanban ProjectId="@Id" />
                }
                else if (activeTab == "Milestones")
                {
                    <MilestoneManager ProjectId="@Id" />
                }
                else if (activeTab == "Strategy")
                {
					<TestPlanManager ProjectId="@Id" />
                }
                else if (activeTab == "Team")
                {
                    <TeamManagement ProjectId="@Id" />
                }
            </div>
        }
    </div>
</div>

@code {
    [Parameter] 
    public int Id { get; set; }

    private ProjectResponse? project;
    private bool isLoading = true;
    private string activeTab = "Overview";
    private ProjectRole? currentUserRole;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            isLoading = true;
            project = await ProjectService.GetProjectByIdAsync(Id);
            currentUserRole = await ProjectService.GetMyRoleInProjectAsync(Id);
        }
        catch (Exception)
        {
            // Handle error or redirect
        }
        finally
        {
            isLoading = false;
        }
    }

}