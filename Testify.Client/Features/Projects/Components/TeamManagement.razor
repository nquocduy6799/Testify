@using Testify.Client.Interfaces
@using Testify.Client.Features.Invitations.Components
@using Testify.Client.Shared.Services
@using Testify.Shared.DTOs.Projects
@using Testify.Shared.DTOs.Invitations
@using Testify.Shared.Enums
@inject IProjectService ProjectService
@inject IInvitationService InvitationService
@inject IServiceProvider ServiceProvider
@implements IAsyncDisposable
<div class="space-y-8 pb-12">
    @* Header *@
    <div class="flex flex-col items-center justify-between gap-6 md:flex-row">
        <div>
            <h2 class="text-3xl font-black tracking-tight text-slate-800">Team Resources</h2>
            <p class="mt-2 font-medium text-slate-400">
                Monitoring bandwidth and allocation across <span class="font-bold text-[#1C1D2A]">@ProjectId</span> contributors.
            </p>
        </div>
        <button @onclick="OpenInviteModal" class="flex items-center gap-3 rounded-[32px] bg-[#1C1D2A] px-8 py-4 text-sm font-black text-white shadow-xl transition-all hover:bg-slate-800 active:scale-95">
            @* Icon: UserPlus (Lucide) *@
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/>
                <circle cx="9" cy="7" r="4"/>
                <line x1="19" x2="19" y1="8" y2="14"/>
                <line x1="22" x2="16" y1="11" y2="11"/>
            </svg>
            Invite Member
        </button>
    </div>

    @if (_isLoadingMembers)
    {
        <div class="flex items-center justify-center py-8">
            <div class="h-6 w-6 animate-spin rounded-full border-2 border-slate-200 border-t-[#E85D3F]"></div>
        </div>
    }
    else if (!_members.Any())
    {
        <div class="flex flex-col items-center justify-center rounded-[60px] border-2 border-dashed border-slate-200 bg-white/40 py-32 text-center">
            <div class="mb-8 flex h-24 w-24 items-center justify-center rounded-[32px] bg-white shadow-sm">
                @* Icon: User (Lucide style) *@
                <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-slate-200">
                    <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/>
                    <circle cx="12" cy="7" r="4"/>
                </svg>
            </div>
            <h3 class="text-2xl font-black text-slate-800">Team is Empty</h3>
            <p class="mt-2 max-w-sm leading-relaxed font-medium text-slate-400">This project hasn't been provisioned with resources yet. Start by inviting your first collaborator.</p>
            <button @onclick="OpenInviteModal" class="mt-8 rounded-2xl bg-[#1C1D2A] px-10 py-4 text-sm font-black tracking-widest text-white uppercase shadow-lg transition-all active:scale-95">
                Provision Member
            </button>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 gap-8 md:grid-cols-2 xl:grid-cols-4">
            @foreach (var member in _members)
            {
                <div class="group relative overflow-hidden rounded-[48px] border border-slate-50 bg-white p-10 shadow-sm transition-all hover:shadow-2xl">
                    @* Role Indicator Bar *@
                    <div class="@GetRoleIndicatorColor(member.Role) absolute top-0 left-0 h-1.5 w-full"></div>

                    <div class="mb-8 flex items-start justify-between">
                        <div class="relative">
                            <div class="h-24 w-24 overflow-hidden rounded-[36px] border-4 border-white shadow-xl">
                                @* Giữ nguyên logic hiển thị Initials của Code 1 nhưng style container giống Code 2 *@
                                <div class="flex h-full w-full items-center justify-center bg-slate-50 text-3xl font-black text-[#1C1D2A]">
                                    @GetInitials(member.FullName ?? member.UserName)
                                </div>
                            </div>
                            @* Status Dot - Real-time *@
                            <div class="absolute -right-1 -bottom-1 h-7 w-7 rounded-full border-4 border-white @GetStatusDotColor(member.UserId)">
                                @if (IsUserOnline(member.UserId))
                                {
                                    <span class="absolute inset-0 animate-ping @GetStatusDotColor(member.UserId) rounded-full opacity-75"></span>
                                }
                            </div>
                        </div>

                        @if (CanManageMember(member))
                        {
                            <button @onclick="() => ConfirmRemoveMember(member)"
                                    disabled="@_isProcessing"
                                    class="p-3 text-slate-300 hover:bg-slate-50 rounded-2xl transition-all">
                                @* Icon: MoreHorizontal (Lucide style) *@
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <circle cx="12" cy="12" r="1"/>
                                    <circle cx="19" cy="12" r="1"/>
                                    <circle cx="5" cy="12" r="1"/>
                                </svg>
                            </button>
                        }
                    </div>

                    <h3 class="text-xl font-black text-slate-800">@(member.FullName ?? member.UserName)</h3>
                    <div class="mt-1 flex items-center gap-2">
                        <span class="font-black tracking-widest text-[10px] uppercase @GetRoleTextColor(member.Role)">@GetRoleName(member.Role)</span>
                        <div class="h-1 w-1 rounded-full bg-slate-200"></div>
                        <span class="font-bold text-[10px] uppercase @GetStatusTextColor(member.UserId)">
                            @(IsUserOnline(member.UserId) ? "Online" : "Offline")
                        </span>
                    </div>

                    <div class="mt-8 grid grid-cols-2 gap-4">
                        <div class="rounded-3xl border border-slate-100/50 bg-slate-50 p-4">
                            <p class="mb-1 font-black tracking-tighter text-[10px] text-slate-400 uppercase">In-Flight</p>
                            <p class="text-2xl font-black text-slate-800">-</p>
                        </div>
                        <div class="rounded-3xl border border-slate-100/50 bg-slate-50 p-4">
                            <p class="mb-1 font-black tracking-tighter text-[10px] text-slate-400 uppercase">Velocity</p>
                            <p class="text-2xl font-black text-[#7E96E1]">-</p>
                        </div>
                    </div>

                    <div class="mt-8 flex gap-3">
                        <button class="flex flex-1 items-center justify-center rounded-[22px] bg-slate-50 py-4 text-slate-400 transition-colors hover:bg-slate-100">
                            @* Icon: Mail (Lucide style) *@
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <rect width="20" height="16" x="2" y="4" rx="2"/>
                                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
                            </svg>
                        </button>
                        <button class="flex flex-1 items-center justify-center rounded-[22px] bg-slate-50 py-4 text-slate-400 transition-colors hover:bg-slate-100">
                            @* Icon: Phone (Lucide style) *@
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
                            </svg>
                        </button>
                    </div>
                </div>
            }
        </div>
    }


    @* Confirmation Dialog *@
    @if (_memberToRemove != null)
    {
        <div class="fixed inset-0 z-[200] flex items-center justify-center">
            <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" @onclick="CancelRemove"></div>
            <div class="relative z-10 w-full max-w-sm rounded-3xl bg-white p-6 shadow-2xl">
                <h3 class="mb-2 text-lg font-bold text-slate-800">Remove Member</h3>
                <p class="mb-6 text-sm text-slate-500">
                    Are you sure you want to remove <strong>@(_memberToRemove.FullName ?? _memberToRemove.UserName)</strong> from this project?
                </p>
                <div class="flex gap-3">
                    <button @onclick="CancelRemove" class="flex-1 cursor-pointer rounded-2xl border border-slate-200 bg-white px-4 py-2.5 text-sm font-bold text-slate-600 hover:bg-slate-50">
                        Cancel
                    </button>
                    <button @onclick="ExecuteRemoveMember" disabled="@_isProcessing" class="flex-1 cursor-pointer rounded-2xl bg-red-500 px-4 py-2.5 text-sm font-bold text-white hover:bg-red-600 disabled:opacity-50">
                        @if (_isProcessing)
                        {
                            <span>Removing...</span>
                        }
                        else
                        {
                            <span>Remove</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    }
</div>

@* Invite Member Modal *@
<InviteMemberModal
    IsVisible="_showInviteModal"
    ProjectId="ProjectId"
    OnClose="CloseInviteModal"
    OnInvitationSent="OnInvitationSent"/>

@code {
    [Parameter] public int ProjectId { get; set; }

    private List<TeamMemberResponse> _members = new();
    private List<PendingInvitationResponse> _pendingInvitations = new();
    private bool _isLoadingMembers;
#pragma warning disable CS0414
    private bool _isLoadingInvitations;
#pragma warning restore CS0414
    private bool _isProcessing;
    private bool _showInviteModal;
    private TeamMemberResponse? _memberToRemove;
    private NotificationHubService? _hubService;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Get HubService if available (WebAssembly mode)
            _hubService = ServiceProvider.GetService<NotificationHubService>();
            
            if (_hubService != null)
            {
                // Start the hub connection if not already connected
                if (!_hubService.IsConnected)
                {
                    Console.WriteLine("[TeamManagement] Starting SignalR connection...");
                    await _hubService.StartAsync();
                }
                
                // Subscribe to status changes
                _hubService.OnUserStatusChanged += HandleUserStatusChanged;
                
                // Subscribe to team member changes
                _hubService.OnTeamMemberAdded += HandleTeamMemberAdded;
                _hubService.OnTeamMemberRemoved += HandleTeamMemberRemoved;
                
                Console.WriteLine("[TeamManagement] Subscribed to real-time events");
                
                // Force a re-render after connection to update status dots
                await Task.Delay(500); // Wait for initial online users to load
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    private void HandleUserStatusChanged(string userId, bool isOnline)
    {
        // Check if this user is in our team
        if (_members.Any(m => m.UserId == userId))
        {
            Console.WriteLine($"[TeamManagement] Team member {userId} is now {(isOnline ? "ONLINE" : "OFFLINE")}");
            // Trigger UI update
            InvokeAsync(StateHasChanged);
        }
    }

    private async void HandleTeamMemberAdded(int projectId, string userId, string userName)
    {
        // Only reload if this is our project
        if (projectId == ProjectId)
        {
            Console.WriteLine($"[TeamManagement] New member {userName} added to project {projectId}, reloading...");
            await InvokeAsync(async () =>
            {
                await LoadMembers();
                StateHasChanged();
            });
        }
    }

    private async void HandleTeamMemberRemoved(int projectId, string userId)
    {
        // Only reload if this is our project
        if (projectId == ProjectId)
        {
            Console.WriteLine($"[TeamManagement] Member {userId} removed from project {projectId}, reloading...");
            await InvokeAsync(async () =>
            {
                await LoadMembers();
                StateHasChanged();
            });
        }
    }

    private async Task LoadData()
    {
        await Task.WhenAll(LoadMembers(), LoadPendingInvitations());
    }

    private async Task LoadMembers()
    {
        _isLoadingMembers = true;
        try
        {
            _members = await ProjectService.GetMembersAsync(ProjectId);
        }
        finally
        {
            _isLoadingMembers = false;
        }
    }

    private async Task LoadPendingInvitations()
    {
        _isLoadingInvitations = true;
        try
        {
            _pendingInvitations = await InvitationService.GetPendingInvitationsAsync(ProjectId);
        }
        finally
        {
            _isLoadingInvitations = false;
        }
    }

    private void OpenInviteModal()
    {
        _showInviteModal = true;
    }

    private void CloseInviteModal()
    {
        _showInviteModal = false;
    }

    private async Task OnInvitationSent()
    {
        // Auto-refresh pending invitations when a new invite is sent
        await LoadPendingInvitations();
    }

    private void ConfirmRemoveMember(TeamMemberResponse member)
    {
        _memberToRemove = member;
    }

    private void CancelRemove()
    {
        _memberToRemove = null;
    }

    private async Task ExecuteRemoveMember()
    {
        if (_memberToRemove == null) return;

        _isProcessing = true;
        try
        {
            var success = await ProjectService.RemoveMemberAsync(ProjectId, _memberToRemove.Id);
            if (success)
            {
                await LoadMembers();
            }
        }
        finally
        {
            _isProcessing = false;
            _memberToRemove = null;
        }
    }

    private async Task RevokeInvitation(PendingInvitationResponse invitation)
    {
        _isProcessing = true;
        try
        {
            var success = await InvitationService.RevokeInvitationAsync(invitation.Id);
            if (success)
            {
                await LoadPendingInvitations();
            }
        }
        finally
        {
            _isProcessing = false;
        }
    }

    private static string GetInitials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2)
            return $"{parts[0][0]}{parts[1][0]}".ToUpper();
        return parts[0].Length >= 2 ? parts[0][..2].ToUpper() : parts[0].ToUpper();
    }

    private static string GetRoleName(ProjectRole role) => role switch
    {
        ProjectRole.PM => "Project Manager",
        ProjectRole.Tester => "Tester",
        ProjectRole.Dev => "Developer",
        _ => role.ToString()
    };

    private static string GetRoleBadgeClass(ProjectRole role) => role switch
    {
        ProjectRole.PM => "bg-purple-100 text-purple-700",
        ProjectRole.Tester => "bg-blue-100 text-blue-700",
        ProjectRole.Dev => "bg-emerald-100 text-emerald-700",
        _ => "bg-slate-100 text-slate-700"
    };

    private static string FormatDate(DateTime date)
    {
        var diff = DateTime.Now - date;
        if (diff.TotalMinutes < 1) return "just now";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours}h ago";
        if (diff.TotalDays < 7) return $"{(int)diff.TotalDays}d ago";
        return date.ToString("MMM dd");
    }

    private static string GetRoleIndicatorColor(ProjectRole role) => role switch
    {
        ProjectRole.Dev => "bg-blue-400",
        ProjectRole.Tester => "bg-emerald-400",
        ProjectRole.PM => "bg-[#E85D3F]",
        _ => "bg-slate-400"
    };

    private static string GetRoleTextColor(ProjectRole role) => role switch
    {
        ProjectRole.Dev => "text-blue-500",
        ProjectRole.Tester => "text-emerald-500",
        ProjectRole.PM => "text-[#E85D3F]",
        _ => "text-slate-500"
    };

    private bool CanManageMember(TeamMemberResponse member)
    {
        // Can't remove yourself or the last PM
        return member.Role != ProjectRole.PM || _members.Count(m => m.Role == ProjectRole.PM) > 1;
    }

    private bool IsUserOnline(string userId)
    {
        return _hubService?.IsUserOnline(userId) ?? false;
    }

    private string GetStatusDotColor(string userId)
    {
        return IsUserOnline(userId) ? "bg-emerald-500" : "bg-slate-300";
    }

    private string GetStatusTextColor(string userId)
    {
        return IsUserOnline(userId) ? "text-emerald-500" : "text-slate-400";
    }

    public async ValueTask DisposeAsync()
    {
        if (_hubService != null)
        {
            _hubService.OnUserStatusChanged -= HandleUserStatusChanged;
            _hubService.OnTeamMemberAdded -= HandleTeamMemberAdded;
            _hubService.OnTeamMemberRemoved -= HandleTeamMemberRemoved;
        }
    }

}
