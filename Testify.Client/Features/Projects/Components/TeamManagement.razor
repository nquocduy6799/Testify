@using Testify.Client.Interfaces
@using Testify.Client.Features.Invitations.Components
@using Testify.Shared.DTOs.Projects
@using Testify.Shared.DTOs.Invitations
@using Testify.Shared.Enums
@inject IProjectService ProjectService
@inject IInvitationService InvitationService
<div class="space-y-8 pb-12">
    @* Header *@
    <div class="flex flex-col md:flex-row justify-between items-center gap-6">
        <div>
            <h2 class="text-3xl font-black text-slate-800 tracking-tight">Team Resources</h2>
            <p class="text-slate-400 mt-2 font-medium">
                Monitoring bandwidth and allocation across <span class="text-[#1C1D2A] font-bold">@ProjectId</span> contributors.
            </p>
        </div>
        <button @onclick="OpenInviteModal" class="bg-[#1C1D2A] text-white px-8 py-4 rounded-[32px] font-black text-sm flex items-center gap-3 hover:bg-slate-800 transition-all shadow-xl active:scale-95">
            @* Icon: UserPlus (Lucide) *@
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/>
                <circle cx="9" cy="7" r="4"/>
                <line x1="19" x2="19" y1="8" y2="14"/>
                <line x1="22" x2="16" y1="11" y2="11"/>
            </svg>
            Invite Member
        </button>
    </div>

    @if (_isLoadingMembers)
    {
        <div class="flex items-center justify-center py-8">
            <div class="h-6 w-6 animate-spin rounded-full border-2 border-slate-200 border-t-[#E85D3F]"></div>
        </div>
    }
    else if (!_members.Any())
    {
        <div class="py-32 flex flex-col items-center justify-center text-center bg-white/40 rounded-[60px] border-2 border-dashed border-slate-200">
            <div class="w-24 h-24 bg-white rounded-[32px] flex items-center justify-center shadow-sm mb-8">
                @* Icon: User (Lucide style) *@
                <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-slate-200">
                    <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/>
                    <circle cx="12" cy="7" r="4"/>
                </svg>
            </div>
            <h3 class="text-2xl font-black text-slate-800">Team is Empty</h3>
            <p class="text-slate-400 max-w-sm mt-2 font-medium leading-relaxed">This project hasn't been provisioned with resources yet. Start by inviting your first collaborator.</p>
            <button @onclick="OpenInviteModal" class="mt-8 px-10 py-4 bg-[#1C1D2A] text-white rounded-2xl font-black text-sm uppercase tracking-widest shadow-lg active:scale-95 transition-all">
                Provision Member
            </button>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-8">
            @foreach (var member in _members)
            {
                <div class="bg-white rounded-[48px] p-10 border border-slate-50 shadow-sm hover:shadow-2xl transition-all group relative overflow-hidden">
                    @* Role Indicator Bar *@
                    <div class="@GetRoleIndicatorColor(member.Role) absolute top-0 left-0 w-full h-1.5"></div>

                    <div class="flex justify-between items-start mb-8">
                        <div class="relative">
                            <div class="w-24 h-24 rounded-[36px] overflow-hidden border-4 border-white shadow-xl">
                                @* Giữ nguyên logic hiển thị Initials của Code 1 nhưng style container giống Code 2 *@
                                <div class="w-full h-full bg-slate-50 flex items-center justify-center text-[#1C1D2A] font-black text-3xl">
                                    @GetInitials(member.FullName ?? member.UserName)
                                </div>
                            </div>
                            @* Status Dot *@
                            <div class="absolute -bottom-1 -right-1 w-7 h-7 rounded-full border-4 border-white bg-emerald-500"></div>
                        </div>

                        @if (CanManageMember(member))
                        {
                            <button @onclick="() => ConfirmRemoveMember(member)"
                                    disabled="@_isProcessing"
                                    class="p-3 text-slate-300 hover:bg-slate-50 rounded-2xl transition-all">
                                @* Icon: MoreHorizontal (Lucide style) *@
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <circle cx="12" cy="12" r="1"/>
                                    <circle cx="19" cy="12" r="1"/>
                                    <circle cx="5" cy="12" r="1"/>
                                </svg>
                            </button>
                        }
                    </div>

                    <h3 class="text-xl font-black text-slate-800">@(member.FullName ?? member.UserName)</h3>
                    <div class="flex items-center gap-2 mt-1">
                        <span class="text-[10px] font-black uppercase tracking-widest @GetRoleTextColor(member.Role)">@GetRoleName(member.Role)</span>
                        <div class="w-1 h-1 bg-slate-200 rounded-full"></div>
                        <span class="text-[10px] font-bold text-slate-400 uppercase">Online</span>
                    </div>

                    <div class="mt-8 grid grid-cols-2 gap-4">
                        <div class="bg-slate-50 p-4 rounded-3xl border border-slate-100/50">
                            <p class="text-[10px] font-black text-slate-400 uppercase tracking-tighter mb-1">In-Flight</p>
                            <p class="text-2xl font-black text-slate-800">-</p>
                        </div>
                        <div class="bg-slate-50 p-4 rounded-3xl border border-slate-100/50">
                            <p class="text-[10px] font-black text-slate-400 uppercase tracking-tighter mb-1">Velocity</p>
                            <p class="text-2xl font-black text-[#7E96E1]">-</p>
                        </div>
                    </div>

                    <div class="mt-8 flex gap-3">
                        <button class="flex-1 py-4 bg-slate-50 hover:bg-slate-100 rounded-[22px] transition-colors flex items-center justify-center text-slate-400">
                            @* Icon: Mail (Lucide style) *@
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <rect width="20" height="16" x="2" y="4" rx="2"/>
                                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
                            </svg>
                        </button>
                        <button class="flex-1 py-4 bg-slate-50 hover:bg-slate-100 rounded-[22px] transition-colors flex items-center justify-center text-slate-400">
                            @* Icon: Phone (Lucide style) *@
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
                            </svg>
                        </button>
                    </div>
                </div>
            }
        </div>
    }

    @* Section B: Pending Invitations - Giữ nguyên layout cũ vì Code 2 không cung cấp mẫu cho phần này, nhưng làm sạch icon *@
    <div class="rounded-3xl border border-slate-100 bg-white p-6 shadow-sm">
        <div class="mb-4 flex items-center justify-between">
            <h3 class="text-sm font-bold text-slate-800">Pending Invitations</h3>
            @if (_pendingInvitations.Any())
            {
                <span class="rounded-full bg-amber-100 px-2.5 py-0.5 text-xs font-bold text-amber-700">
                    @_pendingInvitations.Count pending
                </span>
            }
        </div>

        @if (_isLoadingInvitations)
        {
            <div class="flex items-center justify-center py-8">
                <div class="h-6 w-6 animate-spin rounded-full border-2 border-slate-200 border-t-[#E85D3F]"></div>
            </div>
        }
        else if (!_pendingInvitations.Any())
        {
            <div class="py-8 text-center">
                <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="mx-auto mb-3 text-slate-300">
                    <rect width="20" height="16" x="2" y="4" rx="2"/>
                    <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
                </svg>
                <p class="text-sm text-slate-400">No pending invitations</p>
            </div>
        }
        else
        {
            <div class="space-y-3">
                @foreach (var invitation in _pendingInvitations)
                {
                    <div class="flex items-center justify-between rounded-2xl bg-slate-50/50 p-4 transition-colors hover:bg-slate-100/50">
                        <div class="flex items-center gap-4">
                            <div class="flex h-10 w-10 items-center justify-center rounded-full bg-gradient-to-br from-amber-100 to-amber-200 text-amber-600">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <rect width="20" height="16" x="2" y="4" rx="2"/>
                                    <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
                                </svg>
                            </div>
                            <div>
                                <p class="text-sm font-semibold text-slate-800">@invitation.Email</p>
                                <p class="text-xs text-slate-500">Sent @FormatDate(invitation.SentAt) by @invitation.SenderName</p>
                            </div>
                        </div>
                        <div class="flex items-center gap-3">
                            <span class="rounded-full bg-amber-100 px-3 py-1 text-xs font-bold text-amber-700">
                                Pending
                            </span>
                            <button @onclick="() => RevokeInvitation(invitation)"
                                    disabled="@_isProcessing"
                                    class="rounded-xl bg-slate-200 px-3 py-1.5 text-xs font-bold text-slate-600 transition-colors hover:bg-red-100 hover:text-red-600 disabled:opacity-50 cursor-pointer">
                                Revoke
                            </button>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    @* Confirmation Dialog *@
    @if (_memberToRemove != null)
    {
        <div class="fixed inset-0 z-[200] flex items-center justify-center">
            <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" @onclick="CancelRemove"></div>
            <div class="relative z-10 w-full max-w-sm rounded-3xl bg-white p-6 shadow-2xl">
                <h3 class="mb-2 text-lg font-bold text-slate-800">Remove Member</h3>
                <p class="mb-6 text-sm text-slate-500">
                    Are you sure you want to remove <strong>@(_memberToRemove.FullName ?? _memberToRemove.UserName)</strong> from this project?
                </p>
                <div class="flex gap-3">
                    <button @onclick="CancelRemove" class="flex-1 rounded-2xl border border-slate-200 bg-white px-4 py-2.5 text-sm font-bold text-slate-600 hover:bg-slate-50 cursor-pointer">
                        Cancel
                    </button>
                    <button @onclick="ExecuteRemoveMember" disabled="@_isProcessing" class="flex-1 rounded-2xl bg-red-500 px-4 py-2.5 text-sm font-bold text-white hover:bg-red-600 disabled:opacity-50 cursor-pointer">
                        @if (_isProcessing)
                        {
                            <span>Removing...</span>
                        }
                        else
                        {
                            <span>Remove</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    }
</div>

@* Invite Member Modal *@
<InviteMemberModal
    IsVisible="_showInviteModal"
    ProjectId="ProjectId"
    OnClose="CloseInviteModal"
    OnInvitationSent="OnInvitationSent"/>

@code {
    [Parameter] public int ProjectId { get; set; }

    private List<TeamMemberResponse> _members = new();
    private List<PendingInvitationResponse> _pendingInvitations = new();
    private bool _isLoadingMembers;
    private bool _isLoadingInvitations;
    private bool _isProcessing;
    private bool _showInviteModal;
    private TeamMemberResponse? _memberToRemove;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        await Task.WhenAll(LoadMembers(), LoadPendingInvitations());
    }

    private async Task LoadMembers()
    {
        _isLoadingMembers = true;
        try
        {
            _members = await ProjectService.GetMembersAsync(ProjectId);
        }
        finally
        {
            _isLoadingMembers = false;
        }
    }

    private async Task LoadPendingInvitations()
    {
        _isLoadingInvitations = true;
        try
        {
            _pendingInvitations = await InvitationService.GetPendingInvitationsAsync(ProjectId);
        }
        finally
        {
            _isLoadingInvitations = false;
        }
    }

    private void OpenInviteModal()
    {
        _showInviteModal = true;
    }

    private void CloseInviteModal()
    {
        _showInviteModal = false;
    }

    private async Task OnInvitationSent()
    {
        // Auto-refresh pending invitations when a new invite is sent
        await LoadPendingInvitations();
    }

    private void ConfirmRemoveMember(TeamMemberResponse member)
    {
        _memberToRemove = member;
    }

    private void CancelRemove()
    {
        _memberToRemove = null;
    }

    private async Task ExecuteRemoveMember()
    {
        if (_memberToRemove == null) return;

        _isProcessing = true;
        try
        {
            var success = await ProjectService.RemoveMemberAsync(ProjectId, _memberToRemove.Id);
            if (success)
            {
                await LoadMembers();
            }
        }
        finally
        {
            _isProcessing = false;
            _memberToRemove = null;
        }
    }

    private async Task RevokeInvitation(PendingInvitationResponse invitation)
    {
        _isProcessing = true;
        try
        {
            var success = await InvitationService.RevokeInvitationAsync(invitation.Id);
            if (success)
            {
                await LoadPendingInvitations();
            }
        }
        finally
        {
            _isProcessing = false;
        }
    }

    private static string GetInitials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2)
            return $"{parts[0][0]}{parts[1][0]}".ToUpper();
        return parts[0].Length >= 2 ? parts[0][..2].ToUpper() : parts[0].ToUpper();
    }

    private static string GetRoleName(ProjectRole role) => role switch
    {
        ProjectRole.PM => "Project Manager",
        ProjectRole.Tester => "Tester",
        ProjectRole.Dev => "Developer",
        _ => role.ToString()
    };

    private static string GetRoleBadgeClass(ProjectRole role) => role switch
    {
        ProjectRole.PM => "bg-purple-100 text-purple-700",
        ProjectRole.Tester => "bg-blue-100 text-blue-700",
        ProjectRole.Dev => "bg-emerald-100 text-emerald-700",
        _ => "bg-slate-100 text-slate-700"
    };

    private static string FormatDate(DateTime date)
    {
        var diff = DateTime.Now - date;
        if (diff.TotalMinutes < 1) return "just now";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours}h ago";
        if (diff.TotalDays < 7) return $"{(int)diff.TotalDays}d ago";
        return date.ToString("MMM dd");
    }

    private static string GetRoleIndicatorColor(ProjectRole role) => role switch
    {
        ProjectRole.Dev => "bg-blue-400",
        ProjectRole.Tester => "bg-emerald-400",
        ProjectRole.PM => "bg-[#E85D3F]",
        _ => "bg-slate-400"
    };

    private static string GetRoleTextColor(ProjectRole role) => role switch
    {
        ProjectRole.Dev => "text-blue-500",
        ProjectRole.Tester => "text-emerald-500",
        ProjectRole.PM => "text-[#E85D3F]",
        _ => "text-slate-500"
    };

    private bool CanManageMember(TeamMemberResponse member)
    {
        // Can't remove yourself or the last PM
        return member.Role != ProjectRole.PM || _members.Count(m => m.Role == ProjectRole.PM) > 1;
    }

}
