    private void InitializeRoleDistribution(Dictionary<string, int>? usersByRole, int totalUniqueUsers = 0)
    {
        if (usersByRole == null || !usersByRole.Any())
        {
            // Fallback to mock data
            var totalRoles = 86;
            roleDistribution = new List<RoleDistribution>
            {
                new RoleDistribution { Role = "Developers", Count = 42, Color = "bg-blue-500", Percentage = (42.0 / totalRoles * 100) },
                new RoleDistribution { Role = "Testers", Count = 28, Color = "bg-emerald-500", Percentage = (28.0 / totalRoles * 100) },
                new RoleDistribution { Role = "Managers", Count = 12, Color = "bg-orange-500", Percentage = (12.0 / totalRoles * 100) },
                new RoleDistribution { Role = "Admins", Count = 4, Color = "bg-purple-500", Percentage = (4.0 / totalRoles * 100) }
            };
            return;
        }

        // Use actual unique user count as denominator to avoid double-counting
        // users who may have multiple roles assigned
        var denominator = totalUniqueUsers > 0 ? totalUniqueUsers : usersByRole.Values.Sum();
        if (denominator == 0) denominator = 1; // Avoid division by zero

        roleDistribution = new List<RoleDistribution>
        {
            new RoleDistribution 
            { 
                Role = "Developers", 
                Count = usersByRole.GetValueOrDefault("Dev", 0), 
                Color = "bg-blue-500", 
                Percentage = (usersByRole.GetValueOrDefault("Dev", 0) / (double)denominator * 100) 
            },
            new RoleDistribution 
            { 
                Role = "Testers", 
                Count = usersByRole.GetValueOrDefault("Tester", 0), 
                Color = "bg-emerald-500", 
                Percentage = (usersByRole.GetValueOrDefault("Tester", 0) / (double)denominator * 100) 
            },
            new RoleDistribution 
            { 
                Role = "Managers (PM)", 
                Count = usersByRole.GetValueOrDefault("PM", 0), 
                Color = "bg-orange-500", 
                Percentage = (usersByRole.GetValueOrDefault("PM", 0) / (double)denominator * 100) 
            },
            new RoleDistribution 
            { 
                Role = "Admins", 
                Count = usersByRole.GetValueOrDefault("Admin", 0), 
                Color = "bg-purple-500", 
                Percentage = (usersByRole.GetValueOrDefault("Admin", 0) / (double)denominator * 100) 
            }
        };
    }

