    private async Task InitializeEnvironmentControlsAsync()
    {
        var maintenanceMode = await SettingsService.GetBoolSettingAsync("MaintenanceMode", false);
        var openRegistration = await SettingsService.GetBoolSettingAsync("OpenRegistration", true);

        environmentControls = new List<EnvironmentControl>
        {
            new EnvironmentControl { Label = "Maintenance Mode", Key="MaintenanceMode", Active = maintenanceMode },
            new EnvironmentControl { Label = "Open Registration", Key="OpenRegistration", Active = openRegistration }
        };
    }

    private async Task ToggleSetting(EnvironmentControl control)
    {
        try
        {
            savingKey = control.Key;
            toastMessage = null;
            StateHasChanged();

            control.Active = !control.Active;
            await SettingsService.SetBoolSettingAsync(control.Key, control.Active);

            toastMessage = $"{control.Label} {(control.Active ? "enabled" : "disabled")} successfully.";
            toastIsError = false;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error toggling setting {control.Label}: {ex.Message}");
            control.Active = !control.Active; // revert
            toastMessage = $"Error: {ex.Message}";
            toastIsError = true;
        }
        finally
        {
            savingKey = null;
            StateHasChanged();
            // auto-dismiss toast after 3 s
            _ = Task.Delay(3000).ContinueWith(_ => { toastMessage = null; InvokeAsync(StateHasChanged); });
        }
    }

    private void OnToggleClick(EnvironmentControl ctrl)
    {
        // Enabling Maintenance Mode requires confirmation
        if (ctrl.Key == "MaintenanceMode" && !ctrl.Active)
        {
            pendingToggle = ctrl;
            showMaintenanceConfirm = true;
        }
        else
        {
            _ = ToggleSetting(ctrl);
        }
    }

    private void ConfirmMaintenanceToggle()
    {
        showMaintenanceConfirm = false;
        if (pendingToggle != null)
            _ = ToggleSetting(pendingToggle);
        pendingToggle = null;
    }

