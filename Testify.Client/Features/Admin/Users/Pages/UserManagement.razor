@page "/admin/users"
@layout AdminLayout
@using Microsoft.AspNetCore.Authorization
@using Testify.Client.Interfaces
@using Testify.Client.Features.Admin.Users.Components
@using Testify.Shared.DTOs.Users
@inject IUserService UserService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@inject AuthenticationStateProvider AuthenticationStateProvider
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Admin")]

<PageTitle>Identity Registry | Testify</PageTitle>

<div class="max-w-[1400px] mx-auto px-6 space-y-10 pb-32 animate-in fade-in duration-700">

    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6">
        <div>
            <div class="flex items-center gap-3 mb-2">
                <div class="w-8 h-8 bg-purple-500 rounded-xl flex items-center justify-center text-white shadow-lg shadow-purple-200">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M22 21v-2a4 4 0 0 0-3-3.87" /><path d="M16 3.13a4 4 0 0 1 0 7.75" /></svg>
                </div>
                <h1 class="text-4xl font-black text-slate-800 tracking-tight">Identity Registry</h1>
            </div>
            <p class="text-slate-400 font-medium">Provisioning, role orchestration, and security auditing for all system entities.</p>
        </div>

        <div class="flex items-center gap-4">
            <div class="bg-white p-2 rounded-2xl border border-slate-100 shadow-sm flex items-center gap-2">
                <div class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></div>
                <span class="text-[10px] font-black text-slate-500 uppercase tracking-widest mr-2">
                    @activeUsersCount Entities Online
                </span>
            </div>
           
        </div>
    </div>

    <div class="space-y-6">
        <div class="flex flex-col sm:flex-row items-center justify-between gap-4 px-2">
            <div class="relative group w-full sm:w-80">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-300 group-focus-within:text-purple-500 transition-colors"><circle cx="11" cy="11" r="8" /><path d="m21 21-4.3-4.3" /></svg>
                <input type="text"
                       placeholder="Search name or email..."
                       @bind-value="searchQuery"
                       @bind-value:event="oninput"
                       @bind-value:after="OnSearchOrFilterChanged"
                       class="w-full pl-11 pr-4 py-3.5 bg-white border border-slate-100 rounded-[24px] shadow-sm text-xs font-bold focus:ring-2 focus:ring-purple-500/10 transition-all outline-none" />
            </div>

            <div class="flex bg-white/50 p-1.5 rounded-[24px] border border-white shadow-sm w-full sm:w-auto overflow-x-auto no-scrollbar">
                @foreach (var role in new[] { "All", "Admin", "User" })
                {
                    <button @onclick="() => { roleFilter = role; OnSearchOrFilterChanged(); }"
                            class="@($"px-8 py-2.5 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all whitespace-nowrap {(roleFilter == role ? "bg-[#1C1D2A] text-white shadow-lg" : "text-slate-400 hover:text-slate-600")}")">
                        @role
                    </button>
                }
            </div>
        </div>

        <div class="bg-white rounded-[48px] border border-slate-100 shadow-sm overflow-hidden">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-slate-50/50 border-b border-slate-100">
                            <th class="px-6 py-4 text-[10px] font-black text-slate-400 uppercase tracking-widest">Entity</th>
                            <th class="px-6 py-4 text-[10px] font-black text-slate-400 uppercase tracking-widest">Role</th>
                            <th class="px-6 py-4 text-[10px] font-black text-slate-400 uppercase tracking-widest">Status</th>
                            <th class="px-6 py-4 text-[10px] font-black text-slate-400 uppercase tracking-widest text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-50">
                        @foreach (var user in PaginatedUsers)
                        {
                            <tr class="@GetRowClass(user.IsActive)">
                                <td class="px-6 py-4">
                                    <div class="flex items-center gap-3">
                                        <div class="@GetAvatarClass(user.IsActive)">
                                            <img src="@(string.IsNullOrEmpty(user.AvatarUrl) ? "https://ui-avatars.com/api/?name=" + Uri.EscapeDataString(user.FullName ?? user.Email) : user.AvatarUrl)" alt="@user.FullName" class="w-full h-full object-cover" />
                                        </div>
                                        <div>
                                            <p class="@GetNameClass(user.IsActive)">@user.FullName</p>
                                            <p class="text-[10px] font-bold text-slate-400 uppercase tracking-tight">@user.Email</p>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-4">
                                    <div class="flex items-center gap-2">
                                        @if (user.PrimaryRole == "Admin")
                                        {
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-purple-500"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" /></svg>
                                        }
                                        else
                                        {
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-slate-400"><circle cx="12" cy="12" r="3" /><path d="M12 1v6M12 17v6M4.22 4.22l4.24 4.25M15.54 15.54l4.24 4.25M1 12h6M17 12h6M4.22 19.78l4.24-4.24M15.54 8.46l4.24-4.24" /></svg>
                                        }

                                        <span class="@(GetRoleClass(user.PrimaryRole, user.IsActive))">
                                            @user.PrimaryRole
                                        </span>
                                    </div>
                                </td>
                                <td class="px-6 py-4">
                                    <div class="flex items-center gap-2">
                                        <div class="@(GetStatusBadgeClass(user.IsActive))"></div>
                                        <span class="@(GetStatusTextClass(user.IsActive))">
                                            @(user.IsActive ? "Active" : "Disabled")
                                        </span>
                                    </div>
                                </td>
                                <td class="px-6 py-4 text-right">
                                    <div class="flex items-center justify-end gap-2">
                                        <button @onclick="() => OpenViewUserDialog(user)" class="p-2 text-slate-300 hover:text-slate-500 transition-colors" title="View Intelligence">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z" /><circle cx="12" cy="12" r="3" /></svg>
                                        </button>
                                        <button @onclick="() => OpenEditUserDialog(user)" class="p-2 text-slate-300 hover:text-slate-500 transition-colors" title="Edit User">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M22 21v-2a4 4 0 0 0-3-3.87" /><path d="M16 3.13a4 4 0 0 1 0 7.75" /></svg>
                                        </button>
                                        <button @onclick="() => ToggleUserActive(user.Id, user.IsActive)"
                                                disabled="@(user.Id == currentUserId)"
                                                class="@GetToggleButtonClass(user.IsActive, user.Id == currentUserId)"
                                                title="@GetToggleButtonTitle(user.IsActive, user.Id == currentUserId)">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18.36 6.64a9 9 0 1 1-12.73 0" /><line x1="12" x2="12" y1="2" y2="12" /></svg>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                @if (!FilteredUsers.Any())
                {
                    <div class="p-20 text-center flex flex-col items-center">
                        <div class="w-16 h-16 bg-slate-50 rounded-3xl flex items-center justify-center mb-4">
                            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-slate-200"><circle cx="11" cy="11" r="8" /><path d="m21 21-4.3-4.3" /></svg>
                        </div>
                        <p class="text-sm font-black text-slate-400 uppercase tracking-widest">No matching entities found</p>
                    </div>
                }

                @* Pagination Controls *@
                @if (totalPages > 1)
                {
                    <div class="flex flex-col sm:flex-row items-center justify-between gap-4 px-6 py-4 border-t border-slate-100">
                        @* Page Info *@
                        <div class="text-xs font-bold text-slate-500">
                            Showing 
                            <span class="font-black text-slate-800">@((currentPage - 1) * pageSize + 1)</span>
                            -
                            <span class="font-black text-slate-800">@Math.Min(currentPage * pageSize, FilteredUsers.Count())</span>
                            of
                            <span class="font-black text-slate-800">@FilteredUsers.Count()</span>
                            entities
                        </div>

                        @* Navigation Controls *@
                        <div class="flex items-center gap-2">
                            @* Previous Button *@
                            <button @onclick="PreviousPage"
                                    disabled="@(currentPage == 1)"
                                    class="px-4 py-2.5 rounded-[20px] text-xs font-black uppercase tracking-widest transition-all disabled:opacity-30 disabled:cursor-not-allowed bg-white border border-slate-200 text-slate-700 hover:bg-slate-50 hover:scale-105 active:scale-95 shadow-sm disabled:hover:scale-100 disabled:hover:bg-white">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
                                </svg>
                            </button>

                            @* Page Numbers *@
                            <div class="flex items-center gap-1">
                                @for (int i = 1; i <= totalPages; i++)
                                {
                                    var page = i;
                                    @if (totalPages <= 7 || 
                                         page == 1 || 
                                         page == totalPages || 
                                         (page >= currentPage - 1 && page <= currentPage + 1))
                                    {
                                        <button @onclick="() => GoToPage(page)"
                                                class="@GetPageButtonClass(page)">
                                            @((MarkupString)page.ToString())
                                        </button>
                                    }
                                    else if (page == currentPage - 2 || page == currentPage + 2)
                                    {
                                        <span class="px-2 text-slate-400 font-black">...</span>
                                    }
                                }
                            </div>

                            @* Next Button *@
                            <button @onclick="NextPage"
                                    disabled="@(currentPage == totalPages)"
                                    class="px-4 py-2.5 rounded-[20px] text-xs font-black uppercase tracking-widest transition-all disabled:opacity-30 disabled:cursor-not-allowed bg-white border border-slate-200 text-slate-700 hover:bg-slate-50 hover:scale-105 active:scale-95 shadow-sm disabled:hover:scale-100 disabled:hover:bg-white">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                                </svg>
                            </button>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    @* Modals *@
    <CreateUserModal Show="@showCreateModal"
                     Model="@createUserModel"
                     OnSave="HandleCreateUser"
                     OnCancel="CloseCreateUserDialog"
                     IsSubmitting="@isSubmitting"
                     ErrorMessage="@errorMessage" />

    <ViewUserModal Show="@showViewModal"
                   UserDetails="@viewingUserFullDetails"
                   OnClose="CloseViewUserDialog" />

    <EditUserModal Show="@showEditModal"
                   Model="@editUserModel"
                   UserDetails="@editingUserFullDetails"
                   IsCurrentUser="@(editingUserId == currentUserId)"
                   OnSave="HandleUpdateUser"
                   OnCancel="CloseEditUserDialog"
                   IsSubmitting="@isSubmitting"
                   ErrorMessage="@errorMessage" />

@code {
    private List<UserListItemResponse> users = new();
    private string searchQuery = "";
    private string roleFilter = "All";
    private int activeUsersCount => users.Count(u => u.IsActive);

    // Pagination
    private int currentPage = 1;
    private int pageSize = 6;
    private int totalPages => (int)Math.Ceiling((double)FilteredUsers.Count() / pageSize);

    // Modal state
    private bool showCreateModal = false;
    private bool showViewModal = false;
    private bool showEditModal = false;
    private bool isSubmitting = false;
    private string? errorMessage = null;

    // Modal models
    private CreateUserRequest createUserModel = new();
    private UpdateUserRequest editUserModel = new();
    private UserResponse? editingUserFullDetails;
    private UserResponse? viewingUserFullDetails;
    private string editingUserId = "";
    private string? currentUserId = null;

    protected override async Task OnInitializedAsync()
    {
        await LoadCurrentUser();
        await LoadUsers();
    }

    private async Task LoadCurrentUser()
    {
        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            currentUserId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading current user: {ex}");
        }
    }

    private async Task LoadUsers()
    {
        try
        {
            users = await UserService.GetUsersAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load users: {ex.Message}";
            Console.WriteLine($"Error loading users: {ex}");
        }
    }

    private IEnumerable<UserListItemResponse> FilteredUsers => users
        .Where(u =>
            (string.IsNullOrWhiteSpace(searchQuery) ||
             (u.FullName?.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ?? false) ||
             (u.Email?.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ?? false)) &&
            (roleFilter == "All" ||
             (roleFilter == "Admin" && u.PrimaryRole == "Admin") ||
             (roleFilter == "User" && u.PrimaryRole != "Admin"))
        );

    private IEnumerable<UserListItemResponse> PaginatedUsers => FilteredUsers
        .Skip((currentPage - 1) * pageSize)
        .Take(pageSize);

    // Create User
    private void OpenCreateUserDialog()
    {
        createUserModel = new CreateUserRequest
        {
            Roles = new List<string> { "User" }
        };
        errorMessage = null;
        showCreateModal = true;
    }

    private void CloseCreateUserDialog()
    {
        showCreateModal = false;
        createUserModel = new();
        errorMessage = null;
    }

    private async Task HandleCreateUser()
    {
        isSubmitting = true;
        errorMessage = null;

        try
        {
            var result = await UserService.CreateUserAsync(createUserModel);
            await LoadUsers();
            CloseCreateUserDialog();
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to create user: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    // View User
    private async Task OpenViewUserDialog(UserListItemResponse user)
    {
        try
        {
            var fullUser = await UserService.GetUserByIdAsync(user.Id);
            viewingUserFullDetails = fullUser;
            showViewModal = true;
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load user details: {ex.Message}";
        }
    }

    private void CloseViewUserDialog()
    {
        showViewModal = false;
        viewingUserFullDetails = null;
    }

    // Edit User
    private async Task OpenEditUserDialog(UserListItemResponse user)
    {
        editingUserId = user.Id;
        
        // Load full user details
        try
        {
            var fullUser = await UserService.GetUserByIdAsync(user.Id);
            editingUserFullDetails = fullUser;
            editUserModel = new UpdateUserRequest
            {
                Email = fullUser.Email,
                FullName = fullUser.FullName,
                PhoneNumber = fullUser.PhoneNumber,
                AvatarUrl = fullUser.AvatarUrl,
                IsActive = fullUser.IsActive,
                Roles = fullUser.Roles?.ToList() ?? new List<string> { "User" }
            };
            errorMessage = null;
            showEditModal = true;
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load user details: {ex.Message}";
        }
    }

    private void CloseEditUserDialog()
    {
        showEditModal = false;
        editUserModel = new();
        editingUserId = "";
        errorMessage = null;
    }

    private async Task HandleUpdateUser(UpdateUserRequest updatedModel)
    {
        isSubmitting = true;
        errorMessage = null;

        try
        {
            await UserService.UpdateUserAsync(editingUserId, updatedModel);
            await LoadUsers();
            CloseEditUserDialog();
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to update user: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }


    // Delete User
    private async Task DeleteUser(string userId)
    {
        if (!await JSRuntime.InvokeAsync<bool>("confirm", "Are you sure you want to delete this user?"))
            return;

        try
        {
            var success = await UserService.DeleteUserAsync(userId);
            if (success)
            {
                await LoadUsers();
            }
            else
            {
                errorMessage = "Failed to delete user";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error deleting user: {ex.Message}";
        }
    }

    // Toggle User Active Status
    private async Task ToggleUserActive(string userId, bool currentStatus)
    {
        try
        {
            var user = users.FirstOrDefault(u => u.Id == userId);
            if (user == null) return;

            var updateRequest = new UpdateUserRequest
            {
                Email = user.Email,
                FullName = user.FullName,
                IsActive = !currentStatus,
                Roles = new List<string> { user.PrimaryRole }
            };

            await UserService.UpdateUserAsync(userId, updateRequest);
            await LoadUsers();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error toggling user status: {ex.Message}";
        }
    }


    // Helper methods for CSS classes
    private string GetRowClass(bool isActive)
    {
        return $"transition-colors group {(!isActive ? "bg-slate-50/50" : "hover:bg-slate-50/30")}";
    }

    private string GetAvatarClass(bool isActive)
    {
        var baseClass = "w-11 h-11 rounded-xl overflow-hidden border-2 border-white shadow-sm group-hover:scale-105 transition-transform";
        return !isActive ? $"{baseClass} grayscale opacity-50" : baseClass;
    }

    private string GetNameClass(bool isActive)
    {
        return $"text-xs font-black {(!isActive ? "text-slate-400" : "text-slate-800")}";
    }

    private string GetRoleClass(string role, bool isActive)
    {
        var baseClass = "text-[10px] font-black uppercase tracking-widest";
        if (!isActive) return $"{baseClass} text-slate-300";
        if (role == "Admin") return $"{baseClass} text-purple-500";
        return $"{baseClass} text-slate-700";
    }

    private string GetStatusBadgeClass(bool isActive)
    {
        return $"w-2 h-2 rounded-full {(isActive ? "bg-emerald-500" : "bg-slate-300")}";
    }

    private string GetStatusTextClass(bool isActive)
    {
        return $"text-[10px] font-black uppercase tracking-widest {(isActive ? "text-slate-500" : "text-slate-300")}";
    }

    private string GetPageButtonClass(int page)
    {
        var baseClass = "min-w-[40px] h-10 px-3 rounded-[16px] text-xs font-black transition-all";
        if (page == currentPage)
        {
            return $"{baseClass} bg-gradient-to-r from-purple-600 to-indigo-600 text-white shadow-lg shadow-purple-900/20 scale-105";
        }
        return $"{baseClass} bg-white border border-slate-200 text-slate-700 hover:bg-slate-50 hover:scale-105 active:scale-95 shadow-sm";
    }

    // Pagination methods
    private void GoToPage(int page)
    {
        if (page >= 1 && page <= totalPages)
        {
            currentPage = page;
        }
    }

    private void NextPage()
    {
        if (currentPage < totalPages)
        {
            currentPage++;
        }
    }

    private void PreviousPage()
    {
        if (currentPage > 1)
        {
            currentPage--;
        }
    }

    private void OnSearchOrFilterChanged()
    {
        currentPage = 1; // Reset to first page when search/filter changes
    }

    private string GetToggleButtonClass(bool isActive, bool isCurrentUser)
    {
        if (isCurrentUser)
        {
            return "p-2 transition-colors text-slate-200 cursor-not-allowed opacity-50";
        }
        return $"p-2 transition-colors {(isActive ? "text-slate-300 hover:text-slate-500" : "text-emerald-400 hover:text-emerald-500")}";
    }

    private string GetToggleButtonTitle(bool isActive, bool isCurrentUser)
    {
        if (isCurrentUser)
        {
            return "Cannot disable your own account";
        }
        return isActive ? "Disable User" : "Enable User";
    }
}