@using System.ComponentModel.DataAnnotations
@using Testify.Shared.Constants
@using Testify.Shared.DTOs.Users

@if (Show)
{
    <div class="fixed inset-0 z-[999999] flex items-center justify-center p-4 sm:p-6" style="position: fixed !important;">
        @* Backdrop *@
        <div class="absolute inset-0 bg-slate-900/60 backdrop-blur-md animate-in fade-in duration-200" @onclick="OnCancel"></div>

        @* Modal Content - Styled like Interface 2 *@
        <div class="relative bg-white w-full max-w-4xl rounded-[48px] shadow-2xl overflow-hidden flex flex-col animate-in zoom-in-95 duration-300 max-h-[90vh] overflow-y-auto custom-scrollbar">
            
            @* Header Section *@
            <div class="p-6 border-b border-slate-50 flex items-start justify-between bg-slate-50/50">
                <div class="flex items-center gap-4">
                    <div class="w-20 h-20 rounded-[28px] overflow-hidden border-4 border-white shadow-xl shrink-0">
                        <img src="@(string.IsNullOrEmpty(Model.AvatarUrl) ? "https://ui-avatars.com/api/?name=" + Uri.EscapeDataString(Model.FullName ?? Model.Email ?? "User") + "&background=6b7280&color=fff" : Model.AvatarUrl)"
                             alt="@Model.FullName" class="w-full h-full object-cover" />
                    </div>
                    <div>
                        <h2 class="text-2xl font-black text-slate-800 tracking-tight">@(Model.FullName ?? "Unknown User")</h2>
                        <div class="flex items-center gap-3 mt-2">
                            @{
                                var primaryRole = Model.Roles?.FirstOrDefault() ?? "User";
                            }
                            <span class="bg-[#1C1D2A] text-white px-3 py-1 rounded-lg text-[10px] font-black uppercase tracking-widest">
                                @primaryRole
                            </span>
                            <span class="@(Model.IsActive == true ? "bg-emerald-50 border-emerald-100 text-emerald-600" : "bg-red-50 border-red-100 text-red-500") border px-3 py-1 rounded-lg text-[10px] font-black uppercase tracking-widest">
                                @(Model.IsActive == true ? "Access Active" : "Access Revoked")
                            </span>
                        </div>
                    </div>
                </div>
                <button @onclick="OnCancel" class="p-3 hover:bg-white rounded-2xl text-slate-400 transition-all shadow-sm hover:shadow-md">
                    @* Icon X *@
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18" /><path d="m6 6 12 12" /></svg>
                </button>
            </div>

            @* Body Grid *@
            <div class="p-6 grid grid-cols-1 md:grid-cols-2 gap-6">
                
                @* Left Column: Metadata *@
                <div class="space-y-6">
                    @* Identity Metadata *@
                    <div class="space-y-4">
                        <h4 class="text-[11px] font-black text-slate-400 uppercase tracking-widest flex items-center gap-2 px-1">
                            @* Icon Fingerprint *@
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 10a2 2 0 0 0-2 2c0 1.02-.1 2.51-.26 4" /><path d="M14 13.12c0 2.38 0 6.38-1 8.88" /><path d="M17.29 21.02c.12-.6.43-2.3.5-3.02" /><path d="M2 12a10 10 0 0 1 18-6" /><path d="M2 16h.01" /><path d="M21.8 16c.2-2 .131-5.354 0-6" /><path d="M5 19.5C5.5 18 6 15 6 12a6 6 0 0 1 .34-2" /><path d="M8.65 22c.21-.66.45-1.32.57-2" /><path d="M9 6.8a6 6 0 0 1 9 5.2c0 .47 0 1.17-.02 2" /></svg>
                            Identity Metadata
                        </h4>
                        <div class="bg-slate-50 p-4 rounded-[28px] space-y-3 border border-slate-100">
                            <div class="flex items-center justify-between">
                                <span class="text-[10px] font-black text-slate-400 uppercase">System ID</span>
                                <span class="text-xs font-mono font-bold text-slate-600">USR-@(UserDetails?.Id.Substring(0, Math.Min(4, UserDetails?.Id.Length ?? 0)).ToUpper())</span>
                            </div>
                            <div class="flex items-center justify-between">
                                <span class="text-[10px] font-black text-slate-400 uppercase">Email Origin</span>
                                <span class="text-xs font-bold text-slate-600">@(Model.Email ?? "-")</span>
                            </div>
                            <div class="flex items-center justify-between">
                                <span class="text-[10px] font-black text-slate-400 uppercase">Joined System</span>
                                <span class="text-xs font-bold text-slate-600">@(UserDetails?.CreatedAt.ToString("MMM yyyy") ?? "-")</span>
                            </div>
                            <div class="flex items-center justify-between">
                                <span class="text-[10px] font-black text-slate-400 uppercase">Last Interaction</span>
                                <span class="text-xs font-bold text-emerald-600">@(GetTimeAgo(UserDetails?.LastLoginAt))</span>
                            </div>
                        </div>
                    </div>

                    @* Activity Pulse *@
                    <div class="space-y-4">
                        <h4 class="text-[11px] font-black text-slate-400 uppercase tracking-widest flex items-center gap-2 px-1">
                            @* Icon Activity *@
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2" /></svg>
                            Activity Pulse
                        </h4>
                        <div class="grid grid-cols-2 gap-3">
                            <div class="bg-white border border-slate-100 p-4 rounded-2xl shadow-sm">
                                <p class="text-[9px] font-black text-slate-400 uppercase mb-1">Commits</p>
                                <p class="text-lg font-black text-slate-800">142</p>
                            </div>
                            <div class="bg-white border border-slate-100 p-4 rounded-2xl shadow-sm">
                                <p class="text-[9px] font-black text-slate-400 uppercase mb-1">PR Reviews</p>
                                <p class="text-lg font-black text-slate-800">84</p>
                            </div>
                        </div>
                    </div>
                </div>

                @* Right Column: Orchestration *@
                <div class="space-y-6">
                    @* Role Orchestration *@
                    <div class="space-y-4">
                        <h4 class="text-[11px] font-black text-slate-400 uppercase tracking-widest flex items-center gap-2 px-1">
                            @* Icon UserCog *@
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" /></svg>
                            Role Orchestration
                        </h4>
                        <div class="grid grid-cols-1 gap-3">
                            @foreach (var role in _availableRoles)
                            {
                                var isSelected = Model.Roles?.Contains(role.Name) == true;
                                var isAdmin = role.Name == UserRole.Admin;
                                
                                <button @onclick="() => SetRole(role.Name)"
                                        class="w-full flex items-center justify-between p-4 rounded-2xl border transition-all text-left @(isSelected 
                                            ? (isAdmin ? "bg-purple-50 border-purple-200 text-purple-600 ring-2 ring-purple-100 shadow-md shadow-purple-50" : "bg-slate-800 border-slate-900 text-white shadow-xl shadow-slate-200") 
                                            : "bg-white border-slate-100 text-slate-500 hover:border-slate-200 hover:bg-slate-50")">
                                    <div class="flex items-center gap-2">
                                        <div class="@(isSelected ? (isAdmin ? "text-purple-600" : "text-white") : "text-slate-400")">
                                             @((MarkupString)role.Icon)
                                        </div>
                                        <div>
                                            <p class="text-xs font-black uppercase tracking-tight @(isSelected && !isAdmin ? "text-white" : "text-slate-800")">
                                                @role.Label
                                            </p>
                                            <p class="text-[10px] font-bold @(isSelected && !isAdmin ? "text-slate-400" : "text-slate-400")">
                                                @role.Description
                                            </p>
                                        </div>
                                    </div>
                                    @if (isSelected)
                                    {
                                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="@(isAdmin ? "text-purple-600" : "text-emerald-400")"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>
                                    }
                                </button>
                            }
                        </div>
                    </div>

                    @* Access Override *@
                    <div class="pt-4 space-y-4">
                        <h4 class="text-[11px] font-black text-slate-400 uppercase tracking-widest flex items-center gap-2 px-1">
                            @* Icon ShieldCheck *@
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10" /><path d="m9 12 2 2 4-4" /></svg>
                            Access Override
                        </h4>
                        <button @onclick="ToggleActive"
                                disabled="@IsCurrentUser"
                                class="@GetAccessButtonClass()">
                            @* Icon Power *@
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18.36 6.64a9 9 0 1 1-12.73 0" /><line x1="12" x2="12" y1="2" y2="12" /></svg>
                            @(Model.IsActive == true ? "Suspend Identity Access" : "Restore Identity Access")
                        </button>
                        @if (IsCurrentUser)
                        {
                            <p class="text-[9px] text-center text-amber-600 font-bold px-6 bg-amber-50 py-2 rounded-xl border border-amber-100">
                                ⚠️ You cannot disable your own account for security reasons.
                            </p>
                        }
                        else
                        {
                            <p class="text-[9px] text-center text-slate-400 font-medium px-6">
                                Identity overrides are logged and synchronized across all project repositories immediately.
                            </p>
                        }
                    </div>
                </div>
            </div>

            @* Footer *@
            <div class="p-6 bg-slate-50 border-t border-slate-100 flex flex-col md:flex-row items-center justify-between px-6 gap-4">
                <div class="flex items-center gap-3 text-slate-400">
                     @* Icon ShieldAlert *@
                     <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-purple-500"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10" /><path d="M12 8v4" /><path d="M12 16h.01" /></svg>
                     <p class="text-[10px] font-bold uppercase tracking-tight">Root access active. Changes are permanent in the identity ledger.</p>
                </div>
                
                <div class="flex items-center gap-3">
                    @* Close Button *@
                    <button @onclick="OnCancel"
                            class="px-8 py-3 bg-white border border-slate-200 text-slate-800 font-black text-xs uppercase tracking-widest rounded-xl hover:bg-slate-100 transition-all">
                        Close Detail
                    </button>
                    
                    @* Save Button (Adapted to new style) *@
                    <button @onclick="HandleSubmit"
                            disabled="@IsSubmitting"
                            class="px-8 py-3 bg-[#1C1D2A] text-white font-black text-xs uppercase tracking-widest rounded-xl hover:bg-slate-800 transition-all flex items-center gap-2 shadow-lg shadow-slate-300 disabled:opacity-50">
                        @if (IsSubmitting)
                        {
                            <div class="h-3 w-3 animate-spin rounded-full border-2 border-white/30 border-t-white"></div>
                        }
                        Save Changes
                    </button>
                </div>
            </div>

            @* Error Message Overlay (Preserved from Interface 1 but styled) *@
            @if (!string.IsNullOrEmpty(ErrorMessage))
            {
                <div class="absolute top-0 left-0 w-full p-4 animate-in slide-in-from-top-4">
                    <div class="flex items-start gap-3 rounded-2xl border border-red-200 bg-red-50/95 backdrop-blur shadow-lg p-4 mx-auto max-w-lg">
                        <div class="p-1.5 bg-red-100 rounded-lg text-red-600 shrink-0">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" x2="9" y1="9" y2="15"/><line x1="9" x2="15" y1="9" y2="15"/></svg>
                        </div>
                        <div>
                            <h3 class="text-sm font-bold text-red-900">Update Failed</h3>
                            <p class="text-xs text-red-700 mt-1">@ErrorMessage</p>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
}

@code {
    [Parameter] public bool Show { get; set; }
    [Parameter] public UpdateUserRequest Model { get; set; } = new();
    [Parameter] public UserResponse? UserDetails { get; set; }
    [Parameter] public bool IsCurrentUser { get; set; }
    [Parameter] public EventCallback<UpdateUserRequest> OnSave { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public bool IsSubmitting { get; set; }
    [Parameter] public string? ErrorMessage { get; set; }

    private List<RoleOption> _availableRoles = new()
    {
        new RoleOption
        {
            Name = UserRole.Admin,
            Label = "System Admin",
            Description = "Root system privileges",
            Icon = "<svg xmlns='http://www.w3.org/2000/svg' width='20' height='20' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><path d='M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z'/></svg>"
        },
        new RoleOption
        {
            Name = UserRole.User,
            Label = "Standard User",
            Description = "Standard project participation",
            Icon = "<svg xmlns='http://www.w3.org/2000/svg' width='20' height='20' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><path d='M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2'/><circle cx='12' cy='7' r='4'/></svg>"
        }
    };

    private void SetRole(string roleName)
    {
        Model.Roles = new List<string> { roleName };
    }

    private void ToggleActive()
    {
        Model.IsActive = !Model.IsActive;
    }

    private async Task HandleSubmit()
    {
        await OnSave.InvokeAsync(Model);
    }

    private string GetTimeAgo(DateTime? dateTime)
    {
        if (dateTime == null) return "Never";
        
        var timeSpan = DateTime.UtcNow - dateTime.Value;
        
        if (timeSpan.TotalDays > 365)
            return $"{(int)(timeSpan.TotalDays / 365)}y ago";
        if (timeSpan.TotalDays > 30)
            return $"{(int)(timeSpan.TotalDays / 30)}mo ago";
        if (timeSpan.TotalDays > 1)
            return $"{(int)timeSpan.TotalDays}d ago";
        if (timeSpan.TotalHours > 1)
            return $"{(int)timeSpan.TotalHours}h ago";
        if (timeSpan.TotalMinutes > 1)
            return $"{(int)timeSpan.TotalMinutes}m ago";
        
        return "Just now";
    }

    private string GetAccessButtonClass()
    {
        var baseClass = "w-full py-4 rounded-2xl font-black text-xs uppercase tracking-widest transition-all shadow-xl flex items-center justify-center gap-3";
        
        if (IsCurrentUser)
        {
            return $"{baseClass} bg-slate-200 text-slate-400 cursor-not-allowed opacity-60";
        }
        
        return Model.IsActive == true 
            ? $"{baseClass} bg-red-500 text-white hover:bg-red-600 shadow-red-200" 
            : $"{baseClass} bg-emerald-50 text-emerald-600 hover:bg-emerald-100 hover:text-emerald-700 shadow-emerald-200 border border-emerald-100";
    }

    private class RoleOption
    {
        public string Name { get; set; } = "";
        public string Label { get; set; } = "";
        public string Description { get; set; } = "";
        public string Icon { get; set; } = "";
    }
}