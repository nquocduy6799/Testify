@using System.ComponentModel.DataAnnotations
@using Testify.Shared.Constants
@using Testify.Shared.DTOs.Users

@if (Show)
{
    <div class="fixed inset-0 z-[999999] flex items-center justify-center p-4 sm:p-6" style="position: fixed !important;">
        @* Backdrop *@
        <div class="absolute inset-0 bg-slate-900/60 backdrop-blur-md animate-in fade-in duration-200" @onclick="OnCancel"></div>

        @* Modal Content *@
        <div class="relative bg-white w-full max-w-2xl rounded-[48px] shadow-2xl overflow-hidden flex flex-col animate-in zoom-in-95 duration-300 max-h-[90vh] overflow-y-auto custom-scrollbar">

            @* Header Section *@
            <div class="p-6 border-b border-slate-50 flex items-start justify-between bg-slate-50/50">
                <div class="flex items-center gap-4">
                    <div class="w-14 h-14 rounded-[20px] bg-gradient-to-br from-purple-500 to-indigo-600 flex items-center justify-center text-white shadow-xl shrink-0">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" x2="19" y1="8" y2="14"/><line x1="22" x2="16" y1="11" y2="11"/></svg>
                    </div>
                    <div>
                        <h2 class="text-2xl font-black text-slate-800 tracking-tight">Provision New Identity</h2>
                        <p class="text-xs text-slate-400 font-bold mt-1">Create a new user account in the system registry.</p>
                    </div>
                </div>
                <button @onclick="OnCancel" class="p-3 hover:bg-white rounded-2xl text-slate-400 transition-all shadow-sm hover:shadow-md">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
                </button>
            </div>

            @* Body *@
            <EditForm Model="Model" OnValidSubmit="HandleSubmit">
                <DataAnnotationsValidator />

                <div class="p-6 space-y-6">
                    @* Identity Fields *@
                    <div class="space-y-4">
                        <h4 class="text-[11px] font-black text-slate-400 uppercase tracking-widest flex items-center gap-2 px-1">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 10a2 2 0 0 0-2 2c0 1.02-.1 2.51-.26 4"/><path d="M14 13.12c0 2.38 0 6.38-1 8.88"/><path d="M17.29 21.02c.12-.6.43-2.3.5-3.02"/><path d="M2 12a10 10 0 0 1 18-6"/><path d="M2 16h.01"/><path d="M21.8 16c.2-2 .131-5.354 0-6"/><path d="M5 19.5C5.5 18 6 15 6 12a6 6 0 0 1 .34-2"/><path d="M8.65 22c.21-.66.45-1.32.57-2"/><path d="M9 6.8a6 6 0 0 1 9 5.2c0 .47 0 1.17-.02 2"/></svg>
                            Identity Information
                        </h4>

                        <div class="space-y-4">
                            @* Full Name *@
                            <div>
                                <label class="block text-[10px] font-black text-slate-500 uppercase tracking-widest mb-2">Full Name</label>
                                <InputText @bind-Value="Model.FullName"
                                           class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-2xl text-sm font-bold text-slate-800 focus:outline-none focus:ring-2 focus:ring-purple-200 focus:border-purple-400 transition-all"
                                           placeholder="Enter full name" />
                                <ValidationMessage For="() => Model.FullName" class="text-xs text-red-500 mt-1" />
                            </div>

                            @* Email *@
                            <div>
                                <label class="block text-[10px] font-black text-slate-500 uppercase tracking-widest mb-2">Email Address <span class="text-red-400">*</span></label>
                                <InputText @bind-Value="Model.Email"
                                           class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-2xl text-sm font-bold text-slate-800 focus:outline-none focus:ring-2 focus:ring-purple-200 focus:border-purple-400 transition-all"
                                           placeholder="user@example.com" />
                                <ValidationMessage For="() => Model.Email" class="text-xs text-red-500 mt-1" />
                            </div>

                            @* Phone Number *@
                            <div>
                                <label class="block text-[10px] font-black text-slate-500 uppercase tracking-widest mb-2">Phone Number</label>
                                <InputText @bind-Value="Model.PhoneNumber"
                                           class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-2xl text-sm font-bold text-slate-800 focus:outline-none focus:ring-2 focus:ring-purple-200 focus:border-purple-400 transition-all"
                                           placeholder="+1 (555) 000-0000" />
                                <ValidationMessage For="() => Model.PhoneNumber" class="text-xs text-red-500 mt-1" />
                            </div>
                        </div>
                    </div>

                    @* Security Fields *@
                    <div class="space-y-4">
                        <h4 class="text-[11px] font-black text-slate-400 uppercase tracking-widest flex items-center gap-2 px-1">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                            Security Credentials
                        </h4>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            @* Password *@
                            <div>
                                <label class="block text-[10px] font-black text-slate-500 uppercase tracking-widest mb-2">Password <span class="text-red-400">*</span></label>
                                <InputText @bind-Value="Model.Password" type="password"
                                           class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-2xl text-sm font-bold text-slate-800 focus:outline-none focus:ring-2 focus:ring-purple-200 focus:border-purple-400 transition-all"
                                           placeholder="••••••••" />
                                <ValidationMessage For="() => Model.Password" class="text-xs text-red-500 mt-1" />
                            </div>

                            @* Confirm Password *@
                            <div>
                                <label class="block text-[10px] font-black text-slate-500 uppercase tracking-widest mb-2">Confirm Password <span class="text-red-400">*</span></label>
                                <InputText @bind-Value="Model.ConfirmPassword" type="password"
                                           class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-2xl text-sm font-bold text-slate-800 focus:outline-none focus:ring-2 focus:ring-purple-200 focus:border-purple-400 transition-all"
                                           placeholder="••••••••" />
                                <ValidationMessage For="() => Model.ConfirmPassword" class="text-xs text-red-500 mt-1" />
                            </div>
                        </div>
                    </div>

                    @* Role Selection *@
                    <div class="space-y-4">
                        <h4 class="text-[11px] font-black text-slate-400 uppercase tracking-widest flex items-center gap-2 px-1">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                            Role Assignment
                        </h4>
                        <div class="grid grid-cols-1 gap-3">
                            @foreach (var role in _availableRoles)
                            {
                                var isSelected = Model.Roles?.Contains(role.Name) == true;
                                var isAdmin = role.Name == UserRole.Admin;

                                <button type="button" @onclick="() => SetRole(role.Name)"
                                        class="w-full flex items-center justify-between p-4 rounded-2xl border transition-all text-left @(isSelected
                                            ? (isAdmin ? "bg-purple-50 border-purple-200 text-purple-600 ring-2 ring-purple-100 shadow-md shadow-purple-50" : "bg-slate-800 border-slate-900 text-white shadow-xl shadow-slate-200")
                                            : "bg-white border-slate-100 text-slate-500 hover:border-slate-200 hover:bg-slate-50")">
                                    <div class="flex items-center gap-2">
                                        <div class="@(isSelected ? (isAdmin ? "text-purple-600" : "text-white") : "text-slate-400")">
                                            @((MarkupString)role.Icon)
                                        </div>
                                        <div>
                                            <p class="text-xs font-black uppercase tracking-tight @(isSelected && !isAdmin ? "text-white" : "text-slate-800")">
                                                @role.Label
                                            </p>
                                            <p class="text-[10px] font-bold text-slate-400">
                                                @role.Description
                                            </p>
                                        </div>
                                    </div>
                                    @if (isSelected)
                                    {
                                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="@(isAdmin ? "text-purple-600" : "text-emerald-400")"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>
                                    }
                                </button>
                            }
                        </div>
                    </div>
                </div>

                @* Footer *@
                <div class="p-6 bg-slate-50 border-t border-slate-100 flex flex-col md:flex-row items-center justify-between px-6 gap-4">
                    <div class="flex items-center gap-3 text-slate-400">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-purple-500"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/><path d="M12 8v4"/><path d="M12 16h.01"/></svg>
                        <p class="text-[10px] font-bold uppercase tracking-tight">Identity will be registered and provisioned immediately.</p>
                    </div>

                    <div class="flex items-center gap-3">
                        <button type="button" @onclick="OnCancel"
                                class="px-8 py-3 bg-white border border-slate-200 text-slate-800 font-black text-xs uppercase tracking-widest rounded-xl hover:bg-slate-100 transition-all">
                            Cancel
                        </button>

                        <button type="submit"
                                disabled="@IsSubmitting"
                                class="px-8 py-3 bg-[#1C1D2A] text-white font-black text-xs uppercase tracking-widest rounded-xl hover:bg-slate-800 transition-all flex items-center gap-2 shadow-lg shadow-slate-300 disabled:opacity-50">
                            @if (IsSubmitting)
                            {
                                <div class="h-3 w-3 animate-spin rounded-full border-2 border-white/30 border-t-white"></div>
                            }
                            Create Identity
                        </button>
                    </div>
                </div>
            </EditForm>

            @* Error Message Overlay *@
            @if (!string.IsNullOrEmpty(ErrorMessage))
            {
                <div class="absolute top-0 left-0 w-full p-4 animate-in slide-in-from-top-4">
                    <div class="flex items-start gap-3 rounded-2xl border border-red-200 bg-red-50/95 backdrop-blur shadow-lg p-4 mx-auto max-w-lg">
                        <div class="p-1.5 bg-red-100 rounded-lg text-red-600 shrink-0">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" x2="9" y1="9" y2="15"/><line x1="9" x2="15" y1="9" y2="15"/></svg>
                        </div>
                        <div>
                            <h3 class="text-sm font-bold text-red-900">Creation Failed</h3>
                            <p class="text-xs text-red-700 mt-1">@ErrorMessage</p>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
}

@code {
    [Parameter] public bool Show { get; set; }
    [Parameter] public CreateUserRequest Model { get; set; } = new();
    [Parameter] public EventCallback OnSave { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public bool IsSubmitting { get; set; }
    [Parameter] public string? ErrorMessage { get; set; }

    private List<RoleOption> _availableRoles = new()
    {
        new RoleOption
        {
            Name = UserRole.Admin,
            Label = "System Admin",
            Description = "Root system privileges",
            Icon = "<svg xmlns='http://www.w3.org/2000/svg' width='20' height='20' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><path d='M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z'/></svg>"
        },
        new RoleOption
        {
            Name = UserRole.User,
            Label = "Standard User",
            Description = "Standard project participation",
            Icon = "<svg xmlns='http://www.w3.org/2000/svg' width='20' height='20' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><path d='M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2'/><circle cx='12' cy='7' r='4'/></svg>"
        }
    };

    private void SetRole(string roleName)
    {
        Model.Roles = new List<string> { roleName };
    }

    private async Task HandleSubmit()
    {
        await OnSave.InvokeAsync();
    }

    private class RoleOption
    {
        public string Name { get; set; } = "";
        public string Label { get; set; } = "";
        public string Description { get; set; } = "";
        public string Icon { get; set; } = "";
    }
}
