@using System.ComponentModel.DataAnnotations
@using Testify.Shared.Constants
@using Testify.Shared.DTOs.Users

@if (Show)
{
    <div class="fixed inset-0 z-[999999] flex items-center justify-center p-4 sm:p-6" style="position: fixed !important;">
        @* Backdrop *@
        <div class="absolute inset-0 bg-slate-900/60 backdrop-blur-md animate-in fade-in duration-200" @onclick="OnClose"></div>

        @* Modal Content - View Only *@
        <div class="relative bg-white w-full max-w-4xl rounded-[48px] shadow-2xl overflow-hidden flex flex-col animate-in zoom-in-95 duration-300 max-h-[90vh] overflow-y-auto custom-scrollbar">
            
            @* Header Section *@
            <div class="p-6 border-b border-slate-50 flex items-start justify-between bg-slate-50/50">
                <div class="flex items-center gap-4">
                    <div class="w-20 h-20 rounded-[28px] overflow-hidden border-4 border-white shadow-xl shrink-0">
                        <img src="@(string.IsNullOrEmpty(UserDetails?.AvatarUrl) ? "https://ui-avatars.com/api/?name=" + Uri.EscapeDataString(UserDetails?.FullName ?? UserDetails?.Email ?? "User") + "&background=6b7280&color=fff" : UserDetails.AvatarUrl)"
                             alt="@UserDetails?.FullName" class="w-full h-full object-cover" />
                    </div>
                    <div>
                        <h2 class="text-2xl font-black text-slate-800 tracking-tight">@(UserDetails?.FullName ?? "Unknown User")</h2>
                        <div class="flex items-center gap-3 mt-2">
                            @{
                                var primaryRole = UserDetails?.Roles?.FirstOrDefault() ?? "User";
                            }
                            <span class="bg-[#1C1D2A] text-white px-3 py-1 rounded-lg text-[10px] font-black uppercase tracking-widest">
                                @primaryRole
                            </span>
                            <span class="@(UserDetails?.IsActive == true ? "bg-emerald-50 border-emerald-100 text-emerald-600" : "bg-red-50 border-red-100 text-red-500") border px-3 py-1 rounded-lg text-[10px] font-black uppercase tracking-widest">
                                @(UserDetails?.IsActive == true ? "Access Active" : "Access Revoked")
                            </span>
                        </div>
                    </div>
                </div>
                <button @onclick="OnClose" class="p-3 hover:bg-white rounded-2xl text-slate-400 transition-all shadow-sm hover:shadow-md">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18" /><path d="m6 6 12 12" /></svg>
                </button>
            </div>

            @* Body Grid *@
            <div class="p-6 grid grid-cols-1 md:grid-cols-2 gap-6">
                
                @* Left Column: Metadata *@
                <div class="space-y-6">
                    @* Identity Metadata *@
                    <div class="space-y-4">
                        <h4 class="text-[11px] font-black text-slate-400 uppercase tracking-widest flex items-center gap-2 px-1">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 10a2 2 0 0 0-2 2c0 1.02-.1 2.51-.26 4" /><path d="M14 13.12c0 2.38 0 6.38-1 8.88" /><path d="M17.29 21.02c.12-.6.43-2.3.5-3.02" /><path d="M2 12a10 10 0 0 1 18-6" /><path d="M2 16h.01" /><path d="M21.8 16c.2-2 .131-5.354 0-6" /><path d="M5 19.5C5.5 18 6 15 6 12a6 6 0 0 1 .34-2" /><path d="M8.65 22c.21-.66.45-1.32.57-2" /><path d="M9 6.8a6 6 0 0 1 9 5.2c0 .47 0 1.17-.02 2" /></svg>
                            Identity Metadata
                        </h4>
                        <div class="bg-slate-50 p-4 rounded-[28px] space-y-3 border border-slate-100">
                            <div class="flex items-center justify-between">
                                <span class="text-[10px] font-black text-slate-400 uppercase">System ID</span>
                                <span class="text-xs font-mono font-bold text-slate-600">USR-@(UserDetails?.Id.Substring(0, Math.Min(4, UserDetails?.Id.Length ?? 0)).ToUpper())</span>
                            </div>
                            <div class="flex items-center justify-between">
                                <span class="text-[10px] font-black text-slate-400 uppercase">Email Origin</span>
                                <span class="text-xs font-bold text-slate-600">@(UserDetails?.Email ?? "-")</span>
                            </div>
                            <div class="flex items-center justify-between">
                                <span class="text-[10px] font-black text-slate-400 uppercase">Phone Number</span>
                                <span class="text-xs font-bold text-slate-600">@(UserDetails?.PhoneNumber ?? "-")</span>
                            </div>
                            <div class="flex items-center justify-between">
                                <span class="text-[10px] font-black text-slate-400 uppercase">Joined System</span>
                                <span class="text-xs font-bold text-slate-600">@(UserDetails?.CreatedAt.ToString("MMM yyyy") ?? "-")</span>
                            </div>
                            <div class="flex items-center justify-between">
                                <span class="text-[10px] font-black text-slate-400 uppercase">Last Interaction</span>
                                <span class="text-xs font-bold text-emerald-600">@(GetTimeAgo(UserDetails?.LastLoginAt))</span>
                            </div>
                        </div>
                    </div>

                    @* Activity Pulse *@
                    <div class="space-y-4">
                        <h4 class="text-[11px] font-black text-slate-400 uppercase tracking-widest flex items-center gap-2 px-1">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2" /></svg>
                            Activity Pulse
                        </h4>
                        <div class="grid grid-cols-2 gap-3">
                            <div class="bg-white border border-slate-100 p-4 rounded-2xl shadow-sm">
                                <p class="text-[9px] font-black text-slate-400 uppercase mb-1">Commits</p>
                                <p class="text-lg font-black text-slate-800">142</p>
                            </div>
                            <div class="bg-white border border-slate-100 p-4 rounded-2xl shadow-sm">
                                <p class="text-[9px] font-black text-slate-400 uppercase mb-1">PR Reviews</p>
                                <p class="text-lg font-black text-slate-800">84</p>
                            </div>
                        </div>
                    </div>
                </div>

                @* Right Column: Role & Status Info *@
                <div class="space-y-6">
                    @* Role Information *@
                    <div class="space-y-4">
                        <h4 class="text-[11px] font-black text-slate-400 uppercase tracking-widest flex items-center gap-2 px-1">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" /></svg>
                            Assigned Roles
                        </h4>
                        <div class="space-y-3">
                            @if (UserDetails?.Roles != null && UserDetails.Roles.Any())
                            {
                                @foreach (var role in UserDetails.Roles)
                                {
                                    var isAdmin = role == UserRole.Admin;
                                    <div class="flex items-center justify-between p-4 rounded-2xl border @(isAdmin ? "bg-purple-50 border-purple-200" : "bg-slate-50 border-slate-100")">
                                        <div class="flex items-center gap-2">
                                            <div class="@(isAdmin ? "text-purple-600" : "text-slate-400")">
                                                @if (isAdmin)
                                                {
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                                                }
                                                else
                                                {
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                                                }
                                            </div>
                                            <div>
                                                <p class="text-xs font-black uppercase tracking-tight text-slate-800">
                                                    @(isAdmin ? "System Admin" : "Standard User")
                                                </p>
                                                <p class="text-[10px] font-bold text-slate-400">
                                                    @(isAdmin ? "Root system privileges" : "Standard project participation")
                                                </p>
                                            </div>
                                        </div>
                                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="@(isAdmin ? "text-purple-600" : "text-emerald-500")"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>
                                    </div>
                                }
                            }
                            else
                            {
                                <p class="text-xs text-slate-400 text-center py-4">No roles assigned</p>
                            }
                        </div>
                    </div>

                    @* Access Status *@
                    <div class="pt-4 space-y-4">
                        <h4 class="text-[11px] font-black text-slate-400 uppercase tracking-widest flex items-center gap-2 px-1">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10" /><path d="m9 12 2 2 4-4" /></svg>
                            Access Status
                        </h4>
                        <div class="p-4 rounded-2xl @(UserDetails?.IsActive == true ? "bg-emerald-50 border-emerald-100" : "bg-red-50 border-red-100") border">
                            <div class="flex items-center gap-3">
                                <div class="@(UserDetails?.IsActive == true ? "text-emerald-600" : "text-red-500")">
                                    @if (UserDetails?.IsActive == true)
                                    {
                                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
                                    }
                                    else
                                    {
                                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="4.93" x2="19.07" y1="4.93" y2="19.07"/></svg>
                                    }
                                </div>
                                <div>
                                    <p class="text-sm font-black @(UserDetails?.IsActive == true ? "text-emerald-700" : "text-red-600")">
                                        @(UserDetails?.IsActive == true ? "Access Active" : "Access Suspended")
                                    </p>
                                    <p class="text-[10px] font-bold @(UserDetails?.IsActive == true ? "text-emerald-600" : "text-red-500") mt-0.5">
                                        @(UserDetails?.IsActive == true ? "Full permissions to all project resources" : "All access has been revoked")
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            @* Footer *@
            <div class="p-6 bg-slate-50 border-t border-slate-100 flex items-center justify-between px-6">
                <div class="flex items-center gap-3 text-slate-400">
                     <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-blue-500"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
                     <p class="text-[10px] font-bold uppercase tracking-tight">View-only mode. Use edit button to modify user details.</p>
                </div>
                
                <button @onclick="OnClose"
                        class="px-8 py-3 bg-[#1C1D2A] text-white font-black text-xs uppercase tracking-widest rounded-xl hover:bg-slate-800 transition-all shadow-lg shadow-slate-300">
                    Close
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool Show { get; set; }
    [Parameter] public UserResponse? UserDetails { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    private string GetTimeAgo(DateTime? dateTime)
    {
        if (dateTime == null) return "Never";
        
        var timeSpan = DateTime.UtcNow - dateTime.Value;
        
        if (timeSpan.TotalDays > 365)
            return $"{(int)(timeSpan.TotalDays / 365)}y ago";
        if (timeSpan.TotalDays > 30)
            return $"{(int)(timeSpan.TotalDays / 30)}mo ago";
        if (timeSpan.TotalDays > 1)
            return $"{(int)timeSpan.TotalDays}d ago";
        if (timeSpan.TotalHours > 1)
            return $"{(int)timeSpan.TotalHours}h ago";
        if (timeSpan.TotalMinutes > 1)
            return $"{(int)timeSpan.TotalMinutes}m ago";
        
        return "Just now";
    }
}
