@page "/admin"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin")]
@inject NavigationManager Navigation
@rendermode InteractiveWebAssembly

<PageTitle>Admin Dashboard - Testify</PageTitle>

<div class="max-w-[1400px] mx-auto px-8 mt-10 pb-24 space-y-10">

    @* Header *@
    <div>
        <h1 class="text-4xl font-extrabold text-slate-900 tracking-tight">
            Admin <span class="text-[#E85D3F]">Dashboard</span>
        </h1>
        <p class="text-slate-500 mt-2 text-lg">Manage your platform settings and content.</p>
    </div>

    @* Quick Stats *@
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="bg-white p-6 rounded-[32px] shadow-sm border border-slate-50 flex items-center gap-5 hover:shadow-md transition-shadow">
            <div class="w-14 h-14 bg-purple-50 rounded-2xl flex items-center justify-center">
                <svg class="w-7 h-7 text-purple-500" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect width="7" height="7" x="3" y="3" rx="1"/><rect width="7" height="7" x="14" y="3" rx="1"/><rect width="7" height="7" x="14" y="14" rx="1"/><rect width="7" height="7" x="3" y="14" rx="1"/>
                </svg>
            </div>
            <div>
                <p class="text-slate-400 text-xs font-bold uppercase tracking-wider">Categories</p>
                <h3 class="text-2xl font-bold text-slate-800">Manage</h3>
            </div>
        </div>
        <div class="bg-white p-6 rounded-[32px] shadow-sm border border-slate-50 flex items-center gap-5 hover:shadow-md transition-shadow">
            <div class="w-14 h-14 bg-blue-50 rounded-2xl flex items-center justify-center">
                <svg class="w-7 h-7 text-blue-500" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                </svg>
            </div>
            <div>
                <p class="text-slate-400 text-xs font-bold uppercase tracking-wider">Users</p>
                <h3 class="text-2xl font-bold text-slate-800">Manage</h3>
            </div>
        </div>
        <div class="bg-white p-6 rounded-[32px] shadow-sm border border-slate-50 flex items-center gap-5 hover:shadow-md transition-shadow">
            <div class="w-14 h-14 bg-orange-50 rounded-2xl flex items-center justify-center">
                <svg class="w-7 h-7 text-orange-500" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="8" cy="21" r="1"/><circle cx="19" cy="21" r="1"/><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/>
                </svg>
            </div>
            <div>
                <p class="text-slate-400 text-xs font-bold uppercase tracking-wider">Marketplace</p>
                <h3 class="text-2xl font-bold text-slate-800">Templates</h3>
            </div>
        </div>
        <div class="bg-white p-6 rounded-[32px] shadow-sm border border-slate-50 flex items-center gap-5 hover:shadow-md transition-shadow">
            <div class="w-14 h-14 bg-emerald-50 rounded-2xl flex items-center justify-center">
                <svg class="w-7 h-7 text-emerald-500" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/>
                </svg>
            </div>
            <div>
                <p class="text-slate-400 text-xs font-bold uppercase tracking-wider">System</p>
                <h3 class="text-2xl font-bold text-slate-800">Settings</h3>
            </div>
        </div>
    </div>

    @* Management Cards *@
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">

        @* Categories Management *@
        <div @onclick='() => Navigation.NavigateTo("/admin/categories")'
             class="bg-white rounded-[32px] p-8 shadow-sm border border-slate-50 hover:shadow-lg hover:border-purple-100 transition-all cursor-pointer group">
            <div class="w-16 h-16 bg-purple-100 rounded-2xl flex items-center justify-center mb-6 group-hover:bg-purple-600 transition-colors">
                <svg class="w-8 h-8 text-purple-600 group-hover:text-white transition-colors" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect width="7" height="7" x="3" y="3" rx="1"/><rect width="7" height="7" x="14" y="3" rx="1"/><rect width="7" height="7" x="14" y="14" rx="1"/><rect width="7" height="7" x="3" y="14" rx="1"/>
                </svg>
            </div>
            <h3 class="text-xl font-bold text-slate-800 mb-2 group-hover:text-purple-600 transition-colors">Template Categories</h3>
            <p class="text-sm text-slate-500 leading-relaxed">Create, update, and delete marketplace template categories.</p>
            <div class="mt-6 flex items-center gap-2 text-sm font-bold text-purple-600 opacity-0 group-hover:opacity-100 transition-opacity">
                Manage Categories
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
                </svg>
            </div>
        </div>

        @* Marketplace Preview *@
        <div @onclick='() => Navigation.NavigateTo("/admin/marketplace")'
             class="bg-white rounded-[32px] p-8 shadow-sm border border-slate-50 hover:shadow-lg hover:border-orange-100 transition-all cursor-pointer group">
            <div class="w-16 h-16 bg-orange-100 rounded-2xl flex items-center justify-center mb-6 group-hover:bg-[#E85D3F] transition-colors">
                <svg class="w-8 h-8 text-[#E85D3F] group-hover:text-white transition-colors" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="8" cy="21" r="1"/><circle cx="19" cy="21" r="1"/><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/>
                </svg>
            </div>
            <h3 class="text-xl font-bold text-slate-800 mb-2 group-hover:text-[#E85D3F] transition-colors">Marketplace</h3>
            <p class="text-sm text-slate-500 leading-relaxed">Preview the marketplace as users see it. Test templates, search, and filters.</p>
            <div class="mt-6 flex items-center gap-2 text-sm font-bold text-[#E85D3F] opacity-0 group-hover:opacity-100 transition-opacity">
                View Marketplace
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
                </svg>
            </div>
        </div>

        @* User Management *@
        <div @onclick='() => Navigation.NavigateTo("/admin/users")'
             class="bg-white rounded-[32px] p-8 shadow-sm border border-slate-50 hover:shadow-lg hover:border-blue-100 transition-all cursor-pointer group">
            <div class="w-16 h-16 bg-blue-100 rounded-2xl flex items-center justify-center mb-6 group-hover:bg-blue-600 transition-colors">
                <svg class="w-8 h-8 text-blue-600 group-hover:text-white transition-colors" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                </svg>
            </div>
            <h3 class="text-xl font-bold text-slate-800 mb-2 group-hover:text-blue-600 transition-colors">User Management</h3>
            <p class="text-sm text-slate-500 leading-relaxed">Manage user accounts, roles, and permissions.</p>
            <div class="mt-6 flex items-center gap-2 text-sm font-bold text-blue-600 opacity-0 group-hover:opacity-100 transition-opacity">
                Manage Users
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
                </svg>
            </div>
        </div>

    </div>

    @* Quick Actions *@
    <section class="bg-[#1C1D2A] rounded-[40px] p-10 text-white relative overflow-hidden">
        <div class="absolute top-0 right-0 w-64 h-64 bg-[#E85D3F]/10 rounded-full -mr-32 -mt-32 blur-3xl"></div>
        <div class="relative z-10">
            <h3 class="text-2xl font-bold mb-2">Quick Actions</h3>
            <p class="text-slate-400 text-sm mb-8">Common administrative tasks.</p>
            <div class="flex flex-wrap gap-4">
                <button @onclick='() => Navigation.NavigateTo("/admin/categories")'
                        class="px-6 py-3 bg-purple-600 text-white rounded-2xl font-bold text-sm flex items-center gap-2 hover:bg-purple-700 transition-all">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M5 12h14"/><path d="M12 5v14"/>
                    </svg>
                    Add Category
                </button>
                <button @onclick='() => Navigation.NavigateTo("/marketplace")'
                        class="px-6 py-3 bg-white/10 text-white rounded-2xl font-bold text-sm flex items-center gap-2 hover:bg-white/20 transition-all">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="8" cy="21" r="1"/><circle cx="19" cy="21" r="1"/><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/>
                    </svg>
                    Test Marketplace
                </button>
                <button @onclick='() => Navigation.NavigateTo("/admin/users")'
                        class="px-6 py-3 bg-white/10 text-white rounded-2xl font-bold text-sm flex items-center gap-2 hover:bg-white/20 transition-all">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/>
                    </svg>
                    Manage Users
                </button>
                <button @onclick='() => Navigation.NavigateTo("/dashboard")'
                        class="px-6 py-3 bg-white/10 text-white rounded-2xl font-bold text-sm flex items-center gap-2 hover:bg-white/20 transition-all">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>
                    </svg>
                    User Dashboard
                </button>
            </div>
        </div>
    </section>

</div>
