    //             @page "/projects/{ProjectId:int}/testplans/{TestPlanId:int}/execute"
				// Navigation.NavigateTo($"/projects/{ProjectId}/testplans/{_planToExecute.Id}/execute");
    //         }
    //     }
    //     catch (Exception ex)
    //     {
    //         _errorMessage = $"Failed to start execution: {ex.Message}";
    //     }
    //     finally
    //     {
    //         CloseExecutionPrompt();
    //     }
    // }


    private async Task HandleStartExecutionAsync()
    {
        if (_planToExecute is null)
            return;

        try
        {
            var testSuiteIds = _planToExecute.TestSuites.Select(s => s.Id).ToList();

            if (testSuiteIds.Count == 0)
            {
                _errorMessage = "This test plan has no enrolled test suites. Add at least one suite before starting execution.";
                return;
            }

            var result = await TestRunService.StartExecutionAsync(_planToExecute.Id, testSuiteIds);

            if (result is not null)
            {
                Navigation.NavigateTo($"/projects/{ProjectId}/testplans/{_planToExecute.Id}/execute");
            }
        }
        catch (HttpRequestException ex)
        {
            _errorMessage = $"Failed to start execution: {ex.Message}";
        }
        catch (Exception ex)
        {
            _errorMessage = $"Unexpected error: {ex.Message}";
        }
        finally
        {
            CloseExecutionPrompt();
        }
    }

    private void NavigateToPlan(int planId)
    {
        Navigation.NavigateTo($"/projects/{ProjectId}/testplans/{planId}");
    }

    private void NavigateToPlanBlueprintDetail(int planId)
    {
        Navigation.NavigateTo($"/projects/{ProjectId}/testplans/{planId}/blueprint");
	}

    private string GetTargetName(TestPlanResponse plan)
    {
        return plan.Scope switch
        {
            TestPlanScope.Project => _project?.Name ?? "Project",
            TestPlanScope.Milestone => _milestones.FirstOrDefault(m => m.Id == plan.MilestoneId)?.Name ?? "Milestone",
            TestPlanScope.Task => _milestones
                .SelectMany(m => m.Tasks)
                .FirstOrDefault(t => t.Id == plan.TaskId)?.Title ?? "Task",
            _ => "Scope"
        };
    }

    private static string GetStatusLabel(TestPlanStatus status) => status switch
    {
        TestPlanStatus.Draft => "Draft",
        TestPlanStatus.InProgress => "In Progress",
        TestPlanStatus.Completed => "Completed",
        _ => status.ToString()
    };

    private static string GetStatusBadgeClass(TestPlanStatus status) => status switch
    {
        TestPlanStatus.InProgress => "bg-blue-600 text-white animate-pulse",
        TestPlanStatus.Completed => "bg-emerald-500 text-white",
        _ => "bg-white shadow-sm text-slate-300"
    };

    private static string GetStatusPillClass(TestPlanStatus status) => status switch
    {
        TestPlanStatus.Draft => "bg-slate-400",
        TestPlanStatus.InProgress => "bg-blue-600",
        TestPlanStatus.Completed => "bg-emerald-500",
        _ => "bg-slate-400"
    };
}


