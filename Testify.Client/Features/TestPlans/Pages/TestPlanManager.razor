@page "/projects/{ProjectId:int}/testplans"
@using Microsoft.AspNetCore.Authorization
@using Testify.Client.Features.TestPlans.Components
@using Testify.Client.Interfaces
@using Testify.Client.Shared.Services
@using Testify.Shared.DTOs.Milestones
@using Testify.Shared.DTOs.Projects
@using Testify.Shared.DTOs.TestCases
@using Testify.Shared.DTOs.TestPlans
@using Testify.Shared.Enums
@inject ITestPlanService TestPlanService
@inject IProjectService ProjectService
@inject IMilestoneService MilestoneService
@inject ITestRunService TestRunService
@inject ModalService ModalService
@inject NavigationManager Navigation
@rendermode InteractiveWebAssembly
@attribute [Authorize]

<PageTitle>Test Plans</PageTitle>

<div class="animate-in fade-in slide-in-from-bottom-4 space-y-10 px-5 pt-3 pb-20 duration-700">
    @if (_isLoading)
    {
        <div class="flex flex-col items-center justify-center py-20">
            <div class="h-10 w-10 animate-spin rounded-full border-b-2 border-indigo-500"></div>
            <p class="mt-4 font-medium text-slate-400">Loading plans...</p>
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <div class="flex items-start gap-3 rounded-xl border border-red-100 bg-red-50 p-4">
            <svg class="mt-0.5 h-5 w-5 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <circle cx="12" cy="12" r="10" />
                <line x1="15" x2="9" y1="9" y2="15" />
                <line x1="9" x2="15" y1="9" y2="15" />
            </svg>
            <div>
                <h3 class="text-sm font-bold text-red-800">Something went wrong</h3>
                <p class="text-sm text-red-600">@_errorMessage</p>
            </div>
        </div>
    }
    else
    {
        @* 1. STRATEGIC HEADER *@
        <div class="flex flex-col justify-between gap-6 lg:flex-row lg:items-center">
            <div>
                <h2 class="flex items-center gap-4 text-4xl font-black tracking-tight text-slate-900">
                    Strategy Center
                    <div class="rounded-xl border border-indigo-100 bg-indigo-50 px-3 py-1 font-black tracking-widest text-[10px] text-indigo-600 uppercase">
                        Operational v4.2
                    </div>
                </h2>
                <p class="mt-2 max-w-2xl font-medium text-slate-400">
                    Provision and orchestrate high-integrity validation blueprints for project deliverables and critical logical paths.
                </p>
            </div>

            <button @onclick="OpenCreateForm"
                    class="group flex items-center gap-3 rounded-[28px] bg-[#1C1D2A] px-10 py-5 text-xs font-black tracking-widest text-white uppercase shadow-2xl transition-all hover:bg-slate-800 active:scale-95">
                <svg class="h-5 w-5 text-indigo-400 transition-transform group-hover:rotate-90" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 5v14M5 12h14" />
                </svg>
                <span>Add New Plan</span>
            </button>
        </div>

        @* 2. SPLIT-PANE HUB *@
        <div class="grid grid-cols-1 items-start gap-8 xl:grid-cols-12">
            @* LEFT: PLAN NAVIGATOR *@
            <div class="space-y-6 xl:col-span-4">
                <div class="flex flex-col overflow-hidden rounded-[40px] border border-slate-100 bg-white shadow-sm">
                    <div class="space-y-4 border-b border-slate-50 bg-slate-50/30 p-6">
                        <div class="group relative">
                            <svg class="absolute top-1/2 left-4 h-4 w-4 -translate-y-1/2 text-slate-300 transition-colors group-focus-within:text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35m0 0A7.5 7.5 0 105.5 5.5a7.5 7.5 0 0011.15 11.15z" />
                            </svg>
                            <input type="text"
                                   placeholder="Search identifier or title..."
                                   @bind="_searchQuery"
                                   @bind:event="oninput"
                                   class="w-full rounded-2xl border border-slate-200 bg-white py-3 pr-4 pl-11 font-bold text-[11px] transition-all outline-none focus:ring-4 focus:ring-indigo-500/5" />
                        </div>

                        <div class="no-scrollbar flex items-center gap-1 overflow-x-auto pb-1">
                            @foreach (var type in _typeFilters)
                            {
                                <button @onclick="() => _typeFilter = type"
                                        class="whitespace-nowrap rounded-xl px-4 py-2 text-[9px] font-black uppercase tracking-widest transition-all @(_typeFilter == type ? "bg-indigo-600 text-white shadow-lg" : "border border-slate-100 bg-white text-slate-400 hover:bg-slate-50")">
                                    @type
                                </button>
                            }
                        </div>
                    </div>

                    <div class="no-scrollbar max-h-[600px] space-y-1 overflow-y-auto p-2">
                        @if (FilteredPlans.Count == 0)
                        {
                            <div class="flex flex-col items-center py-20 text-center opacity-30">
                                <svg class="mb-4 h-10 w-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35m0 0A7.5 7.5 0 105.5 5.5a7.5 7.5 0 0011.15 11.15z" />
                                </svg>
                                <p class="font-black tracking-widest text-[10px] uppercase">No plans matched criteria</p>
                            </div>
                        }
                        else
                        {
                            @foreach (var plan in FilteredPlans)
                            {
                                var isSelected = SelectedPlanId == plan.Id || (SelectedPlanId is null && FilteredPlans.First().Id == plan.Id);
                                <button @onclick="() => SelectedPlanId = plan.Id"
                                        class="group flex w-full items-center justify-between rounded-[28px] p-5 text-left transition-all @(isSelected ? "border border-indigo-100 bg-indigo-50 shadow-sm" : "hover:bg-slate-50")">
                                    <div class="flex items-center gap-4 truncate">
                                        <div class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-2xl transition-all @GetStatusBadgeClass(plan.Status)">
                                            @if (plan.Status == TestPlanStatus.Draft)
                                            {
                                                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4h16v4H4zM4 12h16v8H4z" />
                                                </svg>
                                            }
                                            else
                                            {
                                                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                                                </svg>
                                            }
                                        </div>
                                        <div class="truncate">
                                            <p class="font-mono font-bold tracking-widest text-[10px] text-slate-300 uppercase">@plan.Id</p>
                                            <h4 class="truncate text-sm font-black text-slate-800">@plan.Name</h4>
                                        </div>
                                    </div>
                                    <svg class="h-4 w-4 transition-transform @(isSelected ? "translate-x-1 text-indigo-500" : "text-slate-200 group-hover:text-slate-400")" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                                    </svg>
                                </button>
                            }
                        }
                    </div>
                </div>

                <div class="space-y-4 rounded-[40px] border border-amber-100 bg-amber-50 p-8">
                    <div class="flex items-center gap-3">
                        <svg class="h-5 w-5 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                        </svg>
                        <h5 class="text-xs font-black tracking-widest text-amber-800 uppercase">Integrity Gaps</h5>
                    </div>
                    <p class="leading-relaxed font-medium text-[11px] text-amber-600">
                        @_plans.Count(p => p.TestSuites.Count == 0) strategy instances currently have zero logical coverage. This indicates a high risk for the upcoming deployment window.
                    </p>
                </div>
            </div>

            @* RIGHT: STRATEGY CANVAS *@
            <div class="xl:col-span-8">
                @if (ActivePreviewPlan is null)
                {
                    <div class="flex h-full flex-col items-center justify-center rounded-[64px] border-2 border-dashed border-slate-200 bg-white/40 p-20 text-center">
                        <div class="mb-8 flex h-24 w-24 items-center justify-center rounded-[40px] bg-white shadow-sm">
                            <svg class="h-10 w-10 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5h7a2 2 0 012 2v10a2 2 0 01-2 2H8l-4 4V7a2 2 0 012-2h3" />
                            </svg>
                        </div>
                        <h3 class="text-3xl font-black tracking-tight text-slate-800">Select Strategy Node</h3>
                        <p class="mt-4 max-w-sm leading-relaxed font-medium text-slate-400">
                            Select a test plan from the navigator to visualize its architectural depth and execution status.
                        </p>
                    </div>
                }
                else
                {
                    var plan = ActivePreviewPlan;

                    <div class="animate-in fade-in zoom-in-95 overflow-hidden rounded-[48px] border border-slate-100 bg-white shadow-sm duration-500">
                        <div class="flex flex-col justify-between gap-8 border-b border-slate-50 bg-slate-50/20 p-10 md:flex-row md:items-center">
                            <div class="space-y-2">
                                <div class="flex items-center gap-3">
                                    <div class="rounded-full px-4 py-1 font-black tracking-widest text-[9px] text-white uppercase @GetStatusPillClass(plan.Status)">
                                        @GetStatusLabel(plan.Status) Strategy
                                    </div>
                                    <span class="font-mono font-bold tracking-widest text-[11px] text-slate-300 uppercase">@plan.Id</span>
                                </div>
                                <h3 class="text-3xl leading-none font-black tracking-tight text-slate-800">@plan.Name</h3>
                            </div>
                            <div class="flex gap-2">
                                <button @onclick="() => NavigateToPlanBlueprintDetail(plan.Id)"
                                        class="group rounded-3xl border border-slate-100 bg-white p-5 text-slate-400 transition-all hover:text-indigo-600 hover:shadow-md">
                                    <svg class="h-6 w-6 transition-transform group-hover:scale-110" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                                    </svg>
                                </button>

                                @if (ActivePreviewPlan.Status == TestPlanStatus.Draft)
                                {
                                    <button @onclick="() => OpenEditForm(plan)"
                                            class="group rounded-3xl border border-slate-100 bg-white p-5 text-slate-400 transition-all hover:text-slate-700 hover:shadow-md">
                                        <svg class="h-6 w-6 transition-transform group-hover:scale-110" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                        </svg>
                                    </button>

                                    <button @onclick="() => DeletePlan(plan.Id)"
                                            class="group rounded-3xl border border-slate-100 bg-white p-5 text-slate-400 transition-all hover:border-red-100 hover:text-red-500 hover:shadow-md">
                                        <svg class="h-6 w-6 transition-transform group-hover:scale-110" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                        </svg>
                                    </button>
                                }
                            </div>
                        </div>

                        <div class="grid grid-cols-1 gap-10 p-10 md:grid-cols-2">
                            <div class="space-y-6">
                                <div class="space-y-4">
                                    <h5 class="flex items-center gap-2 px-1 font-black tracking-widest text-[10px] text-slate-400 uppercase">
                                        <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h11M9 21V3m8 18l4-4-4-4" />
                                        </svg>
                                        Target Integration
                                    </h5>
                                    <div class="group flex items-center justify-between rounded-[32px] border border-slate-100 bg-slate-50 p-6">
                                        <div class="flex items-center gap-4">
                                            <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-white shadow-sm">
                                                <svg class="h-6 w-6 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7h18M3 12h18M3 17h18" />
                                                </svg>
                                            </div>
                                            <div>
                                                <p class="max-w-[200px] truncate text-xs font-black text-slate-800">@GetTargetName(plan)</p>
                                                <p class="font-bold tracking-widest text-[9px] text-slate-400 uppercase">Scope: @plan.Scope</p>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="space-y-4">
                                    <h5 class="flex items-center gap-2 px-1 font-black tracking-widest text-[10px] text-slate-400 uppercase">
                                        <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                                        </svg>
                                        Enrolled Logic Suites
                                    </h5>
                                    <div class="no-scrollbar max-h-[180px] space-y-2 overflow-y-auto pr-2">
                                        @if (plan.TestSuites.Count == 0)
                                        {
                                            <div class="rounded-[32px] border-2 border-dashed border-slate-100 py-10 text-center opacity-30">
                                                <p class="font-black text-[10px] uppercase">No suites enrolled</p>
                                            </div>
                                        }
                                        else
                                        {
                                            @foreach (var suite in plan.TestSuites)
                                            {
                                                <div class="group flex items-center justify-between rounded-2xl border border-slate-50 bg-white p-4 shadow-sm transition-all hover:border-indigo-200">
                                                    <div class="flex items-center gap-3">
                                                        <div class="flex h-8 w-8 items-center justify-center rounded-xl bg-slate-50 text-slate-300 transition-all group-hover:bg-indigo-50 group-hover:text-indigo-500">
                                                            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                                                            </svg>
                                                        </div>
                                                        <span class="max-w-[150px] truncate font-bold text-[11px] text-slate-600">@suite.Name</span>
                                                    </div>
                                                    <span class="font-black text-[9px] text-slate-300">Suite</span>
                                                </div>
                                            }
                                        }
                                    </div>
                                </div>
                            </div>

                            <div class="space-y-8">
                                <div class="group relative overflow-hidden rounded-[40px] bg-[#1C1D2A] p-8 text-white shadow-xl">
                                    <div class="relative z-10 space-y-6">
                                        <div class="flex items-center justify-between">
                                            <h5 class="flex items-center gap-2 font-black tracking-widest text-[10px] text-indigo-400 uppercase">
                                                <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                                                </svg>
                                                Neural Predictor
                                            </h5>
                                            <svg class="h-5 w-5 animate-pulse text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M12 6v6" />
                                            </svg>
                                        </div>
                                        <p class="text-xs leading-relaxed font-medium text-slate-400 italic">
                                            "Validation logic for <span class="font-bold text-white">@plan.Id</span> targets core protocols. Stability index is projected at <span class="font-bold text-emerald-400">92%</span>."
                                        </p>
                                    </div>
                                    <div class="absolute -right-10 -bottom-10 h-32 w-32 rounded-full bg-indigo-500/10 blur-3xl"></div>
                                </div>

                                <div class="space-y-4">
                                    <h5 class="flex items-center gap-2 px-1 font-black tracking-widest text-[10px] text-slate-400 uppercase">
                                        <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 12a1 1 0 102 0 1 1 0 00-2 0zM4 12a1 1 0 102 0 1 1 0 00-2 0zM18 12a1 1 0 102 0 1 1 0 00-2 0z" />
                                        </svg>
                                        Readiness Matrix
                                    </h5>
                                    <div class="grid grid-cols-2 gap-3">
                                        <div class="rounded-[32px] border border-slate-100/50 bg-slate-50 p-6">
                                            <p class="mb-2 font-black text-[10px] text-slate-400 uppercase">Complexity</p>
                                            <div class="flex gap-1.5">
                                                @for (var lvl = 1; lvl <= 5; lvl++)
                                                {
                                                    <div class="h-1.5 w-full rounded-full @(lvl <= 3 ? "bg-indigo-500" : "bg-slate-200")"></div>
                                                }
                                            </div>
                                        </div>
                                        <div class="rounded-[32px] border border-slate-100/50 bg-slate-50 p-6">
                                            <p class="mb-2 font-black text-[10px] text-slate-400 uppercase">Risk Vector</p>
                                            <p class="text-lg leading-none font-black text-emerald-500 uppercase">Low</p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="flex flex-col justify-between gap-6 border-t border-slate-50 bg-slate-50/50 p-10 md:flex-row md:items-center">
                            <div class="flex items-center gap-4 text-slate-400">
                                <svg class="h-6 w-6 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4" />
                                </svg>
                                <p class="font-bold tracking-widest text-[10px] uppercase">Blueprint Integrity Verified • Strategy Ready for Dispatch</p>
                            </div>

                            <div class="flex gap-3">
                                @if (plan.Status == TestPlanStatus.Draft)
                                {
                                    @* <button @onclick="() => _planToExecute = plan"
                                            class="flex items-center gap-3 rounded-[22px] bg-indigo-600 px-12 py-4 text-xs font-black uppercase tracking-widest text-white shadow-xl transition-all hover:bg-indigo-700 active:scale-95">
                                        <svg class="h-4 w-4 fill-white" viewBox="0 0 24 24"><path d="M8 5v14l11-7z" /></svg>
                                        Start Execution
                                    </button> *@
                                    <button @onclick="async () => { _planToExecute = plan; await HandleStartExecutionAsync(); }"
                                            class="flex items-center gap-3 rounded-[22px] bg-indigo-600 px-12 py-4 text-xs font-black uppercase tracking-widest text-white shadow-xl transition-all hover:bg-indigo-700 active:scale-95">
                                        <svg class="h-4 w-4 fill-white" viewBox="0 0 24 24"><path d="M8 5v14l11-7z" /></svg>
                                        Start Execution
                                    </button>
                                }
                                else
                                {
                                    <button @onclick="() => NavigateToPlan(plan.Id)"
                                            class="flex items-center gap-3 rounded-[22px] bg-blue-600 px-12 py-4 text-xs font-black uppercase tracking-widest text-white shadow-xl transition-all hover:bg-blue-700 active:scale-95">
                                        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14m-7-7 7 7-7 7" />
                                        </svg>
                                        Return to Run
                                    </button>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>


        @* 4. FORM OVERLAY *@
        @if (_isFormOpen && _project is not null)
        {
            <TestPlanForm Project="_project"
                          Milestones="_milestones"
                          TestSuites="_testSuites"
                          ExistingPlan="_editingPlan"
                          OnCreate="HandleCreateAsync"
                          OnUpdate="HandleUpdateAsync"
                          OnClose="CloseForm" />
        }

        @* 5. PORTFOLIO INSIGHT FOOTER *@
        <div class="relative flex flex-col items-center justify-between gap-10 overflow-hidden rounded-[64px] border border-slate-100 bg-white p-12 shadow-sm md:flex-row">
            <div class="relative z-10 space-y-4">
                <h4 class="text-2xl font-black tracking-tight text-slate-800">Portfolio Strategy Traceability</h4>
                <p class="max-w-2xl leading-relaxed font-medium text-slate-400">
                    Global strategy tracking provides cross-sprint auditing. Use the Strategy Center to verify that every critical requirement is shadowed by a verifiable logical blueprint.
                </p>
                <div class="flex gap-4 pt-2">
                    <div class="flex items-center gap-2">
                        <div class="h-2 w-2 rounded-full bg-emerald-500"></div>
                        <span class="font-black tracking-widest text-[10px] text-slate-400 uppercase">Active Syncing</span>
                    </div>
                    <div class="flex items-center gap-2">
                        <div class="h-2 w-2 rounded-full bg-[#E85D3F]"></div>
                        <span class="font-black tracking-widest text-[10px] text-slate-400 uppercase">Compliance Locked</span>
                    </div>
                </div>
            </div>
            <div class="group relative flex h-40 w-40 flex-shrink-0 cursor-help items-center justify-center">
                <div class="h-full w-full rounded-full border-4 border-dashed border-indigo-100 transition-all group-hover:animate-[spin_10s_linear_infinite]"></div>
                <svg class="absolute h-20 w-20 text-indigo-100 transition-colors group-hover:text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                </svg>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public int ProjectId { get; set; }

    private ProjectResponse? _project;
    private List<TestPlanResponse> _plans = [];
    private List<MilestoneResponse> _milestones = [];
    private List<TestSuiteResponse> _testSuites = [];

    private bool _isLoading = true;
    private string? _errorMessage;

    private string _searchQuery = string.Empty;
    private string _typeFilter = "All";
    private readonly string[] _typeFilters = ["All", "Project", "Milestone", "Task"];

    private int? SelectedPlanId { get; set; }
    private bool _isFormOpen;
    private TestPlanResponse? _editingPlan;
    private TestPlanResponse? _planToExecute;

    private List<TestPlanResponse> FilteredPlans =>
        _plans
            .Where(p => MatchesSearch(p) && MatchesFilter(p))
            .OrderByDescending(p => p.Id)
            .ToList();

    private TestPlanResponse? ActivePreviewPlan =>
        SelectedPlanId is null
            ? FilteredPlans.FirstOrDefault()
            : FilteredPlans.FirstOrDefault(p => p.Id == SelectedPlanId);

    protected override async Task OnParametersSetAsync()
    {
        _isLoading = true;
        _errorMessage = null;

        try
        {
            _project = await ProjectService.GetProjectByIdAsync(ProjectId);
            _plans = await TestPlanService.GetAllTestPlansAsync(ProjectId);
            _milestones = await MilestoneService.GetMilestonesByProjectAsync(ProjectId);

            // Add explicit error handling
            var suites = await TestPlanService.GetAllTestSuitesByProjectIdAsync(ProjectId);
            _testSuites = suites.ToList();

            // Debug output
            Console.WriteLine($"Loaded {_testSuites.Count} test suites for project {ProjectId}");
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error loading data: {ex.Message}";
            Console.WriteLine($"Error: {ex}"); 
        }
        finally
        {
            _isLoading = false;
        }
    }

    private bool MatchesSearch(TestPlanResponse plan)
    {
        if (string.IsNullOrWhiteSpace(_searchQuery))
            return true;

        return plan.Name.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase)
               || plan.Id.ToString().Contains(_searchQuery, StringComparison.OrdinalIgnoreCase);
    }

    private bool MatchesFilter(TestPlanResponse plan)
    {
        if (_typeFilter == "All")
            return true;

        return _typeFilter switch
        {
            "Project" => plan.Scope == TestPlanScope.Project,
            "Milestone" => plan.Scope == TestPlanScope.Milestone,
            "Task" => plan.Scope == TestPlanScope.Task,
            _ => true
        };
    }

    private void OpenCreateForm()
    {
        _editingPlan = null;
        _isFormOpen = true;
    }

    private void OpenEditForm(TestPlanResponse plan)
    {
        _editingPlan = plan;
        _isFormOpen = true;
    }

    private void CloseForm()
    {
        _isFormOpen = false;
        _editingPlan = null;
    }

    private async Task HandleCreateAsync(CreateTestPlanRequest request)
    {
        await TestPlanService.CreateTestPlanAsync(request);
        _plans = await TestPlanService.GetAllTestPlansAsync(ProjectId);
        CloseForm();
    }

    private async Task HandleUpdateAsync(UpdateTestPlanRequest request)
    {
        if (_editingPlan is null)
            return;

        await TestPlanService.UpdateTestPlanAsync(_editingPlan.Id, request);
        _plans = await TestPlanService.GetAllTestPlansAsync(ProjectId);
        CloseForm();
    }

    private async Task DeletePlan(int planId)
    {
        bool confirmed = await ModalService.ShowDeleteConfirmation("Delete Test Plan", "Are you sure you want to delete this test plan?");
        if (!confirmed)
            return;
        try
        {
            await TestPlanService.DeleteTestPlanAsync(planId);
            _plans = await TestPlanService.GetAllTestPlansAsync(ProjectId);
            if (SelectedPlanId == planId)
                SelectedPlanId = null;
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to delete test plan: {ex.Message}";
        }
    }

    private void CloseExecutionPrompt()
    {
        _planToExecute = null;
    }

    // private async Task HandleStartExecutionAsync()
