            Strategy Center
            <div className="px-3 py-1 bg-indigo-50 text-indigo-600 rounded-xl text-[10px] font-black uppercase tracking-widest border border-indigo-100">
               Operational v4.2
            </div>
          </h2>
          <p className="text-slate-400 mt-2 font-medium max-w-2xl">Provision and orchestrate high-integrity validation blueprints for project deliverables and critical logical paths.</p>
        </div>
        
        <button 
          onClick={() => { setEditingPlan(null); setIsFormOpen(true); }}
