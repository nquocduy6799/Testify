        >
          <Plus className="w-5 h-5 text-indigo-400 group-hover:rotate-90 transition-transform" />
          <span>Architect New Plan</span>
        </button>
      </div>

      {/* 2. SPLIT-PANE HUB */}
      <div className="grid grid-cols-1 xl:grid-cols-12 gap-8 items-start">
        
        {/* LEFT: PLAN NAVIGATOR (High Density List) */}
        <div className="xl:col-span-4 space-y-6">
           <div className="bg-white rounded-[40px] border border-slate-100 shadow-sm overflow-hidden flex flex-col">
              <div className="p-6 border-b border-slate-50 space-y-4 bg-slate-50/30">
                 <div className="relative group">
                    <Search className="absolute left-4 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-300 group-focus-within:text-indigo-500 transition-colors" />
                    <input 
                      type="text" 
                      placeholder="Search identifier or title..."
                      value={searchQuery}
                      onChange={(e) => setSearchQuery(e.target.value)}
                      className="w-full pl-11 pr-4 py-3 bg-white border border-slate-200 rounded-2xl text-[11px] font-bold outline-none focus:ring-4 focus:ring-indigo-500/5 transition-all"
                    />
                 </div>
                 <div className="flex items-center gap-1 overflow-x-auto no-scrollbar pb-1">
                    {(['All', 'Project', 'Milestone', 'Task'] as const).map(type => (
                      <button
                        key={type}
                        onClick={() => setTypeFilter(type)}
                        className={`px-4 py-2 rounded-xl text-[9px] font-black uppercase tracking-widest transition-all whitespace-nowrap ${
                          typeFilter === type ? 'bg-indigo-600 text-white shadow-lg' : 'bg-white text-slate-400 border border-slate-100 hover:bg-slate-50'
                        }`}
                      >
                         {type}
                      </button>
                    ))}
                 </div>
              </div>

              <div className="p-2 space-y-1 max-h-[600px] overflow-y-auto no-scrollbar">
                 {filteredPlans.map(plan => (
                   <button
                     key={plan.id}
                     onClick={() => setSelectedPlanId(plan.id)}
                     className={`w-full p-5 rounded-[28px] transition-all text-left flex items-center justify-between group ${
                       selectedPlanId === plan.id || (!selectedPlanId && filteredPlans[0]?.id === plan.id)
                         ? 'bg-indigo-50 border border-indigo-100 shadow-sm' 
                         : 'hover:bg-slate-50'
                     }`}
                   >
                      <div className="flex items-center gap-4 truncate">
                         <div className={`w-10 h-10 rounded-2xl flex items-center justify-center flex-shrink-0 transition-all ${
                           plan.status === 'In Progress' ? 'bg-blue-600 text-white animate-pulse' : 
                           plan.status === 'Completed' ? 'bg-emerald-500 text-white' : 'bg-white shadow-sm text-slate-300'
                         }`}>
                            {plan.status === 'Draft' ? <Terminal className="w-5 h-5" /> : <ShieldCheck className="w-5 h-5" />}
                         </div>
                         <div className="truncate">
                            <p className="text-[10px] font-mono font-bold text-slate-300 uppercase tracking-widest">{plan.id}</p>
                            <h4 className="text-sm font-black text-slate-800 truncate">{plan.name}</h4>
                         </div>
                      </div>
                      <ChevronRight className={`w-4 h-4 transition-transform ${
                        selectedPlanId === plan.id ? 'translate-x-1 text-indigo-500' : 'text-slate-200 group-hover:text-slate-400'
                      }`} />
                   </button>
                 ))}

                 {filteredPlans.length === 0 && (
                   <div className="py-20 text-center opacity-30 flex flex-col items-center">
                      <Search className="w-10 h-10 mb-4" />
                      <p className="text-[10px] font-black uppercase tracking-widest">No plans matched criteria</p>
                   </div>
                 )}
              </div>
           </div>

           {/* Health Warning Area */}
           <div className="bg-amber-50 border border-amber-100 rounded-[40px] p-8 space-y-4">
              <div className="flex items-center gap-3">
                 <AlertTriangle className="w-5 h-5 text-amber-500" />
                 <h5 className="text-xs font-black text-amber-800 uppercase tracking-widest">Integrity Gaps</h5>
              </div>
              <p className="text-[11px] text-amber-600 font-medium leading-relaxed">
                 {plans.filter(p => p.suiteIds.length === 0).length} strategy instances currently have zero logical coverage. This indicates a high risk for the upcoming deployment window.
              </p>
           </div>
        </div>

        {/* RIGHT: STRATEGY CANVAS (Active Plan Preview) */}
        <div className="xl:col-span-8">
           {activePreviewPlan ? (
             <div className="bg-white rounded-[48px] border border-slate-100 shadow-sm overflow-hidden animate-in fade-in zoom-in-95 duration-500">
                {/* Preview Header */}
                <div className="p-10 border-b border-slate-50 flex flex-col md:flex-row md:items-center justify-between gap-8 bg-slate-50/20">
                   <div className="space-y-2">
                      <div className="flex items-center gap-3">
                         <div className={`px-4 py-1 rounded-full text-[9px] font-black uppercase tracking-widest text-white ${
                           activePreviewPlan.status === 'Draft' ? 'bg-slate-400' : 'bg-blue-50'
                         }`}>
                           {activePreviewPlan.status} Strategy
                         </div>
                         <span className="text-[11px] font-mono font-bold text-slate-300 uppercase tracking-widest">{activePreviewPlan.id}</span>
                      </div>
                      <h3 className="text-3xl font-black text-slate-800 tracking-tight leading-none">{activePreviewPlan.name}</h3>
                   </div>
                   <div className="flex gap-2">
                      <button 
                        onClick={() => setViewingPlanId(activePreviewPlan.id)}
                        className="p-5 bg-white border border-slate-100 text-slate-400 hover:text-indigo-600 hover:shadow-md rounded-3xl transition-all group"
                      >
                         <Maximize2 className="w-6 h-6 group-hover:scale-110 transition-transform" />
                      </button>
                      <button 
                        onClick={() => { setEditingPlan(activePreviewPlan); setIsFormOpen(true); }}
                        className="p-5 bg-white border border-slate-100 text-slate-400 hover:text-slate-700 hover:shadow-md rounded-3xl transition-all"
                      >
                         <Edit3 className="w-6 h-6" />
                      </button>
                   </div>
                </div>

                <div className="p-10 grid grid-cols-1 md:grid-cols-2 gap-10">
                   {/* Scope Block */}
                   <div className="space-y-6">
                      <div className="space-y-4">
                         <h5 className="text-[10px] font-black text-slate-400 uppercase tracking-widest flex items-center gap-2 px-1">
                            <Target className="w-3.5 h-3.5" /> Target Integration
                         </h5>
                         <div className="p-6 bg-slate-50 rounded-[32px] border border-slate-100 flex items-center justify-between group">
                            <div className="flex items-center gap-4">
                               <div className="w-12 h-12 bg-white rounded-2xl flex items-center justify-center shadow-sm">
                                  {activePreviewPlan.targetType === 'Milestone' ? <Clock className="w-6 h-6 text-orange-400" /> : 
                                   activePreviewPlan.targetType === 'Task' ? <Layout className="w-6 h-6 text-blue-400" /> : 
                                   <Briefcase className="w-6 h-6 text-emerald-400" />}
                               </div>
                               <div>
                                  <p className="text-xs font-black text-slate-800 truncate max-w-[200px]">{getTargetName(activePreviewPlan)}</p>
                                  <p className="text-[9px] font-bold text-slate-400 uppercase tracking-widest">Scope: {activePreviewPlan.targetType}</p>
                               </div>
                            </div>
                         </div>
                      </div>

                      <div className="space-y-4">
                         <h5 className="text-[10px] font-black text-slate-400 uppercase tracking-widest flex items-center gap-2 px-1">
                            <Layers className="w-3.5 h-3.5" /> Enrolled Logic Suites
                         </h5>
                         <div className="space-y-2 max-h-[180px] overflow-y-auto no-scrollbar pr-2">
                            {activePreviewPlan.suiteIds.map(sid => {
                               const suite = project.testSuites?.find(s => s.id === sid);
                               return (
                                 <div key={sid} className="p-4 bg-white border border-slate-50 rounded-2xl flex items-center justify-between group hover:border-indigo-200 transition-all shadow-sm">
                                    <div className="flex items-center gap-3">
                                       <div className="w-8 h-8 rounded-xl bg-slate-50 flex items-center justify-center text-slate-300 group-hover:bg-indigo-50 group-hover:text-indigo-500 transition-all">
                                          <Layers className="w-4 h-4" />
                                       </div>
                                       <span className="text-[11px] font-bold text-slate-600 truncate max-w-[150px]">{suite?.name || sid}</span>
                                    </div>
                                    <span className="text-[9px] font-black text-slate-300">{suite?.testCases.length || 0} Cases</span>
                                 </div>
                               );
                            })}
                            {activePreviewPlan.suiteIds.length === 0 && (
                               <div className="py-10 text-center opacity-30 border-2 border-dashed border-slate-100 rounded-[32px]">
                                  <p className="text-[10px] font-black uppercase">No suites enrolled</p>
                               </div>
                            )}
                         </div>
                      </div>
                   </div>

                   {/* Intelligence Block */}
                   <div className="space-y-8">
                      <div className="bg-[#1C1D2A] rounded-[40px] p-8 text-white relative overflow-hidden group shadow-xl">
                         <div className="relative z-10 space-y-6">
                            <div className="flex items-center justify-between">
                               <h5 className="text-[10px] font-black text-indigo-400 uppercase tracking-widest flex items-center gap-2">
                                  <Zap className="w-3.5 h-3.5" /> Neural Predictor
                               </h5>
                               <Cpu className="w-5 h-5 text-indigo-500 animate-pulse" />
                            </div>
                            <p className="text-xs font-medium text-slate-400 leading-relaxed italic">
                               "Validation logic for <span className="text-white font-bold">{activePreviewPlan.id}</span> targets core Auth protocols. Gemini identifies <span className="text-emerald-400">92% stability index</span> for current suite parameters."
                            </p>
                         </div>
                         <div className="absolute -bottom-10 -right-10 w-32 h-32 bg-indigo-500/10 rounded-full blur-3xl"></div>
                      </div>

                      <div className="space-y-4">
                         <h5 className="text-[10px] font-black text-slate-400 uppercase tracking-widest flex items-center gap-2 px-1">
                            <Activity className="w-3.5 h-3.5" /> Readiness Matrix
                         </h5>
                         <div className="grid grid-cols-2 gap-3">
                            <div className="p-6 bg-slate-50 rounded-[32px] border border-slate-100/50">
                               <p className="text-[10px] font-black text-slate-400 uppercase mb-2">Complexity</p>
                               <div className="flex gap-1.5">
                                  {[1,2,3,4,5].map(lvl => (
                                    <div key={lvl} className={`h-1.5 w-full rounded-full ${lvl <= 3 ? 'bg-indigo-500' : 'bg-slate-200'}`}></div>
                                  ))}
                                </div>
                            </div>
                            <div className="p-6 bg-slate-50 rounded-[32px] border border-slate-100/50">
                               <p className="text-[10px] font-black text-slate-400 uppercase mb-2">Risk Vector</p>
                               <p className="text-lg font-black text-emerald-500 uppercase leading-none">Low</p>
                            </div>
                         </div>
                      </div>
                   </div>
                </div>

                {/* Execution Bar */}
                <div className="p-10 border-t border-slate-50 bg-slate-50/50 flex flex-col md:flex-row md:items-center justify-between gap-6">
                   <div className="flex items-center gap-4 text-slate-400">
                      <ShieldCheck className="w-6 h-6 text-emerald-500" />
                      <p className="text-[10px] font-bold uppercase tracking-widest">Blueprint Integrity Verified • Strategy Ready for Dispatch</p>
                   </div>
                   
                   <div className="flex gap-3">
                      {activePreviewPlan.status === 'Draft' ? (
                        <button 
                          onClick={() => setPlanToExecute(activePreviewPlan)}
                          className="px-12 py-4 bg-indigo-600 text-white rounded-[22px] font-black text-xs uppercase tracking-widest hover:bg-indigo-700 shadow-xl active:scale-95 transition-all flex items-center gap-3"
                        >
                           <Play className="w-4 h-4 fill-white" /> Start Execution
                        </button>
                      ) : (
                        <button 
                          onClick={() => onLaunchExecution(activePreviewPlan)}
                          className="px-12 py-4 bg-blue-600 text-white rounded-[22px] font-black text-xs uppercase tracking-widest hover:bg-blue-700 shadow-xl active:scale-95 transition-all flex items-center gap-3"
                        >
                           <ArrowRight className="w-4 h-4" /> Return to Run
                        </button>
                      )}
                   </div>
                </div>
             </div>
           ) : (
             <div className="h-full flex flex-col items-center justify-center text-center p-20 bg-white/40 rounded-[64px] border-2 border-dashed border-slate-200">
                <div className="w-24 h-24 bg-white rounded-[40px] flex items-center justify-center shadow-sm mb-8">
                   <ClipboardList className="w-10 h-10 text-indigo-400" />
                </div>
                <h3 className="text-3xl font-black text-slate-800 tracking-tight">Select Strategy Node</h3>
                <p className="text-slate-400 max-w-sm mt-4 font-medium leading-relaxed">Select a test plan from the navigator to visualize its architectural depth and execution status.</p>
             </div>
           )}
        </div>
      </div>

      {/* 3. CONFIRMATION OVERLAY */}
      {planToExecute && (
        <div className="fixed inset-0 z-[500] flex items-center justify-center p-6">
          <div className="absolute inset-0 bg-[#0F111A]/80 backdrop-blur-xl animate-in fade-in duration-500" onClick={() => setPlanToExecute(null)}></div>
          <div className="relative bg-white w-full max-w-md rounded-[56px] p-12 text-center animate-in zoom-in-95 duration-300 shadow-2xl overflow-hidden border border-slate-100">
            <div className="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-indigo-500 to-transparent"></div>
            <div className="w-24 h-24 bg-indigo-50 rounded-[40px] flex items-center justify-center mx-auto mb-8 ring-8 ring-indigo-50/50">
              <AlertCircle className="w-12 h-12 text-indigo-500 animate-pulse" />
            </div>
            <h2 className="text-3xl font-black text-slate-800 tracking-tight leading-none uppercase">Deploy Strategy?</h2>
            <p className="text-slate-400 font-medium mt-6 leading-relaxed">
               Initializing <span className="text-indigo-600 font-black">"{planToExecute.name}"</span> will freeze the current logical enrollment. All scenarios will be dispatched to the Execution Hub.
            </p>
            <div className="mt-12 flex flex-col gap-3">
              <button 
                onClick={handleStartExecution}
                className="w-full py-6 bg-[#1C1D2A] text-white rounded-[24px] font-black text-xs uppercase tracking-[0.2em] shadow-2xl hover:bg-slate-800 transition-all active:scale-95 flex items-center justify-center gap-3 group"
              >
                Launch Protocol <ArrowRight className="w-4 h-4 group-hover:translate-x-1 transition-transform" />
              </button>
              <button 
                onClick={() => setPlanToExecute(null)}
                className="w-full py-5 bg-white text-slate-400 font-black text-[10px] uppercase tracking-widest hover:text-slate-800 transition-colors"
              >
                Abort Deployment
              </button>
            </div>
          </div>
        </div>
      )}

      {/* 4. FORM OVERLAY */}
      {isFormOpen && (
        <TestPlanForm 
          project={project}
          globalLibrary={globalLibrary}
          existingPlan={editingPlan}
          onSave={handleSavePlan}
          onClose={() => { setIsFormOpen(false); setEditingPlan(null); }}
        />
      )}

      {/* 5. PORTFOLIO INSIGHT FOOTER */}
      <div className="p-12 bg-white rounded-[64px] border border-slate-100 flex flex-col md:flex-row items-center justify-between gap-10 relative overflow-hidden shadow-sm">
         <div className="relative z-10 space-y-4">
            <h4 className="text-2xl font-black text-slate-800 tracking-tight">Portfolio Strategy Traceability</h4>
            <p className="text-slate-400 font-medium max-w-2xl leading-relaxed">
               Global strategy tracking provides cross-sprint auditing. Use the Strategy Center to verify that every critical requirement is shadowed by a verifiable logical blueprint.
            </p>
            <div className="flex gap-4 pt-2">
               <div className="flex items-center gap-2">
                  <div className="w-2 h-2 rounded-full bg-emerald-500"></div>
                  <span className="text-[10px] font-black text-slate-400 uppercase tracking-widest">Active Syncing</span>
               </div>
               <div className="flex items-center gap-2">
                  <div className="w-2 h-2 rounded-full bg-[#E85D3F]"></div>
                  <span className="text-[10px] font-black text-slate-400 uppercase tracking-widest">Compliance Locked</span>
               </div>
            </div>
         </div>
         <div className="flex-shrink-0 relative w-40 h-40 flex items-center justify-center group cursor-help">
            <div className="w-full h-full rounded-full border-4 border-dashed border-indigo-100 group-hover:animate-[spin_10s_linear_infinite] transition-all"></div>
            <ShieldCheck className="w-20 h-20 text-indigo-100 absolute group-hover:text-indigo-600 transition-colors" />
         </div>
      </div>
    </div>
  );
};
