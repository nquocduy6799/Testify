@page "/projects/{ProjectId:int}/testplans/{TestPlanId:int}/blueprint"
@using Microsoft.AspNetCore.Authorization
@using Testify.Client.Interfaces
@using Testify.Shared.DTOs.TestCases
@using Testify.Shared.DTOs.TestPlans
@using Testify.Shared.Enums
@inject ITestPlanService TestPlanService
@inject NavigationManager Navigation
@rendermode InteractiveWebAssembly
@attribute [Authorize]

<PageTitle>@(_testPlan?.Name ?? "Strategy Blueprint")</PageTitle>

<div class="animate-in fade-in slide-in-from-right-4 space-y-8 pb-32 duration-500">
    @if (_isLoading)
    {
        <div class="flex flex-col items-center justify-center py-40">
            <div class="h-12 w-12 animate-spin rounded-full border-b-4 border-indigo-600"></div>
            <p class="mt-6 text-xs font-black tracking-widest text-slate-400 uppercase">Loading Blueprint...</p>
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <div class="rounded-[32px] border border-red-100 bg-red-50 p-8 text-center">
            <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-2xl bg-red-100 text-red-500">
                <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            </div>
            <h3 class="mt-4 text-lg font-black text-red-900">System Error</h3>
            <p class="mt-2 text-sm font-medium text-red-600">@_errorMessage</p>
        </div>
    }
    else if (_testPlan is not null)
    {
        @* HEADER SECTION *@
        <div class="flex flex-col justify-between gap-6 md:flex-row md:items-end">
            <div class="flex items-center gap-5">
                <button @onclick="NavigateBack"
                        class="rounded-[22px] border border-slate-100 bg-white p-4 text-slate-400 shadow-sm transition-all hover:bg-slate-50 hover:text-slate-800 active:scale-95">
                    <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
                </button>
                <div>
                    <div class="mb-2 flex items-center gap-2">
                        <span class="rounded-lg bg-indigo-600 px-3 py-0.5 font-black tracking-widest text-[10px] text-white uppercase">
                            Strategy Blueprint
                        </span>
                        <span class="font-black tracking-widest text-[10px] text-slate-300 uppercase">ID: @_testPlan.Id</span>
                    </div>
                    <h2 class="text-4xl font-black tracking-tight text-slate-800">@_testPlan.Name</h2>
                </div>
            </div>

            <div class="flex items-center gap-3">
                <button @onclick="ViewResults"
                        class="flex items-center gap-2 rounded-2xl border border-slate-200 bg-white px-8 py-4 text-xs font-black tracking-widest text-slate-800 uppercase shadow-sm transition-all hover:bg-slate-50">
                    <svg class="h-4 w-4 text-purple-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 3.055A9.001 9.001 0 1020.945 13H11V3.055z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.488 9H15V3.512A9.025 9.025 0 0120.488 9z" /></svg>
                    View Analytics
                </button>
                
                @if (_testPlan.Status == TestPlanStatus.Draft)
                {
                    <button @onclick="StartExecution"
                            class="flex items-center gap-2 rounded-2xl bg-indigo-600 px-8 py-4 text-xs font-black tracking-widest text-white uppercase transition-all hover:bg-indigo-700 hover:shadow-xl active:scale-95">
                        <svg class="h-4 w-4 fill-current" viewBox="0 0 24 24"><path d="M8 5v14l11-7z" /></svg>
                        Execute Strategy
                    </button>
                }
                else
                {
                    <button @onclick="StartExecution"
                            class="flex items-center gap-2 rounded-2xl bg-emerald-500 px-8 py-4 text-xs font-black tracking-widest text-white uppercase transition-all hover:bg-emerald-600 hover:shadow-xl active:scale-95">
                        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                        Resume Execution
                    </button>
                }
            </div>
        </div>

        @* BENTO GRID STATS *@
        <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-4">
            @* Dark Card *@
            <div class="relative flex flex-col justify-between overflow-hidden rounded-[48px] bg-[#1C1D2A] p-8 text-white shadow-2xl">
                <div class="relative z-10">
                    <div class="mb-4 flex items-center gap-2 text-indigo-400">
                        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
                        <span class="font-black tracking-widest text-[10px] uppercase">Strategy Scope</span>
                    </div>
                    <h4 class="truncate text-xl font-black">@_testPlan.Scope</h4>
                    <p class="mt-1 font-bold tracking-widest text-[10px] text-slate-500 uppercase">Priority: @_testPlan.Priority</p>
                </div>
                <div class="absolute -right-10 -bottom-10 h-24 w-24 rounded-full bg-indigo-500/10 blur-2xl"></div>
            </div>

            @* Metric 1 *@
            <div class="flex items-center gap-6 rounded-[40px] border border-slate-100 bg-white p-8 shadow-sm">
                <div class="flex h-14 w-14 items-center justify-center rounded-[22px] bg-blue-50">
                    <svg class="h-7 w-7 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" /></svg>
                </div>
                <div>
                    <p class="font-black tracking-widest text-[10px] text-slate-400 uppercase">Test Suites</p>
                    <h4 class="mt-1 text-2xl font-black text-slate-800">@_testPlan.TestSuites.Count</h4>
                </div>
            </div>

            @* Metric 2 *@
            <div class="flex items-center gap-6 rounded-[40px] border border-slate-100 bg-white p-8 shadow-sm">
                <div class="flex h-14 w-14 items-center justify-center rounded-[22px] bg-emerald-50">
                    <svg class="h-7 w-7 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                </div>
                <div>
                    <p class="font-black tracking-widest text-[10px] text-slate-400 uppercase">Outcome</p>
                    <h4 class="mt-1 text-xl font-black text-slate-800">@(_testPlan.Outcome?.ToString() ?? "Pending")</h4>
                </div>
            </div>

            @* Metric 3 *@
            <div class="flex items-center gap-6 rounded-[40px] border border-slate-100 bg-white p-8 shadow-sm">
                <div class="flex h-14 w-14 items-center justify-center rounded-[22px] bg-amber-50">
                    <svg class="h-7 w-7 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                </div>
                <div>
                    <p class="font-black tracking-widest text-[10px] text-slate-400 uppercase">Status</p>
                    <h4 class="mt-1 text-xl font-black text-slate-800">@_testPlan.Status</h4>
                </div>
            </div>
        </div>

        @* MAIN CONTENT *@
        <div class="grid grid-cols-1 gap-10 xl:grid-cols-12">
            
            @* LEFT COLUMN: TEST SUITES LIST *@
            <div class="space-y-6 xl:col-span-8">
                <div class="flex items-center justify-between px-4">
                    <h4 class="flex items-center gap-2 text-xs font-black tracking-widest text-slate-400 uppercase">
                        <svg class="h-4 w-4 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" /></svg>
                        Enrolled Suite Repository
                    </h4>
                    <div class="group relative w-64">
                        <svg class="absolute top-1/2 left-3.5 h-3.5 w-3.5 -translate-y-1/2 text-slate-300 transition-colors group-focus-within:text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
                        <input type="text"
                               @bind="_searchQuery"
                               @bind:event="oninput"
                               placeholder="Filter suites..."
                               class="w-full rounded-xl border border-slate-100 bg-white py-2.5 pr-4 pl-9 font-bold text-[10px] transition-all outline-none focus:ring-2 focus:ring-indigo-500/10" />
                    </div>
                </div>

                <div class="space-y-4">
                    @if (!FilteredSuites.Any())
                    {
                        <div class="flex flex-col items-center justify-center rounded-[32px] border border-dashed border-slate-200 bg-slate-50 py-20">
                            <p class="text-xs font-black text-slate-300 uppercase">No Suites Found</p>
                        </div>
                    }
                    else
                    {
                        @foreach (var suite in FilteredSuites)
                        {
                            <div @onclick="() => NavigateToTestSuite(suite.Id)"
                                 class="group flex cursor-pointer items-center justify-between rounded-[32px] border border-slate-50 bg-white p-5 shadow-sm transition-all hover:shadow-md">
                                <div class="flex items-center gap-4">
                                    <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-slate-50 text-slate-400 transition-colors group-hover:bg-indigo-50 group-hover:text-indigo-600">
                                        <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" /></svg>
                                    </div>
                                    <div>
                                        <p class="text-sm leading-tight font-black text-slate-800 transition-colors group-hover:text-indigo-600">@suite.Name</p>
                                        <div class="mt-1 flex items-center gap-2">
                                            <span class="font-black tracking-widest text-[9px] text-slate-300 uppercase">ID: @suite.Id</span>
                                            <div class="h-0.5 w-0.5 rounded-full bg-slate-200"></div>
                                            <span class="font-black tracking-widest text-[9px] text-slate-400 uppercase">Created @suite.CreatedAt.ToString("MMM dd")</span>
                                        </div>
                                    </div>
                                </div>
                                <div class="flex items-center gap-4">
                                    @if (!string.IsNullOrWhiteSpace(suite.Description))
                                    {
                                        <span class="hidden max-w-[150px] truncate font-medium text-[10px] text-slate-400 md:block">
                                            @suite.Description
                                        </span>
                                    }
                                    <svg class="h-4 w-4 text-slate-200 transition-all group-hover:text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>

            @* RIGHT COLUMN: SIDEBAR *@
            <div class="space-y-8 xl:col-span-4">
                @* Info Card *@
                <div class="space-y-8 rounded-[40px] border border-slate-100 bg-white p-8 shadow-sm">
                    <div class="flex items-center gap-3">
                        <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-indigo-50 text-indigo-600">
                            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                        </div>
                        <h4 class="font-black tracking-widest text-[11px] text-slate-800 uppercase">Plan Definition</h4>
                    </div>
                    <div class="space-y-6">
                        <p class="text-sm leading-relaxed font-medium text-slate-500 italic">
                            "@(_testPlan.Description ?? "No description provided for this blueprint.")"
                        </p>
                        <div class="space-y-4 border-t border-slate-50 pt-6">
                            <div class="flex items-center justify-between font-black text-[9px] text-slate-400 uppercase">
                                <span>Project Context</span>
                                <span class="text-slate-800">Proj-@ProjectId</span>
                            </div>
                            @if (_testPlan.StartedAt.HasValue)
                            {
                                <div class="flex items-center justify-between font-black text-[9px] text-slate-400 uppercase">
                                    <span>Started</span>
                                    <span class="text-slate-800">@_testPlan.StartedAt.Value.ToString("MMM dd, yyyy")</span>
                                </div>
                            }
                            @if (_testPlan.CompletedAt.HasValue)
                            {
                                <div class="flex items-center justify-between font-black text-[9px] text-slate-400 uppercase">
                                    <span>Completed</span>
                                    <span class="text-slate-800">@_testPlan.CompletedAt.Value.ToString("MMM dd, yyyy")</span>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                @* Dark AI Action Card *@
                <div class="group relative overflow-hidden rounded-[40px] bg-[#1C1D2A] p-8 text-white shadow-xl">
                    <div class="relative z-10 space-y-6">
                        <div class="flex items-center gap-3">
                            <svg class="h-6 w-6 animate-pulse text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" /></svg>
                            <h4 class="text-sm font-black tracking-widest uppercase">AI Insights</h4>
                        </div>
                        <p class="text-xs leading-relaxed text-slate-400">
                            This test plan covers @_testPlan.TestSuites.Count suite@(_testPlan.TestSuites.Count != 1 ? "s" : "").
                            @if (_testPlan.Status == TestPlanStatus.Draft)
                            {
                                <span>Ready for execution optimization.</span>
                            }
                            else
                            {
                                <span>Execution tracking enabled.</span>
                            }
                        </p>
                        <button @onclick="EditPlan"
                                class="flex w-full items-center justify-center gap-2 rounded-2xl bg-white py-4 font-black tracking-[0.2em] text-[10px] text-[#1C1D2A] uppercase transition-all hover:bg-slate-200">
                            Edit Configuration <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
                        </button>
                    </div>
                    <div class="absolute -right-10 -bottom-10 h-32 w-32 rounded-full bg-purple-500/10 blur-3xl"></div>
                </div>
                
                @* Secondary Actions *@
                <button @onclick="DuplicatePlan"
                        class="flex w-full items-center justify-between rounded-3xl border border-slate-100 bg-white p-6 transition-all hover:bg-slate-50">
                    <span class="font-black tracking-widest text-[10px] text-slate-600 uppercase">Duplicate Strategy</span>
                    <svg class="h-4 w-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7v8a2 2 0 002 2h6M8 7V5a2 2 0 012-2h4.586a1 1 0 01.707.293l4.414 4.414a1 1 0 01.293.707V15a2 2 0 01-2 2h-2M8 7H6a2 2 0 01-2-2V5" /></svg>
                </button>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public int ProjectId { get; set; }
    [Parameter] public int TestPlanId { get; set; }

    private TestPlanResponse? _testPlan;
    private bool _isLoading = true;
    private string? _errorMessage;
    private string _searchQuery = "";

    // Simple client-side search logic
    private IEnumerable<TestSuiteResponse> FilteredSuites =>
        _testPlan?.TestSuites
            .Where(s => string.IsNullOrWhiteSpace(_searchQuery) ||
                        s.Name.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase))
            ?? Enumerable.Empty<TestSuiteResponse>();

    protected override async Task OnInitializedAsync()
    {
        await LoadTestPlanAsync();
    }

    private async Task LoadTestPlanAsync()
    {
        try
        {
            _isLoading = true;
            _errorMessage = null;
            _testPlan = await TestPlanService.GetTestPlanByIdAsync(TestPlanId);

            if (_testPlan == null)
            {
                _errorMessage = "Strategy not found.";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to load blueprint: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void NavigateBack() => Navigation.NavigateTo($"/projects/{ProjectId}/testplans");
    private void NavigateToTestSuite(int suiteId) => Navigation.NavigateTo($"/projects/{ProjectId}/testsuites/{suiteId}");
    private void StartExecution() => Navigation.NavigateTo($"/projects/{ProjectId}/testplans/{TestPlanId}/execute");
    private void EditPlan() => Navigation.NavigateTo($"/projects/{ProjectId}/testplans/{TestPlanId}/edit");
    private void ViewResults() => Navigation.NavigateTo($"/projects/{ProjectId}/testplans/{TestPlanId}/results");
    private void DuplicatePlan() { /* Todo */ }
}