                                  }`}>
                                    {task.type === 'Bug' ? <Bug className="w-4 h-4" /> : <Layout className="w-4 h-4" />}
                                  </div>
                                  <div className="flex-1 min-w-0">
                                    <p className="text-xs font-black text-slate-800 truncate">{task.title}</p>
                                    <p className="text-[9px] font-bold text-slate-400 uppercase tracking-widest">{task.id} • {task.status}</p>
                                  </div>
                                </div>
                                {formData.targetId === task.id && <CheckCircle2 className="w-4 h-4 text-blue-600" />}
                              </button>
                            )) : (
                              <div className="p-8 text-center">
                                <p className="text-[10px] font-black text-slate-300 uppercase">No matching tasks</p>
                              </div>
                            )}
                          </div>
                        </div>
                      )}
                   </div>
                 )}

                 <div className="space-y-1.5">
                    <label className="text-[10px] font-black text-slate-400 uppercase tracking-widest">Strategy Description</label>
                    <textarea 
                      rows={4}
                      value={formData.description}
                      onChange={(e) => setFormData({ ...formData, description: e.target.value })}
                      placeholder="What is the objective of this testing campaign?"
                      className="w-full px-6 py-4 bg-slate-50 border-2 border-transparent focus:border-[#7E96E1] rounded-[32px] outline-none font-medium text-slate-600 resize-none transition-all"
                    />
                 </div>
              </div>

              <div className="space-y-6">
                 <div className="space-y-4">
                    <div className="flex items-center justify-between px-1">
                       <h4 className="text-[11px] font-black text-slate-800 uppercase tracking-widest flex items-center gap-2">
                          <Layers className="w-4 h-4 text-[#7E96E1]" />
                          Enrolled Logic Suites
                          <span className="ml-2 bg-indigo-50 text-indigo-600 px-3 py-1 rounded-lg text-[9px] font-black">{formData.suiteIds.length} Selected</span>
                       </h4>
                    </div>

                    <div className="relative group">
                       <Search className="absolute left-4 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-300 group-focus-within:text-purple-500 transition-colors" />
                       <input 
                         type="text" 
                         value={suiteSearchQuery}
                         onChange={(e) => setSuiteSearchQuery(e.target.value)}
                         placeholder="Search project suites or library templates..."
                         className="w-full pl-11 pr-4 py-4 bg-slate-50 border-2 border-transparent focus:border-purple-400 focus:bg-white rounded-[24px] outline-none transition-all font-bold text-slate-800 text-xs shadow-inner"
                       />
                    </div>
                 </div>
                 
                 <div className="space-y-6 max-h-[480px] overflow-y-auto pr-3 no-scrollbar pb-10">
                    <div className="space-y-2">
                       <p className="text-[9px] font-black text-slate-400 uppercase tracking-widest flex items-center gap-2 px-2 mb-3">
                          <Layout className="w-3 h-3" /> Project Scope
                       </p>
                       {allAvailableSuites.filter(s => s.source === 'Project').map(suite => (
                        <button
                          key={suite.id}
                          type="button"
                          onClick={() => toggleSuite(suite.id)}
                          className={`w-full flex items-center justify-between p-4 rounded-[28px] border transition-all text-left group ${
                            formData.suiteIds.includes(suite.id)
                              ? 'bg-blue-50 border-blue-400 shadow-md ring-2 ring-blue-100'
                              : 'bg-white border-slate-100 hover:border-blue-200'
                          }`}
                        >
                          <div className="flex items-center gap-4">
                             <div className={`w-10 h-10 rounded-xl flex items-center justify-center transition-colors ${
                               formData.suiteIds.includes(suite.id) ? 'bg-blue-600 text-white' : 'bg-slate-50 text-slate-400 group-hover:bg-blue-100'
                             }`}>
                                <Layers className="w-5 h-5" />
                             </div>
                             <div>
                                <p className="text-xs font-black text-slate-800 truncate max-w-[180px]">{suite.name}</p>
                                <p className="text-[9px] font-bold text-slate-400 uppercase">Local Suite • {suite.testCases.length} Scenarios</p>
                             </div>
                          </div>
                          {formData.suiteIds.includes(suite.id) && (
                            <CheckCircle2 className="w-5 h-5 text-blue-600" />
                          )}
                        </button>
                      ))}
                    </div>

                    <div className="space-y-2 pt-4">
                       <p className="text-[9px] font-black text-purple-400 uppercase tracking-widest flex items-center gap-2 px-2 mb-3">
                          <Library className="w-3 h-3" /> Global Library Templates
                       </p>
                       {allAvailableSuites.filter(s => s.source === 'Library').map(suite => (
                        <button
                          key={suite.id}
                          type="button"
                          onClick={() => toggleSuite(suite.id)}
                          className={`w-full flex items-center justify-between p-4 rounded-[28px] border transition-all text-left group ${
                            formData.suiteIds.includes(suite.id)
                              ? 'bg-purple-50 border-purple-400 shadow-md ring-2 ring-purple-100'
                              : 'bg-white border-slate-100 hover:border-purple-200'
                          }`}
                        >
                          <div className="flex items-center gap-4">
                             <div className={`w-10 h-10 rounded-xl flex items-center justify-center transition-all ${
                               formData.suiteIds.includes(suite.id) ? 'bg-purple-600 text-white shadow-lg' : 'bg-purple-50 text-purple-400'
                             }`}>
                                <Sparkles className="w-5 h-5" />
                             </div>
                             <div>
                                <p className="text-xs font-black text-slate-800 truncate max-w-[180px]">{suite.name}</p>
                                <div className="flex items-center gap-2">
                                   <p className="text-[9px] font-bold text-purple-400 uppercase tracking-tight">Master Template</p>
                                   <div className="w-1 h-1 bg-slate-200 rounded-full"></div>
                                   <p className="text-[9px] font-black text-slate-400 uppercase">{suite.testCases.length} Scenarios</p>
                                </div>
                             </div>
                          </div>
                          {formData.suiteIds.includes(suite.id) ? (
                            <CheckCircle2 className="w-5 h-5 text-purple-600" />
                          ) : (
                             <div className="p-2 bg-slate-50 text-slate-300 rounded-lg group-hover:bg-purple-50 group-hover:text-purple-400 transition-all">
                                <Plus className="w-3.5 h-3.5" />
                             </div>
                          )}
                        </button>
                      ))}

                      {allAvailableSuites.length === 0 && (
                        <div className="py-12 text-center bg-slate-50 rounded-[32px] border-2 border-dashed border-slate-100">
                           <Zap className="w-8 h-8 text-slate-200 mx-auto mb-2" />
                           <p className="text-[10px] font-black text-slate-300 uppercase">No matching logical entities</p>
                        </div>
                      )}
                    </div>
                 </div>
              </div>
            </div>
          </div>
        </form>

        <div className="p-8 border-t border-slate-50 bg-slate-50/50 flex items-center justify-between px-10">
           <div className="flex items-center gap-4">
              <div className="w-10 h-10 bg-white rounded-2xl flex items-center justify-center shadow-sm border border-slate-100">
                 <Zap className="w-5 h-5 text-amber-500" />
              </div>
              <p className="text-[10px] font-black text-slate-400 uppercase tracking-widest leading-relaxed">
                Library suites will be intelligently cloned <br /> into the project scope upon commitment.
              </p>
           </div>
           <div className="flex gap-4">
              <button 
                type="button"
                onClick={onClose}
                className="px-8 py-4 bg-white border border-slate-200 text-slate-400 font-black text-xs uppercase tracking-widest rounded-2xl hover:text-slate-600 transition-all"
              >
                Discard
              </button>
              <button 
                onClick={handleSubmit}
                className="px-12 py-4 bg-[#1C1D2A] text-white font-black text-xs uppercase tracking-widest rounded-2xl hover:bg-slate-800 shadow-xl transition-all active:scale-95 flex items-center gap-2"
              >
                 <Save className="w-4 h-4" /> {existingPlan ? 'Commit Protocol' : 'Initialize Strategy'}
              </button>
           </div>
        </div>
      </div>
    </div>
  );
}; *@
