                                    {
                                        <div class="group flex w-full items-center justify-between rounded-[28px] border border-blue-400 bg-blue-50 p-4 text-left shadow-md ring-2 ring-blue-100 transition-all">
                                            <div class="flex items-center gap-4">
                                                <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-blue-600 text-white transition-colors">
                                                    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4" />
                                                    </svg>
                                                </div>
                                                <div>
                                                    <p class="max-w-[180px] truncate text-xs font-black text-slate-800">Test Suite #@suiteId</p>
                                                    <p class="font-bold text-[9px] text-slate-400 uppercase">Manual Entry • Ready</p>
                                                </div>
                                            </div>
                                            <button type="button" @onclick="() => RemoveSuite(suiteId)" class="mr-2 rounded-full p-2 text-blue-400 hover:bg-blue-100 hover:text-red-500 transition-colors">
                                                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                                </svg>
                                            </button>
                                        </div>
                                    }
                                }
                                else
                                {
                                    <div class="rounded-[32px] border-2 border-dashed border-slate-100 bg-slate-50 py-12 text-center">
                                        <svg class="mx-auto mb-2 h-8 w-8 text-slate-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
                                        </svg>
                                        <p class="font-black text-[10px] text-slate-300 uppercase">No logical entities enrolled</p>
                                    </div>
                                }
                            </div>
                        </div>

                    </div>
                </div>

                <div class="flex items-center justify-between border-t border-slate-50 bg-slate-50/50 p-8 px-10">
                    <div class="flex items-center gap-4">
                        <div class="flex h-10 w-10 items-center justify-center rounded-2xl border border-slate-100 bg-white shadow-sm">
                            <svg class="h-5 w-5 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                            </svg>
                        </div>
                        <p class="leading-relaxed font-black tracking-widest text-[10px] text-slate-400 uppercase">
                            Suites will be processed <br /> into execution queue upon save.
                        </p>
                    </div>

                    <div class="flex gap-4">
                        <button type="button"
                                @onclick="Cancel"
                                class="rounded-2xl border border-slate-200 bg-white px-8 py-4 text-xs font-black tracking-widest text-slate-400 uppercase transition-all hover:text-slate-600">
                            Discard
                        </button>
                        <button type="submit"
                                disabled="@isSubmitting"
                                class="flex items-center gap-2 rounded-2xl bg-[#1C1D2A] px-12 py-4 text-xs font-black tracking-widest text-white uppercase shadow-xl transition-all hover:bg-slate-800 active:scale-95 disabled:opacity-50">
                            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-3m-1 4l-3 3m0 0l-3-3m3 3V4" />
                            </svg>
                            @(isSubmitting ? "Processing..." : ExistingPlan != null ? "Commit Protocol" : "Initialize Strategy")
                        </button>
                    </div>
                </div>
            </EditForm>
        </div>
    </div>
}

@code {
    [Parameter] public int ProjectId { get; set; }
    [Parameter] public TestPlanResponse? ExistingPlan { get; set; }
    [Parameter] public EventCallback<TestPlanResponse> OnSave { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public bool IsVisible { get; set; }

    private TestPlanFormData FormData { get; set; } = new();
    private bool isSubmitting;
    private int? newSuiteId;

    protected override void OnParametersSet()
    {
        if (ExistingPlan != null)
        {
            FormData = new TestPlanFormData
            {
                Name = ExistingPlan.Name,
                Scope = ExistingPlan.Scope,
                Priority = ExistingPlan.Priority,
                TaskId = ExistingPlan.TaskId,
                MilestoneId = ExistingPlan.MilestoneId,
                TestSuiteIds = new List<int>() // Assuming you populate this from existing plan logic if available
            };
        }
        else
        {
            FormData = new TestPlanFormData { Scope = TestPlanScope.Project };
        }
    }

    private void SelectScope(TestPlanScope scope)
    {
        FormData.Scope = scope;
        FormData.TaskId = null;
        FormData.MilestoneId = null;
    }

    private void AddSuite()
    {
        if (newSuiteId.HasValue && !FormData.TestSuiteIds.Contains(newSuiteId.Value))
        {
            FormData.TestSuiteIds.Add(newSuiteId.Value);
            newSuiteId = null;
        }
    }

    private void RemoveSuite(int suiteId)
    {
        FormData.TestSuiteIds.Remove(suiteId);
    }

    private async Task HandleSubmit()
    {
        isSubmitting = true;
        try
        {
            if (ExistingPlan != null)
            {
                var updateRequest = new UpdateTestPlanRequest
                {
                    ProjectId = ProjectId,
                    Name = FormData.Name,
                    Scope = FormData.Scope,
                    Priority = FormData.Priority,
                    TaskId = FormData.TaskId,
                    MilestoneId = FormData.MilestoneId,
                    TestSuiteIds = FormData.TestSuiteIds,
                    Status = ExistingPlan.Status
                };

                var response = await Http.PutAsJsonAsync($"api/TestPlans/{ExistingPlan.Id}", updateRequest);
                response.EnsureSuccessStatusCode();

                var updated = await Http.GetFromJsonAsync<TestPlanResponse>($"api/TestPlans/{ExistingPlan.Id}");
                if (updated != null)
                    await OnSave.InvokeAsync(updated);
            }
            else
            {
                var createRequest = new CreateTestPlanRequest
                {
                    ProjectId = ProjectId,
                    Name = FormData.Name,
                    Scope = FormData.Scope,
                    Priority = FormData.Priority,
                    TaskId = FormData.TaskId,
                    MilestoneId = FormData.MilestoneId,
                    TestSuiteIds = FormData.TestSuiteIds
                };

                var created = await Http.PostAsJsonAsync<CreateTestPlanRequest>("api/TestPlans", createRequest);
                created.EnsureSuccessStatusCode();

                var result = await created.Content.ReadFromJsonAsync<TestPlanResponse>();
                if (result != null)
                    await OnSave.InvokeAsync(result);
            }
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void Cancel()
    {
        OnCancel.InvokeAsync();
    }

    private string GetPriorityClass(TestPlanPriority priority) => priority switch
    {
        TestPlanPriority.High => "bg-orange-600 text-white shadow-md",
        TestPlanPriority.Medium => "bg-blue-600 text-white shadow-md",
        TestPlanPriority.Low => "bg-slate-600 text-white shadow-md",
        _ => "bg-[#1C1D2A] text-white shadow-md"
    };

    private class TestPlanFormData
    {
        public string Name { get; set; } = string.Empty;
        public TestPlanScope Scope { get; set; }
        public TestPlanPriority Priority { get; set; }
        public int? TaskId { get; set; }
        public int? MilestoneId { get; set; }
        public List<int> TestSuiteIds { get; set; } = new();
    }
}



