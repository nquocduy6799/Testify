@using Testify.Client.Interfaces
@using Testify.Shared.DTOs.TestPlans
@using Testify.Shared.Enums
@inject HttpClient Http
@inject ITestPlanService TestPlanService

@if (IsVisible)
{
    <div class="fixed inset-0 z-[250] flex items-center justify-center p-6">
        <div class="animate-in fade-in absolute inset-0 bg-slate-900/60 backdrop-blur-md" @onclick="Cancel"></div>

        <div class="animate-in zoom-in-95 relative flex max-h-[90vh] w-full max-w-6xl flex-col overflow-hidden rounded-[48px] bg-white shadow-2xl">

            <div class="flex items-start justify-between border-b border-slate-50 bg-slate-50/50 p-10">
                <div class="flex items-center gap-4">
                    <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-[#1C1D2A] text-white shadow-lg">
                        <svg class="h-7 w-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
                        </svg>
                    </div>
                    <div>
                        <h2 class="text-3xl font-black tracking-tight text-slate-800">
                            @(ExistingPlan != null ? "Edit Test Plan" : "New Test Plan")
                        </h2>
                        <p class="mt-1 font-black tracking-widest text-[10px] text-slate-400 uppercase">Quality Strategy Architect</p>
                    </div>
                </div>
                <button type="button" @onclick="Cancel" class="rounded-2xl p-3 text-slate-400 shadow-sm transition-all hover:bg-white hover:text-slate-600">
                    <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>

            <EditForm Model="FormData" OnValidSubmit="HandleSubmit" class="flex flex-1 flex-col overflow-hidden">
                <DataAnnotationsValidator />

                <div class="no-scrollbar flex-1 space-y-10 overflow-y-auto p-10">
                    <div class="grid grid-cols-1 gap-12 md:grid-cols-2">

                        <div class="space-y-8">
                            <div class="space-y-1.5">
                                <label class="flex items-center gap-2 font-black tracking-widest text-[10px] text-slate-400 uppercase">
                                    <svg class="h-3.5 w-3.5 text-[#7E96E1]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                    </svg>
                                    Plan Name
                                </label>
                                <InputText @bind-Value="FormData.Name"
                                           placeholder="e.g. Q2 Global Regression"
                                           class="w-full rounded-2xl border-2 border-transparent bg-slate-50 px-6 py-4 font-bold text-slate-800 transition-all outline-none focus:border-[#7E96E1] focus:bg-white" />
                                <ValidationMessage For="@(() => FormData.Name)" class="text-[10px] font-bold text-red-500 uppercase tracking-wide" />
                            </div>

                            <div class="space-y-1.5">
                                <label class="flex items-center gap-2 font-black tracking-widest text-[10px] text-slate-400 uppercase">
                                    Scope Type
                                </label>
                                <div class="grid grid-cols-3 gap-2">
                                    @foreach (var scope in Enum.GetValues<TestPlanScope>())
                                    {
                                        <button type="button"
                                                @onclick="() => SelectScope(scope)"
                                                class="rounded-xl py-3 text-[10px] font-black uppercase transition-all @(FormData.Scope == scope ? "bg-[#1C1D2A] text-white shadow-md" : "bg-slate-50 text-slate-400 hover:bg-slate-100")">
                                            @scope
                                        </button>
                                    }
                                </div>
                            </div>

                            @if (FormData.Scope == TestPlanScope.Milestone)
                            {
                                <div class="animate-in slide-in-from-top-2 space-y-1.5">
                                    <label class="flex items-center gap-2 font-black tracking-widest text-[10px] text-slate-400 uppercase">
                                        <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                                        </svg>
                                        Select Target Milestone
                                    </label>
                                    <div class="relative">
                                        <InputSelect @bind-Value="FormData.MilestoneId"
                                                     class="w-full appearance-none rounded-2xl border-2 border-transparent bg-slate-50 px-6 py-4 font-bold text-slate-800 outline-none focus:border-[#7E96E1] focus:bg-white">
                                            <option value="">Select a milestone...</option>
                                            @* Add options here *@
                                        </InputSelect>
                                        <svg class="pointer-events-none absolute top-1/2 right-6 h-4 w-4 -translate-y-1/2 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                                        </svg>
                                    </div>
                                </div>
                            }

                            @if (FormData.Scope == TestPlanScope.Task)
                            {
                                <div class="animate-in slide-in-from-top-2 space-y-1.5">
                                    <label class="flex items-center gap-2 font-black tracking-widest text-[10px] text-slate-400 uppercase">
                                        <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                                        </svg>
                                        Search Target Task
                                    </label>
                                    <div class="relative">
                                        <InputSelect @bind-Value="FormData.TaskId"
                                                     class="w-full appearance-none rounded-2xl border-2 border-transparent bg-slate-50 px-6 py-4 font-bold text-slate-800 outline-none focus:border-[#7E96E1] focus:bg-white">
                                            <option value="">Select a task...</option>
                                            @* Add options here *@
                                        </InputSelect>
                                        <svg class="pointer-events-none absolute top-1/2 right-6 h-4 w-4 -translate-y-1/2 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                                        </svg>
                                    </div>
                                </div>
                            }

                            <div class="space-y-1.5">
                                <label class="flex items-center gap-2 font-black tracking-widest text-[10px] text-slate-400 uppercase">
                                    Priority Level
                                </label>
                                <div class="grid grid-cols-4 gap-2">
                                    @foreach (var priority in Enum.GetValues<TestPlanPriority>())
                                    {
                                        <button type="button"
                                                @onclick="() => FormData.Priority = priority"
                                                class="rounded-xl py-3 text-[10px] font-black uppercase transition-all @(FormData.Priority == priority ? GetPriorityClass(priority) : "bg-slate-50 text-slate-400 hover:bg-slate-100")">
                                            @priority
                                        </button>
                                    }
                                </div>
                            </div>
                        </div>

                        <div class="space-y-6">
                            <div class="space-y-4">
                                <div class="flex items-center justify-between px-1">
                                    <h4 class="flex items-center gap-2 font-black tracking-widest text-[11px] text-slate-800 uppercase">
                                        <svg class="h-4 w-4 text-[#7E96E1]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
                                        </svg>
                                        Enrolled Logic Suites
                                        <span class="ml-2 rounded-lg bg-indigo-50 px-3 py-1 font-black text-[9px] text-indigo-600">@FormData.TestSuiteIds.Count Selected</span>
                                    </h4>
                                </div>

                                <div class="group relative">
                                    <svg class="absolute top-1/2 left-4 h-4 w-4 -translate-y-1/2 text-slate-300 transition-colors group-focus-within:text-purple-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                                    </svg>
                                    <div class="flex gap-2">
                                        <input type="number"
                                               @bind="newSuiteId"
                                               placeholder="Enter Suite ID to enroll..."
                                               class="w-full rounded-[24px] border-2 border-transparent bg-slate-50 py-4 pr-4 pl-11 text-xs font-bold text-slate-800 shadow-inner transition-all outline-none focus:border-purple-400 focus:bg-white" />
                                        <button type="button"
                                                @onclick="AddSuite"
                                                class="rounded-[24px] bg-purple-100 px-6 py-2 font-black text-[10px] text-purple-600 uppercase transition-all hover:bg-purple-200">
                                            Add
                                        </button>
                                    </div>
                                </div>
                            </div>

                            <div class="no-scrollbar max-h-[480px] space-y-3 overflow-y-auto pr-1 pb-10">
