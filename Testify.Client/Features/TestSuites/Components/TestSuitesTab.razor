@using Testify.Client.Interfaces
@using Testify.Shared.DTOs
@using Testify.Shared.DTOs.TestSuites
@using Testify.Shared.DTOs.TestTemplates
@using Testify.Shared.Enums

<div class="space-y-6">
    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-4">
        <div>
            <h3 class="text-2xl font-black text-slate-800 tracking-tight">Test Suites</h3>
            <p class="mt-1 text-sm font-medium text-slate-400">Manage test suites and cases for this project.</p>
        </div>
        <div class="flex items-center gap-3">
            <!-- Search -->
            <div class="group relative">
                <svg class="absolute top-1/2 left-4 h-4 w-4 -translate-y-1/2 text-slate-300" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35m1.85-5.65a7.5 7.5 0 11-15 0 7.5 7.5 0 0115 0z" />
                </svg>
                <input type="text" placeholder="Search suites..."
                       @bind="_searchQuery"
                       class="w-56 rounded-2xl border border-slate-100 bg-white py-3 pr-4 pl-11 text-xs font-bold shadow-sm outline-none focus:ring-2 focus:ring-[#7E96E1]/20" />
            </div>

            <!-- Import from Template -->
            <button @onclick="OpenImportModal"
                    class="bg-white text-slate-800 px-5 py-3 rounded-2xl border border-slate-100 flex items-center gap-2 font-black text-[10px] uppercase tracking-widest shadow-sm hover:shadow-md transition-all cursor-pointer">
                <svg class="h-4 w-4 text-indigo-500" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5" />
                </svg>
                From Template
            </button>

            <!-- New Suite -->
            <button @onclick="() => _isCreateOpen = true"
                    class="bg-[#1C1D2A] text-white px-6 py-3 rounded-2xl flex items-center gap-2 font-black text-[10px] uppercase tracking-widest shadow-lg hover:bg-slate-800 transition-all cursor-pointer">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 5v14m7-7H5" />
                </svg>
                New Suite
            </button>
        </div>
    </div>

    @if (_isLoading)
    {
        <div class="flex items-center gap-3 text-sm font-medium text-slate-400 py-12">
            <div class="h-4 w-4 animate-spin rounded-full border-2 border-slate-300 border-t-transparent"></div>
            Loading test suites...
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <div class="rounded-2xl border border-red-100 bg-red-50 px-6 py-4 text-sm font-medium text-red-600">
            @_errorMessage
        </div>
    }
    else if (_selectedSuite is not null)
    {
        <!-- Suite Detail View (inline) -->
        <TestSuiteDetailView 
            Suite="_selectedSuite"
            OnBack="CloseSuiteDetail"
            OnReload="ReloadSelectedSuite" />
    }
    else
    {
        <!-- Suites Grid -->
        @if (FilteredSuites.Count == 0)
        {
            <div class="py-24 flex flex-col items-center justify-center text-center bg-white/40 rounded-[48px] border-2 border-dashed border-slate-100">
                <svg class="w-12 h-12 text-slate-200 mb-6" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23-.693L5 14.5m14.8.8l1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0112 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5" />
                </svg>
                <h5 class="text-xl font-black text-slate-400">No Test Suites Yet</h5>
                <p class="text-slate-300 text-sm font-medium mt-1 max-w-xs">Create a new test suite or import from your template library.</p>
                <div class="flex gap-3 mt-8">
                    <button @onclick="OpenImportModal"
                            class="px-6 py-3 bg-white border border-slate-200 text-slate-600 rounded-2xl font-black text-xs uppercase tracking-widest hover:scale-105 transition-all shadow-sm cursor-pointer">
                        Import Template
                    </button>
                    <button @onclick="() => _isCreateOpen = true"
                            class="px-6 py-3 bg-[#1C1D2A] text-white rounded-2xl font-black text-xs uppercase tracking-widest hover:scale-105 transition-all shadow-lg cursor-pointer">
                        Create Suite
                    </button>
                </div>
            </div>
        }
        else
        {
            <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
                @foreach (var suite in FilteredSuites)
                {
                    <div @onclick="() => OpenSuiteDetail(suite.Id)"
                         class="bg-white rounded-[32px] p-6 border border-slate-50 shadow-sm hover:shadow-xl hover:scale-[1.01] transition-all cursor-pointer group relative">
                        <div class="flex items-start justify-between mb-4">
                            <div class="w-11 h-11 bg-blue-50 rounded-xl flex items-center justify-center">
                                <svg class="w-5 h-5 text-blue-500" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082" />
                                </svg>
                            </div>
                            <div class="flex items-center gap-2">
                                @if (suite.SourceTemplateId.HasValue)
                                {
                                    <span class="px-2 py-0.5 bg-indigo-50 text-indigo-500 rounded-lg text-[9px] font-black uppercase tracking-widest">
                                        From Template
                                    </span>
                                }
                                <button @onclick="() => OpenDeleteConfirm(suite)" @onclick:stopPropagation="true"
                                        class="w-8 h-8 rounded-xl flex items-center justify-center text-slate-300 hover:text-red-500 hover:bg-red-50 transition-all opacity-0 group-hover:opacity-100 cursor-pointer"
                                        title="Delete suite">
                                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />
                                    </svg>
                                </button>
                            </div>
                        </div>

                        <h4 class="text-lg font-black text-slate-800 group-hover:text-[#7E96E1] transition-colors mb-1">@suite.Name</h4>
                        @if (!string.IsNullOrWhiteSpace(suite.Description))
                        {
                            <p class="text-xs font-medium text-slate-400 line-clamp-2 mb-4">@suite.Description</p>
                        }

                        <div class="flex items-center justify-between pt-4 border-t border-slate-50">
                            <div class="flex items-center gap-4">
                                <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest flex items-center gap-1">
                                    <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
                                    </svg>
                                    @suite.TestCases.Count cases
                                </span>
                            </div>
                            <span class="text-[10px] font-bold text-slate-300">@suite.CreatedAt.ToString("MMM dd")</span>
                        </div>
                    </div>
                }
            </div>
        }
    }

    @* ── Create Suite Modal ── *@
    @if (_isCreateOpen)
    {
        <div class="fixed inset-0 z-[150] flex items-center justify-center p-6">
            <div class="absolute inset-0 bg-slate-900/40 backdrop-blur-sm animate-in fade-in duration-300" @onclick="() => { _isCreateOpen = false; _createNameError = null; }"></div>
            <div class="relative bg-white w-full max-w-md rounded-[48px] shadow-2xl animate-in zoom-in-95 duration-300 p-10 space-y-6">
                <div class="flex items-center gap-4">
                    <div class="w-12 h-12 bg-[#7E96E1] rounded-2xl flex items-center justify-center text-white shadow-lg">
                        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 5v14m7-7H5" />
                        </svg>
                    </div>
                    <div>
                        <h2 class="text-2xl font-black text-slate-800">New Test Suite</h2>
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mt-0.5">Project test repository</p>
                    </div>
                </div>

                <EditForm Model="_createRequest" OnValidSubmit="HandleCreateSuite">
                    <DataAnnotationsValidator />
                    <div class="space-y-4">
                        <div class="space-y-1.5">
                            <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Suite Name</label>
                            <InputText @bind-Value="_createRequest.Name"
                                       class="@($"w-full rounded-2xl border-2 bg-slate-50 px-6 py-4 font-bold text-slate-800 outline-none focus:bg-white {(_createNameError != null ? "border-red-400 focus:border-red-400" : "border-transparent focus:border-[#7E96E1]")}")"
                                       placeholder="e.g. Authentication & Security" />
                            <ValidationMessage For="@(() => _createRequest.Name)" class="text-xs text-red-500" />
                            @if (_createNameError != null)
                            {
                                <div class="flex items-center gap-1.5 mt-1">
                                    <svg class="w-3.5 h-3.5 text-red-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
                                    </svg>
                                    <span class="text-xs font-semibold text-red-500">@_createNameError</span>
                                </div>
                            }
                        </div>
                        <div class="space-y-1.5">
                            <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Description</label>
                            <InputTextArea @bind-Value="_createRequest.Description" rows="3"
                                           class="w-full resize-none rounded-2xl border-2 border-transparent bg-slate-50 px-6 py-4 font-medium text-slate-600 outline-none focus:border-[#7E96E1] focus:bg-white"
                                           placeholder="What does this suite cover?" />
                        </div>
                        <button type="submit" disabled="@_isSaving"
                                class="w-full py-4 bg-[#1C1D2A] text-white rounded-2xl font-black text-xs uppercase tracking-widest shadow-lg hover:bg-slate-800 transition-all active:scale-95 cursor-pointer disabled:opacity-50">
                            @(_isSaving ? "Creating..." : "Create Suite")
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    }

    @* ── Import from Template Modal (2-step wizard) ── *@
    @if (_isImportOpen)
    {
        <div class="fixed inset-0 z-[150] flex items-center justify-center p-6">
            <div class="absolute inset-0 bg-slate-900/40 backdrop-blur-sm animate-in fade-in duration-300" @onclick="CloseImportModal"></div>
            <div class="relative bg-white w-full max-w-2xl rounded-[48px] shadow-2xl animate-in zoom-in-95 duration-300 p-10 space-y-6 max-h-[85vh] overflow-y-auto">

                @* ── Step 1: Select Template ── *@
                @if (_importStep == 1)
                {
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-12 bg-indigo-500 rounded-2xl flex items-center justify-center text-white shadow-lg">
                            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5" />
                            </svg>
                        </div>
                        <div>
                            <h2 class="text-2xl font-black text-slate-800">Import Template</h2>
                            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mt-0.5">Step 1 — Choose a template</p>
                        </div>
                    </div>

                    <!-- Template Search -->
                    <div class="relative">
                        <svg class="absolute top-1/2 left-4 h-4 w-4 -translate-y-1/2 text-slate-300" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35m1.85-5.65a7.5 7.5 0 11-15 0 7.5 7.5 0 0115 0z" />
                        </svg>
                        <input type="text" placeholder="Search templates..."
                               @bind="_templateSearchQuery"
                               @bind:event="oninput"
                               class="w-full rounded-2xl border border-slate-100 bg-slate-50 py-3 pr-4 pl-11 text-xs font-bold outline-none focus:ring-2 focus:ring-indigo-200 focus:bg-white" />
                    </div>

                    @if (_isLoadingTemplates)
                    {
                        <div class="flex items-center gap-3 text-sm font-medium text-slate-400 py-8">
                            <div class="h-4 w-4 animate-spin rounded-full border-2 border-slate-300 border-t-transparent"></div>
                            Loading templates...
                        </div>
                    }
                    else if (FilteredTemplates.Count == 0)
                    {
                        <div class="text-center py-8 text-slate-400 text-sm font-medium">
                            No templates available. Create templates in the Suite Library first.
                        </div>
                    }
                    else
                    {
                        <div class="space-y-2">
                            @foreach (var tpl in FilteredTemplates)
                            {
                                var isAlreadyCloned = _clonedTemplateIds.Contains(tpl.Id);
                                <button @onclick="() => SelectTemplate(tpl)"
                                        class="w-full text-left p-4 rounded-2xl border border-slate-100 hover:border-indigo-200 hover:bg-indigo-50/30 transition-all group cursor-pointer">
                                    <div class="flex items-center justify-between">
                                        <div class="flex-1 min-w-0">
                                            <div class="flex items-center gap-2">
                                                <h5 class="font-black text-slate-800 group-hover:text-indigo-600 transition-colors">@tpl.Name</h5>
                                                @if (isAlreadyCloned)
                                                {
                                                    <span class="px-2 py-0.5 bg-amber-50 text-amber-600 rounded-lg text-[9px] font-black uppercase tracking-widest flex items-center gap-1 flex-shrink-0">
                                                        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                                                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" />
                                                        </svg>
                                                        In Project
                                                    </span>
                                                }
                                            </div>
                                            <div class="flex items-center gap-3 mt-1">
                                                <span class="text-[10px] font-bold text-slate-400">@tpl.TestCaseTemplates.Count cases</span>
                                                <span class="text-[10px] font-bold text-slate-300">•</span>
                                                <span class="text-[10px] font-bold text-slate-400">@tpl.CloneCount clones</span>
                                                @if (!string.IsNullOrWhiteSpace(tpl.CreatedBy))
                                                {
                                                    <span class="text-[10px] font-bold text-slate-300">•</span>
                                                    <span class="text-[10px] font-bold text-indigo-400">by @tpl.CreatedBy</span>
                                                }
                                            </div>
                                        </div>
                                        <svg class="w-5 h-5 text-slate-300 group-hover:text-indigo-500 transition-colors flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
                                        </svg>
                                    </div>
                                </button>
                            }
                        </div>
                    }

                    <button @onclick="CloseImportModal"
                            class="w-full py-3 bg-slate-100 text-slate-500 rounded-2xl font-black text-xs uppercase tracking-widest hover:bg-slate-200 transition-all cursor-pointer">
                        Cancel
                    </button>
                }

                @* ── Step 2: Configure Clone (select cases, folder, name) ── *@
                @if (_importStep == 2 && _selectedTemplate is not null)
                {
                    <div class="flex items-center gap-4">
                        <button @onclick="() => _importStep = 1" class="w-10 h-10 rounded-xl bg-slate-100 flex items-center justify-center hover:bg-slate-200 transition-all cursor-pointer">
                            <svg class="w-5 h-5 text-slate-500" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
                            </svg>
                        </button>
                        <div>
                            <h2 class="text-2xl font-black text-slate-800">Configure Import</h2>
                            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mt-0.5">Step 2 — Select cases &amp; folder</p>
                        </div>
                    </div>

                    <!-- Template Info -->
                    <div class="rounded-2xl bg-indigo-50 border border-indigo-100 p-4">
                        <h5 class="font-black text-indigo-700 text-sm">@_selectedTemplate.Name</h5>
                        @if (!string.IsNullOrWhiteSpace(_selectedTemplate.Description))
                        {
                            <p class="text-xs text-indigo-500 mt-1">@_selectedTemplate.Description</p>
                        }
                    </div>

                    <!-- Suite Name Override -->
                    <div class="space-y-1.5">
                        <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Suite Name</label>
                        <input type="text" @bind="_importSuiteName"
                               @bind:after="() => { _importNameError = null; _nameWasAutoSuggested = false; }"
                               class="@($"w-full rounded-2xl border-2 bg-slate-50 px-6 py-3 font-bold text-slate-800 outline-none focus:bg-white text-sm {(_importNameError != null ? "border-red-400 focus:border-red-400" : "border-transparent focus:border-indigo-400")}")"
                               placeholder="@_selectedTemplate.Name" />
                        @if (_nameWasAutoSuggested)
                        {
                            <div class="flex items-start gap-2 mt-1.5 rounded-xl bg-amber-50 border border-amber-100 px-3 py-2">
                                <svg class="w-4 h-4 text-amber-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" />
                                </svg>
                                <div>
                                    <span class="text-xs font-bold text-amber-700">Name auto-adjusted</span>
                                    <p class="text-[11px] text-amber-600 mt-0.5">"@_selectedTemplate?.Name" already exists in this project. We suggested "<strong>@_importSuiteName</strong>" for you. Feel free to change it.</p>
                                </div>
                            </div>
                        }
                        @if (_importNameError != null)
                        {
                            <div class="flex items-center gap-1.5 mt-1">
                                <svg class="w-3.5 h-3.5 text-red-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
                                </svg>
                                <span class="text-xs font-semibold text-red-500">@_importNameError</span>
                            </div>
                        }
                    </div>

                    <!-- Folder Selection -->
                    <div class="space-y-1.5">
                        <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Target Folder (optional)</label>
                        <select @bind="_importFolderId"
                                class="w-full rounded-2xl border-2 border-transparent bg-slate-50 px-6 py-3 font-bold text-slate-800 outline-none focus:border-indigo-400 focus:bg-white text-sm">
                            <option value="">— Root (no folder) —</option>
                            @foreach (var folder in _projectFolders)
                            {
                                <option value="@folder.Id">@folder.Name</option>
                            }
                        </select>
                    </div>

                    <!-- Select Test Cases -->
                    <div class="space-y-2">
                        <div class="flex items-center justify-between">
                            <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Select Test Cases</label>
                            <button @onclick="ToggleAllCases"
                                    class="text-[10px] font-black text-indigo-500 uppercase tracking-widest hover:text-indigo-700 cursor-pointer">
                                @(_selectedCaseIds.Count == _selectedTemplate.TestCaseTemplates.Count ? "Deselect All" : "Select All")
                            </button>
                        </div>

                        <div class="space-y-1 max-h-56 overflow-y-auto rounded-2xl border border-slate-100 p-3">
                            @foreach (var tc in _selectedTemplate.TestCaseTemplates)
                            {
                                <label class="flex items-center gap-3 p-2 rounded-xl hover:bg-slate-50 cursor-pointer transition-all">
                                    <input type="checkbox" checked="@_selectedCaseIds.Contains(tc.Id)"
                                           @onchange="() => ToggleCaseSelection(tc.Id)"
                                           class="w-4 h-4 rounded border-slate-300 text-indigo-600 focus:ring-indigo-500" />
                                    <div class="flex-1 min-w-0">
                                        <span class="text-sm font-bold text-slate-700">@tc.Title</span>
                                        <span class="text-[10px] font-bold text-slate-400 ml-2">@tc.TestStepTemplates.Count steps</span>
                                    </div>
                                    <span class="px-2 py-0.5 rounded-lg text-[9px] font-black uppercase tracking-widest
                                        @(tc.Priority == TestCasePriority.High ? "bg-red-50 text-red-500" :
                                          tc.Priority == TestCasePriority.Medium ? "bg-amber-50 text-amber-500" :
                                          "bg-green-50 text-green-500")">
                                        @tc.Priority
                                    </span>
                                </label>
                            }
                        </div>
                        <p class="text-[10px] font-bold text-slate-400">@_selectedCaseIds.Count of @_selectedTemplate.TestCaseTemplates.Count cases selected</p>
                    </div>

                    <!-- Import Button -->
                    <button @onclick="HandleImportFromWizard" disabled="@(_isSaving || _selectedCaseIds.Count == 0)"
                            class="w-full py-4 bg-indigo-600 text-white rounded-2xl font-black text-xs uppercase tracking-widest shadow-lg hover:bg-indigo-700 transition-all active:scale-95 cursor-pointer disabled:opacity-50">
                        @(_isSaving ? "Importing..." : $"Import {_selectedCaseIds.Count} Case(s)")
                    </button>

                    <button @onclick="CloseImportModal"
                            class="w-full py-3 bg-slate-100 text-slate-500 rounded-2xl font-black text-xs uppercase tracking-widest hover:bg-slate-200 transition-all cursor-pointer">
                        Cancel
                    </button>
                }
            </div>
        </div>
    }

    @* ── Delete Suite Confirmation Modal ── *@
    @if (_isDeleteOpen && _suiteToDelete is not null)
    {
        <div class="fixed inset-0 z-[150] flex items-center justify-center p-6">
            <div class="absolute inset-0 bg-slate-900/40 backdrop-blur-sm animate-in fade-in duration-300" @onclick="() => { _isDeleteOpen = false; _suiteToDelete = null; }"></div>
            <div class="relative bg-white w-full max-w-md rounded-[48px] shadow-2xl animate-in zoom-in-95 duration-300 p-10 space-y-6">
                <div class="flex items-center gap-4">
                    <div class="w-12 h-12 bg-red-500 rounded-2xl flex items-center justify-center text-white shadow-lg">
                        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />
                        </svg>
                    </div>
                    <div>
                        <h2 class="text-2xl font-black text-slate-800">Delete Suite</h2>
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mt-0.5">This action cannot be undone</p>
                    </div>
                </div>

                <div class="rounded-2xl bg-red-50 border border-red-100 p-5">
                    <p class="text-sm font-medium text-slate-600">
                        Are you sure you want to delete <span class="font-black text-slate-800">"@_suiteToDelete.Name"</span>?
                        This will also remove all <span class="font-black text-red-500">@_suiteToDelete.TestCases.Count test case(s)</span> inside it.
                    </p>
                </div>

                <div class="flex gap-3">
                    <button @onclick="() => { _isDeleteOpen = false; _suiteToDelete = null; }"
                            class="flex-1 py-4 bg-slate-100 text-slate-500 rounded-2xl font-black text-xs uppercase tracking-widest hover:bg-slate-200 transition-all cursor-pointer">
                        Cancel
                    </button>
                    <button @onclick="HandleDeleteSuite" disabled="@_isDeleting"
                            class="flex-1 py-4 bg-red-500 text-white rounded-2xl font-black text-xs uppercase tracking-widest shadow-lg hover:bg-red-600 transition-all active:scale-95 cursor-pointer disabled:opacity-50">
                        @(_isDeleting ? "Deleting..." : "Delete")
                    </button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public int ProjectId { get; set; }

    [Inject] private ITestSuiteService TestSuiteService { get; set; } = default!;
    [Inject] private ITestSuiteTemplateService TestSuiteTemplateService { get; set; } = default!;
    [Inject] private HttpClient Http { get; set; } = default!;

    private List<TestSuiteResponse> _suites = new();
    private List<TestSuiteTemplateResponse> _templates = new();
    private TestSuiteResponse? _selectedSuite;
    private bool _isLoading = true;
    private bool _isLoadingTemplates;
    private bool _isSaving;
    private bool _isCreateOpen;
    private bool _isImportOpen;
    private bool _isDeleteOpen;
    private bool _isDeleting;
    private TestSuiteResponse? _suiteToDelete;
    private string? _errorMessage;
    private string _searchQuery = string.Empty;

    // Import wizard state
    private int _importStep = 1;
    private TestSuiteTemplateResponse? _selectedTemplate;
    private string _templateSearchQuery = string.Empty;
    private string _importSuiteName = string.Empty;
    private string _importFolderId = string.Empty;
    private HashSet<int> _selectedCaseIds = new();
    private List<ProjectFolderDto> _projectFolders = new();
    private string? _importNameError;
    private bool _nameWasAutoSuggested;
    private HashSet<int> _clonedTemplateIds = new();

    // Create suite state
    private CreateTestSuiteRequest _createRequest = new();
    private string? _createNameError;

    private List<TestSuiteResponse> FilteredSuites =>
        string.IsNullOrWhiteSpace(_searchQuery)
            ? _suites
            : _suites.Where(s => s.Name.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase)).ToList();

    private List<TestSuiteTemplateResponse> FilteredTemplates =>
        string.IsNullOrWhiteSpace(_templateSearchQuery)
            ? _templates
            : _templates.Where(t => t.Name.Contains(_templateSearchQuery, StringComparison.OrdinalIgnoreCase)
                || (t.Description ?? "").Contains(_templateSearchQuery, StringComparison.OrdinalIgnoreCase)).ToList();

    protected override async Task OnInitializedAsync()
    {
        await LoadSuitesAsync();
    }

    private async Task LoadSuitesAsync()
    {
        _isLoading = true;
        _errorMessage = null;
        try
        {
            _suites = await TestSuiteService.GetTestSuitesByProjectIdAsync(ProjectId);
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to load test suites. {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task OpenSuiteDetail(int suiteId)
    {
        try
        {
            _selectedSuite = await TestSuiteService.GetTestSuiteByIdAsync(suiteId);
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to load suite. {ex.Message}";
        }
    }

    private async Task ReloadSelectedSuite()
    {
        if (_selectedSuite is not null)
        {
            await OpenSuiteDetail(_selectedSuite.Id);
        }
    }

    private async Task CloseSuiteDetail()
    {
        _selectedSuite = null;
        await LoadSuitesAsync();
    }

    private async Task HandleCreateSuite()
    {
        _isSaving = true;
        _createNameError = null;
        try
        {
            _createRequest.ProjectId = ProjectId;

            // Check for duplicate name
            if (!string.IsNullOrWhiteSpace(_createRequest.Name))
            {
                var exists = await TestSuiteService.CheckSuiteNameExistsAsync(ProjectId, _createRequest.Name);
                if (exists)
                {
                    _createNameError = $"A test suite named \"{_createRequest.Name}\" already exists in this project.";
                    return;
                }
            }

            await TestSuiteService.CreateTestSuiteAsync(_createRequest);
            _createRequest = new();
            _isCreateOpen = false;
            _createNameError = null;
            await LoadSuitesAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to create suite. {ex.Message}";
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task HandleImportFromWizard()
    {
        if (_selectedTemplate is null || _selectedCaseIds.Count == 0) return;
        _isSaving = true;
        _importNameError = null;
        try
        {
            var effectiveName = string.IsNullOrWhiteSpace(_importSuiteName) ? _selectedTemplate.Name : _importSuiteName;

            // Check for duplicate name
            var exists = await TestSuiteService.CheckSuiteNameExistsAsync(ProjectId, effectiveName);
            if (exists)
            {
                _importNameError = $"A test suite named \"{effectiveName}\" already exists in this project. Please choose a different name.";
                return;
            }

            var allSelected = _selectedCaseIds.Count == _selectedTemplate.TestCaseTemplates.Count;
            var request = new CreateTestSuiteRequest
            {
                ProjectId = ProjectId,
                Name = effectiveName,
                Description = _selectedTemplate.Description,
                SourceTemplateId = _selectedTemplate.Id,
                FolderId = string.IsNullOrWhiteSpace(_importFolderId) ? null : int.Parse(_importFolderId),
                SelectedTestCaseTemplateIds = allSelected ? null : _selectedCaseIds.ToList()
            };
            await TestSuiteService.CreateTestSuiteAsync(request);
            CloseImportModal();
            await LoadSuitesAsync();
        }
        catch (Exception ex)
        {
            _importNameError = ex.Message;
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task SelectTemplate(TestSuiteTemplateResponse template)
    {
        _selectedTemplate = template;
        _selectedCaseIds = new HashSet<int>(template.TestCaseTemplates.Select(c => c.Id));
        _importNameError = null;
        _nameWasAutoSuggested = false;
        _importStep = 2;

        // Auto-suggest a unique name (handles duplicates automatically)
        var suggestedName = await TestSuiteService.SuggestUniqueNameAsync(ProjectId, template.Name);
        _importSuiteName = suggestedName;

        // If name was changed from original, notify user
        if (!string.Equals(suggestedName, template.Name, StringComparison.OrdinalIgnoreCase))
        {
            _nameWasAutoSuggested = true;
        }
    }

    private void ToggleCaseSelection(int caseId)
    {
        if (!_selectedCaseIds.Remove(caseId))
            _selectedCaseIds.Add(caseId);
    }

    private void ToggleAllCases()
    {
        if (_selectedTemplate is null) return;
        if (_selectedCaseIds.Count == _selectedTemplate.TestCaseTemplates.Count)
            _selectedCaseIds.Clear();
        else
            _selectedCaseIds = new HashSet<int>(_selectedTemplate.TestCaseTemplates.Select(c => c.Id));
    }

    private void CloseImportModal()
    {
        _isImportOpen = false;
        _importStep = 1;
        _selectedTemplate = null;
        _importSuiteName = string.Empty;
        _importFolderId = string.Empty;
        _selectedCaseIds.Clear();
        _templateSearchQuery = string.Empty;
        _importNameError = null;
        _nameWasAutoSuggested = false;
    }

    private void OpenDeleteConfirm(TestSuiteResponse suite)
    {
        _suiteToDelete = suite;
        _isDeleteOpen = true;
    }

    private async Task HandleDeleteSuite()
    {
        if (_suiteToDelete is null) return;
        _isDeleting = true;
        try
        {
            await TestSuiteService.DeleteTestSuiteAsync(_suiteToDelete.Id);
            _isDeleteOpen = false;
            _suiteToDelete = null;
            await LoadSuitesAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to delete suite. {ex.Message}";
        }
        finally
        {
            _isDeleting = false;
        }
    }

    protected override async Task OnParametersSetAsync()
    {
    }

    // Load templates when import modal opens
    private async Task OpenImportModal()
    {
        _isImportOpen = true;
        _importStep = 1;
        _selectedTemplate = null;
        _templateSearchQuery = string.Empty;
        _nameWasAutoSuggested = false;
        await Task.WhenAll(LoadTemplatesAsync(), LoadProjectFoldersAsync(), LoadSuitesForCloneCheck());
    }

    private async Task LoadSuitesForCloneCheck()
    {
        try
        {
            var suites = await TestSuiteService.GetTestSuitesByProjectIdAsync(ProjectId);
            _clonedTemplateIds = new HashSet<int>(
                suites.Where(s => s.SourceTemplateId.HasValue)
                      .Select(s => s.SourceTemplateId!.Value));
        }
        catch
        {
            _clonedTemplateIds = new();
        }
    }

    private async Task LoadTemplatesAsync()
    {
        _isLoadingTemplates = true;
        try
        {
            _templates = await TestSuiteTemplateService.GetCloneableTemplatesAsync();
        }
        catch { }
        finally
        {
            _isLoadingTemplates = false;
        }
    }

    private async Task LoadProjectFoldersAsync()
    {
        try
        {
            var folders = await Http.GetFromJsonAsync<List<ProjectFolderDto>>($"api/projectfolders/project/{ProjectId}");
            _projectFolders = folders ?? new();
        }
        catch
        {
            _projectFolders = new();
        }
    }

    // Simple DTO for project folders (used inline)
    private class ProjectFolderDto
    {
        public int Id { get; set; }
        public string Name { get; set; } = string.Empty;
        public int? ParentId { get; set; }
    }

}
