@page "/projects/{ProjectId:int}/testplans/{TestPlanId:int}"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.JSInterop
@using Testify.Client.Interfaces
@using Testify.Client.Shared.Services
@using Testify.Shared.DTOs.TestPlans
@using Testify.Shared.DTOs.TestRuns
@using Testify.Shared.DTOs.TestCases
@using Testify.Shared.Enums
@using Testify.Shared.Helpers
@inject ITestRunService TestRunService
@inject ITestPlanService TestPlanService
@inject ModalService ModalService
@inject NavigationManager Navigation
@inject IJSRuntime JsRuntime
@rendermode InteractiveWebAssembly
@attribute [Authorize]

<PageTitle>Test Execution Hub</PageTitle>

<div class="animate-in fade-in slide-in-from-bottom-4 px-5 pt-2 pb-20 duration-500">
    @if (_isLoading)
    {
        <div class="flex flex-col items-center justify-center rounded-[64px] border-2 border-dashed border-slate-200 bg-white/40 py-32">
            <div class="h-12 w-12 animate-spin rounded-full border-4 border-slate-200 border-t-[#7E96E1]"></div>
            <p class="mt-6 text-xs font-black tracking-widest text-slate-400 uppercase">Loading Execution Ledger...</p>
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <div class="flex items-start gap-4 rounded-[32px] border border-red-100 bg-red-50/50 p-8">
            <div class="flex h-10 w-10 items-center justify-center rounded-2xl bg-red-100 text-red-500">
                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" /><line x1="15" x2="9" y1="9" y2="15" /><line x1="9" x2="15" y1="9" y2="15" /></svg>
            </div>
            <div>
                <h3 class="text-lg font-black text-red-800">System Alert</h3>
                <p class="mt-1 font-medium text-red-600">@_errorMessage</p>
            </div>
        </div>
    }
    else if (_activeRun is not null)
    {
        @* ========================================== *@
        @* ACTIVE EXECUTION VIEW (Matches Code 2 UI)  *@
        @* ========================================== *@
        <div class="animate-in fade-in zoom-in-95 duration-500">
            
            @* Header *@
            <div class="mb-8 flex items-center justify-between">
                <div class="flex items-center gap-4">
                    <button @onclick="BackToOverview"
                            class="rounded-2xl border border-slate-100 bg-white p-3 text-slate-400 shadow-sm transition-all hover:bg-slate-50 hover:text-slate-800">
                        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
                    </button>
                    <div>
                        <div class="flex items-center gap-2">
                            <span class="font-black tracking-widest text-[10px] text-[#7E96E1] uppercase">RUN-@_activeRun.Id</span>
                            <div class="h-1 w-1 rounded-full bg-slate-300"></div>
                            <span class="font-black tracking-widest text-[10px] text-slate-400 uppercase">@_activeRun.CreatedAt.ToString("HH:mm")</span>
                        </div>
                        <h2 class="text-3xl font-black text-slate-800">@_testPlan?.Name</h2>
                    </div>
                </div>

                <div class="flex items-center gap-4">
                    <div class="text-right">
                        <p class="font-black text-[10px] text-slate-400 uppercase">Progress</p>
                        <p class="text-xl font-black text-slate-800">
                            @_completedCount
                            <span class="font-medium text-slate-300">/@_totalCount</span>
                        </p>
                    </div>
                    <div class="relative flex h-12 w-12 items-center justify-center overflow-hidden rounded-full border-4 border-slate-100">
                        <div class="absolute inset-0 bg-[#7E96E1]/10"></div>
                        <div class="absolute bottom-0 left-0 w-full bg-[#7E96E1] transition-all duration-500"
                             style="height: @(_progressPercentage)%"></div>
                    </div>
                </div>
            </div>

            <div class="grid grid-cols-1 gap-8 xl:grid-cols-4">
                @* LEFT: Worklist Pipeline *@
                <div class="space-y-4 xl:col-span-1">
                    <div class="flex max-h-[700px] flex-col overflow-hidden rounded-[40px] border border-slate-100 bg-white p-6 shadow-sm">
                        <p class="mb-4 px-2 font-black tracking-widest text-[10px] text-slate-400 uppercase">Worklist Pipeline</p>
                        <div class="no-scrollbar flex-1 space-y-2 overflow-y-auto">
                            @foreach (var run in _testRuns)
                            {
                                var isCompleted = run.Status == TestRunStatus.Passed || run.Status == TestRunStatus.Failed;
                                var badgeClass = run.Status == TestRunStatus.Passed ? "bg-emerald-50/50" :
                                                 run.Status == TestRunStatus.Failed ? "bg-red-50/50" : "hover:bg-slate-50";
                                
                                <button @onclick="() => ScrollToCase(run.Id)"
                                        class="flex w-full items-center justify-between rounded-3xl p-4 transition-all @badgeClass">
                                    <div class="flex items-center gap-3">
                                        <div class="@GetStatusIconClass(run.Status) flex h-8 w-8 items-center justify-center rounded-xl transition-colors">
                                            @if (run.Status == TestRunStatus.Passed)
                                            {
                                                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                                            }
                                            else if (run.Status == TestRunStatus.Failed)
                                            {

                                                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                                            }
                                            else
                                            {

                                                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" /><polyline points="12 6 12 12 16 14" /></svg>
                                            }
                                        </div>
                                        <div class="text-left">
                                            <p class="line-clamp-1 font-black text-[10px] text-slate-800">@GetTestCaseTitle(run.TestCaseId)</p>
                                            <p class="font-bold text-[8px] text-slate-400 uppercase">TC-@run.TestCaseId</p>
                                        </div>
                                    </div>
                                </button>
                            }
                        </div>
                    </div>
                </div>

                @* RIGHT: Execution Details *@
                <div class="space-y-12 xl:col-span-3">
                    @foreach (var run in _testRuns.OrderBy(r => r.TestCaseId))
                    {
                        var detail = _testRunDetails.FirstOrDefault(d => d.Id == run.Id);
                        if (detail is null) continue;

                        var cardBorderClass = run.Status == TestRunStatus.Passed ? "border-emerald-200 bg-emerald-50/5" :
                                              run.Status == TestRunStatus.Failed ? "border-red-200 bg-red-50/5" : "border-slate-100 bg-white";

                        <div id="case-@run.Id" class="@cardBorderClass relative space-y-10 overflow-hidden rounded-[48px] border p-10 shadow-sm transition-all">
                            
                            @* Case Header *@
                            <div class="flex items-start justify-between">
                                <div class="flex-1">
                                    <div class="mb-1 flex items-center gap-2">
                                        <span class="font-black tracking-widest text-[10px] text-[#7E96E1] uppercase">TC-@run.TestCaseId</span>
                                    </div>
                                    <h3 class="text-2xl leading-tight font-black text-slate-800">@detail.TestCaseTitle</h3>
                                    <p class="mt-2 text-xs font-medium text-slate-400 italic">Preconditions: "@GetTestCasePreconditions(run.TestCaseId)"</p>
                                </div>
                                
                                @* Overall Status Badge *@
                                <div class="@GetStatusPillClass(run.Status) flex items-center gap-2 rounded-2xl border px-4 py-2 shadow-sm transition-all">
                                    @if (run.Status == TestRunStatus.Passed)
                                    {
                                        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                                    }
                                    else if (run.Status == TestRunStatus.Failed)
                                    {

                                        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                                    }
                                    else
                                    {

                                        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" /><polyline points="12 6 12 12 16 14" /></svg>
                                    }
                                    <span class="font-black tracking-widest text-[10px] uppercase">@run.Status</span>
                                </div>
                            </div>

                            @* Steps Loop *@
                            <div class="space-y-6">
                                @foreach (var step in detail.Steps.OrderBy(s => s.StepNumber))
                                {
                                    var stepClass = step.Status == TestStepStatus.Pass ? "bg-emerald-50/50 border-emerald-100" :
                                                    step.Status == TestStepStatus.Fail ? "bg-red-50/50 border-red-100" :
                                                    "bg-slate-50 border-slate-100 hover:border-[#7E96E1]/20";

                                    <div id="@GetStepElementId(step.Id)" class="@stepClass group space-y-6 rounded-[40px] border p-8 transition-all">
                                        
                                        @* Step Top Bar *@
                                        <div class="flex items-center justify-between">
                                            <div class="flex items-center gap-3">
                                                <span class="@GetStepNumberClass(step.Status) flex h-8 w-8 items-center justify-center rounded-xl font-black text-[11px] shadow-sm">
                                                    @step.StepNumber
                                                </span>
                                                <span class="font-black tracking-widest text-[10px] text-slate-400 uppercase">Protocol Node</span>
                                            </div>
                                            
                                            @* Step Actions (Hover) *@
                                            <div class="flex items-center gap-1.5 opacity-0 transition-opacity group-hover:opacity-100">
                                                <button @onclick="() => UpdateStepStatusAsync(detail, step, TestStepStatus.Pass)"
                                                        class="@(step.Status == TestStepStatus.Pass ? "bg-emerald-500 text-white shadow-lg" : "bg-white text-slate-300 shadow-inner hover:text-emerald-500 hover:shadow-sm") rounded-xl p-2 transition-all">
                                                    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                                                </button>
                                                <button @onclick="() => UpdateStepStatusAsync(detail, step, TestStepStatus.Fail)"
                                                        class="@(step.Status == TestStepStatus.Fail ? "bg-red-500 text-white shadow-lg" : "bg-white text-slate-300 shadow-inner hover:text-red-500 hover:shadow-sm") rounded-xl p-2 transition-all">
                                                    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                                                </button>
                                            </div>
                                        </div>

                                        <div class="grid grid-cols-1 gap-10 md:grid-cols-2">
                                            @* Left Column: Instruction & Data *@
                                            <div class="space-y-6">
                                                <div class="space-y-2">
                                                    <p class="px-1 font-black tracking-widest text-[9px] text-slate-400 uppercase">Instruction</p>
                                                    <p class="text-sm leading-relaxed font-bold text-slate-700">@step.Action</p>
                                                </div>
                                                <div class="space-y-2">
                                                    <p class="px-1 font-black tracking-widest text-[9px] text-[#E85D3F] uppercase">Input / Test Data</p>
                                                    <div class="group/data flex items-center gap-3 rounded-2xl border border-[#E85D3F]/10 bg-white px-4 py-3 shadow-inner">
                                                        <svg class="h-4 w-4 text-[#E85D3F]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4" /></svg>
                                                        <code class="font-mono break-all text-[11px] text-[#E85D3F]">@(step.TestData ?? "Default: SYSTEM_AUTO")</code>
                                                    </div>
                                                </div>
                                            </div>

                                            @* Right Column: Expected & Actual *@
                                            <div class="space-y-6">
                                                <div class="space-y-2">
                                                    <p class="px-1 font-black tracking-widest text-[9px] text-emerald-500 uppercase">Expected Outcome</p>
                                                    <p class="text-xs leading-relaxed font-medium text-slate-500 italic">"@step.ExpectedResult"</p>
                                                </div>
                                                <div class="space-y-2">
                                                    <p class="px-1 font-black tracking-widest text-[9px] text-slate-400 uppercase">Execution Observer Log</p>
                                                    @* Note: Assuming purely visual here as per request style, since backend field might not exist yet *@
                                                    <textarea placeholder="Record observed deviation or result..."
                                                              class="min-h-[80px] w-full resize-none rounded-2xl border border-slate-200 bg-white p-4 text-xs font-medium text-slate-700 shadow-inner transition-all outline-none focus:border-[#7E96E1]"></textarea>
                                                </div>
                                                
                                                @if (step.Status == TestStepStatus.Fail)
                                                {
                                                    <div class="flex justify-end">
                                                        <button @onclick="() => CreateBugForStepAsync(detail.Id, step.Id)"
                                                                class="flex items-center gap-2 rounded-xl border border-red-100 bg-red-50 px-4 py-2 text-[9px] font-black uppercase tracking-widest text-red-600 transition-all hover:bg-red-100">
                                                            <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>
                                                            Create Defect Ticket
                                                        </button>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>

                            @* Footer Actions *@
                            <div class="flex items-center justify-end gap-3 border-t border-slate-50/50 pt-8">
                                <button @onclick="() => UpdateRunStatusAsync(run.Id, TestRunStatus.Failed)"
                                        class="@(run.Status == TestRunStatus.Failed ? "bg-red-500 text-white shadow-lg" : "bg-red-50 text-red-600 border border-red-100 hover:bg-red-100") rounded-2xl px-6 py-3 text-[10px] font-black uppercase tracking-widest transition-all">
                                    Mark as Failed
                                </button>
                                <button @onclick="() => PassAllStepsAsync(detail)"
                                        disabled="@(run.Status == TestRunStatus.Passed)"
                                        class="@(run.Status == TestRunStatus.Passed ? "bg-emerald-500 text-white shadow-lg" : "bg-emerald-50 text-emerald-600 border border-emerald-100 hover:bg-emerald-100") rounded-2xl px-6 py-3 text-[10px] font-black uppercase tracking-widest transition-all">
                                    Pass All Steps
                                </button>
                            </div>

                        </div>
                    }
                </div>
            </div>
        </div>
    }
    else
    {
        @* ========================================== *@
        @* DASHBOARD OVERVIEW (Matches Code 2 UI)     *@
        @* ========================================== *@
        <div class="animate-in fade-in space-y-8 duration-500">
            <div class="flex flex-col justify-between gap-6 md:flex-row md:items-center">
                <div>
                    <h3 class="text-2xl font-black tracking-tight text-slate-800">Execution Ledger</h3>
                    <p class="mt-1 text-sm font-medium text-slate-400">Audit of active and historical verification cycles.</p>
                </div>
                <button @onclick="BackToTestPlan"
                        class="group flex items-center gap-3 rounded-[24px] bg-[#E85D3F] px-8 py-4 text-xs font-black tracking-widest text-white uppercase shadow-xl shadow-orange-900/10 transition-all hover:bg-orange-600 active:scale-95">
                    <svg class="h-4 w-4 fill-white transition-transform group-hover:scale-110" viewBox="0 0 24 24"><path d="M8 5v14l11-7z" /></svg>
                    Return to Plan
                </button>
            </div>

            <div class="grid grid-cols-1 gap-8 md:grid-cols-2 xl:grid-cols-3">
                @if (_testRuns.Any())
                {
                    @foreach (var run in _testRuns)
                    {
                        var isCompleted = run.Status == TestRunStatus.Passed || run.Status == TestRunStatus.Failed;
                        // Assuming simple calculation here for the overview card
                        var passPercent = run.Status == TestRunStatus.Passed ? 100 : 0;
                        var statusIcon = run.Status == TestRunStatus.Passed ?
                            "<path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z' />" :
                            "<path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M13 10V3L4 14h7v7l9-11h-7z' />";

                        <div class="group relative flex h-full flex-col overflow-hidden rounded-[48px] border border-slate-50 bg-white p-10 shadow-sm transition-all hover:shadow-2xl">
                            <div class="mb-8 flex items-start justify-between">
                                <div class="@(isCompleted ? "bg-emerald-50 text-emerald-500" : "bg-blue-50 text-blue-500") flex h-14 w-14 items-center justify-center rounded-2xl">
                                    <svg class="h-7 w-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">@((MarkupString)statusIcon)</svg>
                                </div>
                                <div class="rounded-xl bg-slate-50 px-4 py-1.5 font-black tracking-widest text-[9px] text-slate-400 uppercase">
                                    @run.Status
                                </div>
                            </div>

                            <div class="flex-1">
                                <h4 class="mb-2 text-xl font-black text-slate-800 transition-colors group-hover:text-[#E85D3F]">@GetTestCaseTitle(run.TestCaseId)</h4>
                                <div class="mb-8 flex items-center gap-4 font-bold text-[10px] text-slate-300 uppercase">
                                    <span class="flex items-center gap-1.5">
                                        <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                                        @run.CreatedAt.ToString("MMM dd")
                                    </span>
                                    <div class="h-1 w-1 rounded-full bg-slate-200"></div>
                                    <span class="flex items-center gap-1.5">TC-@run.TestCaseId</span>
                                </div>

                                <div class="space-y-6">
                                    <div class="space-y-2">
                                        <div class="flex items-center justify-between font-black text-[10px] uppercase">
                                            <span class="text-slate-400">Result Integrity</span>
                                            <span class="@(run.Status == TestRunStatus.Passed ? "text-emerald-500" : "text-slate-400")">@(run.Status == TestRunStatus.Passed ? "100%" : "Pending")</span>
                                        </div>
                                        <div class="h-1.5 w-full overflow-hidden rounded-full bg-slate-100">
                                            <div class="h-full bg-emerald-500 transition-all duration-1000" style="width: @(run.Status == TestRunStatus.Passed ? "100%" : "0%")"></div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <button @onclick="() => _activeRun = run"
                                    class="mt-10 flex w-full items-center justify-center gap-3 rounded-2xl bg-[#1C1D2A] py-5 text-xs font-black uppercase tracking-[0.2em] text-white shadow-xl transition-all hover:bg-slate-800 active:scale-95">
                                Open Protocol <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
                            </button>
                        </div>
                    }
                }
                else
                {
                    <div class="col-span-full flex flex-col items-center justify-center rounded-[64px] border-2 border-dashed border-slate-200 bg-white/40 py-32 text-center">
                        <div class="mb-8 flex h-24 w-24 items-center justify-center rounded-[40px] bg-white shadow-sm">
                            <svg class="h-10 w-10 text-slate-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
                        </div>
                        <h3 class="text-3xl font-black tracking-widest text-slate-800 uppercase">No Cycles Initiated</h3>
                        <p class="mt-4 max-w-sm leading-relaxed font-medium text-slate-400">The project ledger contains no recorded execution cycles for this plan.</p>
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public int ProjectId { get; set; }
    [Parameter] public int TestPlanId { get; set; }

    private const string StepElementPrefix = "run-step-";
    private TestPlanResponse? _testPlan;
    private List<TestRunResponse> _testRuns = [];
    private List<TestRunDetailResponse> _testRunDetails = [];
    private List<TestCaseResponse> _testCases = [];

    private TestRunResponse? _activeRun;
    private bool _isLoading = true;
    private string? _errorMessage;

    private int _completedCount => _testRuns.Count(r => r.Status != TestRunStatus.Untested);
    private int _totalCount => _testRuns.Count;
    private decimal _progressPercentage => _totalCount > 0 ? (decimal)_completedCount / _totalCount * 100 : 0;

    protected override async Task OnParametersSetAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        _isLoading = true;
        _errorMessage = null;

        try
        {
            _testPlan = await TestPlanService.GetTestPlanByIdAsync(TestPlanId);
            _testRuns = await TestRunService.GetByTestPlanIdAsync(TestPlanId);
            
            // Load detailed information for each test run
            _testRunDetails.Clear();
            foreach (var run in _testRuns)
            {
                var detail = await TestRunService.GetDetailedByIdAsync(run.Id);
                if (detail is not null)
                {
                    _testRunDetails.Add(detail);
                }
            }
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task UpdateRunStatusAsync(int runId, TestRunStatus status, bool refreshData = true, bool showFailureWarning = true)
    {
        try
        {
            var request = new UpdateTestRunRequest
            {
                Status = status,
                // ExecutedAt = DateTimeHelper.GetVietnamTime()
            };

            var success = await TestRunService.UpdateAsync(runId, request);
            if (!success)
            {
                _errorMessage = "Failed to update test run status.";
                return;
            }

            var run = _testRuns.FirstOrDefault(r => r.Id == runId);
            if (run is not null)
            {
                run.Status = status;
            }

            if (refreshData)
            {
                await LoadDataAsync();
            }
            else
            {
                StateHasChanged();
            }

            if (status == TestRunStatus.Failed && showFailureWarning)
            {
                await ModalService.ShowWarningAsync(
                    "Test Failed",
                    "This test case has been marked as failed. Consider logging a bug report.",
                    showCancel: false
                );
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to update status: {ex.Message}";
        }
    }

    private async Task UpdateStepStatusAsync(TestRunDetailResponse detail, TestRunStepResponse step, TestStepStatus status)
    {
        try
        {
            var request = new UpdateTestRunStepRequest
            {
                Status = status
            };

            var success = await TestRunService.UpdateStepAsync(step.Id, request);
            if (!success)
            {
                _errorMessage = "Failed to update test step status.";
                return;
            }

            step.Status = status;

            if (status == TestStepStatus.Fail)
            {
                await UpdateRunStatusAsync(detail.Id, TestRunStatus.Failed, refreshData: false, showFailureWarning: false);
                return;
            }

            await TryUpdateRunStatusFromStepsAsync(detail);
            await FocusNextStepAsync(detail, step.StepNumber);
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to update step status: {ex.Message}";
        }
    }

    private async Task PassAllStepsAsync(TestRunDetailResponse detail)
    {
        try
        {
            var updates = detail.Steps.ToDictionary(
                step => step.Id,
                step => new UpdateTestRunStepRequest { Status = TestStepStatus.Pass });

            var success = await TestRunService.BatchUpdateStepsAsync(updates);
            if (!success)
            {
                _errorMessage = "Failed to pass all steps.";
                return;
            }

            foreach (var step in detail.Steps)
            {
                step.Status = TestStepStatus.Pass;
            }

            await UpdateRunStatusAsync(detail.Id, TestRunStatus.Passed, refreshData: false);
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to pass all steps: {ex.Message}";
        }
    }

    private async Task TryUpdateRunStatusFromStepsAsync(TestRunDetailResponse detail)
    {
        var run = _testRuns.FirstOrDefault(r => r.Id == detail.Id);
        if (run is null)
        {
            return;
        }

        if (detail.Steps.Any(step => step.Status == TestStepStatus.Fail))
        {
            if (run.Status != TestRunStatus.Failed)
            {
                await UpdateRunStatusAsync(detail.Id, TestRunStatus.Failed, refreshData: false, showFailureWarning: false);
            }
            return;
        }

        if (detail.Steps.All(step => step.Status == TestStepStatus.Pass) && run.Status != TestRunStatus.Passed)
        {
            await UpdateRunStatusAsync(detail.Id, TestRunStatus.Passed, refreshData: false);
        }
    }

    private async Task FocusNextStepAsync(TestRunDetailResponse detail, int stepNumber)
    {
        var nextStep = detail.Steps
            .OrderBy(s => s.StepNumber)
            .FirstOrDefault(s => s.StepNumber > stepNumber);

        if (nextStep is null)
        {
            return;
        }

        await JsRuntime.InvokeVoidAsync("testExecutionHub.focusStep", GetStepElementId(nextStep.Id));
    }

    private async Task CreateBugForStepAsync(int runId, int stepId)
    {
        var result = await ModalService.ShowConfirmationAsync(
            "Create Bug",
            "Open Kanban to link a bug to this failed step?");

        if (!result.Confirmed)
        {
            return;
        }

        Navigation.NavigateTo($"/projects/{ProjectId}/kanban?runId={runId}&runStepId={stepId}");
    }

    private void BackToOverview()
    {
        _activeRun = null;
    }

    private void BackToTestPlan()
    {
        Navigation.NavigateTo($"/projects/{ProjectId}/testplans");
    }

    private void ScrollToCase(int runId)
    {
        _activeRun = _testRuns.FirstOrDefault(r => r.Id == runId);
    }

    private string GetTestCaseTitle(int testCaseId)
    {
        // This would ideally come from the TestCase object, currently using ID/mock lookup based on Code 1
        var testCase = _testCases.FirstOrDefault(tc => tc.Id == testCaseId);
        return testCase?.Title ?? $"Test Case Specification {testCaseId}";
    }

    private string GetTestCasePreconditions(int testCaseId)
    {
        var testCase = _testCases.FirstOrDefault(tc => tc.Id == testCaseId);
        return testCase?.Preconditions ?? "System Initialized";
    }

    // Helper classes for UI states
    private string GetStatusIconClass(TestRunStatus status) => status switch
    {
        TestRunStatus.Passed => "bg-emerald-500 text-white shadow-md",
        TestRunStatus.Failed => "bg-red-500 text-white shadow-md",
        _ => "bg-slate-100 text-slate-300"
    };

    private string GetStatusPillClass(TestRunStatus status) => status switch
    {
        TestRunStatus.Passed => "bg-emerald-500 text-white border-emerald-400",
        TestRunStatus.Failed => "bg-red-500 text-white border-red-400",
        _ => "bg-white text-slate-400 border-slate-100"
    };

    private string GetStepNumberClass(TestStepStatus status) => status switch
    {
        TestStepStatus.Pass => "bg-emerald-500 text-white",
        TestStepStatus.Fail => "bg-red-500 text-white",
        _ => "bg-white text-slate-400"
    };

    private static string GetStepElementId(int stepId) => $"{StepElementPrefix}{stepId}";
}


