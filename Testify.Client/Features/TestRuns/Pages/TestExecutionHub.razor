@page "/projects/{ProjectId:int}/testruns"
@using Microsoft.AspNetCore.Authorization
@using Testify.Client.Interfaces
@using Testify.Client.Shared.Services
@using Testify.Shared.DTOs.Projects
@using Testify.Shared.DTOs.TestPlans
@using Testify.Shared.DTOs.TestRuns
@using Testify.Shared.Enums
@inject ITestRunService TestRunService
@inject ITestPlanService TestPlanService
@inject IProjectService ProjectService
@inject ModalService ModalService
@inject NavigationManager Navigation
@rendermode InteractiveWebAssembly
@attribute [Authorize]

<PageTitle>Test Execution</PageTitle>

<div class="animate-in fade-in slide-in-from-bottom-4 space-y-10 px-5 pt-3 pb-20 duration-700">
    @if (_isLoading)
    {
        <div class="flex flex-col items-center justify-center py-20">
            <div class="h-10 w-10 animate-spin rounded-full border-b-2 border-indigo-500"></div>
            <p class="mt-4 font-medium text-slate-400">Loading test runs...</p>
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <div class="flex items-start gap-3 rounded-xl border border-red-100 bg-red-50 p-4">
            <svg class="mt-0.5 h-5 w-5 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <circle cx="12" cy="12" r="10" />
                <line x1="15" x2="9" y1="9" y2="15" />
                <line x1="9" x2="15" y1="9" y2="15" />
            </svg>
            <div>
                <h3 class="text-sm font-bold text-red-800">Something went wrong</h3>
                <p class="text-sm text-red-600">@_errorMessage</p>
            </div>
        </div>
    }
    else if (_activeRunId.HasValue && _activeRun != null)
    {
        <div class="animate-in fade-in zoom-in-95 duration-500">
            @* Active Test Run View *@
            <div class="mb-8 flex items-center justify-between">
                <div class="flex items-center gap-4">
                    <button @onclick="() => _activeRunId = null"
                            class="p-3 bg-white hover:bg-slate-50 rounded-2xl border border-slate-100 shadow-sm transition-all text-slate-400 hover:text-slate-800">
                        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                        </svg>
                    </button>
                    <div>
                        <div class="flex items-center gap-2">
                            <span class="font-black tracking-widest text-[10px] text-[#7E96E1] uppercase">RUN-@(_activeRun.Id)</span>
                            <div class="h-1 w-1 rounded-full bg-slate-300"></div>
                            <span class="font-black tracking-widest text-[10px] text-slate-400 uppercase">@(_activeRun.CreatedAt)</span>
                        </div>
                        <h2 class="text-3xl font-black text-slate-800">@(_activeRun.Status)</h2>
                    </div>
                </div>
                
                <div class="flex items-center gap-4">
                    <div class="text-right">
                        <p class="font-black text-[10px] text-slate-400 uppercase">Progress</p>
                        <p class="text-xl font-black text-slate-800">
                            @(GetCompletedStepsCount())
                            <span class="font-medium text-slate-300">/@(_activeRun.Steps?.Count ?? 0)</span>
                        </p>
                    </div>
                    <div class="relative flex h-12 w-12 items-center justify-center overflow-hidden rounded-full border-4 border-slate-100">
                        <div class="absolute inset-0 bg-[#7E96E1]/10"></div>
                        <div class="absolute bottom-0 left-0 w-full bg-[#7E96E1] transition-all duration-500"
                             style="height: @(GetProgressPercentage())%"></div>
                    </div>
                </div>
            </div>

            <div class="grid grid-cols-1 gap-8 xl:grid-cols-4">
                <div class="space-y-4 xl:col-span-1">
                    <div class="flex max-h-[700px] flex-col overflow-hidden rounded-[40px] border border-slate-100 bg-white p-6 shadow-sm">
                        <p class="mb-4 px-2 font-black tracking-widest text-[10px] text-slate-400 uppercase">Test Steps</p>
                        <div class="no-scrollbar flex-1 space-y-2 overflow-y-auto">
                            @if (_activeRun.Steps != null && _activeRun.Steps.Any())
                            {
                                @foreach (var step in _activeRun.Steps)
                                {
                                    <div class="flex w-full items-center justify-between rounded-3xl bg-slate-50 p-4 transition-all hover:bg-slate-50">
                                        <div class="flex items-center gap-3">
                                            <div class="flex h-8 w-8 items-center justify-center rounded-xl bg-slate-100 text-xs font-bold text-slate-300">
                                                @step.StepNumber
                                            </div>
                                            <div class="text-left">
                                                <p class="line-clamp-1 font-black text-[10px] text-slate-800">Step @step.StepNumber</p>
                                                <p class="font-bold text-[8px] text-slate-400 uppercase">@(step.Status)</p>
                                            </div>
                                        </div>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                </div>

                <div class="space-y-8 xl:col-span-3">
                    @if (_activeRun.Steps != null && _activeRun.Steps.Any())
                    {
                        @foreach (var step in _activeRun.Steps)
                        {
                            <div class="relative space-y-8 overflow-hidden rounded-[48px] border border-slate-100 bg-white p-10 shadow-sm transition-all">
                                <div class="flex items-start justify-between">
                                    <div class="flex-1">
                                        <div class="mb-1 flex items-center gap-2">
                                            <span class="font-black tracking-widest text-[10px] text-[#7E96E1] uppercase">STEP-@step.Id</span>
                                        </div>
                                        <h3 class="text-2xl leading-tight font-black text-slate-800">Step @step.StepNumber</h3>
                                    </div>
                                    
                                    <div class="flex items-center gap-2 rounded-2xl border border-slate-100 bg-white px-4 py-2 text-slate-400 shadow-sm">
                                        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                                        </svg>
                                        <span class="font-black tracking-widest text-[10px] uppercase">@step.Status</span>
                                    </div>
                                </div>

                                <div class="space-y-6">
                                    <div class="group space-y-6 rounded-[40px] border border-slate-100 bg-slate-50 p-8">
                                        <div class="flex items-center justify-between">
                                            <div class="flex items-center gap-3">
                                                <span class="flex h-8 w-8 items-center justify-center rounded-xl bg-white font-black text-[11px] text-slate-400 shadow-sm">
                                                    @step.StepNumber
                                                </span>
                                                <span class="font-black tracking-widest text-[10px] text-slate-400 uppercase">Protocol Node</span>
                                            </div>
                                            <div class="flex items-center gap-1.5 opacity-100 transition-opacity">
                                                <button @onclick="() => UpdateStepStatus(step.Id, TestStepStatus.Pass)"
                                                        class="p-2 rounded-xl transition-all bg-white text-slate-300 hover:text-emerald-500 hover:shadow-sm shadow-inner">
                                                    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                                                    </svg>
                                                </button>
                                                <button @onclick="() => UpdateStepStatus(step.Id, TestStepStatus.Fail)"
                                                        class="p-2 rounded-xl transition-all bg-white text-slate-300 hover:text-red-500 hover:shadow-sm shadow-inner">
                                                    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                                                    </svg>
                                                </button>
                                            </div>
                                        </div>
                                        
                                        <div class="grid grid-cols-1 gap-10 md:grid-cols-2">
                                            <div class="space-y-6">
                                                <div class="space-y-2">
                                                    <p class="px-1 font-black tracking-widest text-[9px] text-slate-400 uppercase">Instruction</p>
                                                    <p class="text-sm leading-relaxed font-bold text-slate-700">@step.Action</p>
                                                </div>
                                                <div class="space-y-2">
                                                    <p class="px-1 font-black tracking-widest text-[9px] text-[#E85D3F] uppercase">Input / Test Data</p>
                                                    <div class="flex items-center gap-3 rounded-2xl border border-[#E85D3F]/10 bg-white px-4 py-3 shadow-inner">
                                                        <svg class="h-4 w-4 text-[#E85D3F]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10a2 2 0 002 2h12a2 2 0 002-2V9a2 2 0 00-2-2h-6.586a1 1 0 00-.707.293l-5.414 5.414a1 1 0 00-.293.707V7a2 2 0 00-2-2H6a2 2 0 00-2 2z" />
                                                        </svg>
                                                        <code class="font-mono break-all text-[11px] text-[#E85D3F]">
                                                            @(string.IsNullOrEmpty(step.TestData) ? "Default: SYSTEM_AUTO" : step.TestData)
                                                        </code>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="space-y-6">
                                                <div class="space-y-2">
                                                    <p class="px-1 font-black tracking-widest text-[9px] text-emerald-500 uppercase">Expected Outcome</p>
                                                    <p class="text-xs leading-relaxed font-medium text-slate-500 italic">"@step.ExpectedResult"</p>
                                                </div>
                                                <div class="space-y-2">
                                                    <p class="px-1 font-black tracking-widest text-[9px] text-slate-400 uppercase">Execution Observer Log</p>
                                                    <textarea @onchange="(ChangeEventArgs e) => UpdateStepActualResult(step.Id, (string?)e.Value)"
                                                              placeholder="Record observed deviation or result..."
                                                              class="w-full bg-white border border-slate-200 rounded-2xl p-4 text-xs font-medium text-slate-700 outline-none focus:border-[#7E96E1] min-h-[80px] resize-none transition-all shadow-inner">@(step.ActualResult ?? "")</textarea>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="rounded-[48px] border border-slate-100 bg-white p-20 text-center">
                            <p class="font-medium text-slate-400">No steps available for this test run.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
    else
    {
        @* Test Runs List View *@
        <div class="flex flex-col justify-between gap-6 lg:flex-row lg:items-center">
            <div>
                <h3 class="text-2xl font-black tracking-tight text-slate-800">Execution Ledger</h3>
                <p class="mt-1 text-sm font-medium text-slate-400">Audit of active and historical verification cycles.</p>
            </div>
            <button @onclick="StartNewRun"
                    class="group flex items-center gap-3 rounded-[24px] bg-[#E85D3F] px-8 py-4 text-xs font-black tracking-widest text-white uppercase shadow-xl shadow-orange-900/10 transition-all hover:bg-orange-600 active:scale-95">
                <svg class="h-4 w-4 fill-white transition-transform group-hover:scale-110" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M8 5v14l11-7z" />
                </svg>
                Initialize Regression Run
            </button>
        </div>

        <div class="grid grid-cols-1 gap-8 md:grid-cols-2 xl:grid-cols-3">
            @if (_testRuns != null && _testRuns.Any())
            {
                @foreach (var run in _testRuns)
                {
                    var passPercent = CalculatePassPercent(run);
                    var progressPercent = CalculateProgressPercent(run);
                    var totalCount = run.Steps?.Count ?? 0;

                    <div class="group relative flex h-full flex-col overflow-hidden rounded-[48px] border border-slate-50 bg-white p-10 shadow-sm transition-all hover:shadow-2xl">
                        <div class="mb-8 flex items-start justify-between">
                            <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-blue-50 text-blue-500">
                                <svg class="h-7 w-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
                                </svg>
                            </div>
                            <div class="rounded-xl bg-red-50 px-4 py-1.5 font-black tracking-widest text-[9px] text-red-500 uppercase">
                                High Priority
                            </div>
                        </div>

                        <div class="flex-1">
                            <h4 class="mb-2 text-xl font-black text-slate-800 transition-colors group-hover:text-[#E85D3F]">Test Run @run.Id</h4>
                            <div class="mb-8 flex items-center gap-4 font-bold text-[10px] text-slate-300 uppercase">
                                <span class="flex items-center gap-1.5">
                                    <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                                    </svg>
                                    @run.CreatedAt.ToString("g")
                                </span>
                                <div class="h-1 w-1 rounded-full bg-slate-200"></div>
                                <span class="flex items-center gap-1.5">
                                    <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                                    </svg>
                                    @run.Status
                                </span>
                            </div>

                            <div class="space-y-6">
                                <div class="space-y-2">
                                    <div class="flex items-center justify-between font-black text-[10px] uppercase">
                                        <span class="text-slate-400">Pass Integrity</span>
                                        <span class="text-emerald-500">@passPercent%</span>
                                    </div>
                                    <div class="h-1.5 w-full overflow-hidden rounded-full bg-slate-100">
                                        <div class="h-full bg-emerald-500 transition-all duration-1000" style="width: @passPercent%"></div>
                                    </div>
                                </div>
                                
                                <div class="grid grid-cols-2 gap-4">
                                    <div class="rounded-2xl border border-slate-100/50 bg-slate-50 p-4">
                                        <p class="mb-1 font-black text-[9px] text-slate-400 uppercase">Progress</p>
                                        <p class="text-lg font-black text-slate-700">@progressPercent%</p>
                                    </div>
                                    <div class="rounded-2xl border border-slate-100/50 bg-slate-50 p-4">
                                        <p class="mb-1 font-black text-[9px] text-slate-400 uppercase">Steps</p>
                                        <p class="text-lg font-black text-slate-700">@totalCount</p>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <button @onclick="() => _activeRunId = run.Id"
                                class="w-full mt-10 py-5 bg-[#1C1D2A] text-white rounded-2xl font-black text-xs uppercase tracking-[0.2em] shadow-xl hover:bg-slate-800 transition-all flex items-center justify-center gap-3 active:scale-95">
                            Resume Execution
                            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                            </svg>
                        </button>
                    </div>
                }
            }
            else
            {
                <div class="col-span-full flex flex-col items-center justify-center rounded-[64px] border-2 border-dashed border-slate-200 bg-white/40 py-32 text-center">
                    <div class="mb-8 flex h-24 w-24 items-center justify-center rounded-[40px] bg-white shadow-sm">
                        <svg class="h-10 w-10 text-slate-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                        </svg>
                    </div>
                    <h3 class="text-3xl font-black tracking-widest text-slate-800 uppercase">No Cycles Initiated</h3>
                    <p class="mt-4 max-w-sm leading-relaxed font-medium text-slate-400">The project ledger contains no recorded execution cycles. Start a new regression run to begin validation.</p>
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter] public int ProjectId { get; set; }
    [Parameter] public int TestPlanId { get; set; }


    private List<TestRunDetailResponse> _testRuns = new();
    private TestRunDetailResponse? _activeRun;
    private int? _activeRunId;
    private string _errorMessage = string.Empty;
    private bool _isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadTestRuns();
    }

    private async Task LoadTestRuns()
    {
        try
        {
            _isLoading = true;
            _errorMessage = string.Empty;
            var testPlans = await TestPlanService.GetAllTestPlansAsync(ProjectId);
            
            _testRuns = new();
            foreach (var plan in testPlans)
            {
                var runs = await TestRunService.GetByTestPlanIdAsync(plan.Id);
                foreach (var run in runs)
                {
                    var detailedRun = await TestRunService.GetDetailedByIdAsync(run.Id);
                    if (detailedRun != null)
                    {
                        _testRuns.Add(detailedRun);
                    }
                }
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to load test runs: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task StartNewRun()
    {
        try
        {
            _isLoading = true;
			var testPlans = await TestPlanService.GetAllTestPlansAsync(ProjectId);
            if (!testPlans.Any())
            {
                _errorMessage = "No test plans available. Please create a test plan first.";
                return;
            }

            var firstPlan = testPlans.First();
            var response = await TestRunService.StartExecutionAsync(firstPlan.Id, new());
            
            if (response != null)
            {
                await LoadTestRuns();
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to start new test run: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task UpdateStepStatus(int stepId, TestStepStatus status)
    {
        try
        {
            var request = new UpdateTestRunStepRequest { Status = status };
            await TestRunService.UpdateStepAsync(stepId, request);
            
            if (_activeRun != null)
            {
                var step = _activeRun.Steps?.FirstOrDefault(s => s.Id == stepId);
                if (step != null)
                {
                    step.Status = status;
                }
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to update step status: {ex.Message}";
        }
    }

    private async Task UpdateStepActualResult(int stepId, string? actualResult)
    {
        try
        {
            var request = new UpdateTestRunStepRequest
            {
                Status = _activeRun?.Steps?.FirstOrDefault(s => s.Id == stepId)?.Status ?? TestStepStatus.Pass,
                ActualResult = actualResult
            };
            await TestRunService.UpdateStepAsync(stepId, request);
            
            if (_activeRun != null)
            {
                var step = _activeRun.Steps?.FirstOrDefault(s => s.Id == stepId);
                if (step != null)
                {
                    step.ActualResult = actualResult;
                }
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to update step result: {ex.Message}";
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        _activeRunId = null;
        await LoadTestRuns();
    }

    private void SetActiveRun(int runId)
    {
        _activeRunId = runId;
        _activeRun = _testRuns.FirstOrDefault(r => r.Id == runId);
    }

    private int GetCompletedStepsCount()
    {
        return _activeRun?.Steps?.Count(s => s.Status != TestStepStatus.Pass) ?? 0;
    }

    private decimal GetProgressPercentage()
    {
        var total = _activeRun?.Steps?.Count ?? 0;
        if (total == 0) return 0;
        return (GetCompletedStepsCount() / (decimal)total) * 100;
    }

    private int CalculatePassPercent(TestRunDetailResponse run)
    {
        var total = run.Steps?.Count ?? 0;
        if (total == 0) return 0;
        var passed = run.Steps?.Count(s => s.Status == TestStepStatus.Pass) ?? 0;
        return (int)((passed / (decimal)total) * 100);
    }

    private int CalculateProgressPercent(TestRunDetailResponse run)
    {
        var total = run.Steps?.Count ?? 0;
        if (total == 0) return 0;
        var completed = run.Steps?.Count(s => s.Status != TestStepStatus.Pass) ?? 0;
        return (int)((completed / (decimal)total) * 100);
    }
}