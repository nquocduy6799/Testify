                     </div>
                  </div>
               </div>

               <button 
                 onClick={() => setActiveExecutionId(run.id)}
                 className="w-full mt-10 py-5 bg-[#1C1D2A] text-white rounded-2xl font-black text-xs uppercase tracking-[0.2em] shadow-xl hover:bg-slate-800 transition-all flex items-center justify-center gap-3 active:scale-95"
               >
                  Resume Execution <ArrowRight className="w-4 h-4" />
               </button>
            </div>
          );
        })}

        {(!project.testRuns || project.testRuns.length === 0) && (
           <div className="col-span-full py-32 flex flex-col items-center justify-center text-center bg-white/40 rounded-[64px] border-2 border-dashed border-slate-200">
              <div className="w-24 h-24 bg-white rounded-[40px] flex items-center justify-center shadow-sm mb-8">
                 <Zap className="w-10 h-10 text-slate-200" />
              </div>
              <h3 className="text-3xl font-black text-slate-800 uppercase tracking-widest">No Cycles Initiated</h3>
              <p className="text-slate-400 max-w-sm mt-4 font-medium leading-relaxed">The project ledger contains no recorded execution cycles. Start a new regression run to begin validation.</p>
           </div>
        )}
      </div>
    </div>
  );
};

