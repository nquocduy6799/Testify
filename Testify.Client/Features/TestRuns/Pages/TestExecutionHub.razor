@page "/projects/{ProjectId:int}/testplans/{TestPlanId:int}"
@using Microsoft.AspNetCore.Authorization
@using Testify.Client.Interfaces
@using Testify.Client.Shared.Services
@using Testify.Shared.DTOs.TestPlans
@using Testify.Shared.DTOs.TestRuns
@using Testify.Shared.DTOs.TestCases
@using Testify.Shared.Enums
@using Testify.Shared.Helpers
@inject ITestRunService TestRunService
@inject ITestPlanService TestPlanService
@inject ModalService ModalService
@inject NavigationManager Navigation
@rendermode InteractiveWebAssembly
@attribute [Authorize]

<PageTitle>Test Execution Hub</PageTitle>

<div class="animate-in fade-in slide-in-from-bottom-4 space-y-8 pb-20 duration-500">
    @if (_isLoading)
    {
        <div class="flex flex-col items-center justify-center py-20">
            <div class="h-10 w-10 animate-spin rounded-full border-b-2 border-indigo-500"></div>
            <p class="mt-4 font-medium text-slate-400">Loading execution hub...</p>
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <div class="flex items-start gap-3 rounded-xl border border-red-100 bg-red-50 p-4">
            <svg class="mt-0.5 h-5 w-5 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <circle cx="12" cy="12" r="10" />
                <line x1="15" x2="9" y1="9" y2="15" />
                <line x1="9" x2="15" y1="9" y2="15" />
            </svg>
            <div>
                <h3 class="text-sm font-bold text-red-800">Something went wrong</h3>
                <p class="text-sm text-red-600">@_errorMessage</p>
            </div>
        </div>
    }
    else if (_activeRun is not null)
    {
        @* ACTIVE EXECUTION VIEW *@
        <div class="animate-in fade-in zoom-in-95 duration-500">
            @* Header with Back Button *@
            <div class="mb-8 flex items-center justify-between">
                <div class="flex items-center gap-4">
                    <button @onclick="BackToOverview"
                            class="rounded-2xl border border-slate-100 bg-white p-3 shadow-sm transition-all hover:bg-slate-50">
                        <svg class="h-5 w-5 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                        </svg>
                    </button>
                    <div>
                        <div class="flex items-center gap-2">
                            <span class="font-black tracking-widest text-[10px] text-[#7E96E1] uppercase">RUN-@_activeRun.Id</span>
                            <div class="h-1 w-1 rounded-full bg-slate-300"></div>
                            <span class="font-black tracking-widest text-[10px] text-slate-400 uppercase">@_activeRun.CreatedAt.ToString("HH:mm")</span>
                        </div>
                        <h2 class="text-3xl font-black text-slate-800">@_testPlan?.Name Execution</h2>
                    </div>
                </div>

                <div class="flex items-center gap-4">
                    <div class="text-right">
                        <p class="font-black text-[10px] text-slate-400 uppercase">Progress</p>
                        <p class="text-xl font-black text-slate-800">
                            @_completedCount
                            <span class="font-medium text-slate-300">/@_totalCount</span>
                        </p>
                    </div>
                    <div class="relative flex h-12 w-12 items-center justify-center overflow-hidden rounded-full border-4 border-slate-100">
                        <div class="absolute inset-0 bg-[#7E96E1]/10"></div>
                        <div class="absolute bottom-0 left-0 w-full bg-[#7E96E1] transition-all duration-500"
                             style="height: @(_progressPercentage)%"></div>
                    </div>
                </div>
            </div>

            <div class="grid grid-cols-1 gap-8 xl:grid-cols-4">
                @* LEFT: Worklist Pipeline *@
                <div class="space-y-4 xl:col-span-1">
                    <div class="flex max-h-[700px] flex-col overflow-hidden rounded-[40px] border border-slate-100 bg-white p-6 shadow-sm">
                        <p class="mb-4 px-2 font-black tracking-widest text-[10px] text-slate-400 uppercase">Worklist Pipeline</p>
                        <div class="no-scrollbar flex-1 space-y-2 overflow-y-auto">
                            @foreach (var run in _testRuns)
                            {
                                var statusClass = GetStatusBadgeClass(run.Status);
                                <button @onclick="() => ScrollToCase(run.Id)"
                                        class="flex w-full items-center justify-between rounded-3xl p-4 transition-all @statusClass">
                                    <div class="flex items-center gap-3">
                                        <div class="flex h-8 w-8 items-center justify-center rounded-xl @GetStatusIconClass(run.Status)">
                                            @if (run.Status == TestRunStatus.Passed)
                                            {
                                                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                                                </svg>
                                            }
                                            else if (run.Status == TestRunStatus.Failed)
                                            {
                                                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
                                                </svg>
                                            }
                                            else
                                            {
                                                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                                                </svg>
                                            }
                                        </div>
                                        <div class="text-left">
                                            <p class="line-clamp-1 font-black text-[10px] text-slate-800">@GetTestCaseTitle(run.TestCaseId)</p>
                                            <p class="font-bold text-[8px] text-slate-400 uppercase">TC-@run.TestCaseId</p>
                                        </div>
                                    </div>
                                </button>
                            }
                        </div>
                    </div>
                </div>

                @* RIGHT: Execution Details *@
                <div class="space-y-8 xl:col-span-3">
                    @foreach (var run in _testRuns.OrderBy(r => r.TestCaseId))
                    {
                        var detail = _testRunDetails.FirstOrDefault(d => d.Id == run.Id);
                        if (detail is null) continue;

                        <div id="case-@run.Id" class="rounded-[48px] border border-slate-100 bg-white p-10 shadow-sm">
                            @* Case Header *@
                            <div class="mb-10 flex flex-col justify-between gap-6 border-b border-slate-50 pb-8 md:flex-row md:items-center">
                                <div>
                                    <span class="mb-2 block font-black tracking-[0.2em] text-[10px] text-[#E85D3F] uppercase">Execution Active</span>
                                    <h3 class="text-2xl font-black text-slate-800">@detail.TestCaseTitle</h3>
                                    <div class="mt-2 flex items-center gap-3">
                                        <span class="text-xs font-medium text-slate-400 italic">"@GetTestCasePreconditions(run.TestCaseId)"</span>
                                    </div>
                                </div>
                                <div class="flex items-center gap-3">
                                    <button @onclick="() => UpdateRunStatus(run.Id, TestRunStatus.Passed)"
                                            class="flex items-center gap-2 rounded-2xl px-8 py-4 text-xs font-black uppercase transition-all @GetPassButtonClass(run.Status)">
                                        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                                        </svg>
                                        Passed
                                    </button>
                                    <button @onclick="() => UpdateRunStatus(run.Id, TestRunStatus.Failed)"
                                            class="flex items-center gap-2 rounded-2xl px-8 py-4 text-xs font-black uppercase transition-all @GetFailButtonClass(run.Status)">
                                        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
                                        </svg>
                                        Failed
                                    </button>
                                </div>
                            </div>

                            @* Execution Steps Table *@
                            <div class="space-y-4">
                                <div class="grid grid-cols-[60px_1fr_1fr_1fr] gap-4 border-b border-slate-50 px-4 py-2">
                                    <span class="text-center font-black text-[9px] text-slate-400 uppercase">Step</span>
                                    <span class="font-black text-[9px] text-slate-400 uppercase">Protocol</span>
                                    <span class="font-black text-[9px] text-slate-400 uppercase">Input / Data</span>
                                    <span class="font-black text-[9px] text-slate-400 uppercase">Target Outcome</span>
                                </div>
                                <div class="space-y-2">
                                    @foreach (var step in detail.Steps.OrderBy(s => s.StepNumber))
                                    {
                                        <div class="group grid grid-cols-[60px_1fr_1fr_1fr] gap-4 rounded-[32px] border border-slate-100 bg-slate-50/50 p-6 transition-all hover:border-[#7E96E1]/20 hover:bg-white">
                                            <div class="flex items-center justify-center">
                                                <div class="flex h-10 w-10 items-center justify-center rounded-2xl bg-white text-xs font-black text-slate-400 shadow-sm transition-all group-hover:bg-[#7E96E1] group-hover:text-white">
                                                    @step.StepNumber
                                                </div>
                                            </div>
                                            <div class="flex items-center">
                                                <p class="text-sm leading-relaxed font-bold text-slate-700">@step.Action</p>
                                            </div>
                                            <div class="flex items-center">
                                                <code class="rounded-xl border border-slate-100 bg-white px-3 py-2 font-mono break-all text-[11px] text-[#E85D3F]">@(step.TestData ?? "Default")</code>
                                            </div>
                                            <div class="flex items-center gap-3">
                                                <p class="flex-1 text-sm font-medium text-emerald-600 italic">@step.ExpectedResult</p>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>

                            @* Footer Actions *@
                            <div class="mt-8 flex items-center justify-between border-t border-slate-50 pt-8">
                                <div class="flex items-center gap-3">
                                    <button class="flex items-center gap-2 font-black text-[10px] text-slate-400 uppercase transition-colors hover:text-slate-800">
                                        <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z" />
                                        </svg>
                                        Log Observation
                                    </button>
                                </div>
                                @if (run.ExecutedAt.HasValue)
                                {
                                    <span class="font-bold tracking-widest text-[9px] text-slate-300 uppercase italic">Syncing result at @run.ExecutedAt.Value.ToString("HH:mm")</span>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
    else
    {
        @* OVERVIEW - List of Test Runs *@
        <div class="flex flex-col justify-between gap-6 md:flex-row md:items-end">
            <div>
                <h2 class="text-3xl font-black tracking-tight text-slate-800">Execution Hub</h2>
                <p class="mt-2 font-medium text-slate-400">Coordinate and record granular manual verification cycles.</p>
            </div>
            <button @onclick="BackToTestPlan"
                    class="flex items-center gap-3 rounded-[32px] bg-[#1C1D2A] p-6 font-black text-white shadow-lg transition-all hover:bg-slate-800">
                <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                </svg>
                <span>Back to Test Plan</span>
            </button>
        </div>

        <div class="grid grid-cols-1 gap-8 md:grid-cols-2 xl:grid-cols-3">
            @if (_testRuns.Any())
            {
                @* Group runs by status for better organization *@
                var groupedByPlan = _testRuns.GroupBy(r => r.TestPlanId).FirstOrDefault();
                
                <div @onclick="() => _activeRun = _testRuns.First()"
                     class="group flex h-full cursor-pointer flex-col rounded-[40px] border border-slate-50 bg-white p-8 shadow-sm transition-all hover:shadow-xl">
                    <div class="mb-6 flex items-start justify-between">
                        <div>
                            <span class="rounded-full bg-[#7E96E1] px-2.5 py-0.5 font-extrabold tracking-wider text-[10px] text-white uppercase">
                                @GetOverallStatus()
                            </span>
                            <h3 class="mt-2 text-xl font-black text-slate-800">@_testPlan?.Name</h3>
                        </div>
                        <svg class="h-5 w-5 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                        </svg>
                    </div>
                    <div class="mt-auto flex items-center justify-between border-t border-slate-50 pt-6">
                        <span class="font-black tracking-widest text-[10px] text-slate-400 uppercase">@_testRuns.Count Test Cases</span>
                        <div class="flex h-8 w-8 items-center justify-center rounded-xl bg-slate-50 text-slate-400 transition-all group-hover:bg-[#1C1D2A] group-hover:text-white">
                            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                            </svg>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="col-span-full flex flex-col items-center justify-center rounded-[48px] border-2 border-dashed border-slate-200 bg-white/40 py-24">
                    <svg class="mb-6 h-10 w-10 text-slate-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    <h3 class="text-2xl font-black text-slate-800">Standby Mode</h3>
                    <p class="mt-2 max-w-sm font-medium text-slate-400">No active execution protocols initialized for this workspace.</p>
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter] public int ProjectId { get; set; }
    [Parameter] public int TestPlanId { get; set; }

    private TestPlanResponse? _testPlan;
    private List<TestRunResponse> _testRuns = [];
    private List<TestRunDetailResponse> _testRunDetails = [];
    private List<TestCaseResponse> _testCases = [];

    private TestRunResponse? _activeRun;
    private bool _isLoading = true;
    private string? _errorMessage;

    private int _completedCount => _testRuns.Count(r => r.Status != TestRunStatus.Untested);
    private int _totalCount => _testRuns.Count;
    private decimal _progressPercentage => _totalCount > 0 ? (decimal)_completedCount / _totalCount * 100 : 0;

    protected override async Task OnParametersSetAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        _isLoading = true;
        _errorMessage = null;

        try
        {
            _testPlan = await TestPlanService.GetTestPlanByIdAsync(TestPlanId);
            _testRuns = await TestRunService.GetByTestPlanIdAsync(TestPlanId);
            
            // Load detailed information for each test run
            _testRunDetails.Clear();
            foreach (var run in _testRuns)
            {
                var detail = await TestRunService.GetDetailedByIdAsync(run.Id);
                if (detail is not null)
                {
                    _testRunDetails.Add(detail);
                }
            }

            // Load test cases for display purposes
            // if (_testPlan is not null)
            // {
            //     var allTestCases = new List<TestCaseResponse>();
            //     foreach (var suite in _testPlan.TestSuites)
            //     {
            //         allTestCases.AddRange(suite.TestCases);
            //     }
            //     _testCases = allTestCases;
            // }
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task UpdateRunStatus(int runId, TestRunStatus status)
    {
        try
        {
            var request = new UpdateTestRunRequest
            {
                Status = status,
				ExecutedAt = DateTimeHelper.GetVietnamTime()
            };

            await TestRunService.UpdateAsync(runId, request);
            
            // Refresh data
            await LoadDataAsync();

            // Show success message
            if (status == TestRunStatus.Failed)
            {
                await ModalService.ShowWarningAsync(
                    "Test Failed",
                    "This test case has been marked as failed. Consider logging a bug report.",
                    showCancel: false
                );
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to update status: {ex.Message}";
        }
    }

    private void BackToOverview()
    {
        _activeRun = null;
    }

    private void BackToTestPlan()
    {
        Navigation.NavigateTo($"/projects/{ProjectId}/testplans");
    }

    private void ScrollToCase(int runId)
    {
        // Note: Blazor doesn't have built-in smooth scrolling to element
        // You might need to use JavaScript interop for this functionality
    }

    private string GetTestCaseTitle(int testCaseId)
    {
        var testCase = _testCases.FirstOrDefault(tc => tc.Id == testCaseId);
        return testCase?.Title ?? $"Test Case {testCaseId}";
    }

    private string GetTestCasePreconditions(int testCaseId)
    {
        var testCase = _testCases.FirstOrDefault(tc => tc.Id == testCaseId);
        return testCase?.Preconditions ?? "No preconditions";
    }

    private string GetOverallStatus()
    {
        var passedCount = _testRuns.Count(r => r.Status == TestRunStatus.Passed);
        var failedCount = _testRuns.Count(r => r.Status == TestRunStatus.Failed);
        
        if (failedCount > 0) return "Has Failures";
        if (passedCount == _testRuns.Count) return "Completed";
        return "In Progress";
    }

    private static string GetStatusBadgeClass(TestRunStatus status) => status switch
    {
        TestRunStatus.Passed => "bg-emerald-50/50",
        TestRunStatus.Failed => "bg-red-50/50",
        _ => "hover:bg-slate-50"
    };

    private static string GetStatusIconClass(TestRunStatus status) => status switch
    {
        TestRunStatus.Passed => "bg-emerald-500 text-white",
        TestRunStatus.Failed => "bg-red-500 text-white",
        _ => "bg-slate-100 text-slate-300"
    };

    private static string GetPassButtonClass(TestRunStatus status) => status == TestRunStatus.Passed
        ? "bg-emerald-500 text-white shadow-xl"
        : "bg-slate-50 text-emerald-600 hover:bg-emerald-100";

    private static string GetFailButtonClass(TestRunStatus status) => status == TestRunStatus.Failed
        ? "bg-red-500 text-white shadow-xl"
        : "bg-slate-50 text-red-600 hover:bg-red-100";
}



