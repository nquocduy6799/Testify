                 <div className="absolute bottom-0 left-0 w-full bg-[#7E96E1] transition-all duration-500" 
                      style={{ height: `${(activeRun.cases.filter(c => c.resultStatus !== 'Pending' && c.resultStatus !== 'Untested').length / activeRun.cases.length) * 100}%` }}></div>
