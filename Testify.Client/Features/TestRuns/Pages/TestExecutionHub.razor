        <div className="grid grid-cols-1 xl:grid-cols-4 gap-8">
           <div className="xl:col-span-1 space-y-4">
              <div className="bg-white rounded-[40px] border border-slate-100 p-6 shadow-sm overflow-hidden flex flex-col max-h-[700px]">
                 <p className="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-4 px-2">Worklist Pipeline</p>
                 <div className="flex-1 overflow-y-auto no-scrollbar space-y-2">
                    {activeRun.cases.map(c => (
                      <button key={c.id} className={`w-full flex items-center justify-between p-4 rounded-3xl transition-all ${
                        c.resultStatus === 'Passed' ? 'bg-emerald-50/50' : c.resultStatus === 'Failed' ? 'bg-red-50/50' : 'hover:bg-slate-50'
                      }`}>
                         <div className="flex items-center gap-3">
                            <div className={`w-8 h-8 rounded-xl flex items-center justify-center ${
                              c.resultStatus === 'Passed' ? 'bg-emerald-500 text-white' : c.resultStatus === 'Failed' ? 'bg-red-500 text-white' : 'bg-slate-100 text-slate-300'
                            }`}>
                               {c.resultStatus === 'Passed' ? <CheckCircle2 className="w-4 h-4" /> : c.resultStatus === 'Failed' ? <XCircle className="w-4 h-4" /> : <Clock className="w-4 h-4" />}
                            </div>
                            <div className="text-left">
                               <p className="text-[10px] font-black text-slate-800 line-clamp-1">{c.title}</p>
                               <p className="text-[8px] font-bold text-slate-400 uppercase">{c.id}</p>
                            </div>
                         </div>
                      </button>
                    ))}
                 </div>
              </div>
        </div>

        <div className="xl:col-span-3 space-y-8">
          {activeRun.cases.map(c => (
            <div key={c.id} className="bg-white rounded-[48px] p-10 border border-slate-100 shadow-sm">
               <div className="flex flex-col md:flex-row md:items-center justify-between gap-6 mb-10 border-b border-slate-50 pb-8">
                  <div>
                     <span className="text-[10px] font-black text-[#E85D3F] uppercase tracking-[0.2em] mb-2 block">Execution Active</span>
                     <h3 className="text-2xl font-black text-slate-800">{c.title}</h3>
                     <div className="flex items-center gap-3 mt-2">
                        <span className="text-xs font-medium text-slate-400 italic">"{c.preconditions || 'No preconditions'}"</span>
                     </div>
                  </div>
                  <div className="flex items-center gap-3">
                     <button onClick={() => updateCaseStatus(activeRun.id, c.id, 'Passed')} className={`px-8 py-4 rounded-2xl font-black text-xs uppercase transition-all flex items-center gap-2 ${c.resultStatus === 'Passed' ? 'bg-emerald-500 text-white shadow-xl' : 'bg-slate-50 text-emerald-600 hover:bg-emerald-100'}`}>
                        <CheckCircle2 className="w-4 h-4" /> Passed
                     </button>
                     <button onClick={() => updateCaseStatus(activeRun.id, c.id, 'Failed')} className={`px-8 py-4 rounded-2xl font-black text-xs uppercase transition-all flex items-center gap-2 ${c.resultStatus === 'Failed' ? 'bg-red-500 text-white shadow-xl' : 'bg-slate-50 text-red-600 hover:bg-red-100'}`}>
                        <XCircle className="w-4 h-4" /> Failed
                     </button>
                  </div>
               </div>

               {/* Granular Execution Steps */}
               <div className="space-y-4">
                  <div className="grid grid-cols-[60px_1fr_1fr_1fr] gap-4 px-4 py-2 border-b border-slate-50">
                     <span className="text-[9px] font-black text-slate-400 uppercase text-center">Step</span>
                     <span className="text-[9px] font-black text-slate-400 uppercase">Protocol</span>
                     <span className="text-[9px] font-black text-slate-400 uppercase">Input / Data</span>
                     <span className="text-[9px] font-black text-slate-400 uppercase">Target Outcome</span>
                  </div>
                  <div className="space-y-2">
                     {c.steps.map((step) => (
                       <div key={step.id} className="grid grid-cols-[60px_1fr_1fr_1fr] gap-4 p-6 bg-slate-50/50 rounded-[32px] border border-slate-100 group hover:bg-white hover:border-[#7E96E1]/20 transition-all">
                          <div className="flex items-center justify-center">
                             <div className="w-10 h-10 rounded-2xl bg-white flex items-center justify-center text-xs font-black text-slate-400 group-hover:bg-[#7E96E1] group-hover:text-white transition-all shadow-sm">
                                {step.stepNumber}
                             </div>
                          </div>
                          <div className="flex items-center">
                             <p className="text-sm font-bold text-slate-700 leading-relaxed">{step.action}</p>
                          </div>
                          <div className="flex items-center">
                             <code className="text-[11px] font-mono bg-white px-3 py-2 rounded-xl text-[#E85D3F] border border-slate-100 break-all">{step.testData || 'Default'}</code>
                          </div>
                          <div className="flex items-center gap-3">
                             <p className="text-sm font-medium text-emerald-600 italic flex-1">{step.expectedResult}</p>
                          </div>
                       </div>
                     ))}
                  </div>
               </div>

               <div className="mt-8 pt-8 border-t border-slate-50 flex items-center justify-between">
                  <div className="flex items-center gap-3">
                     <button className="flex items-center gap-2 text-[10px] font-black text-slate-400 uppercase hover:text-slate-800 transition-colors">
                        <MessageSquare className="w-3.5 h-3.5" /> Log Observation
                     </button>
                  </div>
                  {c.executedAt && <span className="text-[9px] font-bold text-slate-300 uppercase tracking-widest italic">Syncing result at {c.executedAt}</span>}
               </div>
            </div>
          ))}
        </div>
      </div>

      {failingCase && (
        <BugReportForm testCase={failingCase} onSave={(bugData) => { onAddBugToKanban(bugData); setFailingCase(null); }} onClose={() => setFailingCase(null)} />
      )}
    </div>
    );
  }

  return (
    <div className="space-y-8 animate-in fade-in slide-in-from-bottom-4 duration-500 pb-20">
       <div className="flex flex-col md:flex-row md:items-end justify-between gap-6">
          <div>
            <h2 className="text-3xl font-black text-slate-800 tracking-tight">Execution Hub</h2>
            <p className="text-slate-400 mt-2 font-medium">Coordinate and record granular manual verification cycles.</p>
          </div>
          <button onClick={startNewRun} className="bg-[#1C1D2A] text-white p-6 rounded-[32px] flex items-center gap-3 font-black shadow-lg hover:bg-slate-800 transition-all">
            <Play className="w-6 h-6" />
            <span>Launch Validation Protocol</span>
          </button>
       </div>

       <div className="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-8">
          {project.testRuns && project.testRuns.length > 0 ? project.testRuns.map(run => (
            <div key={run.id} onClick={() => setActiveExecutionId(run.id)} className="bg-white rounded-[40px] p-8 border border-slate-50 shadow-sm hover:shadow-xl transition-all group cursor-pointer flex flex-col h-full">
              <div className="flex justify-between items-start mb-6">
                <div>
                   <span className={`px-2.5 py-0.5 rounded-full text-[10px] font-extrabold uppercase tracking-wider ${run.status === 'Completed' ? 'bg-emerald-500 text-white' : 'bg-[#7E96E1] text-white'}`}>{run.status}</span>
                   <h3 className="text-xl font-black text-slate-800 mt-2">{run.name}</h3>
                </div>
                <Settings2 className="w-5 h-5 text-slate-300" />
              </div>
              <div className="mt-auto pt-6 border-t border-slate-50 flex items-center justify-between">
                 <span className="text-[10px] font-black text-slate-400 uppercase tracking-widest">{run.cases.length} Entities</span>
                 <div className="w-8 h-8 rounded-xl bg-slate-50 flex items-center justify-center text-slate-400 group-hover:bg-[#1C1D2A] group-hover:text-white transition-all">
                    <ArrowRight className="w-4 h-4" />
                 </div>
              </div>
            </div>
          )) : (
            <div className="col-span-full py-24 flex flex-col items-center justify-center bg-white/40 rounded-[48px] border-2 border-dashed border-slate-200">
              <Play className="w-10 h-10 text-slate-200 mb-6" />
              <h3 className="text-2xl font-black text-slate-800">Standby Mode</h3>
              <p className="text-slate-400 max-w-sm mt-2 font-medium">No active execution protocols initialized for this workspace.</p>
            </div>
          )}
       </div>
    </div>
  );
}; *@
