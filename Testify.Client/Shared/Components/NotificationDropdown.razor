@using Testify.Client.Interfaces
@using Testify.Shared.DTOs.Notifications
@using Testify.Shared.Enums
@inject INotificationService NotificationService

<div class="relative">
    @* Notification Bell Button *@
    <button @onclick="ToggleDropdown" class="relative rounded-xl border-none bg-transparent p-2.5 text-slate-500 transition-all hover:bg-white hover:shadow-md cursor-pointer">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/>
            <path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/>
        </svg>
        @if (UnreadCount > 0)
        {
            <span class="absolute top-1 right-1 flex h-5 w-5 items-center justify-center rounded-full bg-red-500 text-[10px] font-bold text-white">
                @(UnreadCount > 9 ? "9+" : UnreadCount.ToString())
            </span>
        }
    </button>

    @* Dropdown Panel *@
    @if (_isOpen)
    {
        <div class="animate-in fade-in slide-in-from-top-4 absolute right-0 z-50 mt-3 w-80 overflow-hidden rounded-3xl border border-slate-100 bg-white shadow-2xl ring-1 ring-black/5 duration-200">
            @* Header *@
            <div class="flex items-center justify-between border-b border-slate-100 bg-slate-50/50 px-5 py-4">
                <h3 class="text-sm font-bold text-slate-800">Notifications</h3>
                @if (UnreadCount > 0)
                {
                    <span class="rounded-full bg-[#E85D3F] px-2 py-0.5 text-[10px] font-bold text-white">
                        @UnreadCount new
                    </span>
                }
            </div>

            @* Notification List *@
            <div class="max-h-80 overflow-y-auto">
                @if (_isLoading)
                {
                    <div class="flex items-center justify-center p-8">
                        <div class="h-6 w-6 animate-spin rounded-full border-2 border-slate-200 border-t-[#E85D3F]"></div>
                    </div>
                }
                else if (!_notifications.Any())
                {
                    <div class="p-8 text-center">
                        <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="mx-auto mb-3 text-slate-300">
                            <path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/>
                            <path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/>
                        </svg>
                        <p class="text-sm text-slate-400">No notifications yet</p>
                    </div>
                }
                else
                {
                    @foreach (var notification in _notifications)
                    {
                        <div class="border-b border-slate-50 p-4 transition-colors hover:bg-slate-50/50 @(!notification.IsRead ? "bg-blue-50/30" : "")">
                            @* Notification Content *@
                            <div class="mb-2">
                                <p class="text-sm font-semibold text-slate-800">@notification.Title</p>
                                <p class="text-xs text-slate-500">@notification.Content</p>
                                <p class="mt-1 text-[10px] text-slate-400">@FormatTime(notification.CreatedAt)</p>
                            </div>

                            @* Invitation Actions *@
                            @if (notification.Type == NotificationType.ProjectInvitation && notification.InvitationStatus == InvitationStatus.Pending)
                            {
                                <div class="flex gap-2">
                                    <button @onclick="() => AcceptInvitation(notification.Id)"
                                            disabled="@_isProcessing"
                                            class="flex-1 rounded-xl bg-emerald-500 px-3 py-2 text-xs font-bold text-white transition-all hover:bg-emerald-600 disabled:opacity-50 cursor-pointer">
                                        Accept
                                    </button>
                                    <button @onclick="() => DeclineInvitation(notification.Id)"
                                            disabled="@_isProcessing"
                                            class="flex-1 rounded-xl bg-slate-200 px-3 py-2 text-xs font-bold text-slate-600 transition-all hover:bg-slate-300 disabled:opacity-50 cursor-pointer">
                                        Decline
                                    </button>
                                </div>
                            }
                            else if (notification.Type == NotificationType.ProjectInvitation)
                            {
                                <span class="inline-block rounded-full px-2 py-0.5 text-[10px] font-bold @GetStatusClass(notification.InvitationStatus)">
                                    @(notification.InvitationStatus == InvitationStatus.Accepted ? "Accepted" : "Declined")
                                </span>
                            }
                        </div>
                    }
                }
            </div>

            @* Footer *@
            @if (_notifications.Any())
            {
                <div class="border-t border-slate-100 bg-slate-50/20 p-3 text-center">
                    <a href="/notifications" class="text-xs font-semibold text-[#E85D3F] hover:underline">
                        View all notifications
                    </a>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<NotificationResponse> _notifications = new();
    private bool _isOpen = false;
    private bool _isLoading = false;
    private bool _isProcessing = false;

    private int UnreadCount => _notifications.Count(n => !n.IsRead);

    protected override async Task OnInitializedAsync()
    {
        await LoadNotifications();
    }

    private async Task LoadNotifications()
    {
        _isLoading = true;
        try
        {
            _notifications = await NotificationService.GetNotificationsAsync();
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void ToggleDropdown()
    {
        _isOpen = !_isOpen;
    }

    private async Task AcceptInvitation(long notificationId)
    {
        _isProcessing = true;
        try
        {
            var success = await NotificationService.AcceptInvitationAsync(notificationId);
            if (success)
            {
                await LoadNotifications();
            }
        }
        finally
        {
            _isProcessing = false;
        }
    }

    private async Task DeclineInvitation(long notificationId)
    {
        _isProcessing = true;
        try
        {
            var success = await NotificationService.DeclineInvitationAsync(notificationId);
            if (success)
            {
                await LoadNotifications();
            }
        }
        finally
        {
            _isProcessing = false;
        }
    }

    private static string FormatTime(DateTime dateTime)
    {
        var diff = DateTime.Now - dateTime;
        if (diff.TotalMinutes < 1) return "Just now";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours}h ago";
        if (diff.TotalDays < 7) return $"{(int)diff.TotalDays}d ago";
        return dateTime.ToString("MMM dd");
    }

    private static string GetStatusClass(InvitationStatus? status)
    {
        return status switch
        {
            InvitationStatus.Accepted => "bg-emerald-100 text-emerald-700",
            InvitationStatus.Declined => "bg-slate-100 text-slate-500",
            _ => "bg-amber-100 text-amber-700"
        };
    }

}
