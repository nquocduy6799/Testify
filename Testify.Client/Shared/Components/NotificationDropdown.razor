@using Testify.Client.Interfaces
@using Testify.Client.Services
@using Testify.Shared.DTOs.Notifications
@using Testify.Shared.Enums
@using Microsoft.AspNetCore.Components.Authorization
@inject INotificationService NotificationService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IServiceProvider ServiceProvider
@implements IAsyncDisposable

<style>
    @@keyframes wiggle {
        0%, 100% { transform: rotate(0deg); }
        25% { transform: rotate(-10deg); }
        50% { transform: rotate(10deg); }
        75% { transform: rotate(-5deg); }
    }
    
    @@keyframes slideDown {
        from {
            opacity: 0;
            transform: translateY(-10px) scale(0.95);
        }
        to {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
    }
    
    @@keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
    }
    
    @@keyframes bounceIn {
        0% {
            opacity: 0;
            transform: scale(0.3);
        }
        50% {
            opacity: 1;
            transform: scale(1.05);
        }
        70% {
            transform: scale(0.9);
        }
        100% {
            transform: scale(1);
        }
    }
    
    @@keyframes slideInRight {
        from {
            opacity: 0;
            transform: translateX(20px);
        }
        to {
            opacity: 1;
            transform: translateX(0);
        }
    }
    
    /* Custom scrollbar */
    .max-h-80::-webkit-scrollbar {
        width: 6px;
    }
    
    .max-h-80::-webkit-scrollbar-track {
        background: transparent;
    }
    
    .max-h-80::-webkit-scrollbar-thumb {
        background: rgba(203, 213, 225, 0.5);
        border-radius: 3px;
        transition: background 0.3s;
    }
    
    .max-h-80::-webkit-scrollbar-thumb:hover {
        background: rgba(148, 163, 184, 0.7);
    }
</style>

<div class="relative" tabindex="-1" @onkeydown="HandleKeyDown">
    @* Notification Bell Button *@
    <button @onclick="ToggleDropdown" 
            class="group relative rounded-xl border-none bg-transparent p-2.5 text-slate-500 transition-all duration-300 hover:scale-110 hover:bg-white hover:shadow-lg hover:text-[#E85D3F] cursor-pointer @(_isOpen ? "bg-white shadow-md text-[#E85D3F] scale-105" : "")">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" 
             class="transition-transform duration-300 @(UnreadCount > 0 ? "animate-[wiggle_0.5s_ease-in-out]" : "")">
            <path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/>
            <path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/>
        </svg>
        @if (UnreadCount > 0)
        {
            <span class="absolute -top-1 -right-1 flex h-5 w-5 items-center justify-center rounded-full bg-gradient-to-br from-red-500 to-red-600 text-[10px] font-bold text-white shadow-lg shadow-red-500/50 animate-[pulse_2s_ease-in-out_infinite]">
                @(UnreadCount > 9 ? "9+" : UnreadCount.ToString())
            </span>
            @* Ping effect *@
            <span class="absolute -top-1 -right-1 h-5 w-5 rounded-full bg-red-500 opacity-75 animate-ping"></span>
        }
    </button>

    @* Backdrop - Click outside to close *@
    @if (_isOpen)
    {
        <div class="fixed inset-0 z-40" @onclick="CloseDropdown"></div>
    }

    @* Dropdown Panel *@
    @if (_isOpen)
    {
        <div class="absolute right-0 z-50 mt-3 w-80 overflow-hidden rounded-3xl border border-slate-100 bg-white shadow-2xl ring-1 ring-black/5 animate-[slideDown_0.3s_ease-out,fadeIn_0.3s_ease-out] origin-top-right"
             @onclick:stopPropagation="true">
            @* Header *@
            <div class="flex items-center justify-between border-b border-slate-100 bg-gradient-to-r from-slate-50 to-slate-100/50 px-5 py-4 backdrop-blur-sm">
                <h3 class="text-sm font-bold text-slate-800 animate-[fadeIn_0.5s_ease-out]">Notifications</h3>
                @if (UnreadCount > 0)
                {
                    <span class="rounded-full bg-gradient-to-r from-[#E85D3F] to-[#d54e32] px-2.5 py-1 text-[10px] font-bold text-white shadow-lg shadow-[#E85D3F]/30 animate-[bounceIn_0.5s_ease-out]">
                        @UnreadCount new
                    </span>
                }
            </div>

            @* Notification List *@
            <div class="max-h-80 overflow-y-auto scroll-smooth">
                @if (_isLoading)
                {
                    <div class="flex flex-col items-center justify-center gap-3 p-8">
                        <div class="relative">
                            <div class="h-8 w-8 animate-spin rounded-full border-3 border-slate-200 border-t-[#E85D3F]"></div>
                            <div class="absolute inset-0 h-8 w-8 animate-ping rounded-full border-2 border-[#E85D3F] opacity-20"></div>
                        </div>
                        <p class="text-xs text-slate-400 animate-pulse">Loading notifications...</p>
                    </div>
                }
                else if (!_notifications.Any())
                {
                    <div class="p-8 text-center animate-[fadeIn_0.6s_ease-out]">
                        <div class="relative inline-block">
                            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" 
                                 class="mx-auto mb-3 text-slate-300 animate-[bounce_3s_ease-in-out_infinite]">
                                <path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/>
                                <path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/>
                            </svg>
                            <div class="absolute -top-1 -right-1 h-3 w-3 rounded-full bg-slate-200 animate-ping"></div>
                        </div>
                        <p class="text-sm font-medium text-slate-500">No notifications yet</p>
                        <p class="mt-1 text-xs text-slate-400">We'll notify you when something happens</p>
                    </div>
                }
                else
                {
                    var index = 0;
                    @foreach (var notification in _notifications)
                    {
                        var delay = index * 50;
                        <div class="group border-b border-slate-50 p-4 transition-all duration-300 hover:bg-gradient-to-r hover:from-slate-50 hover:to-transparent hover:shadow-sm @(!notification.IsRead ? "bg-gradient-to-r from-blue-50/40 to-transparent border-l-2 border-l-[#E85D3F]" : "")"
                             style="animation: slideInRight 0.4s ease-out @(delay)ms backwards;">
                            @* Notification Content *@
                            <div class="mb-2">
                                <p class="text-sm font-semibold text-slate-800">@notification.Title</p>
                                <p class="text-xs text-slate-500">@((MarkupString)(notification.Content ?? ""))</p>
                                <p class="mt-1 text-[10px] text-slate-400">@FormatTime(notification.CreatedAt)</p>
                            </div>

                            @* Invitation Actions *@
                            @if (notification.Type == NotificationType.ProjectInvitation && notification.InvitationStatus == InvitationStatus.Pending)
                            {
                                <div class="flex gap-2">
                                    <button @onclick="() => AcceptInvitation(notification.Id)"
                                            disabled="@_isProcessing"
                                            class="flex-1 rounded-xl bg-gradient-to-r from-emerald-500 to-emerald-600 px-3 py-2.5 text-xs font-bold text-white shadow-lg shadow-emerald-500/30 transition-all duration-300 hover:scale-105 hover:shadow-xl hover:shadow-emerald-500/40 active:scale-95 disabled:opacity-50 disabled:cursor-not-allowed cursor-pointer">
                                        <span class="flex items-center justify-center gap-1">
                                            @if (_isProcessing)
                                            {
                                                <svg class="h-3 w-3 animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                                                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                                                </svg>
                                            }
                                            <span>Accept</span>
                                        </span>
                                    </button>
                                    <button @onclick="() => DeclineInvitation(notification.Id)"
                                            disabled="@_isProcessing"
                                            class="flex-1 rounded-xl border-2 border-slate-200 bg-white px-3 py-2.5 text-xs font-bold text-slate-600 transition-all duration-300 hover:scale-105 hover:border-slate-300 hover:bg-slate-50 hover:shadow-md active:scale-95 disabled:opacity-50 disabled:cursor-not-allowed cursor-pointer">
                                        Decline
                                    </button>
                                </div>
                            }
                            else if (notification.Type == NotificationType.ProjectInvitation)
                            {
                                <span class="inline-flex items-center gap-1 rounded-full px-2.5 py-1 text-[10px] font-bold @GetStatusClass(notification.InvitationStatus) animate-[fadeIn_0.5s_ease-out]">
                                    @if (notification.InvitationStatus == InvitationStatus.Accepted)
                                    {
                                        <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                                        </svg>
                                        <span>Accepted</span>
                                    }
                                    else
                                    {
                                        <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                                        </svg>
                                        <span>Declined</span>
                                    }
                                </span>
                            }
                        </div>
                        index++;
                    }
                }
            </div>

            @* Footer *@
            @if (_notifications.Any())
            {
                <div class="border-t border-slate-100 bg-gradient-to-r from-slate-50/50 to-transparent p-3 text-center backdrop-blur-sm">
                    <a href="/notifications" 
                       @onclick="CloseDropdown"
                       class="group inline-flex items-center gap-2 text-xs font-bold text-[#E85D3F] transition-all duration-300 hover:gap-3 hover:text-[#d54e32]">
                        <span>View all notifications</span>
                        <svg class="h-3 w-3 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                        </svg>
                    </a>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<NotificationResponse> _notifications = new();
    private bool _isOpen = false;
    private bool _isLoading = false;
    private bool _isProcessing = false;
    private NotificationHubService? _hubService;

    private int UnreadCount => _notifications.Count(n => !n.IsRead);

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            Console.WriteLine($"[NotificationDropdown] User authenticated: {user.Identity?.IsAuthenticated}");
            Console.WriteLine($"[NotificationDropdown] User name: {user.Identity?.Name}");
            
            if (user.Identity?.IsAuthenticated == true)
            {
                await LoadNotifications();
            }
            else
            {
                Console.WriteLine("[NotificationDropdown] User not authenticated, skipping load");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[NotificationDropdown] OnInitializedAsync error: {ex.Message}");
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Try to get HubService (only available in WebAssembly mode)
            _hubService = ServiceProvider.GetService<NotificationHubService>();
            
            if (_hubService != null)
            {
                Console.WriteLine("[NotificationDropdown] Running in WebAssembly mode, setting up SignalR");
                var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
                if (authState.User.Identity?.IsAuthenticated == true)
                {
                    await SetupSignalR();
                }
            }
            else
            {
                Console.WriteLine("[NotificationDropdown] Running in Server mode, SignalR not available");
            }
        }
    }

    private async Task SetupSignalR()
    {
        if (_hubService == null)
        {
            return;
        }

        try
        {
            // Subscribe to notification events
            _hubService.OnNotificationReceived += HandleNewNotification;
            _hubService.OnReconnected += async () => await LoadNotifications();
            
            // Start SignalR connection
            await _hubService.StartAsync();
            Console.WriteLine("[NotificationDropdown] SignalR connected");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[NotificationDropdown] SignalR setup error: {ex.Message}");
        }
    }

    private void HandleNewNotification(NotificationResponse notification)
    {
        Console.WriteLine($"[NotificationDropdown] New notification received: {notification.Title}");
        
        // Add to list at the beginning
        _notifications.Insert(0, notification);
        
        // Trigger UI update
        InvokeAsync(StateHasChanged);
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            // Setup keyboard listener for ESC key
            SetupKeyboardListener();
        }
    }

    private void SetupKeyboardListener()
    {
        // Listen for ESC key globally
        // Note: In production, you might want to use JS Interop for better keyboard handling
    }

    private void HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape" && _isOpen)
        {
            CloseDropdown();
        }
    }

    private async Task LoadNotifications()
    {
        _isLoading = true;
        try
        {
            Console.WriteLine("[NotificationDropdown] Starting to load notifications...");
            _notifications = await NotificationService.GetNotificationsAsync();
            Console.WriteLine($"[NotificationDropdown] Loaded {_notifications.Count} notifications");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[NotificationDropdown] Error: {ex.Message}");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void ToggleDropdown()
    {
        _isOpen = !_isOpen;
    }

    private void CloseDropdown()
    {
        _isOpen = false;
    }

    private async Task AcceptInvitation(long notificationId)
    {
        _isProcessing = true;
        try
        {
            var success = await NotificationService.AcceptInvitationAsync(notificationId);
            if (success)
            {
                await LoadNotifications();
                // Đóng dropdown sau khi accept thành công
                await Task.Delay(500); // Delay nhẹ để user thấy animation
                CloseDropdown();
            }
        }
        finally
        {
            _isProcessing = false;
        }
    }

    private async Task DeclineInvitation(long notificationId)
    {
        _isProcessing = true;
        try
        {
            var success = await NotificationService.DeclineInvitationAsync(notificationId);
            if (success)
            {
                await LoadNotifications();
                // Đóng dropdown sau khi decline thành công
                await Task.Delay(500); // Delay nhẹ để user thấy animation
                CloseDropdown();
            }
        }
        finally
        {
            _isProcessing = false;
        }
    }

    private static string FormatTime(DateTime dateTime)
    {
        var diff = DateTime.Now - dateTime;
        if (diff.TotalMinutes < 1) return "Just now";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours}h ago";
        if (diff.TotalDays < 7) return $"{(int)diff.TotalDays}d ago";
        return dateTime.ToString("MMM dd");
    }

    private static string GetStatusClass(InvitationStatus? status)
    {
        return status switch
        {
            InvitationStatus.Accepted => "bg-emerald-100 text-emerald-700",
            InvitationStatus.Declined => "bg-slate-100 text-slate-500",
            _ => "bg-amber-100 text-amber-700"
        };
    }

    public async ValueTask DisposeAsync()
    {
        if (_hubService != null)
        {
            // Unsubscribe from events
            _hubService.OnNotificationReceived -= HandleNewNotification;
            
            // Stop SignalR connection
            await _hubService.StopAsync();
            Console.WriteLine("[NotificationDropdown] SignalR disconnected");
        }
    }

}
