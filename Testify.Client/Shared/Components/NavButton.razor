@inject NavigationManager Navigation

<button 
    class="@GetButtonClasses()" 
    @onclick="HandleClick">
    <LucideIcon Name="@Icon" Class="h-4 w-4" />
    @Label
</button>

@code {
    [Parameter, EditorRequired] public string Icon { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string Label { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string Route { get; set; } = string.Empty;
    [Parameter] public bool IsActive { get; set; }

    private string GetButtonClasses()
    {
        var baseClasses = "flex items-center gap-2 px-6 py-3 rounded-3xl text-sm font-black transition-all whitespace-nowrap";
        
        if (IsActive)
        {
            return $"{baseClasses} bg-[#1C1D2A] text-white shadow-lg";
        }
        
        return $"{baseClasses} text-slate-400 hover:text-slate-600 hover:bg-white";
    }

    private void HandleClick()
    {
        Navigation.NavigateTo(Route);
    }
}