@using Testify.Shared.Enums
@if (isVisible)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/50 backdrop-blur-sm"
         @onclick="HandleBackdropClick">
        <div class="animate-in fade-in zoom-in w-full max-w-md rounded-3xl bg-white p-6 shadow-2xl duration-200"
             @onclick:stopPropagation="true">

            @* Icon *@
            <div class="mb-4 flex justify-center">
                <div class="rounded-full @GetIconBgColor() p-3">
                    @if (Type == ConfirmDialogType.Danger)
                    {
                        <svg class="h-6 w-6 @GetIconColor()" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                        </svg>
                    }
                    else if (Type == ConfirmDialogType.Warning)
                    {
                        <svg class="h-6 w-6 @GetIconColor()" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                    }
                    else
                    {
                        <svg class="h-6 w-6 @GetIconColor()" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                    }
                </div>
            </div>

            @* Title *@
            <h3 class="mb-2 text-center text-xl font-bold text-slate-800">
                @Title
            </h3>

            @* Message *@
            <p class="mb-6 text-center text-sm text-slate-600">
                @Message
            </p>

            @* Actions *@
            <div class="flex gap-3">
                <button @onclick="HandleCancel"
                        class="flex-1 rounded-xl border-2 border-slate-200 bg-white px-4 py-2.5 font-bold text-slate-600 transition-all hover:border-slate-300 hover:bg-slate-50">
                    @CancelText
                </button>
                <button @onclick="HandleConfirm"
                        class="flex-1 rounded-xl px-4 py-2.5 font-bold text-white transition-all @GetConfirmButtonClass()">
                    @ConfirmText
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string Title { get; set; } = "Are you sure?";
    [Parameter] public string Message { get; set; } = "This action cannot be undone.";
    [Parameter] public string ConfirmText { get; set; } = "Confirm";
    [Parameter] public string CancelText { get; set; } = "Cancel";
    [Parameter] public ConfirmDialogType Type { get; set; } = ConfirmDialogType.Danger;
    [Parameter] public EventCallback OnConfirm { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    private bool isVisible = false;

    public void Show()
    {
        isVisible = true;
        StateHasChanged();
    }

    public void Hide()
    {
        isVisible = false;
        StateHasChanged();
    }

    private async Task HandleConfirm()
    {
        Hide();
        await OnConfirm.InvokeAsync();
    }

    private async Task HandleCancel()
    {
        Hide();
        await OnCancel.InvokeAsync();
    }

    private void HandleBackdropClick()
    {
        HandleCancel();
    }

    private string GetIconBgColor() => Type switch
    {
        ConfirmDialogType.Danger => "bg-red-100",
        ConfirmDialogType.Warning => "bg-yellow-100",
        ConfirmDialogType.Info => "bg-blue-100",
        _ => "bg-slate-100"
    };

    private string GetIconColor() => Type switch
    {
        ConfirmDialogType.Danger => "text-red-600",
        ConfirmDialogType.Warning => "text-yellow-600",
        ConfirmDialogType.Info => "text-blue-600",
        _ => "text-slate-600"
    };

    private string GetConfirmButtonClass() => Type switch
    {
        ConfirmDialogType.Danger => "bg-red-500 hover:bg-red-600",
        ConfirmDialogType.Warning => "bg-yellow-500 hover:bg-yellow-600",
        ConfirmDialogType.Info => "bg-blue-500 hover:bg-blue-600",
        _ => "bg-slate-500 hover:bg-slate-600"
    };
}