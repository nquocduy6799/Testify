@inject NavigationManager Navigation

<div class="no-scrollbar mb-8 flex w-fit max-w-full items-center gap-2 overflow-x-auto rounded-[32px] border border-white bg-white/60 p-1.5 shadow-sm">
    <NavButton 
        Icon="layout-dashboard" 
        Label="Overview" 
        Route="@GetRoute("overview")" 
        IsActive="@IsActiveRoute("overview")" />
    
    <NavButton 
        Icon="trello" 
        Label="Kanban Board" 
        Route="@GetRoute("kanban")" 
        IsActive="@IsActiveRoute("kanban")" />
    
    <NavButton 
        Icon="flag" 
        Label="Milestones" 
        Route="@GetRoute("milestones")" 
        IsActive="@IsActiveRoute("milestones")" />
    
    <NavButton 
        Icon="users" 
        Label="Team Members" 
        Route="@GetRoute("team")" 
        IsActive="@IsActiveRoute("team")" />
</div>

@code {
    [Parameter] public int ProjectId { get; set; }

    [CascadingParameter] public string? CurrentSection { get; set; }

    private string GetRoute(string section)
    {
        return section.ToLower() switch
        {
            "overview" => $"/projects/{ProjectId}/pm",
            "kanban" => $"/projects/{ProjectId}/pm/kanban",
            "milestones" => $"/projects/{ProjectId}/pm/milestones",
            "team" => $"/projects/{ProjectId}/pm/team",
            _ => $"/projects/{ProjectId}/pm"
        };
    }

    private bool IsActiveRoute(string section)
    {
        var currentUri = Navigation.Uri;
        var expectedRoute = GetRoute(section);
        
        // If overview, check if we're at the base PM route
        if (section == "overview")
        {
            return currentUri.EndsWith($"/projects/{ProjectId}/pm", StringComparison.OrdinalIgnoreCase);
        }
        
        return currentUri.Contains(section, StringComparison.OrdinalIgnoreCase);
    }
}