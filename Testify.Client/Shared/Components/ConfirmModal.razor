@using Testify.Client.Shared.Services
@inject ModalService ModalService

@if (IsVisible)
{
    @* Backdrop with Blur *@
    <div class="fixed inset-0 z-[300] flex items-center justify-center p-6">
        <div class="animate-in fade-in absolute inset-0 bg-[#0F111A]/80 backdrop-blur-xl duration-500"
             @onclick="Cancel"></div>

        @* Modal Container *@
        <div class="animate-in zoom-in-95 relative flex w-full max-w-lg flex-col overflow-hidden rounded-[48px] border border-slate-100 bg-white shadow-[0_30px_100px_rgba(0,0,0,0.4)] duration-300">
            <div class="space-y-8 p-12 text-center">
                @* Heroicon Branding: ShieldExclamation & Trash *@
                <div class="relative inline-block">
                    <div class="mx-auto flex h-24 w-24 items-center justify-center rounded-[40px] bg-red-50 ring-8 ring-red-50/50">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"
                             class="h-12 w-12 animate-pulse text-red-500">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z" />
                        </svg>
                    </div>
                    <div class="absolute -top-2 -right-2 flex h-8 w-8 items-center justify-center rounded-2xl border-4 border-white bg-red-500 text-white shadow-lg">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="h-4 w-4">
                            <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
                        </svg>
                    </div>
                </div>

                @* Typography Section *@
                <div class="space-y-3">
                    <h2 class="text-3xl leading-none font-black tracking-tight text-slate-800 uppercase">@Title</h2>
                    <p class="font-black tracking-[0.3em] text-[10px] text-red-500 uppercase">Critical Action Required</p>
                </div>

                @* Message Box *@
                <div class="space-y-4 rounded-[32px] border border-slate-100 bg-slate-50/50 p-8 text-left">
                    <p class="text-sm leading-relaxed font-medium text-slate-500">
                        @((MarkupString)Message)
                    </p>
                    <div class="flex items-center gap-3 pt-2">
                        <div class="rounded-lg border border-slate-200 bg-white px-3 py-1 font-bold text-[10px] text-slate-400 uppercase">Status: Pending Purge</div>
                        <div class="rounded-lg border border-slate-200 bg-white px-3 py-1 font-bold text-[10px] text-slate-400 uppercase">Integrity: Shielded</div>
                    </div>
                </div>

                @* Action Buttons *@
                <div class="flex flex-col gap-3">
                    <button @onclick="Confirm"
                            class="group relative flex w-full items-center justify-center gap-3 overflow-hidden rounded-[24px] bg-red-600 py-6 text-xs font-black tracking-[0.2em] text-white uppercase shadow-2xl shadow-red-200 transition-all hover:bg-red-700 active:scale-95">
                        <span class="relative z-10">Permanently Erase Entity</span>
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"
                             class="relative z-10 h-4 w-4 transition-transform group-hover:translate-x-1">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
                        </svg>
                        @* Shimmer Effect *@
                        <div class="absolute inset-0 -translate-x-full bg-gradient-to-r from-transparent via-white/10 to-transparent transition-transform duration-1000 group-hover:translate-x-full"></div>
                    </button>

                    <button @onclick="Cancel"
                            class="w-full bg-white py-5 font-black tracking-[0.2em] text-slate-400 text-[10px] uppercase transition-colors hover:text-slate-800">
                        Abort and Maintain Integrity
                    </button>
                </div>
            </div>

            @* Close Button (Heroicon X-Mark) *@
            <button @onclick="Cancel"
                    class="absolute top-8 right-8 p-2 text-slate-300 transition-colors hover:text-slate-600">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-6 w-6">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
                </svg>
            </button>
        </div>
    </div>
}

@code {
    private bool IsVisible;
    private string Title = "Confirm Decommission";
    private string Message = "This operation will permanently decommission the entity and sever all synchronized traceability links.";
    private TaskCompletionSource<bool> _tcs;

    protected override void OnInitialized()
    {
        ModalService.OnShow += ShowModal;
    }

    private Task<bool> ShowModal(string title, string message)
    {
        Title = title;
        Message = message;
        IsVisible = true;
        _tcs = new TaskCompletionSource<bool>();
        StateHasChanged();
        return _tcs.Task;
    }

    private void Confirm()
    {
        IsVisible = false;
        _tcs.SetResult(true);
    }

    private void Cancel()
    {
        IsVisible = false;
        _tcs.SetResult(false);
    }
}