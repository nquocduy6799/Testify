@using Testify.Client.Shared.Services
@using Testify.Shared.Models
@inject ModalService ModalService

@if (isVisible)
{
    // Backdrop with Blur and Animation
    <div class="fixed inset-0 z-[300] flex items-center justify-center p-6">
        <div class="animate-in fade-in absolute inset-0 bg-[#0F111A]/80 backdrop-blur-xl duration-500"
             @onclick="HandleBackdropClick">
        </div>

        <div class="animate-in zoom-in-95 relative flex w-full max-w-lg flex-col overflow-hidden rounded-[48px] border border-slate-100 bg-white shadow-[0_30px_100px_rgba(0,0,0,0.4)] duration-300"
             @onclick:stopPropagation="true">
            
            <div class="h-2 bg-gradient-to-r @GetGradientClass()"></div>

            @if (options?.ShowCloseButton ?? true)
            {
                <button type="button"
                        class="absolute top-8 right-8 z-20 p-2 text-slate-300 transition-colors hover:text-slate-600"
                        aria-label="Close"
                        @onclick="() => Cancel()">
                    <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                </button>
            }

            <div class="space-y-8 p-12 text-center">
                
                <div class="relative inline-block">
                    <div class="ring-opacity-50 mx-auto @GetIconBgClass() flex h-24 w-24 items-center justify-center rounded-[40px] ring-8 @GetRingClass()">
                        @if (!string.IsNullOrEmpty(options?.Icon))
                        {
                            <svg class="h-12 w-12 @GetIconTextClass() animate-pulse"
                                 fill="none"
                                 viewBox="0 0 24 24"
                                 stroke-width="1.5"
                                 stroke="currentColor"
                                 aria-hidden="true">
                                <path stroke-linecap="round" stroke-linejoin="round" d="@options.Icon" />
                            </svg>
                        }
                        else
                        {
                            <span class="text-4xl font-bold @GetIconTextClass()">!</span>
                        }
                    </div>
                </div>

                <div class="space-y-3">
                    <h2 class="text-3xl leading-none font-black tracking-tight text-slate-800 uppercase">
                        @title
                    </h2>
                    <p class="font-black tracking-[0.3em] @GetIconTextClass() text-[10px] uppercase">
                        Action Required
                    </p>
                </div>

                <div class="space-y-4 rounded-[32px] border border-slate-100 bg-slate-50/50 p-8 text-left">
                    <p class="text-sm leading-relaxed font-medium text-slate-500">
                        @message
                    </p>
                </div>

                <div class="flex flex-col gap-3">
                    @RenderButtonsFragment
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool isVisible = false;
    private string title = string.Empty;
    private string message = string.Empty;
    private ModalOptions? options;
    private TaskCompletionSource<ModalResult>? taskCompletionSource;

    protected override void OnInitialized()
    {
        ModalService.OnShow += Show;
    }

    private async Task<ModalResult> Show(ModalOptions opts)
    {
        options = opts;
        title = opts.Title;
        message = opts.Message;
        isVisible = true;
        taskCompletionSource = new TaskCompletionSource<ModalResult>();
        StateHasChanged();

        return await taskCompletionSource.Task;
    }

    private void HandleBackdropClick()
    {
        if (options?.AllowBackdropClick ?? true)
        {
            Cancel();
        }
    }

    private void Confirm(ModalResultType resultType = ModalResultType.Yes)
    {
        isVisible = false;
        taskCompletionSource?.SetResult(new ModalResult
        {
            Confirmed = true,
            ResultType = resultType
        });
        StateHasChanged();
    }

    private void Cancel(ModalResultType resultType = ModalResultType.Cancel)
    {
        isVisible = false;
        taskCompletionSource?.SetResult(new ModalResult
        {
            Confirmed = false,
            ResultType = resultType
        });
        StateHasChanged();
    }

    private RenderFragment RenderButtonsFragment => __builder =>
    {
        var buttonType = options?.Buttons ?? ModalButton.OK;

        switch (buttonType)
        {
            case ModalButton.OK:
                <button type="button"
                        class="@GetPrimaryButtonClass()"
                        @onclick="() => Confirm(ModalResultType.OK)">
                    <span class="relative z-10">OK</span>
                </button>
                break;

            case ModalButton.OKCancel:
            case ModalButton.YesNo:
                var confirmText = options?.ConfirmButtonText ?? (buttonType == ModalButton.YesNo ? "Yes" : "OK");
                var cancelText = options?.CancelButtonText ?? (buttonType == ModalButton.YesNo ? "No" : "Cancel");
                var cancelResult = buttonType == ModalButton.YesNo ? ModalResultType.No : ModalResultType.Cancel;
                var confirmResult = buttonType == ModalButton.YesNo ? ModalResultType.Yes : ModalResultType.OK;

                // Primary Action (Stacked Top)
                <button type="button"
                        class="@GetPrimaryButtonClass()"
                        @onclick="() => Confirm(confirmResult)">
                    <span class="relative z-10">@confirmText</span>
                    <div class="absolute inset-0 -translate-x-full bg-gradient-to-r from-transparent via-white/10 to-transparent transition-transform duration-1000 group-hover:translate-x-full"></div>
                </button>

                // Secondary Action (Stacked Bottom)
                <button type="button"
                        class="w-full bg-white py-5 font-black tracking-[0.2em] text-slate-400 text-[10px] uppercase transition-colors hover:text-slate-800"
                        @onclick="() => Cancel(cancelResult)">
                    @cancelText
                </button>
                break;
        }
    };

    // --- Dynamic Styling Helpers based on ModalType ---

    private string GetGradientClass() => options?.Type switch
    {
        ModalType.Success => "from-green-600 via-emerald-500 to-green-600",
        ModalType.Warning => "from-amber-500 via-yellow-400 to-amber-500",
        ModalType.Error => "from-red-600 via-orange-500 to-red-600",
        ModalType.Info => "from-blue-600 via-cyan-500 to-blue-600",
        _ => "from-slate-600 via-gray-500 to-slate-600"
    };

    private string GetIconBgClass() => options?.Type switch
    {
        ModalType.Success => "bg-green-50",
        ModalType.Warning => "bg-yellow-50",
        ModalType.Error => "bg-red-50",
        ModalType.Info => "bg-blue-50",
        _ => "bg-slate-50"
    };

    private string GetRingClass() => options?.Type switch
    {
        ModalType.Success => "ring-green-50/50",
        ModalType.Warning => "ring-yellow-50/50",
        ModalType.Error => "ring-red-50/50",
        ModalType.Info => "ring-blue-50/50",
        _ => "ring-slate-50/50"
    };

    private string GetIconTextClass() => options?.Type switch
    {
        ModalType.Success => "text-green-500",
        ModalType.Warning => "text-yellow-500",
        ModalType.Error => "text-red-500",
        ModalType.Info => "text-blue-500",
        _ => "text-slate-500"
    };

    private string GetPrimaryButtonClass()
    {
        var baseClass = "group relative w-full py-6 text-white rounded-[24px] font-black text-xs uppercase tracking-[0.2em] shadow-2xl overflow-hidden transition-all active:scale-95 flex items-center justify-center gap-3";
        
        var colorClass = options?.Type switch
        {
            ModalType.Success => "bg-green-600 shadow-green-200 hover:bg-green-700",
            ModalType.Warning => "bg-amber-500 shadow-yellow-200 hover:bg-amber-600",
            ModalType.Error => "bg-red-600 shadow-red-200 hover:bg-red-700",
            ModalType.Info => "bg-blue-600 shadow-blue-200 hover:bg-blue-700",
            _ => "bg-slate-800 shadow-slate-200 hover:bg-slate-900"
        };

        return $"{baseClass} {colorClass}";
    }

    public void Dispose()
    {
        ModalService.OnShow -= Show;
    }
}