@page "/marketplace"
@using Blazicons
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using System.Security.Claims
@using Testify.Data
@using Testify.Entities
@rendermode InteractiveServer
@inject ApplicationDbContext DbContext
@inject IJSRuntime JSRuntime
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Marketplace - Testify</PageTitle>

<div class="w-full mx-auto px-10 space-y-12 pb-32 animate-in fade-in slide-in-from-bottom-4 duration-700">

    @* ══════ Hero Marketplace Header ══════ *@
    <div class="bg-[#1C1D2A] rounded-[48px] p-12 text-white relative overflow-hidden shadow-2xl flex flex-col md:flex-row items-center justify-between gap-10">
        <div class="relative z-10 space-y-6 flex-1">
            <div class="inline-flex items-center gap-2 px-4 py-1.5 bg-white/5 backdrop-blur-md border border-white/10 rounded-full text-[#E85D3F] text-[10px] font-black uppercase tracking-[0.3em]">
                <span style="font-size:14px;"><Blazicon Svg="@Lucide.Sparkles" /></span>
                Neural Blueprint Exchange
            </div>
            <h1 class="text-5xl lg:text-7xl font-black tracking-tighter leading-none">
                The Global <br />
                <span class="text-[#E85D3F]">Quality</span> Registry.
            </h1>
            <p class="text-slate-400 text-lg font-medium max-w-xl">
                Browse, sync, and deploy industry-standard test architectures directly to your workspace. Powered by community intelligence.
            </p>
            <div class="flex gap-4">
                <button @onclick='() => Navigation.NavigateTo("/test-templates/suite-library")' class="bg-white text-[#1C1D2A] px-10 py-5 rounded-[24px] font-black text-xs uppercase tracking-widest hover:scale-105 transition-all shadow-xl shadow-white/5">
                    Publish Your Logic
                </button>
                <div class="flex items-center gap-6 pl-6 border-l border-white/10">
                    <div>
                        <p class="text-2xl font-black">@totalClones</p>
                        <p class="text-[10px] font-black text-slate-500 uppercase tracking-widest">Global Clones</p>
                    </div>
                    <div>
                        <p class="text-2xl font-black">@totalAuthors</p>
                        <p class="text-[10px] font-black text-slate-500 uppercase tracking-widest">Verified Authors</p>
                    </div>
                </div>
            </div>
        </div>

        @* Abstract Neural Globe Visual *@
        <div class="hidden md:flex relative w-80 h-80 items-center justify-center flex-shrink-0 z-10">
            <div class="w-full h-full rounded-full border-4 border-dashed border-[#E85D3F]/20 animate-[spin_60s_linear_infinite] absolute"></div>
            <div class="w-[80%] h-[80%] rounded-full border-2 border-dashed border-[#7E96E1]/20 animate-[spin_40s_linear_infinite_reverse] absolute"></div>
            <div class="relative">
                <span class="text-[#E85D3F]" style="font-size:96px;"><Blazicon Svg="@Lucide.ShoppingBag" /></span>
                <div class="absolute inset-0 blur-3xl opacity-30 bg-[#E85D3F] animate-pulse"></div>
            </div>
        </div>

        <div class="absolute -bottom-24 -right-24 w-96 h-96 bg-[#E85D3F] rounded-full blur-[150px] opacity-10"></div>
        <div class="absolute top-0 left-1/2 w-96 h-96 bg-[#7E96E1] rounded-full blur-[150px] opacity-5"></div>
    </div>

    @* ══════ Discovery Controls ══════ *@
    <div class="flex flex-nowrap items-center justify-between gap-6">
        <div class="relative group flex-shrink-0" style="width:300px;">
            <span class="absolute left-3.5 top-1/2 -translate-y-1/2 text-slate-300 group-focus-within:text-[#E85D3F] transition-colors">
                <Blazicon Svg="@Lucide.Search" Size="16px" />
            </span>
            <input type="text"
                   placeholder="Search blueprints..."
                   @bind="searchQuery"
                   @bind:event="oninput"
                   class="w-full pl-10 pr-4 py-2.5 bg-white border border-slate-200 rounded-full shadow-sm text-xs text-slate-600 placeholder:text-slate-300 font-medium outline-none focus:ring-4 focus:ring-[#E85D3F]/10 focus:border-[#E85D3F]/40 transition-all" />
        </div>

        <div class="flex items-center gap-0.5 bg-slate-50 border border-slate-200 p-0.5 rounded-full flex-shrink-0">
            @foreach (var cat in categories)
            {
                <button @onclick="() => selectedCategory = cat"
                        class="@($"px-5 py-1.5 rounded-full text-[10px] font-black uppercase tracking-wider transition-all whitespace-nowrap {(selectedCategory == cat ? "bg-[#1C1D2A] text-white shadow-md" : "text-slate-500 hover:text-slate-700")}")">
                    @cat
                </button>
            }
        </div>
    </div>

    @* ══════ Grid Content ══════ *@
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-8">
        @foreach (var item in FilteredItems)
        {
            <div class="bg-white rounded-[48px] p-10 border border-slate-50 shadow-sm hover:shadow-2xl transition-all group flex flex-col h-full relative overflow-hidden">
                @* Categories & Stats Row *@
                <div class="flex justify-between items-start mb-8">
                    <div class="flex flex-wrap gap-2">
                        <span class="px-3 py-1 bg-slate-50 text-slate-500 rounded-lg text-[9px] font-black uppercase tracking-widest">@item.CategoryName</span>
                        @if (item.IsVerified)
                        {
                            <div class="flex items-center gap-1 px-3 py-1 bg-emerald-50 text-emerald-600 rounded-lg text-[9px] font-black uppercase tracking-widest border border-emerald-100">
                                <span style="font-size:12px;"><Blazicon Svg="@Lucide.ShieldCheck" /></span>
                                Verified
                            </div>
                        }
                    </div>
                    <button @onclick="() => ToggleStar(item)" class="flex items-center gap-1.5 px-2 py-1 rounded-xl hover:bg-amber-50 transition-all group">
                        <span class="@(_userStarredIds.Contains(item.Id) ? "text-amber-400" : "text-slate-300 group-hover:text-amber-400")" style="font-size:16px;"><Blazicon Svg="@Lucide.Star" /></span>
                        <span class="text-xs font-black text-slate-800">@item.Stars</span>
                    </button>
                </div>

                @* Title & Description *@
                <div class="space-y-4 flex-1">
                    <h3 class="text-2xl font-black text-slate-800 group-hover:text-[#E85D3F] transition-colors leading-tight">@item.Title</h3>
                    <p class="text-slate-400 text-sm font-medium leading-relaxed line-clamp-3 italic">"@item.Description"</p>

                    <div class="flex flex-wrap gap-2 pt-2">
                        @foreach (var tag in item.Tags)
                        {
                            <span class="text-[10px] font-bold text-slate-300 uppercase">#@tag</span>
                        }
                    </div>
                </div>

                @* Interaction Footer *@
                <div class="mt-10 space-y-6">
                    <div class="flex items-center justify-between p-6 bg-slate-50 rounded-[32px] border border-slate-100/50">
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-2xl bg-white flex items-center justify-center shadow-sm">
                                <span class="text-[#7E96E1]" style="font-size:20px;"><Blazicon Svg="@Lucide.Download" /></span>
                            </div>
                            <div>
                                <p class="text-sm font-black text-slate-800">@FormatCount(item.Clones)</p>
                                <p class="text-[9px] font-bold text-slate-400 uppercase tracking-widest">Active Clones</p>
                            </div>
                        </div>
                        <div class="text-right">
                            <p class="text-sm font-black text-slate-800">@item.CasesCount</p>
                            <p class="text-[9px] font-bold text-slate-400 uppercase tracking-widest">Scenarios</p>
                        </div>
                    </div>

                    <div class="flex gap-3">
                        <button @onclick="() => OpenCloneModal(item)"
                                class="flex-1 py-5 bg-[#1C1D2A] text-white rounded-[24px] font-black text-xs uppercase tracking-widest hover:bg-slate-800 transition-all flex items-center justify-center gap-3 shadow-xl active:scale-95 shadow-slate-100">
                            <span class="text-[#E85D3F]" style="font-size:16px;"><Blazicon Svg="@Lucide.Zap" /></span>
                            Sync to Library
                        </button>
                        <button @onclick="() => CopyShareLink(item.Id)"
                                class="@($"p-5 border rounded-[24px] transition-all group/btn shadow-sm relative {(copiedId == item.Id ? "bg-emerald-500 border-emerald-500 text-white" : "bg-white border-slate-100 hover:border-[#7E96E1] text-[#7E96E1]")}")"
                                title="Copy Share Link">
                            @if (copiedId == item.Id)
                            {
                                <span style="font-size:20px;"><Blazicon Svg="@Lucide.Check" /></span>
                            }
                            else
                            {
                                <span style="font-size:20px;"><Blazicon Svg="@Lucide.ArrowUpRight" /></span>
                            }
                            @if (copiedId == item.Id)
                            {
                                <span class="absolute -top-10 left-1/2 -translate-x-1/2 px-3 py-1.5 bg-emerald-600 text-white text-[9px] font-black uppercase tracking-widest rounded-lg shadow-xl">
                                    Link Copied
                                </span>
                            }
                        </button>
                    </div>
                </div>

            </div>
        }

        @if (!FilteredItems.Any())
        {
            <div class="col-span-full py-40 flex flex-col items-center justify-center text-center bg-white/40 rounded-[64px] border-2 border-dashed border-slate-100">
                <div class="w-24 h-24 bg-white rounded-[40px] flex items-center justify-center shadow-sm mb-8">
                    <span class="text-slate-200" style="font-size:40px;"><Blazicon Svg="@Lucide.Search" /></span>
                </div>
                <h3 class="text-3xl font-black text-slate-800 uppercase tracking-widest">No Intelligence Matches</h3>
                <p class="text-slate-400 max-w-md mt-2 font-medium leading-relaxed">We couldn't find any blueprints matching your query. Consider initiating a custom architecture request.</p>
                <button @onclick="ResetFilters"
                        class="mt-8 px-10 py-4 bg-[#1C1D2A] text-white rounded-2xl font-black text-sm uppercase tracking-widest shadow-lg active:scale-95 transition-all">
                    Reset Marketplace Feed
                </button>
            </div>
        }
    </div>

</div>

@* ══════ Clone Confirmation Modal ══════ *@
@if (stagedItem != null)
{
    <div class="fixed inset-0 z-[250] flex items-center justify-center p-6">
        <div class="absolute inset-0 bg-slate-900/40 backdrop-blur-md" @onclick="() => stagedItem = null"></div>
        <div class="relative bg-white w-full max-w-lg rounded-[48px] shadow-2xl overflow-hidden flex flex-col animate-in zoom-in-95 duration-300">
            <div class="p-10 border-b border-slate-50 flex items-start justify-between bg-slate-50/50">
                <div class="flex items-center gap-4">
                    <div class="w-14 h-14 bg-[#1C1D2A] rounded-2xl flex items-center justify-center text-[#E85D3F] shadow-lg" style="font-size:28px;">
                        <Blazicon Svg="@Lucide.Zap" />
                    </div>
                    <div>
                        <h2 class="text-2xl font-black text-slate-800">Sync Blueprint</h2>
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mt-1">Clone to Library</p>
                    </div>
                </div>
                <button @onclick="() => stagedItem = null" class="p-3 hover:bg-white rounded-2xl text-slate-400 transition-all" style="font-size:24px;">
                    <Blazicon Svg="@Lucide.X" />
                </button>
            </div>

            <div class="p-10 space-y-8">
                <div class="p-6 bg-slate-50 rounded-[32px] border border-slate-100">
                    <p class="text-sm font-black text-slate-800 mb-1">@stagedItem.Title</p>
                    <p class="text-xs text-slate-400 italic line-clamp-2">@stagedItem.Description</p>
                    <div class="flex items-center gap-4 mt-4">
                        <span class="text-[10px] font-black text-slate-500 uppercase">@stagedItem.AuthorName</span>
                        <span class="text-[10px] font-black text-emerald-500 uppercase">@FormatCount(stagedItem.Clones) Clones</span>
                    </div>
                </div>

                <div class="p-6 bg-blue-50 border border-blue-100 rounded-[32px] space-y-2">
                    <div class="flex items-center gap-2">
                        <span class="text-blue-500 animate-pulse" style="font-size:14px;"><Blazicon Svg="@Lucide.Zap" /></span>
                        <span class="text-[9px] font-black text-blue-600 uppercase tracking-widest">Sync Notice</span>
                    </div>
                    <p class="text-[10px] text-blue-500 font-medium leading-relaxed">
                        This will clone the template into your project workspace. All test cases and steps will be copied.
                    </p>
                </div>

                @* Project Selector *@
                <div class="space-y-2">
                    <label class="text-[9px] font-black text-slate-500 uppercase tracking-widest">Select Target Project</label>
                    @if (_userProjects.Count == 0)
                    {
                        <p class="text-xs text-red-400 font-medium">You have no projects. Please create a project first.</p>
                    }
                    else
                    {
                        <div class="relative">
                            <select @bind="_selectedProjectId"
                                    class="w-full appearance-none border border-slate-200 bg-white rounded-2xl px-5 py-3.5 text-sm font-bold text-slate-700 outline-none focus:border-[#1C1D2A] focus:ring-2 focus:ring-[#1C1D2A]/10 transition-all">
                                <option value="">— Choose a project —</option>
                                @foreach (var project in _userProjects)
                                {
                                    <option value="@project.Id">@project.Name</option>
                                }
                            </select>
                            <svg class="pointer-events-none absolute right-4 top-1/2 -translate-y-1/2 h-4 w-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                            </svg>
                        </div>
                    }
                </div>

                @if (!string.IsNullOrEmpty(_cloneMessage))
                {
                    <div class="@(_cloneSuccess ? "bg-emerald-50 border-emerald-200 text-emerald-700" : "bg-red-50 border-red-200 text-red-700") border rounded-2xl px-5 py-3 text-xs font-bold">
                        @_cloneMessage
                    </div>
                }

                <div class="flex gap-3">
                    <button @onclick="ConfirmClone"
                            disabled="@(_selectedProjectId == null || _isCloning || _userProjects.Count == 0)"
                            class="flex-1 py-5 bg-[#1C1D2A] text-white font-black text-lg rounded-2xl hover:bg-slate-800 hover:shadow-xl transition-all active:scale-95 flex items-center justify-center gap-3 shadow-lg shadow-slate-200 disabled:opacity-50 disabled:cursor-not-allowed disabled:active:scale-100">
                        @if (_isCloning)
                        {
                            <div class="w-5 h-5 border-2 border-white/30 border-t-white rounded-full animate-spin"></div>
                            <span class="text-sm">Cloning...</span>
                        }
                        else
                        {
                            <span class="text-emerald-400" style="font-size:20px;"><Blazicon Svg="@Lucide.Check" /></span>
                            <span class="text-sm">Confirm Sync</span>
                        }
                    </button>
                    <button @onclick="() => { stagedItem = null; _cloneMessage = null; _selectedProjectId = null; }"
                            class="px-8 py-5 border border-slate-100 text-slate-400 font-black text-sm rounded-2xl hover:bg-slate-50 transition-all">
                        Cancel
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private string searchQuery = "";
    private string selectedCategory = "All";
    private int? copiedId = null;
    private TemplateViewModel? stagedItem = null;

    private List<TemplateViewModel> allTemplates = new();
    private List<string> categories = new() { "All" };
    private int totalClones;
    private int totalAuthors;
    private readonly HashSet<int> _userStarredIds = new();

    // Clone state
    private List<(int Id, string Name)> _userProjects = new();
    private int? _selectedProjectId = null;
    private bool _isCloning = false;
    private string? _cloneMessage = null;
    private bool _cloneSuccess = false;

    private IEnumerable<TemplateViewModel> FilteredItems => allTemplates.Where(item =>
    {
        var matchesSearch = string.IsNullOrWhiteSpace(searchQuery) ||
            item.Title.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ||
            item.Description.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ||
            item.CategoryName.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ||
            item.Tags.Any(t => t.Contains(searchQuery, StringComparison.OrdinalIgnoreCase));
        var matchesCat = selectedCategory == "All" || item.CategoryName.Equals(selectedCategory, StringComparison.OrdinalIgnoreCase);
        return matchesSearch && matchesCat;
    });

    protected override async Task OnInitializedAsync()
    {
        var templates = await DbContext.TestSuiteTemplates
            .Where(t => t.IsPublic)
            .Include(t => t.User)
            .Include(t => t.Category)
            .Include(t => t.Tags).ThenInclude(tt => tt.Tag)
            .Include(t => t.TestCaseTemplates)
            .Include(t => t.Reviews)
            .AsNoTracking()
            .ToListAsync();

        allTemplates = templates.Select(t => new TemplateViewModel
        {
            Id = t.Id,
            Title = t.Name,
            Description = t.Description ?? "",
            AuthorName = t.User?.UserName ?? "Unknown",
            CategoryName = t.Category?.Name ?? "Uncategorized",
            Stars = t.TotalStarred,
            Clones = t.CloneCount,
            Views = t.ViewCount,
            CasesCount = t.TestCaseTemplates?.Count ?? 0,
            IsVerified = t.Reviews.Count(r => r.IsStarred) >= 3 && t.CloneCount >= 3,
            Tags = t.Tags?.Select(tt => tt.Tag?.TagName ?? "").Where(x => !string.IsNullOrEmpty(x)).ToList() ?? new()
        }).ToList();

        // Build category list from DB
        var dbCategories = await DbContext.TemplateCategories
            .Select(c => c.Name ?? "")
            .Where(n => !string.IsNullOrEmpty(n))
            .Distinct()
            .AsNoTracking()
            .ToListAsync();
        categories = new List<string> { "All" };
        categories.AddRange(dbCategories);

        // Stats
        totalClones = templates.Sum(t => t.CloneCount);
        totalAuthors = templates.Select(t => t.UserId).Distinct().Count();

        // Load user's starred template IDs
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var userId = authState.User.FindFirstValue(ClaimTypes.NameIdentifier);
        if (!string.IsNullOrEmpty(userId))
        {
            var starredIds = await DbContext.TemplateReviews
                .Where(r => r.UserId == userId && r.IsStarred)
                .Select(r => r.TemplateId)
                .ToListAsync();
            _userStarredIds.UnionWith(starredIds);

            _userProjects = await DbContext.ProjectTeamMembers
                .Where(m => m.UserId == userId)
                .Include(m => m.Project)
                .Select(m => new { m.Project.Id, m.Project.Name })
                .AsNoTracking()
                .ToListAsync()
                .ContinueWith(t => t.Result.Select(p => (p.Id, p.Name)).ToList());
        }
    }

    private void OpenCloneModal(TemplateViewModel item)
    {
        stagedItem = item;
        _selectedProjectId = null;
        _cloneMessage = null;
        _cloneSuccess = false;
    }

    private async Task ConfirmClone()
    {
        if (stagedItem == null || _selectedProjectId == null) return;

        _isCloning = true;
        _cloneMessage = null;
        StateHasChanged();

        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var userId = authState.User.FindFirstValue(ClaimTypes.NameIdentifier);
            if (string.IsNullOrEmpty(userId))
            {
                _cloneMessage = "You must be logged in to clone a template.";
                _cloneSuccess = false;
                return;
            }

            // Load template with full test data
            var templateSuite = await DbContext.TestSuiteTemplates
                .Include(t => t.TestCaseTemplates)
                    .ThenInclude(tc => tc.TestStepTemplates)
                .FirstOrDefaultAsync(t => t.Id == stagedItem.Id);

            if (templateSuite == null)
            {
                _cloneMessage = "Template not found.";
                _cloneSuccess = false;
                return;
            }

            // Tạo TestSuite thực trong project đích
            var newSuite = new TestSuite
            {
                ProjectId = _selectedProjectId.Value,
                Name = templateSuite.Name,
                Description = templateSuite.Description,
                SourceTemplateId = templateSuite.Id,
                CreatedBy = userId,
                CreatedAt = DateTime.UtcNow
            };

            DbContext.TestSuites.Add(newSuite);
            await DbContext.SaveChangesAsync();

            // Copy TestCases và TestSteps
            foreach (var templateCase in templateSuite.TestCaseTemplates)
            {
                var newCase = new TestCase
                {
                    SuiteId = newSuite.Id,
                    Title = templateCase.Title,
                    Priority = templateCase.Priority,
                    Preconditions = templateCase.Preconditions,
                    Postconditions = templateCase.Postconditions,
                    CreatedBy = userId,
                    CreatedAt = DateTime.UtcNow
                };
                DbContext.TestCases.Add(newCase);
                await DbContext.SaveChangesAsync();

                foreach (var templateStep in templateCase.TestStepTemplates)
                {
                    DbContext.TestSteps.Add(new TestStep
                    {
                        TestCaseId = newCase.Id,
                        StepNumber = templateStep.StepNumber,
                        Action = templateStep.Action,
                        TestData = templateStep.TestData,
                        ExpectedResult = templateStep.ExpectedResult
                    });
                }
            }

            // Tăng CloneCount
            templateSuite.CloneCount++;
            await DbContext.SaveChangesAsync();

            // Cập nhật view
            var local = allTemplates.FirstOrDefault(t => t.Id == stagedItem.Id);
            if (local != null) local.Clones = templateSuite.CloneCount;
            totalClones++;

            var projectName = _userProjects.FirstOrDefault(p => p.Id == _selectedProjectId.Value).Name ?? "selected project";
            _cloneMessage = $"✓ Cloned successfully into \"{projectName}\" with {templateSuite.TestCaseTemplates.Count} test case(s).";
            _cloneSuccess = true;

            // Đóng modal sau 2 giây
            await Task.Delay(2000);
            stagedItem = null;
            _selectedProjectId = null;
            _cloneMessage = null;
        }
        catch (Exception ex)
        {
            _cloneMessage = $"Clone failed: {ex.Message}";
            _cloneSuccess = false;
        }
        finally
        {
            _isCloning = false;
            StateHasChanged();
        }
    }

    private async Task CopyShareLink(int itemId)
    {
        var shareLink = $"{Navigation.BaseUri}marketplace?template={itemId}";
        await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", shareLink);
        copiedId = itemId;
        StateHasChanged();
        await Task.Delay(2000);
        copiedId = null;
        StateHasChanged();
    }

    private async Task ToggleStar(TemplateViewModel item)
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var userId = authState.User.FindFirstValue(ClaimTypes.NameIdentifier);
        if (string.IsNullOrEmpty(userId)) return;

        var template = await DbContext.TestSuiteTemplates.FindAsync(item.Id);
        if (template == null) return;

        var review = await DbContext.TemplateReviews
            .FirstOrDefaultAsync(r => r.TemplateId == item.Id && r.UserId == userId);

        if (review == null)
        {
            DbContext.TemplateReviews.Add(new TemplateReview { TemplateId = item.Id, UserId = userId, IsStarred = true });
            template.TotalStarred++;
            _userStarredIds.Add(item.Id);
            item.Stars++;
        }
        else if (review.IsStarred)
        {
            review.IsStarred = false;
            template.TotalStarred = Math.Max(0, template.TotalStarred - 1);
            _userStarredIds.Remove(item.Id);
            item.Stars = Math.Max(0, item.Stars - 1);
        }
        else
        {
            review.IsStarred = true;
            template.TotalStarred++;
            _userStarredIds.Add(item.Id);
            item.Stars++;
        }

        await DbContext.SaveChangesAsync();
        StateHasChanged();
    }

    private void ResetFilters()
    {
        searchQuery = "";
        selectedCategory = "All";
    }

    private string FormatCount(int count) =>
        count >= 1000 ? $"{count / 1000.0:0.#}k" : count.ToString();

    private class TemplateViewModel
    {
        public int Id { get; set; }
        public string Title { get; set; } = "";
        public string Description { get; set; } = "";
        public string AuthorName { get; set; } = "";
        public string CategoryName { get; set; } = "";
        public int Stars { get; set; }
        public int Clones { get; set; }
        public int Views { get; set; }
        public int CasesCount { get; set; }
        public bool IsVerified { get; set; }
        public List<string> Tags { get; set; } = new();
    }
}
