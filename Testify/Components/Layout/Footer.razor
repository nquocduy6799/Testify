    // Use SVG Path Data strings for Brand Icons (Heroicons does not include Brands)
    private List<SocialLink> SocialLinks = new()
    {
        // Twitter / X Icon
        new SocialLink { SvgPath = "M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z", Href = "https://twitter.com" },
