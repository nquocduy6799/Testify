@inject NavigationManager Navigation

<footer class="relative mt-8 overflow-hidden bg-[#1C1D2A] pt-24 pb-12 text-white">
    @* Decorative Background Elements *@
    <div class="absolute top-0 right-0 -mt-48 -mr-48 h-96 w-96 rounded-full bg-[#E85D3F]/5 blur-[120px]"></div>
    <div class="absolute bottom-0 left-0 -mb-32 -ml-32 h-64 w-64 rounded-full bg-[#7E96E1]/5 blur-[100px]"></div>

    <div class="relative z-10 mx-auto max-w-[1400px] px-8">
        <div class="grid grid-cols-1 gap-16 border-b border-white/5 pb-20 md:grid-cols-2 lg:grid-cols-12 lg:gap-8">

            @* Brand Identity *@
            <div class="space-y-8 lg:col-span-4">
                <div class="group flex w-fit cursor-pointer items-center gap-3" @onclick="@(() => NavigateTo("/"))">
                    <div class="relative flex h-12 w-12 items-center justify-center rounded-2xl bg-[#E85D3F] shadow-[#E85D3F]/20 shadow-lg transition-transform group-hover:scale-110">
                        <div class="h-6 w-6 rounded-full bg-white opacity-30 blur-[1px]"></div>
                        <div class="absolute text-2xl font-bold text-white">T</div>
                    </div>
                    <span class="text-2xl font-bold tracking-tight text-white">TESTIFY</span>
                </div>

                <p class="max-w-sm text-lg leading-relaxed text-slate-400">
                    Empowering development teams with comprehensive testing tools and seamless project management solutions.
                </p>

                <div class="flex items-center gap-4">
                    @foreach (var social in SocialLinks)
                    {
                        <a href="@social.Href"
                           class="flex h-10 w-10 items-center justify-center rounded-xl bg-white/5 text-slate-400 transition-all duration-300 hover:bg-[#E85D3F] hover:text-white"
                           target="_blank"
                           rel="noopener noreferrer">
                            @* Render SVG Path directly *@
                            <svg class="h-5 w-5 fill-current" viewBox="0 0 24 24" aria-hidden="true">
                                <path fill-rule="evenodd" clip-rule="evenodd" d="@social.SvgPath" />
                            </svg>
                        </a>
                    }
                </div>
            </div>

            @* Quick Links *@
            <div class="space-y-6 lg:col-span-2">
                <h4 class="text-xs font-bold tracking-[0.2em] text-[#E85D3F] uppercase">Platform</h4>
                <ul class="space-y-4">
                    @foreach (var item in PlatformLinks)
                    {
                        <li>
                            <button @onclick="@(() => NavigateTo(item.Route))"
                                    class="text-slate-400 hover:text-white transition-colors text-sm font-semibold">
                                @item.Name
                            </button>
                        </li>
                    }
                </ul>
            </div>

            @* Resources *@
            <div class="space-y-6 lg:col-span-2">
                <h4 class="text-xs font-bold tracking-[0.2em] text-[#E85D3F] uppercase">Resources</h4>
                <ul class="space-y-4">
                    @foreach (var item in ResourceLinks)
                    {
                        <li>
                            <a href="@item.Href"
                               class="group flex items-center gap-2 text-sm font-semibold text-slate-400 transition-colors hover:text-white">
                                @item.Name
                                @* Heroicon: ArrowTopRightOnSquare *@
                                <svg class="h-3 w-3 opacity-0 transition-opacity group-hover:opacity-100" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
                                </svg>
                            </a>
                        </li>
                    }
                </ul>
            </div>

            @* Newsletter *@
            <div class="space-y-8 lg:col-span-4">
                <div class="rounded-[40px] border border-white/5 bg-white/5 p-8 backdrop-blur-sm">
                    <h4 class="mb-4 text-xl font-bold">Stay ahead of the curve</h4>
                    <p class="mb-6 text-sm leading-relaxed text-slate-400">
                        Get monthly insights on testing best practices and platform updates.
                    </p>
                    <div class="group relative">
                        <input type="email"
                               @bind="newsletterEmail"
                               placeholder="Enter your email"
                               class="w-full rounded-2xl border border-white/10 bg-white/5 px-6 py-4 pr-14 text-sm text-white transition-all focus:border-[#E85D3F]/50 focus:outline-none" />
                        <button @onclick="SubscribeToNewsletter"
                                class="absolute top-1/2 right-2 flex h-10 w-10 -translate-y-1/2 items-center justify-center rounded-xl bg-[#E85D3F] text-white shadow-[#E85D3F]/20 shadow-lg transition-all hover:scale-105">
                            @* Heroicon: PaperAirplane *@
                            <svg class="h-5 w-5 -rotate-45" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5" />
                            </svg>
                        </button>
                    </div>
                </div>
            </div>
        </div>

        @* Bottom Bar *@
        <div class="flex flex-col items-center justify-between gap-8 pt-12 md:flex-row">
            <div class="flex flex-wrap items-center justify-center gap-8 font-bold tracking-widest text-[11px] text-slate-500 uppercase md:justify-start">
                <span>© @DateTime.Now.Year Testify Inc.</span>
                <a href="/privacy" class="transition-colors hover:text-[#E85D3F]">Privacy Policy</a>
                <a href="/terms" class="transition-colors hover:text-[#E85D3F]">Terms of Service</a>
                <a href="/cookies" class="transition-colors hover:text-[#E85D3F]">Cookies</a>
            </div>

            <div class="flex items-center gap-6">
                <div class="flex items-center gap-2 text-xs font-bold tracking-widest text-slate-500 uppercase">
                    @* Heroicon: GlobeAlt *@
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S12 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S12 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418" />
                    </svg>
                    English (US)
                </div>
                <div class="flex items-center gap-2 text-xs font-bold tracking-widest text-slate-500 uppercase">
                    @* Heroicon: ShieldCheck *@
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z" />
                    </svg>
                    Verified
                </div>
                <button @onclick="ScrollToTop"
                        class="group flex h-12 w-12 items-center justify-center rounded-full border border-white/10 transition-all hover:bg-white hover:text-[#1C1D2A]">
                    @* Heroicon: ArrowUp *@
                    <svg class="h-5 w-5 transition-transform group-hover:-translate-y-1" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 10.5L12 3m0 0l7.5 7.5M12 3v18" />
                    </svg>
                </button>
            </div>
        </div>
    </div>
</footer>

@code {
