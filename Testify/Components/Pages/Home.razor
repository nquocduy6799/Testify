@page "/"

<PageTitle>Home</PageTitle>

<div class="animate-in fade-in pb-32 duration-700">
    
    @* Hero Section *@
    <section class="relative overflow-hidden bg-[#1C1D2A] px-8 pt-32 pb-48 text-center">
        <div class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')] opacity-10"></div>
        <div class="absolute top-0 left-12 -mt-48 h-[600px] w-[1000px] -translate-x-12 rounded-full bg-[#E85D3F]/10 blur-[150px]"></div>
        <div class="absolute right-0 bottom-0 -mr-48 -mb-48 h-[600px] w-[600px] rounded-full bg-[#7E96E1]/5 blur-[120px]"></div>

        <div class="relative z-10 mx-auto max-w-4xl space-y-8">
            <div class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-5 py-2 text-xs font-bold tracking-[0.3em] text-[#E85D3F] uppercase backdrop-blur-md">
                <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
                </svg>
                Defining Engineering Excellence
            </div>
            <h1 class="text-6xl leading-none font-black tracking-tighter text-white md:text-8xl">
                Where velocity meets <span class="bg-gradient-to-r from-[#E85D3F] to-[#7E96E1] bg-clip-text text-transparent">integrity.</span>
            </h1>
            <p class="mx-auto max-w-2xl text-xl leading-relaxed font-medium text-slate-400 md:text-2xl">
                Testify is the premier Scrumban ecosystem built to unify Developers, Testers, and PMs under a single AI-augmented command center.
            </p>
        </div>
    </section>

    @* The Pillars *@
    <section class="relative z-20 mx-auto -mt-24 max-w-[1400px] px-8">
        <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
            @foreach (var pillar in _pillars)
            {
                <div class="@pillar.BgClass group space-y-6 rounded-[48px] border border-slate-100 p-12 shadow-2xl transition-all hover:scale-[1.02]">
                    <div class="flex h-16 w-16 items-center justify-center rounded-3xl bg-slate-50 @pillar.ColorClass transition-transform group-hover:scale-110">
                        @((MarkupString)pillar.Icon)
                    </div>
                    <h3 class="text-2xl font-bold text-slate-800">@pillar.Title</h3>
                    <p class="leading-relaxed font-medium text-slate-500">@pillar.Description</p>
                </div>
            }
        </div>
    </section>

    @* The Ecosystem *@
    <section class="mx-auto mt-40 max-w-[1400px] space-y-20 px-8">
        <div class="space-y-4 text-center">
            <h2 class="text-4xl font-extrabold tracking-tight text-slate-900">The Testify Ecosystem</h2>
            <p class="mx-auto max-w-xl text-lg text-slate-500">A symbiotic environment where quality is the primary currency.</p>
        </div>

        <div class="grid grid-cols-1 items-center gap-12 lg:grid-cols-12">
            @* Left Column: Roles *@
            <div class="order-2 space-y-12 lg:order-1 lg:col-span-4">
                <div class="group relative space-y-4 overflow-hidden rounded-[40px] border border-slate-50 bg-white p-10 shadow-sm">
                    <div class="absolute top-0 left-0 h-full w-2 bg-[#7E96E1]"></div>
                    <h4 class="flex items-center gap-3 text-xl font-bold text-slate-800">
                        <svg class="h-5 w-5 text-[#7E96E1]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
                        </svg>
                        The Developer
                    </h4>
                    <p class="text-sm leading-relaxed text-slate-500">Builders of the digital future. They ship with confidence knowing every commit is shadowed by an automated and manual validation strategy.</p>
                </div>
                <div class="relative space-y-4 overflow-hidden rounded-[40px] border border-slate-50 bg-white p-10 shadow-sm">
                    <div class="absolute top-0 left-0 h-full w-2 bg-emerald-500"></div>
                    <h4 class="flex items-center gap-3 text-xl font-bold text-slate-800">
                        <svg class="h-5 w-5 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
                        </svg>
                        The Tester
                    </h4>
                    <p class="text-sm leading-relaxed text-slate-500">The guardians of integrity. They translate vision into verifiable logic, ensuring the platform remains stable through every iteration.</p>
                </div>
            </div>

            @* Center: Animating Core *@
            <div class="order-1 flex flex-col items-center justify-center lg:order-2 lg:col-span-4">
                <div class="relative">
                    <div class="flex h-80 w-80 animate-[spin_20s_linear_infinite] items-center justify-center rounded-full border-2 border-dashed border-[#E85D3F]/20">
                        <div class="h-64 w-64 rounded-full border-2 border-dashed border-[#7E96E1]/20"></div>
                    </div>
                    <div class="absolute inset-0 flex items-center justify-center">
                        <div class="flex h-32 w-32 items-center justify-center rounded-[40px] bg-[#1C1D2A] shadow-2xl">
                            <div class="text-5xl font-black text-white">T</div>
                        </div>
                    </div>
                </div>
            </div>

            @* Right Column: PM *@
            <div class="order-3 space-y-8 lg:col-span-4">
                <div class="group relative space-y-6 overflow-hidden rounded-[48px] bg-slate-900 p-10 text-white shadow-2xl">
                    <div class="absolute top-0 right-0 h-32 w-32 rounded-full bg-[#E85D3F]/10 blur-2xl"></div>
                    <h4 class="flex items-center gap-3 text-xl font-bold">
                        <svg class="h-6 w-6 text-[#E85D3F]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                        </svg>
                        The Manager
                    </h4>
                    <p class="text-sm leading-relaxed text-slate-400">The strategic architects. They orchestrate resources, monitor portfolio health, and use AI-driven forecasts to navigate critical paths.</p>
                    <button class="flex items-center gap-2 text-xs font-black tracking-widest text-[#E85D3F] uppercase hover:underline">
                        View Strategy Protocol
                        <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                        </svg>
                    </button>
                </div>
            </div>
        </div>
    </section>

    @* Trust Section *@
    <section class="mt-40 bg-slate-50 px-8 py-32">
        <div class="mx-auto grid max-w-[1400px] grid-cols-1 items-center gap-20 lg:grid-cols-2">
            <div class="space-y-10">
                <div class="space-y-6">
                    <h2 class="text-5xl font-extrabold tracking-tight text-slate-900">Quality is hard-coded into every interaction.</h2>
                    <p class="text-xl leading-relaxed font-medium text-slate-500 italic">We built Testify because we were tired of siloed tools that forced quality to be an afterthought. We treat testing and development as two sides of the same coin.</p>
                </div>
                <div class="grid grid-cols-2 gap-8">
                    <div class="space-y-2">
                        <p class="text-4xl font-black text-[#E85D3F]">99.8%</p>
                        <p class="text-xs font-bold tracking-widest text-slate-400 uppercase">Defect Prevention Rate</p>
                    </div>
                    <div class="space-y-2">
                        <p class="text-4xl font-black text-[#7E96E1]">3.4x</p>
                        <p class="text-xs font-bold tracking-widest text-slate-400 uppercase">Velocity Improvement</p>
                    </div>
                </div>
            </div>
            
            <div class="space-y-10 rounded-[64px] border border-slate-100 bg-white p-12 shadow-xl">
                <h3 class="text-2xl font-bold text-slate-800">Our Quality Commitment</h3>
                <div class="space-y-8">
                    @foreach (var item in _commitments)
                    {
                        <div class="flex gap-6">
                            <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl bg-slate-50">
                                @((MarkupString)item.Icon)
                            </div>
                            <div class="space-y-1">
                                <h4 class="font-bold text-slate-800">@item.Title</h4>
                                <p class="text-sm text-slate-500">@item.Description</p>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </section>

    @* CTA Section *@
    <section class="mx-auto mt-40 max-w-[1400px] px-8">
        <div class="relative space-y-10 overflow-hidden rounded-[64px] bg-[#1C1D2A] p-16 text-center shadow-2xl md:p-24">
            <div class="absolute top-0 right-0 -mt-48 -mr-48 h-[500px] w-[500px] rounded-full bg-[#E85D3F]/5 blur-[100px]"></div>
            <div class="relative z-10 mx-auto max-w-2xl space-y-6">
                <h2 class="text-4xl leading-tight font-black tracking-tight text-white md:text-6xl">Ready to build your <span class="text-[#E85D3F]">legacy?</span></h2>
                <p class="text-lg font-medium text-slate-400">Join the ranks of high-performance engineering teams using AI to secure their digital infrastructure.</p>
            </div>
            <div class="relative z-10 flex flex-col items-center justify-center gap-6 pt-6 md:flex-row">
                <button class="flex items-center gap-3 rounded-3xl bg-[#E85D3F] px-12 py-6 text-lg font-bold text-white shadow-[#E85D3F]/20 shadow-xl transition-all hover:scale-105">
                    Initialize Workspace
                    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                    </svg>
                </button>
                <button class="rounded-3xl border border-white/10 bg-white/5 px-12 py-6 text-lg font-bold text-white backdrop-blur-md transition-all hover:bg-white/10">
                    Request Demo
                </button>
            </div>
        </div>
    </section>

</div>

@code {
    private List<PillarItem> _pillars = new()
    {
        new PillarItem
        {
            Title = "Neural Quality",
            Description = "Leverage Gemini AI to automatically generate test scenarios directly from your requirement descriptions and codebase.",
            Icon = "<svg class=\"w-8 h-8\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z\" /></svg>",
            ColorClass = "text-[#E85D3F]",
            BgClass = "bg-white"
        },
        new PillarItem
        {
            Title = "Absolute Traceability",
            Description = "Hard-link every Kanban task to its validation suite. Know exactly which feature is ready for production in real-time.",
            Icon = "<svg class=\"w-8 h-8\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z\" /></svg>",
            ColorClass = "text-emerald-500",
            BgClass = "bg-white"
        },
        new PillarItem
        {
            Title = "Strategic Velocity",
            Description = "A unified Scrumban workflow that eliminates the friction between development cycles and quality assurance phases.",
            Icon = "<svg class=\"w-8 h-8\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M13 10V3L4 14h7v7l9-11h-7z\" /></svg>",
            ColorClass = "text-[#7E96E1]",
            BgClass = "bg-white"
        }
    };

    private List<CommitmentItem> _commitments = new()
    {
        new CommitmentItem
        {
            Icon = "<svg class=\"w-6 h-6 text-slate-400\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z\" /></svg>",
            Title = "Proactive Detection",
            Description = "AI-driven gap analysis identifies untested edge cases before they reach testing."
        },
        new CommitmentItem
        {
            Icon = "<svg class=\"w-6 h-6 text-slate-400\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4\" /></svg>",
            Title = "Compliance-First",
            Description = "Every project audit trail is immutable and exportable for regulatory needs."
        },
        new CommitmentItem
        {
            Icon = "<svg class=\"w-6 h-6 text-slate-400\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z\" /></svg>",
            Title = "Proof of Validation",
            Description = "Requirements only move to Done when cryptographic proof of pass is recorded."
        }
    };

    private class PillarItem
    {
        public string Title { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
        public string Icon { get; set; } = string.Empty;
        public string ColorClass { get; set; } = string.Empty;
        public string BgClass { get; set; } = string.Empty;
    }

    private class CommitmentItem
    {
        public string Icon { get; set; } = string.Empty;
        public string Title { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
    }
}